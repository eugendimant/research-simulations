aVisibility":[],"AnalyzeText":false,"Value":"A"}]},{"Type":"Standard","ID":"BL_0St6uMnRjuwbl0q","FlowID":"FL_7","Autofill":[]},{"Type":"EmbeddedData","FlowID":"FL_11","EmbeddedData":[{"Description":"instruction_condition","Type":"Custom","Field":"instruction_condition","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"B"}]}]},{"Type":"Block","ID":"BL_diib5uX5S9sqVN4","FlowID":"FL_15","Autofill":[]},{"Type":"Standard","ID":"BL_cvuDQhbvSFnRmPY","FlowID":"FL_16","Autofill":[]},{"Type":"Standard","ID":"BL_56XkO9gecTx7Z6S","FlowID":"FL_18","Autofill":[]},{"Type":"Standard","ID":"BL_b8IqlroLk4fL9RA","FlowID":"FL_17","Autofill":[]},{"Type":"Standard","ID":"BL_bBkqLZmqhB2Ve5M","FlowID":"FL_24","Autofill":[]},{"Type":"Standard","ID":"BL_8DlHYuY3tgVlpY2","FlowID":"FL_25","Autofill":[]},{"Type":"Standard","ID":"BL_8DnwNabx6tsXUmq","FlowID":"FL_26","Autofill":[]}],"Properties":{"Count":27}}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"PL","PrimaryAttribute":"Preview Link","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"PreviewType":"Brand","PreviewID":"fe5bf792-ff1a-4957-b92f-26884d21f88d"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"PROJ","PrimaryAttribute":"CORE","SecondaryAttribute":null,"TertiaryAttribute":"1.1.0","Payload":{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"QC","PrimaryAttribute":"Survey Question Count","SecondaryAttribute":"37","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"RS","PrimaryAttribute":"RS_4PnvlXYOl6Skxwi","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"true","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":"None","SurveyTermination":"DisplayMessage","Header":"","Footer":"","ProgressBarDisplay":"None","PartialData":"+1 week","ValidationMessage":null,"PreviousButton":" \u2190 ","NextButton":"Next","SurveyTitle":"Qualtrics Survey | Qualtrics Experience Management","SkinLibrary":"upenn","SkinType":"templated","Skin":{"brandingId":"4025773068","templateId":"*base","overrides":{"background":{"url":"","color":"#ffffff"}}},"NewScoring":1,"SurveyMetaDescription":"The most powerful, simple and trusted way to gather experience data. Start your journey to experience management and try a free account today.","EOSMessage":"MS_6kTpYR9qe361EqO","ShowExportTags":"false","CollectGeoLocation":"false","PasswordProtection":"No","AnonymizeResponse":"No","RefererCheck":"No","BallotBoxStuffingPreventionBehavior":null,"BallotBoxStuffingPreventionMessage":null,"BallotBoxStuffingPreventionMessageLibrary":null,"BallotBoxStuffingPreventionURL":null,"RecaptchaV3":"false","ConfirmStart":false,"AutoConfirmStart":false,"RelevantID":"false","RelevantIDLockoutPeriod":"+30 days","UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessageLibrary":null,"ResponseSummary":"No","EOSMessageLibrary":"UR_3CoZ2NZu2pTLWhE","EOSRedirectURL":null,"EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":null,"PartialDeletion":null,"PartialDataCloseAfter":"LastActivity","InactiveMessageLibrary":null,"InactiveMessage":null,"AvailableLanguages":{"EN":[]},"nextButtonLid":"UR_3CoZ2NZu2pTLWhE","nextButtonMid":"MS_4GyCf9GXRxtHeOG","SurveyName":"Pilot Survey V.2","CustomStyles":{"customCSS":""}}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID11","SecondaryAttribute":"Now assign a percentage share to each switching point you selected. The shares must sum to 100%....","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"pct-container\" style=\"background:#fff;border:1px solid #dde2ea;border-radius:4px;padding:36px 40px 32px;max-width:520px;width:100%;margin:auto;font-family:Georgia,serif;\">\n\n  <p style=\"font-size:15px;color:#333;line-height:1.6;margin-bottom:8px;\">\n    Now assign a <strong>percentage share<\/strong> to each switching point you selected. The shares must sum to <strong>100%<\/strong>.\n  <\/p>\n  <p style=\"font-size:13px;color:#888;margin-bottom:24px;\">\n    You will earn a bonus if your assigned shares are within 5 percentage points of the actual distribution.\n  <\/p>\n\n  <div id=\"pct-list\" style=\"display:flex;flex-direction:column;gap:10px;margin-bottom:20px;\">\n    \n  <\/div>\n\n  <div style=\"display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:#f4f6f9;border-radius:3px;margin-bottom:8px;\">\n    <span style=\"font-size:15px;font-weight:bold;\">Total<\/span>\n    <span id=\"total-display\" style=\"font-size:15px;font-weight:bold;color:#c0392b;\">0%<\/span>\n  <\/div>\n\n  <p id=\"pct-error\" style=\"font-size:13px;color:#c0392b;text-align:center;display:none;margin-top:6px;\">\n    Your percentages must sum to exactly 100% before continuing.\n  <\/p>\n\n<\/div>","DefaultChoices":false,"DataExportTag":"Q11","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Now assign a percentage share to each switching point you selected. The shares must sum to 100%....","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID11","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n\n  var engine = this;\n  engine.showNextButton();\n\n  var saved = sessionStorage.getItem('norm_selected_points')\n    || Qualtrics.SurveyEngine.getEmbeddedData('norm_selected_points');\n  var points = saved ? saved.split(',') : [];\n\n  var list = document.getElementById('pct-list');\n\n  if (points.length === 0) {\n    list.innerHTML = '<p style=\"color:#c0392b;font-size:14px;\">No switching points found. Please go back and select at least one.<\/p>';\n    return;\n  }\n\n  points.forEach(function(pt) {\n    var row = document.createElement('div');\n    row.style.cssText = 'display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border:1.5px solid #ccc;border-radius:3px;';\n    row.innerHTML =\n      '<label style=\"font-size:15px;\">' + pt + ' winning numbers<\/label>' +\n      '<div style=\"display:flex;align-items:center;gap:6px;\">' +\n      '<input type=\"number\" id=\"pct_' + pt + '\" min=\"0\" max=\"100\" value=\"0\" ' +\n      'style=\"width:70px;font-size:15px;font-family:Georgia,serif;padding:6px 8px;border:1.5px solid #ccc;border-radius:3px;text-align:right;\">' +\n      '<span style=\"font-size:15px;\">%<\/span>' +\n      '<\/div>';\n    list.appendChild(row);\n  });\n\n  function updateTotal() {\n    var total = 0;\n    points.forEach(function(pt) {\n      var val = parseInt(document.getElementById('pct_' + pt).value) || 0;\n      total += val;\n    });\n    var display = document.getElementById('total-display');\n    display.textContent = total + '%';\n    display.style.color = total === 100 ? '#27ae60' : '#c0392b';\n    return total;\n  }\n\n  points.forEach(function(pt) {\n    document.getElementById('pct_' + pt).addEventListener('input', updateTotal);\n  });\n\n  jQuery('#NextButton').on('click', function(e) {\n    var total = updateTotal();\n    if (total !== 100) {\n      e.stopImmediatePropagation();\n      document.getElementById('pct-error').style.display = 'block';\n      return false;\n    }\n    var result = points.map(function(pt) {\n      return pt + ':' + document.getElementById('pct_' + pt).value;\n    }).join(',');\n    Qualtrics.SurveyEngine.setEmbeddedData('norm_percentages', result);\n    sessionStorage.removeItem('norm_selected_points');\n  });\n\n});"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID12","SecondaryAttribute":"Round 1 of 20 Choose a square in your mind, then click 'I made my choice'. I made my choice What...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"wheel-container\" style=\"background:#fff;border:1px solid #dde2ea;border-radius:4px;padding:36px 40px 32px;max-width:520px;width:100%;margin:auto;font-family:Georgia,serif;\">\n\n  <div id=\"round-label\" style=\"font-size:13px;font-weight:bold;letter-spacing:0.08em;text-transform:uppercase;color:#888;margin-bottom:6px;text-align:center;\">Round 1 of 20<\/div>\n\n  <div id=\"instructions\" style=\"font-size:15px;color:#333;text-align:center;margin-bottom:28px;line-height:1.5;min-height:44px;\">\n    Choose a square <strong>in your mind<\/strong>, then click <em>'I made my choice'<\/em>.\n  <\/div>\n\n  <div style=\"display:flex;justify-content:center;margin-bottom:28px;\">\n    <svg id=\"wheel-svg\" viewBox=\"0 0 280 280\" style=\"width:280px;height:280px;overflow:visible;\">\n      <line stroke=\"#333\" stroke-width=\"1.5\" x1=\"140\" y1=\"140\" x2=\"140\" y2=\"58\"\/>\n      <line stroke=\"#333\" stroke-width=\"1.5\" x1=\"140\" y1=\"140\" x2=\"222\" y2=\"98\"\/>\n      <line stroke=\"#333\" stroke-width=\"1.5\" x1=\"140\" y1=\"140\" x2=\"222\" y2=\"182\"\/>\n      <line stroke=\"#333\" stroke-width=\"1.5\" x1=\"140\" y1=\"140\" x2=\"140\" y2=\"222\"\/>\n      <line stroke=\"#333\" stroke-width=\"1.5\" x1=\"140\" y1=\"140\" x2=\"58\"  y2=\"182\"\/>\n      <line stroke=\"#333\" stroke-width=\"1.5\" x1=\"140\" y1=\"140\" x2=\"58\"  y2=\"98\"\/>\n      <circle cx=\"140\" cy=\"140\" r=\"4\" fill=\"#333\"\/>\n      <rect id=\"sq0\" x=\"114\" y=\"20\"  width=\"52\" height=\"36\" rx=\"2\" fill=\"#fff\" stroke=\"#333\" stroke-width=\"1.8\"\/>\n      <text id=\"txt0\" x=\"140\" y=\"38\"  font-size=\"22\" font-family=\"Georgia,serif\" font-weight=\"bold\" fill=\"#222\" text-anchor=\"middle\" dominant-baseline=\"central\" style=\"pointer-events:none;\"><\/text>\n      <rect id=\"sq1\" x=\"196\" y=\"62\"  width=\"52\" height=\"36\" rx=\"2\" fill=\"#fff\" stroke=\"#333\" stroke-width=\"1.8\"\/>\n      <text id=\"txt1\" x=\"222\" y=\"80\"  font-size=\"22\" font-family=\"Georgia,serif\" font-weight=\"bold\" fill=\"#222\" text-anchor=\"middle\" dominant-baseline=\"central\" style=\"pointer-events:none;\"><\/text>\n      <rect id=\"sq2\" x=\"196\" y=\"164\" width=\"52\" height=\"36\" rx=\"2\" fill=\"#fff\" stroke=\"#333\" stroke-width=\"1.8\"\/>\n      <text id=\"txt2\" x=\"222\" y=\"182\" font-size=\"22\" font-family=\"Georgia,serif\" font-weight=\"bold\" fill=\"#222\" text-anchor=\"middle\" dominant-baseline=\"central\" style=\"pointer-events:none;\"><\/text>\n      <rect id=\"sq3\" x=\"114\" y=\"224\" width=\"52\" height=\"36\" rx=\"2\" fill=\"#fff\" stroke=\"#333\" stroke-width=\"1.8\"\/>\n      <text id=\"txt3\" x=\"140\" y=\"242\" font-size=\"22\" font-family=\"Georgia,serif\" font-weight=\"bold\" fill=\"#222\" text-anchor=\"middle\" dominant-baseline=\"central\" style=\"pointer-events:none;\"><\/text>\n      <rect id=\"sq4\" x=\"32\"  y=\"164\" width=\"52\" height=\"36\" rx=\"2\" fill=\"#fff\" stroke=\"#333\" stroke-width=\"1.8\"\/>\n      <text id=\"txt4\" x=\"58\"  y=\"182\" font-size=\"22\" font-family=\"Georgia,serif\" font-weight=\"bold\" fill=\"#222\" text-anchor=\"middle\" dominant-baseline=\"central\" style=\"pointer-events:none;\"><\/text>\n      <rect id=\"sq5\" x=\"32\"  y=\"62\"  width=\"52\" height=\"36\" rx=\"2\" fill=\"#fff\" stroke=\"#333\" stroke-width=\"1.8\"\/>\n      <text id=\"txt5\" x=\"58\"  y=\"80\"  font-size=\"22\" font-family=\"Georgia,serif\" font-weight=\"bold\" fill=\"#222\" text-anchor=\"middle\" dominant-baseline=\"central\" style=\"pointer-events:none;\"><\/text>\n    <\/svg>\n  <\/div>\n\n  <button id=\"choice-btn\" style=\"display:block;margin:0 auto;padding:11px 32px;font-size:15px;font-family:Georgia,serif;background:#1F3864;color:#fff;border:none;border-radius:3px;cursor:pointer;letter-spacing:0.03em;\">\n    I made my choice\n  <\/button>\n\n  <div id=\"report-section\" style=\"display:none;text-align:center;margin-top:20px;\">\n    <p style=\"font-size:15px;color:#333;margin-bottom:14px;\">What number is in the square you chose?<\/p>\n    <div style=\"display:flex;justify-content:center;gap:16px;\">\n      <button id=\"btn0\" style=\"width:72px;height:72px;font-size:28px;font-family:Georgia,serif;font-weight:bold;background:#fff;border:2px solid #333;border-radius:3px;cursor:pointer;\">0<\/button>\n      <button id=\"btn1\" style=\"width:72px;height:72px;font-size:28px;font-family:Georgia,serif;font-weight:bold;background:#fff;border:2px solid #333;border-radius:3px;cursor:pointer;\">1<\/button>\n    <\/div>\n  <\/div>\n\n<\/div>","DefaultChoices":false,"DataExportTag":"wheel game 2","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Round 1 of 20 Choose a square in your mind, then click 'I made my choice'. I made my choice What...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID12","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n\n  var round = 1;\n  var totalRounds = 20;\n  var responses = [];\n  var engine = this;\n\n  this.hideNextButton();\n\n  document.getElementById('btn0').addEventListener('click', function() { recordResponse(0); });\n  document.getElementById('btn1').addEventListener('click', function() { recordResponse(1); });\n\n  document.getElementById('choice-btn').addEventListener('click', function() {\n    revealWheel();\n  });\n\n  function revealWheel() {\n    var values = [0, 0, 0, 1, 1, 1];\n    for (var i = values.length - 1; i > 0; i--) {\n      var j = Math.floor(Math.random() * (i + 1));\n      var tmp = values[i]; values[i] = values[j]; values[j] = tmp;\n    }\n    for (var k = 0; k < 6; k++) {\n      document.getElementById('txt' + k).textContent = values[k];\n    }\n    document.getElementById('choice-btn').style.display = 'none';\n    document.getElementById('instructions').innerHTML = 'What number is in the square you chose?';\n    document.getElementById('report-section').style.display = 'block';\n  }\n\n  function recordResponse(response) {\n    responses.push(response);\n\n    if (round < totalRounds) {\n      round++;\n      document.getElementById('round-label').textContent = 'Round ' + round + ' of ' + totalRounds;\n      document.getElementById('instructions').innerHTML = 'Choose a square <strong>in your mind<\/strong>, then click <em>\\'I made my choice\\'<\/em>.';\n      for (var k = 0; k < 6; k++) {\n        document.getElementById('txt' + k).textContent = '';\n      }\n      var btn = document.getElementById('choice-btn');\n      btn.style.display = 'block';\n      btn.style.background = '#1F3864';\n      btn.style.cursor = 'pointer';\n      btn.disabled = false;\n      document.getElementById('report-section').style.display = 'none';\n\n    } else {\n      var total1s = responses.reduce(function(a, b) { return a + b; }, 0);\n      Qualtrics.SurveyEngine.setEmbeddedData('wheel_part2_responses', responses.join(','));\n      Qualtrics.SurveyEngine.setEmbeddedData('wheel_part2_total', total1s);\n      document.getElementById('wheel-container').innerHTML =\n        '<p style=\"text-align:center;font-size:17px;font-family:Georgia,serif;padding:20px 0;\">Task complete. Please click <strong>Next<\/strong> to continue.<\/p>';\n      engine.showNextButton();\n    }\n  }\n\n});"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID14","SecondaryAttribute":"To earn more, make another guess: In your opinion, on average how many winning '1's (between 1 an...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>To earn more<\/b>, <b>make another guess<\/b>: In your opinion, on average how many winning '1's (between 1 and 20) did participants in the previous study actually report? Click on the scale below to enter your guess. If your prediction is correct (within 1), you will earn $1.","DefaultChoices":false,"DataExportTag":"Q14","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":1,"CSSliderMax":20,"GridLines":19,"SnapToGrid":true,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"NotApplicable":false,"MobileFirst":true,"SliderStartPositions":{"1":0.5}},"QuestionDescription":"To earn more, make another guess: In your opinion, on average how many winning '1's (between 1 an...","Choices":{"1":{"Display":"Average Number of Reported 1's"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":1,"Labels":[],"QuestionID":"QID14","Answers":{"1":{"Display":1},"2":{"Display":2},"3":{"Display":3},"4":{"Display":4},"5":{"Display":5},"6":{"Display":6},"7":{"Display":7},"8":{"Display":8},"9":{"Display":9},"10":{"Display":10},"11":{"Display":11},"12":{"Display":12},"13":{"Display":13},"14":{"Display":14},"15":{"Display":15},"16":{"Display":16},"17":{"Display":17},"18":{"Display":18},"19":{"Display":19},"20":{"Display":20}},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n\n  var engine = this;\n  engine.hideNextButton();\n\n  var qid = engine.questionId;\n  var hasInteracted = false;\n\n  \/\/ Wait for slider to render then hide handle\n  var attempts = 0;\n  var interval = setInterval(function() {\n    var handle = document.querySelector('.handle.selected');\n    if (handle) {\n      handle.style.visibility = 'hidden';\n      handle.style.opacity = '0';\n      clearInterval(interval);\n    }\n    attempts++;\n    if (attempts > 20) clearInterval(interval);\n  }, 100);\n\n  \/\/ Listen on the whole question container\n  var container = document.getElementById('QID' + qid);\n  if (!container) container = document.body;\n\n  function revealHandle() {\n    if (!hasInteracted) {\n      hasInteracted = true;\n      var handle = document.querySelector('.handle.selected');\n      if (handle) {\n        handle.style.visibility = 'visible';\n        handle.style.opacity = '1';\n      }\n      engine.showNextButton();\n    }\n  }\n\n  container.addEventListener('mousedown', revealHandle);\n  container.addEventListener('touchstart', revealHandle);\n\n});"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID2","SecondaryAttribute":"Thank you for taking part in this study! Please read the following information carefully before p...","TertiaryAttribute":null,"Payload":{"QuestionText":"Thank you for taking part in this study! Please read the following information carefully before proceeding.<br><br><b>About this study:<\/b> This is a survey-based study on human decision-making. You will be asked to complete simple tasks and answer questions. At the end of the study, you will complete a short demographic questionnaire. There is no deception in this study, everything you see or read is true.<br><br><b>Duration and compensation:&nbsp;<\/b>The study will take approximately 10 minutes. You will receive your Prolific participation fee for completing the study. In addition, you will have the opportunity to earn a bonus payment of up to $[TBD] depending on the accuracy of your responses and the outcomes of your choices.<br><br><b>Voluntary participation and withdrawal:<\/b> Your participation is entirely voluntary and you may withdraw at any time. Please note that only participants who complete the entire study will receive compensation.<br><b><br>Attention check:<\/b>&nbsp;This study contains an attention check question. Please read all instructions carefully and respond to the best of your ability.<br><br><b>Confidentiality:<\/b> Your responses are completely anonymous and will be used for academic research purposes only. No information that could identify you will be collected.<br><br><b>No AI tools:<\/b> To ensure scientific validity, all responses must reflect your own thoughts. The use of AI tools (such as ChatGPT) to generate or assist with your responses is strictly prohibited and may result in exclusion from the study.<br><br><b>Contact: <\/b>If you have any questions about this study, please contact Ryan Novak at ryanovak@sas.upenn.edu. This study is conducted under the auspices of the University of Pennsylvania.<br><br><b>Note:<\/b> This study must be completed on a laptop or PC. Submissions from mobile or tablet devices will be returned.<br>","DefaultChoices":false,"DataExportTag":"Q2","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thank you for taking part in this study! Please read the following information carefully before p...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID2"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID20","SecondaryAttribute":"This task is exactly the same as the first task. You will see 20 different wheels one after the o...","TertiaryAttribute":null,"Payload":{"QuestionText":"This task is exactly the same as the first task. You will see 20 different wheels one after the other, with as many 1s as 0s in each wheel. Before seeing the numbers in each wheel, choose a square in your mind. After seeing the numbers, you will <b>be asked to report the number displayed in that square.\n<\/b><br><br>At the end of the study, one wheel will be randomly selected from the 20. The money you will earn depends on the number you reported for that wheel:\n<br><br>- $1 if you reported '1'\n<br>- $0 if you reported '0'\n<br><br>&nbsp;We would like you not to take any breaks while completing the 20 wheels. When you are ready, please press <b>Next<\/b>&nbsp;to start the task.","DefaultChoices":false,"DataExportTag":"Q20","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"This task is exactly the same as the first task. You will see 20 different wheels one after the o...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID20"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID21","SecondaryAttribute":"Your job will be to choose in your mind one square in the wheel. Once you have chosen a square, y...","TertiaryAttribute":null,"Payload":{"QuestionText":"Your job will be to choose <b>in your mind<\/b> one square in the wheel. Once you have chosen a square, you will have to press the button \u2018I made my choice\u2019.<br><br>The program will then display a number in each square of the wheel. This number is either 0 or 1. In each wheel, there are as many 1s as 0s. Your job will be to report the number displayed in the square that you have previously chosen in your mind.<br><br>Suppose that before seeing the numbers in the wheel, you have chosen in your mind the square located at the top right of the wheel (highlighted in blue in the wheel below for illustration).&nbsp;<br>","DefaultChoices":false,"DataExportTag":"Q21","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Your job will be to choose in your mind one square in the wheel. Once you have chosen a square, y...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID21","Graphics":"IM_kSvyAtYnBz3BNha","GraphicsDescription":"Blue wheel","SubSelector":"WTXB"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID22","SecondaryAttribute":"You then discover the numbers are displayed in the wheel as follows:","TertiaryAttribute":null,"Payload":{"QuestionText":"You then discover the numbers are displayed in the wheel as follows:<br>","DefaultChoices":false,"DataExportTag":"Q22","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You then discover the numbers are displayed in the wheel as follows:","ChoiceOrder":["4","5","6","7","8"],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID22","SubSelector":"WTXB","Graphics":"IM_Z7qNxzIEKFxxC3w","GraphicsDescription":"Populated wheel"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID23","SecondaryAttribute":"Your job will be to report \u20180\u2019 as there is a \u20180\u2019 in the square you selected. Before seeing t","TertiaryAttribute":null,"Payload":{"QuestionText":"Your job will be to report \u20180\u2019 as there is a \u20180\u2019 in the square you selected.\n<br><br>Before seeing the numbers in each wheel, you will choose a square in your mind. After seeing the numbers in the wheel, you will be <b>asked to report the number displayed in this square<\/b>.&nbsp;<br><br>When you are ready, please press <b>Next&nbsp;<\/b>to start the task.","DefaultChoices":false,"DataExportTag":"Q23","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Your job will be to report \u20180\u2019 as there is a \u20180\u2019 in the square you selected. Before seeing the nu...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID23"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID24","SecondaryAttribute":"What is your age?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your age?","DefaultChoices":false,"DataExportTag":"Q17","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","InputWidth":580,"InputHeight":29},"QuestionDescription":"What is your age?","Validation":{"Settings":{"ForceResponse":"OFF","Type":"ContentType","MinChars":"1","ContentType":"ValidNumber","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip","ValidNumber":{"Min":"17","Max":"99","NumDecimals":"0"}}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID24","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"]}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID25","SecondaryAttribute":"What is your gender?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your gender?","DefaultChoices":false,"DataExportTag":"Q18","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","Autoscale":{"YScale":{"Name":"maleFemale","Type":"likert","Reverse":false}}},"QuestionDescription":"What is your gender?","Choices":{"1":{"Display":"Male"},"2":{"Display":"Female"},"3":{"Display":"Non-binary \/ third gender"},"4":{"Display":"Prefer not to say"}},"ChoiceOrder":["1","2","3","4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID25"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID26","SecondaryAttribute":"Were there any questions you found confusing or difficult to understand?","TertiaryAttribute":null,"Payload":{"QuestionText":"Were there any questions you found confusing or difficult to understand?","DefaultChoices":false,"DataExportTag":"Q19","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","Autoscale":{"YScale":{"Name":"yesNo","Type":"likert","Reverse":true}}},"QuestionDescription":"Were there any questions you found confusing or difficult to understand?","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID26"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID27","SecondaryAttribute":"Please specify which question(s) and why","TertiaryAttribute":null,"Payload":{"QuestionText":"Please specify which question(s) and why","DefaultChoices":false,"DataExportTag":"Q20","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please specify which question(s) and why","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None","MinChars":"1"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID27","DisplayLogic":{"0":{"0":{"LogicType":"Question","QuestionID":"QID26","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID26\/SelectableChoice\/1","Operator":"Selected","QuestionIDFromLocator":"QID26","LeftOperand":"q:\/\/QID26\/SelectableChoice\/1","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Were there any questions you found confusing or difficult to understand?\n\n<\/span> <span class=\"LeftOpDesc\">Yes<\/span> <span class=\"OpDesc\">Is Selected<\/span> "},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID28","SecondaryAttribute":"Did you experience any technical difficulties while completing the survey?","TertiaryAttribute":null,"Payload":{"QuestionText":"Did you experience any technical difficulties while completing the survey?","DefaultChoices":false,"DataExportTag":"Q21","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","Autoscale":{"YScale":{"Name":"yesNo","Type":"likert","Reverse":true}}},"QuestionDescription":"Did you experience any technical difficulties while completing the survey?","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID28"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID29","SecondaryAttribute":"Please describe the issue(s)","TertiaryAttribute":null,"Payload":{"QuestionText":"Please describe the issue(s)","DefaultChoices":false,"DataExportTag":"Q22","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please describe the issue(s)","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID29","DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID28\/SelectableChoice\/1","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Did you experience any technical difficulties while completing the survey?<\/span> <span class=\"LeftOpDesc\">Yes<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID28\/SelectableChoice\/1","LogicType":"Question","Operator":"Selected","QuestionID":"QID28","QuestionIDFromLocator":"QID28","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID3","SecondaryAttribute":"Round 1 of 5 Choose a square in your mind, then click 'I made my choice'. I made my choice What n...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"wheel-container\" style=\"background:#fff;border:1px solid #dde2ea;border-radius:4px;padding:36px 40px 32px;max-width:520px;width:100%;margin:auto;font-family:Georgia,serif;\">\n<div id=\"round-label\" style=\"font-size:13px;font-weight:bold;letter-spacing:0.08em;text-transform:uppercase;color:#888;margin-bottom:6px;text-align:center;\">Round 1 of 5<\/div>\n\n<div id=\"instructions\" style=\"font-size:15px;color:#333;text-align:center;margin-bottom:28px;line-height:1.5;min-height:44px;\">Choose a square <strong>in your mind<\/strong>, then click <em>'I made my choice'<\/em>.<\/div>\n\n<div style=\"display:flex;justify-content:center;margin-bottom:28px;\"><svg id=\"wheel-svg\" style=\"width:280px;height:280px;overflow:visible;\" viewBox=\"0 0 280 280\"> <line stroke=\"#333\" stroke-width=\"1.5\" x1=\"140\" x2=\"140\" y1=\"140\" y2=\"58\"><\/line> <line stroke=\"#333\" stroke-width=\"1.5\" x1=\"140\" x2=\"222\" y1=\"140\" y2=\"98\"><\/line> <line stroke=\"#333\" stroke-width=\"1.5\" x1=\"140\" x2=\"222\" y1=\"140\" y2=\"182\"><\/line> <line stroke=\"#333\" stroke-width=\"1.5\" x1=\"140\" x2=\"140\" y1=\"140\" y2=\"222\"><\/line> <line stroke=\"#333\" stroke-width=\"1.5\" x1=\"140\" x2=\"58\" y1=\"140\" y2=\"182\"><\/line> <line stroke=\"#333\" stroke-width=\"1.5\" x1=\"140\" x2=\"58\" y1=\"140\" y2=\"98\"><\/line> <circle cx=\"140\" cy=\"140\" fill=\"#333\" r=\"4\"><\/circle> <rect fill=\"#fff\" height=\"36\" id=\"sq0\" rx=\"2\" stroke=\"#333\" stroke-width=\"1.8\" width=\"52\" x=\"114\" y=\"20\"><\/rect> <text fill=\"#222\" font-family=\"Georgia,serif\" font-size=\"22\" font-weight=\"bold\" id=\"txt0\" style=\"pointer-events:none;\" text-anchor=\"middle\" x=\"140\" y=\"38\"><\/text> <rect fill=\"#fff\" height=\"36\" id=\"sq1\" rx=\"2\" stroke=\"#333\" stroke-width=\"1.8\" width=\"52\" x=\"196\" y=\"62\"><\/rect> <text fill=\"#222\" font-family=\"Georgia,serif\" font-size=\"22\" font-weight=\"bold\" id=\"txt1\" style=\"pointer-events:none;\" text-anchor=\"middle\" x=\"222\" y=\"80\"><\/text> <rect fill=\"#fff\" height=\"36\" id=\"sq2\" rx=\"2\" stroke=\"#333\" stroke-width=\"1.8\" width=\"52\" x=\"196\" y=\"164\"><\/rect> <text fill=\"#222\" font-family=\"Georgia,serif\" font-size=\"22\" font-weight=\"bold\" id=\"txt2\" style=\"pointer-events:none;\" text-anchor=\"middle\" x=\"222\" y=\"182\"><\/text> <rect fill=\"#fff\" height=\"36\" id=\"sq3\" rx=\"2\" stroke=\"#333\" stroke-width=\"1.8\" width=\"52\" x=\"114\" y=\"224\"><\/rect> <text fill=\"#222\" font-family=\"Georgia,serif\" font-size=\"22\" font-weight=\"bold\" id=\"txt3\" style=\"pointer-events:none;\" text-anchor=\"middle\" x=\"140\" y=\"242\"><\/text> <rect fill=\"#fff\" height=\"36\" id=\"sq4\" rx=\"2\" stroke=\"#333\" stroke-width=\"1.8\" width=\"52\" x=\"32\" y=\"164\"><\/rect> <text fill=\"#222\" font-family=\"Georgia,serif\" font-size=\"22\" font-weight=\"bold\" id=\"txt4\" style=\"pointer-events:none;\" text-anchor=\"middle\" x=\"58\" y=\"182\"><\/text> <rect fill=\"#fff\" height=\"36\" id=\"sq5\" rx=\"2\" stroke=\"#333\" stroke-width=\"1.8\" width=\"52\" x=\"32\" y=\"62\"><\/rect> <text fill=\"#222\" font-family=\"Georgia,serif\" font-size=\"22\" font-weight=\"bold\" id=\"txt5\" style=\"pointer-events:none;\" text-anchor=\"middle\" x=\"58\" y=\"80\"><\/text> <\/svg><\/div>\n<button id=\"choice-btn\" style=\"display:block;margin:0 auto;padding:11px 32px;font-size:15px;font-family:Georgia,serif;background:#1F3864;color:#fff;border:none;border-radius:3px;cursor:pointer;letter-spacing:0.03em;\">I made my choice<\/button>\n\n<div id=\"report-section\" style=\"display:none;text-align:center;margin-top:20px;\">\n<p style=\"font-size:15px;color:#333;margin-bottom:14px;\">What number is in the square you chose?<\/p>\n\n<div style=\"display:flex;justify-content:center;gap:16px;\"><button id=\"btn0\" style=\"width:72px;height:72px;font-size:28px;font-family:Georgia,serif;font-weight:bold;background:#fff;border:2px solid #333;border-radius:3px;cursor:pointer;\">0<\/button><button id=\"btn1\" style=\"width:72px;height:72px;font-size:28px;font-family:Georgia,serif;font-weight:bold;background:#fff;border:2px solid #333;border-radius:3px;cursor:pointer;\">1<\/button><\/div>\n<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"Instructions","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Round 1 of 5 Choose a square in your mind, then click 'I made my choice'. I made my choice What n...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID3","SubSelector":"WTXB","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n\n  var round = 1;\n  var totalRounds = 5;\n  var responses = [];\n  var engine = this;\n\n  this.hideNextButton();\n\n  document.getElementById('btn0').addEventListener('click', function() { recordResponse(0); });\n  document.getElementById('btn1').addEventListener('click', function() { recordResponse(1); });\n\n  document.getElementById('choice-btn').addEventListener('click', function() {\n    revealWheel();\n  });\n\n  function revealWheel() {\n    var values = [0, 0, 0, 1, 1, 1];\n    for (var i = values.length - 1; i > 0; i--) {\n      var j = Math.floor(Math.random() * (i + 1));\n      var tmp = values[i]; values[i] = values[j]; values[j] = tmp;\n    }\n    for (var k = 0; k < 6; k++) {\n      document.getElementById('txt' + k).textContent = values[k];\n    }\n    document.getElementById('choice-btn').style.display = 'none';\n    document.getElementById('instructions').innerHTML = 'What number is in the square you chose?';\n    document.getElementById('report-section').style.display = 'block';\n  }\n\n  function recordResponse(response) {\n    responses.push(response);\n\n    if (round < totalRounds) {\n      round++;\n      document.getElementById('round-label').textContent = 'Round ' + round + ' of ' + totalRounds;\n      document.getElementById('instructions').innerHTML = 'Choose a square <strong>in your mind<\/strong>, then click <em>\\'I made my choice\\'<\/em>.';\n      for (var k = 0; k < 6; k++) {\n        document.getElementById('txt' + k).textContent = '';\n      }\n      var btn = document.getElementById('choice-btn');\n      btn.style.display = 'block';\n      btn.style.background = '#1F3864';\n      btn.style.cursor = 'pointer';\n      btn.disabled = false;\n      document.getElementById('report-section').style.display = 'none';\n\n    } else {\n      var total1s = responses.reduce(function(a, b) { return a + b; }, 0);\n      Qualtrics.SurveyEngine.setEmbeddedData('wheel_part1_responses', responses.join(','));\n      Qualtrics.SurveyEngine.setEmbeddedData('wheel_part1_total', total1s);\n      document.getElementById('wheel-container').innerHTML =\n        '<p style=\"text-align:center;font-size:17px;font-family:Georgia,serif;padding:20px 0;\">Task complete. Please click <strong>Next<\/strong> to continue.<\/p>';\n      engine.showNextButton();\n    }\n  }\n\n});"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID30","SecondaryAttribute":"Do you have any additional comments, suggestions, or feedback about this survey that could help u...","TertiaryAttribute":null,"Payload":{"QuestionText":"Do you have any additional comments, suggestions, or feedback about this survey that could help us improve it?","DefaultChoices":false,"DataExportTag":"Q23","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Do you have any additional comments, suggestions, or feedback about this survey that could help u...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID30"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID31","SecondaryAttribute":"How confident are you in your guess above?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you in your guess above?","DefaultChoices":false,"DataExportTag":"Q24","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you in your guess above?","Choices":{"1":{"Display":"Confidence Level"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":3,"Labels":{"1":{"Display":"Not at all confident"},"2":{"Display":"Confident"}},"QuestionID":"QID31","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n\n  var engine = this;\n  engine.hideNextButton();\n  var hasInteracted = false;\n\n  var attempts = 0;\n  var interval = setInterval(function() {\n    var handle = document.querySelector('.QID31-1-handle');\n    if (handle) {\n      handle.style.visibility = 'hidden';\n      handle.style.opacity = '0';\n      clearInterval(interval);\n    }\n    attempts++;\n    if (attempts > 20) clearInterval(interval);\n  }, 100);\n\n  var container = document.getElementById('QID31');\n  if (!container) container = document.body;\n\n  function revealHandle() {\n    if (!hasInteracted) {\n      hasInteracted = true;\n      var handle = document.querySelector('.QID31-1-handle');\n      if (handle) {\n        handle.style.visibility = 'visible';\n        handle.style.opacity = '1';\n      }\n      engine.showNextButton();\n    }\n  }\n\n  container.addEventListener('mousedown', revealHandle);\n  container.addEventListener('touchstart', revealHandle);\n\n});"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID32","SecondaryAttribute":"How much do you think participants in the previous study differed from one another in how many 1s...","TertiaryAttribute":null,"Payload":{"QuestionText":"How much do you think participants in the previous study differed from one another in how many 1s they reported? (0 = Everyone reported roughly the same amount, 100 = There was a lot of variation)","DefaultChoices":false,"DataExportTag":"Q25","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How much do you think participants in the previous study differed from one another in how many 1s...","Choices":{"1":{"Display":"Level of Variation"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":3,"Labels":{"1":{"Display":"Everyone reported roughly the same amount"},"2":{"Display":"There was a lot of variation"}},"QuestionID":"QID32","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n\n  var engine = this;\n  engine.hideNextButton();\n  var hasInteracted = false;\n\n  var attempts = 0;\n  var interval = setInterval(function() {\n    var handle = document.querySelector('.QID32-1-handle');\n    if (handle) {\n      handle.style.visibility = 'hidden';\n      handle.style.opacity = '0';\n      clearInterval(interval);\n    }\n    attempts++;\n    if (attempts > 20) clearInterval(interval);\n  }, 100);\n\n  var container = document.getElementById('QID32');\n  if (!container) container = document.body;\n\n  function revealHandle() {\n    if (!hasInteracted) {\n      hasInteracted = true;\n      var handle = document.querySelector('.QID32-1-handle');\n      if (handle) {\n        handle.style.visibility = 'visible';\n        handle.style.opacity = '1';\n      }\n      engine.showNextButton();\n    }\n  }\n\n  container.addEventListener('mousedown', revealHandle);\n  container.addEventListener('touchstart', revealHandle);\n\n});"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID33","SecondaryAttribute":"The following statements concern your personal tendencies and typical behavior. Please indicate h...","TertiaryAttribute":null,"Payload":{"QuestionText":"The following statements concern your personal tendencies and typical behavior. Please indicate how much you agree or disagree with each statement. There are no right or wrong answers; please answer honestly based on how you actually think and behave, not how you think you should.","DefaultChoices":false,"DataExportTag":"Q26","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true,"ChoiceColumnWidthPixels":439.33331298828125},"QuestionDescription":"The following statements concern your personal tendencies and typical behavior. Please indicate h...","Choices":{"1":{"Display":"I wouldn't use flattery to get a raise or promotion at work, even if I thought it would succeed."},"2":{"Display":"If I want something from a person I dislike, I will act very nicely toward that person in order to get it."},"3":{"Display":"I would never accept a bribe, even if it were very large."},"4":{"Display":"I would be tempted to use counterfeit money, if I were sure I could get away with it."},"5":{"Display":"I would never cheat on my taxes, even if I thought I could get away with it."},"6":{"Display":"I wouldn't pretend to like someone just to get that person to do favors for me."}},"ChoiceOrder":[1,2,3,4,5,6],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":6,"Answers":{"1":{"Display":"Strongly Disagree"},"2":{"Display":"Disagree"},"3":{"Display":"Neither agree nor disagree"},"4":{"Display":"Agree"},"5":{"Display":"Strongly agree"}},"AnswerOrder":[1,2,3,4,5],"ChoiceDataExportTags":false,"QuestionID":"QID33"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID34","SecondaryAttribute":"The following statements concern your personal tendencies and typical behavior. Please indicate h...","TertiaryAttribute":null,"Payload":{"QuestionText":"The following statements concern your personal tendencies and typical behavior. Please indicate how much you agree or disagree with each statement.\nThere are no right or wrong answers; please answer honestly based on how you actually think and behave, not how you think you should.","DefaultChoices":false,"DataExportTag":"Q27","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"The following statements concern your personal tendencies and typical behavior. Please indicate h...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID34"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID35","SecondaryAttribute":"By clicking 'I agree, continue to survey' you confirm that: 1. You have read and understood the i...","TertiaryAttribute":null,"Payload":{"QuestionText":"By clicking<b> 'I agree, continue to survey'<\/b> you confirm that:\n<br><br>1. You have read and understood the information above.<br>2. You are at least 18 years old.<br>3. You understand that no personally identifying information will be collected.<br>4. All responses you provide will be your own, without the assistance of any AI tools.<br>5. You voluntarily agree to participate.","DefaultChoices":false,"DataExportTag":"Q25","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"By clicking 'I agree, continue to survey' you confirm that: 1. You have read and understood the i...","Choices":{"1":{"Display":"I agree, continue to survey"},"2":{"Display":"I do not wish to participate"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID35","QuestionJS":false}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID36","SecondaryAttribute":"In this task, you will have the chance to earn an additional bonus. To earn more, you will be ask...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>In this task, you will have the chance to earn an additional bonus.<\/b> To earn more, you will be asked to indicate your beliefs about how participants in a previous study evaluated different choices.<br><br><b>About the Previous Study<br><\/b>In that study, participants were asked to consider a participant who played the wheel game 20 times. In the wheel game, there are as many 1s as 0s across the six squares. <b>That participant drew exactly 10 winning numbers (1s) and 10 losing numbers (0s)<\/b> across their 20 wheels. At the end of the study, one wheel was randomly selected. That participant earned $1 if they had reported a winning 1 for that wheel, and $0 if they had reported a 0. This means that reporting more 1s increased their chances of earning the bonus.<br><br>Participants were then asked to evaluate a range of possible behaviors, specifically how many 1s that participant could have reported, and to indicate at what point reporting a certain number of 1s becomes socially appropriate or inappropriate. To ensure participants took this task seriously, they could earn additional money each time their answer matched the most common answer given by other participants in the study. See below for the table that participants filled out to indicate their beliefs:\n\n<br><br>","DefaultChoices":false,"DataExportTag":"Q26","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In this task, you will have the chance to earn an additional bonus. To earn more, you will be ask...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID36","SubSelector":"WTXB","Graphics":"IM_QZgXex4b2UkaqHr","GraphicsDescription":"Norm disclosure"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID37","SecondaryAttribute":"I have read the above, click to continue:","TertiaryAttribute":null,"Payload":{"QuestionText":"I have read the above, click to continue:","DefaultChoices":false,"DataExportTag":"Q27","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"I have read the above, click to continue:","Choices":{"1":{"Display":"Continue"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID37"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID4","SecondaryAttribute":"Game Instructions You will see a wheel with six empty squares. The wheel will look like the one b...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b><u>Game Instructions<br><\/u><\/b><br>You will see a wheel with six empty squares. The wheel will look like the one below:<br>","DefaultChoices":false,"DataExportTag":"Q4","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game Instructions You will see a wheel with six empty squares. The wheel will look like the one b...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID4","SubSelector":"WTXB","Graphics":"IM_dv4CAbWvye4pmzM","GraphicsDescription":"Blank wheel"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID5","SecondaryAttribute":"Later in this study, you will play the wheel game for 20 rounds with the same incentivization sch...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b style=\"text-decoration-line: underline;\">Later in this study, you will play the wheel game for 20 rounds <\/b>with the same incentivization scheme as in the previous experiment.&nbsp;Before you do, we would like you to complete a short task related to the previous study.<br><br><b>Your Task<br><\/b>Your task is to <b>identify the switching points<\/b> you think existed across participants in the previous study. (Reminder: <i>a switching point is the number of reported 1s at which they considered the described participant's behaviour to switch from socially appropriate to socially inappropriate<\/i>.)<br><br>Different participants may have drawn the line in different places. You may <b>select up to 8 switching points to reflect this variety<\/b>. On the next screen, you will assign a <b>percentage share <\/b>to each, reflecting how common you think each was. The shares must sum to 100%.<br><br>You will earn a bonus if your assigned shares are within <b>5 percentage points<\/b> of the actual distribution.<br><br>When you are ready, please press <b>Next<\/b> to begin.\n\n<br>","DefaultChoices":false,"DataExportTag":"Q5","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Later in this study, you will play the wheel game for 20 rounds with the same incentivization sch...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID5"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID6","SecondaryAttribute":"Your TaskYour task is to identify the switching points you think existed across participants in t...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Your Task<br><\/b>Your task is to <b>identify the switching points<\/b> you think existed across participants in the previous study. (<i>Reminder: a switching point is the number of reported 1s at which they considered the described participant's behaviour to switch from socially appropriate to socially inappropriate.<\/i>)<br><br>Different participants may have drawn the line in different places. You may select up to <b>8 switching points<\/b> to reflect this variety. On the next screen, you will assign a <b>percentage share<\/b> to each, reflecting how common you think each was. The shares must sum to 100%.<br><br>You will earn a bonus if your assigned shares are within <b>5 percentage points<\/b> of the actual distribution.<br><br>When you are ready, please press <b>Next<\/b> to begin.","DefaultChoices":false,"DataExportTag":"Q6","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Your TaskYour task is to identify the switching points you think existed across participants in t...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID6","Graphics":"IM_wV1fJ6v8CdH94XI","GraphicsDescription":"Norm disclosure"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"SQ","PrimaryAttribute":"QID7","SecondaryAttribute":"Each participant in the previous study held a single switching point at which the number of repor...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"norm-container\" style=\"background:#fff;border:1px solid #dde2ea;border-radius:4px;padding:36px 40px 32px;max-width:520px;width:100%;margin:auto;font-family:Georgia,serif;\">\n\n  <p style=\"font-size:15px;color:#333;line-height:1.6;margin-bottom:8px;\">\n    Each participant in the previous study held a <strong>single switching point<\/strong> at which the number of reported winning outcomes switched from appropriate to socially inappropriate.\n  <\/p>\n  <p style=\"font-size:15px;color:#333;line-height:1.6;margin-bottom:20px;\">\n    Please select <strong>up to 8 switching points<\/strong> from the list below.\n  <\/p>\n\n  <div id=\"checkbox-list\" style=\"display:flex;flex-direction:column;gap:10px;margin-bottom:24px;\">\n    <label id=\"lbl11\" style=\"display:flex;align-items:center;gap:12px;font-size:15px;cursor:pointer;padding:10px 14px;border:1.5px solid #ccc;border-radius:3px;\">\n      <input type=\"checkbox\" value=\"11\" style=\"width:18px;height:18px;cursor:pointer;\"> 11 winning numbers\n    <\/label>\n    <label id=\"lbl12\" style=\"display:flex;align-items:center;gap:12px;font-size:15px;cursor:pointer;padding:10px 14px;border:1.5px solid #ccc;border-radius:3px;\">\n      <input type=\"checkbox\" value=\"12\" style=\"width:18px;height:18px;cursor:pointer;\"> 12 winning numbers\n    <\/label>\n    <label id=\"lbl13\" style=\"display:flex;align-items:center;gap:12px;font-size:15px;cursor:pointer;padding:10px 14px;border:1.5px solid #ccc;border-radius:3px;\">\n      <input type=\"checkbox\" value=\"13\" style=\"width:18px;height:18px;cursor:pointer;\"> 13 winning numbers\n    <\/label>\n    <label id=\"lbl14\" style=\"display:flex;align-items:center;gap:12px;font-size:15px;cursor:pointer;padding:10px 14px;border:1.5px solid #ccc;border-radius:3px;\">\n      <input type=\"checkbox\" value=\"14\" style=\"width:18px;height:18px;cursor:pointer;\"> 14 winning numbers\n    <\/label>\n    <label id=\"lbl15\" style=\"display:flex;align-items:center;gap:12px;font-size:15px;cursor:pointer;padding:10px 14px;border:1.5px solid #ccc;border-radius:3px;\">\n      <input type=\"checkbox\" value=\"15\" style=\"width:18px;height:18px;cursor:pointer;\"> 15 winning numbers\n    <\/label>\n    <label id=\"lbl16\" style=\"display:flex;align-items:center;gap:12px;font-size:15px;cursor:pointer;padding:10px 14px;border:1.5px solid #ccc;border-radius:3px;\">\n      <input type=\"checkbox\" value=\"16\" style=\"width:18px;height:18px;cursor:pointer;\"> 16 winning numbers\n    <\/label>\n    <label id=\"lbl17\" style=\"display:flex;align-items:center;gap:12px;font-size:15px;cursor:pointer;padding:10px 14px;border:1.5px solid #ccc;border-radius:3px;\">\n      <input type=\"checkbox\" value=\"17\" style=\"width:18px;height:18px;cursor:pointer;\"> 17 winning numbers\n    <\/label>\n    <label id=\"lbl18\" style=\"display:flex;align-items:center;gap:12px;font-size:15px;cursor:pointer;padding:10px 14px;border:1.5px solid #ccc;border-radius:3px;\">\n      <input type=\"checkbox\" value=\"18\" style=\"width:18px;height:18px;cursor:pointer;\"> 18 winning numbers\n    <\/label>\n    <label id=\"lbl19\" style=\"display:flex;align-items:center;gap:12px;font-size:15px;cursor:pointer;padding:10px 14px;border:1.5px solid #ccc;border-radius:3px;\">\n      <input type=\"checkbox\" value=\"19\" style=\"width:18px;height:18px;cursor:pointer;\"> 19 winning numbers\n    <\/label>\n    <label id=\"lbl20\" style=\"display:flex;align-items:center;gap:12px;font-size:15px;cursor:pointer;padding:10px 14px;border:1.5px solid #ccc;border-radius:3px;\">\n      <input type=\"checkbox\" value=\"20\" style=\"width:18px;height:18px;cursor:pointer;\"> 20 winning numbers\n    <\/label>\n  <\/div>\n\n  <p id=\"selection-count\" style=\"font-size:13px;color:#888;text-align:center;margin-bottom:0;\">0 of 8 selected<\/p>\n  <p id=\"error-msg\" style=\"font-size:13px;color:#c0392b;text-align:center;display:none;margin-top:6px;\">Please select at least one switching point.<\/p>\n\n<\/div>","DefaultChoices":false,"DataExportTag":"Normative Expect","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Each participant in the previous study held a single switching point at which the number of repor...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID7","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n\n  var engine = this;\n  var MAX = 8;\n  this.hideNextButton();\n\n  var checkboxes = document.querySelectorAll('#checkbox-list input[type=\"checkbox\"]');\n\n  checkboxes.forEach(function(cb) {\n    cb.addEventListener('change', function() {\n      var checked = document.querySelectorAll('#checkbox-list input:checked');\n\n      \/\/ Enforce max 8\n      if (checked.length > MAX) {\n        this.checked = false;\n        checked = document.querySelectorAll('#checkbox-list input:checked');\n      }\n\n      \/\/ Update count label\n      document.getElementById('selection-count').textContent = checked.length + ' of 8 selected';\n\n      \/\/ Highlight selected rows\n      checkboxes.forEach(function(c) {\n        var lbl = c.parentElement;\n        if (c.checked) {\n          lbl.style.borderColor = '#1F3864';\n          lbl.style.background = '#eef2f8';\n        } else {\n          lbl.style.borderColor = '#ccc';\n          lbl.style.background = '#fff';\n        }\n      });\n    });\n  });\n\n  \/\/ Validate on Next\n  engine.showNextButton();\n  jQuery('#NextButton').on('click', function(e) {\n    var checked = document.querySelectorAll('#checkbox-list input:checked');\n    if (checked.length === 0) {\n      e.stopImmediatePropagation();\n      document.getElementById('error-msg').style.display = 'block';\n      return false;\n    }\n    \/\/ Save selected points to embedded data\n    var selected = Array.from(checked).map(function(c) { return c.value; });\n    Qualtrics.SurveyEngine.setEmbeddedData('norm_selected_points', selected.join(','));\n  });\n\n});"}},{"SurveyID":"SV_42t4zrRtKe0IFcG","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}}]}