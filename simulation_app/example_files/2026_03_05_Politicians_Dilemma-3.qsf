alic; line-height: 1.6; }\n.debate-container .progress-row { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; }\n.debate-container .progress-track { flex: 1; height: 4px; background: var(--progress-track); border-radius: 2px; overflow: hidden; }\n.debate-container .progress-fill { height: 100%; background: var(--progress-fill); border-radius: 2px; transition: width 0.5s ease; width: 0%; }\n.debate-container .progress-label { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--subtext); white-space: nowrap; }\n.debate-container #bubble-area { display: flex; flex-direction: column; gap: 14px; min-height: 60px; }\n.debate-container .bubble { padding: 16px 20px; border-radius: 10px; border-left: 4px solid transparent; opacity: 0; transform: translateY(10px); animation: bubbleIn 0.4s ease forwards; line-height: 1.7; font-size: 15.5px; }\n@keyframes bubbleIn { to { opacity: 1; transform: translateY(0); } }\n.debate-container .bubble.dem { background: var(--dem-bg); border-left-color: var(--dem-border); }\n.debate-container .bubble.rep { background: var(--rep-bg); border-left-color: var(--rep-border); }\n.debate-container .bubble .speaker-tag { display: block; font-family: 'IBM Plex Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500; margin-bottom: 7px; }\n.debate-container .bubble.dem .speaker-tag { color: var(--dem-label); }\n.debate-container .bubble.rep .speaker-tag { color: var(--rep-label); }\n.debate-container .bubble .bubble-text { color: var(--text); }\n.debate-container #typing-row { display: none; align-items: center; gap: 10px; padding: 14px 18px; background: var(--typing-bg); border-radius: 10px; margin-top: 14px; opacity: 0; transition: opacity 0.3s ease; }\n.debate-container #typing-row.visible { display: flex; opacity: 1; }\n.debate-container #typing-name { font-family: 'IBM Plex Mono', monospace; font-size: 12px; color: var(--subtext); }\n.debate-container .dot-row { display: flex; gap: 4px; align-items: center; }\n.debate-container .dot-row span { width: 6px; height: 6px; background: var(--subtext); border-radius: 50%; display: inline-block; animation: blink 1.2s infinite; }\n.debate-container .dot-row span:nth-child(2) { animation-delay: 0.2s; }\n.debate-container .dot-row span:nth-child(3) { animation-delay: 0.4s; }\n@keyframes blink { 0%, 80%, 100% { opacity: 0.25; transform: scale(0.85); } 40% { opacity: 1; transform: scale(1); } }\n.debate-container #continue-btn { display: none; margin-top: 22px; padding: 12px 28px; background: var(--btn-bg); color: white; border: none; border-radius: 8px; font-family: 'IBM Plex Mono', monospace; font-size: 13px; letter-spacing: 0.04em; cursor: pointer; transition: background 0.2s ease, transform 0.1s ease; }\n.debate-container #continue-btn:hover { background: var(--btn-hover); transform: translateY(-1px); }\n.debate-container #continue-btn:active { transform: translateY(0); }\n.debate-container #completion-banner { display: none; margin-top: 24px; padding: 16px 20px; background: #F0FDF4; border: 1px solid #BBF7D0; border-radius: 10px; font-size: 14px; color: #166534; font-style: italic; }\n.debate-container .turn-divider { height: 1px; background: var(--border); margin: 6px 0 2px; opacity: 0; animation: fadeIn 0.4s ease 0.3s forwards; }\n@keyframes fadeIn { to { opacity: 1; } }\n.debate-container .instructions { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 16px 20px; margin-bottom: 28px; font-size: 14px; color: var(--subtext); line-height: 1.6; }\n.debate-container .instructions strong { color: var(--text); }"}}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID1","SecondaryAttribute":"You are being asked to complete a survey as part of a research study.\u00a0 What is the purpose of thi..","TertiaryAttribute":null,"Payload":{"QuestionText":"You are being asked to complete a survey as part of a research study.&nbsp;<br>\n<br>\n<b><i>What is the purpose of this research?&nbsp;<\/i><\/b>The purpose of this research is to understand people\u2019s views and opinions on current political issues and other people in the context of political debates.\n<p><br>\n<b><i>How long will I take part in this research?<\/i><\/b>&nbsp;Your participation for the entire study will be 5-10 minutes.<br>\n<br>\n<b><i>What can I expect if I take part in this research?<\/i><\/b>&nbsp;As a participant you will read debate transcripts from political debates and fill out a short questionnaire about your views on the participants in the debate (e.g. two politicians). You will also be asked to explain your opinions on political issues to future study participants.&nbsp;<br>\n<br>\n<b><i>What should I know about a research study?&nbsp;<\/i><\/b><br>\n<br>\n\u2022 Whether or not you take part is up to you.<br>\n\u2022 Your participation is completely voluntary.<br>\n\u2022 You can choose not to take part.<br>\n\u2022 You can agree to take part and later change your mind.<br>\n\u2022 Your decision will not be held against you. &nbsp;<br>\n\u2022 Your refusal to participate will not result in any consequences or any loss of benefits that you are otherwise entitled to receive.<br>\n\u2022 You can ask all the questions you want before you decide.<br>\n<br>\n<b><i>What are the risks and possible discomforts?&nbsp;<\/i><\/b>We do not foresee any risks from participating in the study. All political issues in this study are regularly discussed in the media and the probability of discomfort is no greater than in daily life.<br>\n<br>\n<b><i>Will I be compensated for participating in this research?&nbsp;<\/i><\/b>Participants recruited from Prolific will receive the amount listed in the posting.&nbsp;<\/p><p><br><\/p>\n\n<p><b><i>Who can I talk to?&nbsp;<\/i><\/b>If you have questions, concerns, or complaints, or think the research has hurt you, talk to the research team at <a href=\"mailto:hspohn@g.harvard.edu\">hspohn@g.harvard.edu<\/a>.<\/p><p>&nbsp;<\/p>\n\n<p><b><i>Statement of Consent<\/i><\/b>: Being in this study is voluntary. If you want to participate in this study, click the button below. Please save or print a copy of this form for your records.<\/p>","DefaultChoices":false,"DataExportTag":"consent","QuestionID":"QID1","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You are being asked to complete a survey as part of a research study.\u00a0 What is the purpose of thi...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID10","SecondaryAttribute":"In general, do you think of yourself as","TertiaryAttribute":null,"Payload":{"QuestionText":"In general, do you think of yourself as","DataExportTag":"Liberal\/Conservative","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In general, do you think of yourself as","Choices":{"1":{"Display":"Extremely liberal"},"2":{"Display":"Liberal"},"3":{"Display":"Slightly liberal"},"4":{"Display":"Moderate"},"5":{"Display":"Slightly conservative"},"6":{"Display":"Conservative"},"7":{"Display":"Extremely conservative"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":8,"NextAnswerId":1,"QuestionID":"QID10"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID11","SecondaryAttribute":"Generally speaking, do you usually think of yourself as a Republican, a Democrat, an Independent,...","TertiaryAttribute":null,"Payload":{"QuestionText":"Generally speaking, do you usually think of yourself as a Republican, a Democrat, an Independent, or what?","DataExportTag":"Republican\/Democrat","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Generally speaking, do you usually think of yourself as a Republican, a Democrat, an Independent,...","Choices":{"1":{"Display":"Strong Republican"},"2":{"Display":"Republican"},"3":{"Display":"Lean Republican"},"4":{"Display":"Independent\/ middle of the road"},"5":{"Display":"Lean Democrat"},"6":{"Display":"Democrat"},"7":{"Display":"Strong Democrat"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":8,"NextAnswerId":1,"QuestionID":"QID11"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID12","SecondaryAttribute":"Are you registered to vote?","TertiaryAttribute":null,"Payload":{"QuestionText":"Are you registered to vote?","DataExportTag":"Voting behavior","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Are you registered to vote?","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID12"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID13","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"Q13","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID13"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID14","SecondaryAttribute":"\u25b6 Review the debate conversation Loading debate... We would like to get your feelings toward both.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"debate-accordion\" style=\"margin-bottom:24px;border:1px solid #e5e7eb;\n            border-radius:8px;overflow:hidden;\n            font-family:-apple-system,BlinkMacSystemFont,\n            'Segoe UI',sans-serif;\"><button id=\"toggle-debate-btn\" style=\"width:100%;padding:14px 20px;text-align:left;\n                 background:#f9fafb;border:none;cursor:pointer;\n                 font-size:14px;font-weight:600;color:#374151;\n                 display:flex;align-items:center;gap:8px;\n                 transition:background 0.15s;\"><span id=\"accordion-arrow\" style=\"display:inline-block;transition:transform 0.2s;\n                 font-size:12px;\">\u25b6<\/span> Review the debate conversation<\/button>\n<div id=\"debate-content\" style=\"display:none;padding:20px;border-top:1px solid #e5e7eb;\n              background:#ffffff;max-height:400px;overflow-y:auto;\">\n<p style=\"color:#6b7280;font-size:13px;font-style:italic;\n              margin-top:0;\">Loading debate...<\/p>\n<\/div>\n<\/div>\nWe would like to get your feelings toward both Individual A and Individual B. We would like you to rate them using something we call the feeling thermometer.<br \/>\n<br \/>\nRatings between 50 degrees and 100 degrees mean that you feel favorable and warm toward them. Ratings between 0 degrees and 50 degrees mean that you don&#39;t feel favorable toward them and that you don&#39;t care too much for them. You would rate them at the 50-degree mark if you don&#39;t feel particularly warm or cold toward them.","DefaultChoices":{"1":{"Value":"50"},"2":{"Value":"50"}},"DataExportTag":"FeelingThermometer","QuestionID":"QID14","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true,"SliderStartPositions":{"1":0.5,"2":0.5}},"QuestionDescription":"\u25b6 Review the debate conversation Loading debate... We would like to get your feelings toward both...","Choices":{"1":{"Display":"How would you rate Individual A?"},"2":{"Display":"How would you rate Individual B?"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"Labels":[],"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    var qid = 'therm';\n    var debateOpened = 0;\n    var toggleCount = 0;\n    var firstOpenTime = null;\n    var pageStart = Date.now();\n\n    window._accordion_totalViewTime = 0;\n    window._accordion_viewStart = null;\n    window._accordion_qid = qid;\n\n    function setED(key, value) {\n        Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    \/\/ --- Load debate content ---\n    var contentDiv = document.getElementById('debate-content');\n    var bubbles = null;\n\n    if (window._debateBubbles) {\n        bubbles = window._debateBubbles;\n    }\n\n    if (!bubbles) {\n        try {\n            var raw = \"${e:\/\/Field\/debateJSON}\";\n            raw = raw.replace(\/&amp;\/g,'&').replace(\/&lt;\/g,'<').replace(\/&gt;\/g,'>').replace(\/&quot;\/g,'\"').replace(\/&#39;\/g,\"'\").replace(\/&#x27;\/g,\"'\").replace(\/&apos;\/g,\"'\");\n            bubbles = JSON.parse(raw);\n        } catch(e) {}\n    }\n\n    if (bubbles && contentDiv) {\n        var html = '';\n        for (var i = 0; i < bubbles.length; i++) {\n            var b = bubbles[i];\n            html += '<div style=\"display:flex;margin-bottom:12px;'\n                + (b.side === 'rep' ? 'justify-content:flex-end;' : '') + '\">'\n                + '<div style=\"max-width:80%;padding:12px 16px;border-radius:16px;'\n                + (b.side === 'dem'\n                    ? 'background:#dbeafe;border-bottom-left-radius:4px;'\n                    : 'background:#fee2e2;border-bottom-right-radius:4px;')\n                + 'font-size:14px;line-height:1.5;\">'\n                + '<div style=\"font-weight:600;font-size:12px;margin-bottom:4px;'\n                + (b.side === 'dem' ? 'color:#1e40af;' : 'color:#991b1b;')\n                + '\">' + b.speaker + '<\/div>'\n                + '<div>\\u201c' + b.text + '\\u201d<\/div>'\n                + '<\/div><\/div>';\n        }\n        contentDiv.innerHTML = html;\n    } else if (contentDiv) {\n        contentDiv.innerHTML =\n            '<p style=\"color:#999;font-style:italic;\">'\n            + 'Debate transcript not available.<\/p>';\n    }\n\n    \/\/ --- Toggle function ---\n    window.toggleDebate = function() {\n        var content = document.getElementById('debate-content');\n        var arrow = document.getElementById('accordion-arrow');\n        if (!content) return;\n\n        if (content.style.display === 'none') {\n            content.style.display = 'block';\n            if (arrow) arrow.style.transform = 'rotate(90deg)';\n            debateOpened = 1;\n            toggleCount++;\n            window._accordion_viewStart = Date.now();\n            if (firstOpenTime === null) {\n                firstOpenTime = Date.now() - pageStart;\n                setED(qid + '_accordion_firstOpen_ms', firstOpenTime);\n            }\n        } else {\n            content.style.display = 'none';\n            if (arrow) arrow.style.transform = 'rotate(0deg)';\n            if (window._accordion_viewStart) {\n                window._accordion_totalViewTime += Date.now() - window._accordion_viewStart;\n                window._accordion_viewStart = null;\n            }\n        }\n        setED(qid + '_accordion_opened', debateOpened);\n        setED(qid + '_accordion_toggles', toggleCount);\n    };\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var btn = document.getElementById('toggle-debate-btn');\n    if (btn) {\n        btn.addEventListener('click', function() {\n            window.toggleDebate();\n        });\n    }\n\n    try {\n        var choices = this.getChoices();\n        for (var i = 0; i < choices.length; i++) {\n            this.setChoiceValue(choices[i], 50);\n        }\n    } catch(e) {}\n});\n\nQualtrics.SurveyEngine.addOnUnload(function() {\n    if (window._accordion_viewStart) {\n        window._accordion_totalViewTime += Date.now() - window._accordion_viewStart;\n        window._accordion_viewStart = null;\n    }\n    Qualtrics.SurveyEngine.setEmbeddedData(\n        window._accordion_qid + '_accordion_viewTime_ms',\n        String(window._accordion_totalViewTime || 0)\n    );\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID15","SecondaryAttribute":"\u25b6 Review the debate conversation Loading debate... We would like to get your feelings toward Indi.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"debate-accordion\" style=\"margin-bottom:24px;border:1px solid #e5e7eb;\n            border-radius:8px;overflow:hidden;\n            font-family:-apple-system,BlinkMacSystemFont,\n            'Segoe UI',sans-serif;\"><button id=\"toggle-debate-btn\" style=\"width:100%;padding:14px 20px;text-align:left;\n                 background:#f9fafb;border:none;cursor:pointer;\n                 font-size:14px;font-weight:600;color:#374151;\n                 display:flex;align-items:center;gap:8px;\n                 transition:background 0.15s;\"><span id=\"accordion-arrow\" style=\"display:inline-block;transition:transform 0.2s;\n                 font-size:12px;\">\u25b6<\/span> Review the debate conversation<\/button>\n<div id=\"debate-content\" style=\"display:none;padding:20px;border-top:1px solid #e5e7eb;\n              background:#ffffff;max-height:400px;overflow-y:auto;\">\n<p style=\"color:#6b7280;font-size:13px;font-style:italic;\n              margin-top:0;\">Loading debate...<\/p>\n<\/div>\n<\/div>\nWe would like to get your feelings toward <strong>Individual A and B.<\/strong>&nbsp;<br>Rate individual A on the following traits.","DefaultChoices":false,"DataExportTag":"TraitRatings_A","QuestionID":"QID15","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true,"ChoiceColumnWidthPixels":190},"QuestionDescription":"\u25b6 Review the debate conversation Loading debate... We would like to get your feelings toward Indi...","Choices":{"1":{"Display":"Individual A is intelligent."},"2":{"Display":"Individual A is open-minded."},"3":{"Display":"Individual A is generous."},"4":{"Display":"Individual A is hypocritical."},"5":{"Display":"Individual A is selfish."},"6":{"Display":"Individual A is mean."},"7":{"Display":"Individual A is moral."}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":6,"Answers":{"1":{"Display":"Not at all"},"2":{"Display":"Slightly"},"3":{"Display":"Moderately"},"4":{"Display":"Very"},"5":{"Display":"Extremely"}},"AnswerOrder":[1,2,3,4,5],"ChoiceDataExportTags":false,"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    var qid = 'traitA';\n    var debateOpened = 0;\n    var toggleCount = 0;\n    var firstOpenTime = null;\n    var pageStart = Date.now();\n    window._accordion_totalViewTime = 0;\n    window._accordion_viewStart = null;\n    window._accordion_qid = qid;\n    function setED(key, value) {\n        Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n    var contentDiv = document.getElementById('debate-content');\n    var bubbles = null;\n    if (window._debateBubbles) { bubbles = window._debateBubbles; }\n    if (!bubbles) {\n        try {\n            var raw = \"${e:\/\/Field\/debateJSON}\";\n            raw = raw.replace(\/&amp;\/g,'&').replace(\/&lt;\/g,'<').replace(\/&gt;\/g,'>').replace(\/&quot;\/g,'\"').replace(\/&#39;\/g,\"'\").replace(\/&#x27;\/g,\"'\").replace(\/&apos;\/g,\"'\");\n            bubbles = JSON.parse(raw);\n        } catch(e) {}\n    }\n    if (bubbles && contentDiv) {\n        var html = '';\n        for (var i = 0; i < bubbles.length; i++) {\n            var b = bubbles[i];\n            html += '<div style=\"display:flex;margin-bottom:12px;' + (b.side === 'rep' ? 'justify-content:flex-end;' : '') + '\"><div style=\"max-width:80%;padding:12px 16px;border-radius:16px;' + (b.side === 'dem' ? 'background:#dbeafe;border-bottom-left-radius:4px;' : 'background:#fee2e2;border-bottom-right-radius:4px;') + 'font-size:14px;line-height:1.5;\"><div style=\"font-weight:600;font-size:12px;margin-bottom:4px;' + (b.side === 'dem' ? 'color:#1e40af;' : 'color:#991b1b;') + '\">' + b.speaker + '<\/div><div>\\u201c' + b.text + '\\u201d<\/div><\/div><\/div>';\n        }\n        contentDiv.innerHTML = html;\n    } else if (contentDiv) {\n        contentDiv.innerHTML = '<p style=\"color:#999;font-style:italic;\">Debate transcript not available.<\/p>';\n    }\n    window.toggleDebate = function() {\n        var content = document.getElementById('debate-content');\n        var arrow = document.getElementById('accordion-arrow');\n        if (!content) return;\n        if (content.style.display === 'none') {\n            content.style.display = 'block';\n            if (arrow) arrow.style.transform = 'rotate(90deg)';\n            debateOpened = 1; toggleCount++;\n            window._accordion_viewStart = Date.now();\n            if (firstOpenTime === null) { firstOpenTime = Date.now() - pageStart; setED(qid + '_accordion_firstOpen_ms', firstOpenTime); }\n        } else {\n            content.style.display = 'none';\n            if (arrow) arrow.style.transform = 'rotate(0deg)';\n            if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n        }\n        setED(qid + '_accordion_opened', debateOpened);\n        setED(qid + '_accordion_toggles', toggleCount);\n    };\n});\nQualtrics.SurveyEngine.addOnReady(function() {\n    var btn = document.getElementById('toggle-debate-btn');\n    if (btn) { btn.addEventListener('click', function() { window.toggleDebate(); }); }\n});\nQualtrics.SurveyEngine.addOnUnload(function() {\n    if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n    Qualtrics.SurveyEngine.setEmbeddedData(window._accordion_qid + '_accordion_viewTime_ms', String(window._accordion_totalViewTime || 0));\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID16","SecondaryAttribute":"Rate individual B on the following traits.","TertiaryAttribute":null,"Payload":{"QuestionText":"Rate individual B on the following traits.","DefaultChoices":false,"DataExportTag":"TraitRatings_B","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Rate individual B on the following traits.","Choices":{"1":{"Display":"Individual B is intelligent."},"2":{"Display":"Individual B is open-minded."},"3":{"Display":"Individual B is generous."},"4":{"Display"