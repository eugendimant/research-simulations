ll) { firstOpenTime = Date.now() - pageStart; setED(qid + '_accordion_firstOpen_ms', firstOpenTime); }\n        } else {\n            content.style.display = 'none';\n            if (arrow) arrow.style.transform = 'rotate(0deg)';\n            if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n        }\n        setED(qid + '_accordion_opened', debateOpened);\n        setED(qid + '_accordion_toggles', toggleCount);\n    };\n});\nQualtrics.SurveyEngine.addOnReady(function() {\n    var btn = document.getElementById('toggle-debate-btn');\n    if (btn) { btn.addEventListener('click', function() { window.toggleDebate(); }); }\n});\nQualtrics.SurveyEngine.addOnUnload(function() {\n    if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n    Qualtrics.SurveyEngine.setEmbeddedData(window._accordion_qid + '_accordion_viewTime_ms', String(window._accordion_totalViewTime || 0));\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID18","SecondaryAttribute":"Rate individual B.","TertiaryAttribute":null,"Payload":{"QuestionText":"Rate individual B.","DefaultChoices":false,"DataExportTag":"Interpersonal_B","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Rate individual B.","Choices":{"1":{"Display":"I think Individual B could be a friend of mine."},"2":{"Display":"I would like to have a friendly chat with Individual B."},"3":{"Display":"It would be difficult to meet and talk with Individual B."},"4":{"Display":"Individual B just wouldn't fit into my circle of friends."},"5":{"Display":"We could never establish a personal friendship with each other."},"6":{"Display":"Individual B would be pleasant to be with."}},"ChoiceOrder":[1,2,3,4,5,6],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":6,"Answers":{"1":{"Display":"Strongly Disagree"},"2":{"Display":"Disagree"},"3":{"Display":"Neutral"},"4":{"Display":"Somewhat agree"},"5":{"Display":"Strongly agree"}},"AnswerOrder":[1,2,3,4,5],"ChoiceDataExportTags":false,"QuestionID":"QID18","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n});\nQualtrics.SurveyEngine.addOnReady(function() {\n});\nQualtrics.SurveyEngine.addOnUnload(function() {\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID19","SecondaryAttribute":"We would like you to now briefly share your opinion about this topic for another study participan...","TertiaryAttribute":null,"Payload":{"QuestionText":"We would like you to now briefly share your opinion about this topic for another study participant. Imagine that this participant identifies themselves as&nbsp;<strong>more Republican.<\/strong>","DefaultChoices":false,"DataExportTag":"OpenText_R","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"We would like you to now briefly share your opinion about this topic for another study participan...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID19","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">open_text_condition<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>","LeftOperand":"open_text_condition","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"1","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID2","SecondaryAttribute":"[]","TertiaryAttribute":null,"Payload":{"QuestionText":"[]","DefaultChoices":false,"DataExportTag":"Consent","QuestionID":"QID2","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[]","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID20","SecondaryAttribute":"You will now read a hypothetical discussion between two individuals. Individual A holds a Democra...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p style=\"margin-top: 15px; line-height: 1.6;\">You will now read a hypothetical discussion between two individuals. <strong>Individual A<\/strong> holds a Democratic perspective, while <strong>Individual B<\/strong> holds a Republican perspective. The discussion will include each individual taking three turns (six turns in total).&nbsp;<br><\/p><p style=\"margin-top: 15px; line-height: 1.6;\"><\/p>\n\n<p style=\"margin-top: 15px; line-height: 1.6;\"><strong>Please read the debate carefully<\/strong>, as you will be asked questions about Individual A and B's interaction afterward.<\/p>","DefaultChoices":false,"DataExportTag":"debate_text","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You will now read a hypothetical discussion between two individuals. Individual A holds a Democra...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID20"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID21","SecondaryAttribute":"Individual A and individual B are having a conversation about the tougher immigration policies th...","TertiaryAttribute":null,"Payload":{"QuestionText":"Individual A and individual B are having a conversation about the tougher immigration policies that have been put into place recently. Individual A identifies as more liberal and opposes the current tough immigration enforcement, while individual B identifies as more conservative and believes that the enforcement is needed as immigrants can have negative social and economic effects on the country. Below, you can read a snippet of their debate, in which they specifically discuss the implementation of increased penalties on businesses for hiring staff without legal work authorization.","DefaultChoices":false,"DataExportTag":"Debate_RIRO_intro","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A and individual B are having a conversation about the tougher immigration policies th...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID21"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID22","SecondaryAttribute":"Individual A: \u201cI don\u2019t think policies like these are very effective at reforming immigration pra","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Individual A: <\/strong><em>&ldquo;I don&rsquo;t think policies like these are very effective at reforming immigration practices. My concern is that they worry businesses and make it harder for them to hire specialized workers in science and technology, which the U.S. has relied on for decades.&quot;<\/em><br \/>\n<br \/>\n<strong>Individual B: <\/strong><em>&ldquo;I understand your concern about access to specialized talent, and why it worries you. At the same time, don&rsquo;t you think that imposing these higher fines will encourage companies to hire more American workers?&rdquo;<\/em>","DefaultChoices":false,"DataExportTag":"Debate_RIRO_round1","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \u201cI don\u2019t think policies like these are very effective at reforming immigration prac...","ChoiceOrder":["4","5","6","7","8"],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID22"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID23","SecondaryAttribute":"Individual A: \u201cYeah, maybe, but I guess that that makes me worry about the broader economic conse.","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Individual A:<\/strong> <em>&ldquo;Yeah, maybe, but I guess that that makes me worry about the broader economic consequences. If the increased penalties indeed make businesses more reluctant to hire foreign-born workers altogether, which has been shown to be crucial for the US labor market, overall labor growth could slow down, which might hurt U.S. GDP in the long run.&rdquo;<\/em><br \/>\n<br \/>\n<strong>Individual B: <\/strong><em>&ldquo;That&rsquo;s a reasonable concern. Still, I think some of these implementations are needed to regain control. I recently read that the number of unauthorized immigrants in the U.S. workforce increased about 7.8 million in 2021 to 9.7 million in 2023, especially in sectors like construction, agriculture, and leisure and hospitality. In order for employers to be willing to give up their illegal labor, these strong workplace enforcement actions are necessary.&rdquo;<\/em>","DefaultChoices":false,"DataExportTag":"Debate_RIRO_round2","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \u201cYeah, maybe, but I guess that that makes me worry about the broader economic conse...","ChoiceOrder":["4","5","6","7","8"],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID23"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID24","SecondaryAttribute":"Individual A: \u201cThat makes sense, but do you think employers should be held solely responsible? So.","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Individual A:<\/strong> <em>&ldquo;That makes sense, but do you think employers should be held solely responsible? Some employers have previously raised that they aren&rsquo;t even aware they&rsquo;ve hired unauthorized workers because the documentation process can be confusing and overwhelming.&rdquo;<\/em><br \/>\n<br \/>\n<strong>Individual B:<em> <\/em><\/strong><em>&ldquo;You raise a fair point about employer confusion, especially given how complex the documentation process can be. Still, I think that without meaningful penalties, there&rsquo;s very little incentive for firms to comply with the law and businesses should be held accountable for violating immigration and labor laws.&rdquo;<\/em>","DefaultChoices":false,"DataExportTag":"Debate_RIRO_round3","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \u201cThat makes sense, but do you think employers should be held solely responsible? So...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID24"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID25","SecondaryAttribute":"H","TertiaryAttribute":null,"Payload":{"QuestionText":"H","DefaultChoices":false,"DataExportTag":"Q25","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"H","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID25"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID26","SecondaryAttribute":"\u25b6 Review the debate conversation Loading debate... How important is this issue to you?","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"margin-bottom:24px;border:1px solid #e5e7eb;\n            border-radius:8px;overflow:hidden;\n            font-family:-apple-system,BlinkMacSystemFont,\n            'Segoe UI',sans-serif;\" id=\"debate-accordion\"><button style=\"width:100%;padding:14px 20px;text-align:left;\n                 background:#f9fafb;border:none;cursor:pointer;\n                 font-size:14px;font-weight:600;color:#374151;\n                 display:flex;align-items:center;gap:8px;\n                 transition:background 0.15s;\" id=\"toggle-debate-btn\"><span style=\"display:inline-block;transition:transform 0.2s;\n                 font-size:12px;\" id=\"accordion-arrow\">\u25b6<\/span> Review the debate conversation<\/button>\n<div style=\"display:none;padding:20px;border-top:1px solid #e5e7eb;\n              background:#ffffff;max-height:400px;overflow-y:auto;\" id=\"debate-content\">\n<p style=\"color:#6b7280;font-size:13px;font-style:italic;\n              margin-top:0;\">Loading debate...<\/p>\n<\/div>\n<\/div>\nHow important is this issue to you?","DefaultChoices":false,"DataExportTag":"Importance","QuestionID":"QID26","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline"},"QuestionDescription":"\u25b6 Review the debate conversation Loading debate... How important is this issue to you?","Choices":{"1":{"Display":"Not at all important to me"},"2":{"Display":"Slightly important to me"},"3":{"Display":"Moderately important to me"},"4":{"Display":"Very important to me"},"5":{"Display":"Extremely important to me"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":4,"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    var qid = 'importance';\n    var debateOpened = 0;\n    var toggleCount = 0;\n    var firstOpenTime = null;\n    var pageStart = Date.now();\n    window._accordion_totalViewTime = 0;\n    window._accordion_viewStart = null;\n    window._accordion_qid = qid;\n    function setED(key, value) {\n        Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n    var contentDiv = document.getElementById('debate-content');\n    var bubbles = null;\n    if (window._debateBubbles) { bubbles = window._debateBubbles; }\n    if (!bubbles) {\n        try {\n            var raw = \"${e:\/\/Field\/debateJSON}\";\n            raw = raw.replace(\/&amp;\/g,'&').replace(\/&lt;\/g,'<').replace(\/&gt;\/g,'>').replace(\/&quot;\/g,'\"').replace(\/&#39;\/g,\"'\").replace(\/&#x27;\/g,\"'\").replace(\/&apos;\/g,\"'\");\n            bubbles = JSON.parse(raw);\n        } catch(e) {}\n    }\n    if (bubbles && contentDiv) {\n        var html = '';\n        for (var i = 0; i < bubbles.length; i++) {\n            var b = bubbles[i];\n            html += '<div style=\"display:flex;margin-bottom:12px;' + (b.side === 'rep' ? 'justify-content:flex-end;' : '') + '\"><div style=\"max-width:80%;padding:12px 16px;border-radius:16px;' + (b.side === 'dem' ? 'background:#dbeafe;border-bottom-left-radius:4px;' : 'background:#fee2e2;border-bottom-right-radius:4px;') + 'font-size:14px;line-height:1.5;\"><div style=\"font-weight:600;font-size:12px;margin-bottom:4px;' + (b.side === 'dem' ? 'color:#1e40af;' : 'color:#991b1b;') + '\">' + b.speaker + '<\/div><div>\\u201c' + b.text + '\\u201d<\/div><\/div><\/div>';\n        }\n        contentDiv.innerHTML = html;\n    } else if (contentDiv) {\n        contentDiv.innerHTML = '<p style=\"color:#999;font-style:italic;\">Debate transcript not available.<\/p>';\n    }\n    window.toggleDebate = function() {\n        var content = document.getElementById('debate-content');\n        var arrow = document.getElementById('accordion-arrow');\n        if (!content) return;\n        if (content.style.display === 'none') {\n            content.style.display = 'block';\n            if (arrow) arrow.style.transform = 'rotate(90deg)';\n            debateOpened = 1; toggleCount++;\n            window._accordion_viewStart = Date.now();\n            if (firstOpenTime === null) { firstOpenTime = Date.now() - pageStart; setED(qid + '_accordion_firstOpen_ms', firstOpenTime); }\n        } else {\n            content.style.display = 'none';\n            if (arrow) arrow.style.transform = 'rotate(0deg)';\n            if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n        }\n        setED(qid + '_accordion_opened', debateOpened);\n        setED(qid + '_accordion_toggles', toggleCount);\n    };\n});\nQualtrics.SurveyEngine.addOnReady(function() {\n    var btn = document.getElementById('toggle-debate-btn');\n    if (btn) { btn.addEventListener('click', function() { window.toggleDebate(); }); }\n});\nQualtrics.SurveyEngine.addOnUnload(function() {\n    if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n    Qualtrics.SurveyEngine.setEmbeddedData(window._accordion_qid + '_accordion_viewTime_ms', String(window._accordion_totalViewTime || 0));\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID27","SecondaryAttribute":"We would like you to now briefly write about this topic and your opinion for another study's part...","TertiaryAttribute":null,"Payload":{"QuestionText":"We would like you to now briefly write about this topic and your opinion for another study&#39;s participant. Imagine that this participant identifies themselves as <strong>more Democratic.<\/strong>","DefaultChoices":false,"DataExportTag":"OpenText_D","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"We would like you to now briefly write about this topic and your opinion for another study's part...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID27","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">open_text_condition<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 2 <\/span>","LeftOperand":"open_text_condition","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"2","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID28","SecondaryAttribute":"Please answer these quick questions about your background.","TertiaryAttribute":null,"Payload":{"QuestionText":"Please answer these quick questions about your background.","DefaultChoices":false,"DataExportTag":"DemographicsText","QuestionID":"QID28","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"