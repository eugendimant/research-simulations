. If you are selected, yo...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID16"}},{"SurveyID":"SV_6M33amoAOtOJoj4","Element":"SQ","PrimaryAttribute":"QID17","SecondaryAttribute":"This survey is about a review of:","TertiaryAttribute":null,"Payload":{"QuestionText":"This survey is about a review of:","DefaultChoices":false,"DataExportTag":"Attention check","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"This survey is about a review of:","Choices":{"1":{"Display":"A restaruant"},"2":{"Display":"A charity"},"3":{"Display":"A hotel"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID17"}},{"SurveyID":"SV_6M33amoAOtOJoj4","Element":"SQ","PrimaryAttribute":"QID18","SecondaryAttribute":"What is your gender?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your gender?","DefaultChoices":false,"DataExportTag":"Gender","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","Autoscale":{"YScale":{"Name":"maleFemale","Type":"likert","Reverse":false}}},"QuestionDescription":"What is your gender?","Choices":{"1":{"Display":"Male"},"2":{"Display":"Female"},"3":{"Display":"Non-binary \/ third gender"},"4":{"Display":"Prefer not to say"}},"ChoiceOrder":["1","2","3","4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID18"}},{"SurveyID":"SV_6M33amoAOtOJoj4","Element":"SQ","PrimaryAttribute":"QID19","SecondaryAttribute":"(Optional) If you selected to win the prize of our study, would you be willing to leave your emai...","TertiaryAttribute":null,"Payload":{"QuestionText":"(Optional) If you selected to win the prize of our study, would you be willing to leave your email or phone number so we can contact you and transfer the money to you? (Optional)","DefaultChoices":false,"DataExportTag":"Q19","QuestionID":"QID19","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"(Optional) If you selected to win the prize of our study, would you be willing to leave your emai...","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"}}},{"SurveyID":"SV_6M33amoAOtOJoj4","Element":"SQ","PrimaryAttribute":"QID2","SecondaryAttribute":"Which of the following best describes your age?","TertiaryAttribute":null,"Payload":{"QuestionText":"Which of the following best describes your age?","DefaultChoices":false,"DataExportTag":"Age","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Which of the following best describes your age?","Choices":{"1":{"Display":"18 - 24"},"2":{"Display":"25 - 34"},"3":{"Display":"35 - 44"},"4":{"Display":"45 - 54"},"5":{"Display":"55 or above"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID2"}},{"SurveyID":"SV_6M33amoAOtOJoj4","Element":"SQ","PrimaryAttribute":"QID20","SecondaryAttribute":"If you are selected to receive the amount of the $10 that you choose to keep for yourself, would...","TertiaryAttribute":null,"Payload":{"QuestionText":"If you are selected to receive the amount of the $10 that you choose to keep for yourself, would you be willing to provide your email address or phone number so that we can contact you and send you the payment?\n(Optional)","DefaultChoices":false,"DataExportTag":"Contact information","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"If you are selected to receive the amount of the $10 that you choose to keep for yourself, would...","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID20"}},{"SurveyID":"SV_6M33amoAOtOJoj4","Element":"SQ","PrimaryAttribute":"QID21","SecondaryAttribute":"Here is an anonymous review from Google Maps: \u201cThis charity was helpful during our difficult time.","TertiaryAttribute":null,"Payload":{"QuestionText":"Here is an anonymous review from Google Maps:\n<br><br>\u201cThis charity was helpful during our difficult time. Their staff were helpful, the space was clean and comfortable, and the meals were provided on schedule every day.\u201d","DefaultChoices":false,"DataExportTag":"PN","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is an anonymous review from Google Maps: \u201cThis charity was helpful during our difficult time...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID21"}},{"SurveyID":"SV_6M33amoAOtOJoj4","Element":"SQ","PrimaryAttribute":"QID22","SecondaryAttribute":"Here is an anonymous review from Google Maps: \u201cThis charity was helpful during our difficult time.","TertiaryAttribute":null,"Payload":{"QuestionText":"Here is an anonymous review from Google Maps:\n<br><br>\u201cThis charity was helpful during our difficult time. Their staff were helpful \u2013 they answered our questions clearly. The space was clean and comfortable \u2013 our room and the shared areas were kept clean. Meals are provided on schedule every day \u2013 the posted times were followed and food was available when we checked.\u201d","DefaultChoices":false,"DataExportTag":"PD","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is an anonymous review from Google Maps: \u201cThis charity was helpful during our difficult time...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID22"}},{"SurveyID":"SV_6M33amoAOtOJoj4","Element":"SQ","PrimaryAttribute":"QID23","SecondaryAttribute":"Here is an anonymous review from Google Maps: \u201cThis charity was not helpful during our difficult..","TertiaryAttribute":null,"Payload":{"QuestionText":"Here is an anonymous review from Google Maps:\n<br><br>\u201cThis charity was not helpful during our difficult time. Their staff were unhelpful, the space was dirty and uncomfortable, and the meals were not provided on schedule.\u201d","DefaultChoices":false,"DataExportTag":"NN","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is an anonymous review from Google Maps: \u201cThis charity was not helpful during our difficult...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID23"}},{"SurveyID":"SV_6M33amoAOtOJoj4","Element":"SQ","PrimaryAttribute":"QID24","SecondaryAttribute":"Here is an anonymous review from Google Maps: \u201cThis charity was not helpful during our difficult..","TertiaryAttribute":null,"Payload":{"QuestionText":"Here is an anonymous review from Google Maps:\n<br><br>\u201cThis charity was not helpful during our difficult time. Their staff were unhelpful \u2013 they did not answer our questions clearly. The space was dirty and uncomfortable \u2013 our room and the shared areas were not kept clean. Meals are not provided on schedule every day \u2013 the posted times were missed and food was not available when we checked.","DefaultChoices":false,"DataExportTag":"ND","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Here is an anonymous review from Google Maps: \u201cThis charity was not helpful during our difficult...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID24"}},{"SurveyID":"SV_6M33amoAOtOJoj4","Element":"SQ","PrimaryAttribute":"QID25","SecondaryAttribute":"Please follow the instruction below.","TertiaryAttribute":null,"Payload":{"QuestionText":"Please follow the instruction below.","DefaultChoices":false,"DataExportTag":"Captcha verification","QuestionType":"Captcha","Selector":"V2","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","Align":"left","Theme":"light"},"QuestionDescription":"Please follow the instruction below.","GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID25"}},{"SurveyID":"SV_6M33amoAOtOJoj4","Element":"SQ","PrimaryAttribute":"QID26","SecondaryAttribute":"You are invited to take part in a study named Decision Task. The purpose of this research study i...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are invited to take part in a study named Decision Task. The purpose of this research study is to understand human decision-making. You will answer a series of questions regarding beliefs and behaviors. We will also ask you to provide demographic information. We will not ask for your name or any information that will make you identifiable. Overall, this study will take approximately 2-5 minutes.<br><br>For your participation in this study, you will receive a fixed payment of $0.30. Additionally, you may receive a monetary bonus. If a question is eligible for a monetary bonus, it will clearly state so.<br><br>You will be paid within 10 days of completing the study via MTurk. Your email address will only be used to pay you correctly and will be deleted permanently from the experimenter's data after payment is complete.<br><br>The risks to participating are no greater than those encountered in everyday life. Your participation in this study is completely voluntary, and you may refuse to participate. If you withdraw from the study before completing it, you will not be paid. Compensation will be awarded upon completion of the entire study.<br><br>If you have any questions about this study, you may contact us at luo03@sas.upenn.edu.<br><br>Please feel free to print or save a copy of this consent form.<br><br>By continuing from this page, you are indicating that you have read and understood this consent form and wish to continue your participation in this study.","DefaultChoices":false,"DataExportTag":"Informed Consent","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You are invited to take part in a study named Decision Task. The purpose of this research study i...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID26"}},{"SurveyID":"SV_6M33amoAOtOJoj4","Element":"SQ","PrimaryAttribute":"QID27","SecondaryAttribute":"Please enter your MTurk Worker ID in the box below.","TertiaryAttribute":null,"Payload":{"QuestionText":"Please enter your MTurk Worker ID in the box below.","DefaultChoices":false,"DataExportTag":"MTurk ID","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private