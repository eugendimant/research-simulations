ionDescription":"How helpful was this review?","Choices":{"1":{"Display":"Strongly disagree"},"2":{"Display":"Somewhat disagree"},"3":{"Display":"Neither agree nor disagree"},"4":{"Display":"Somewhat agree"},"5":{"Display":"Strongly agree"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID12"}},{"SurveyID":"SV_6M33amoAOtOJoj4","Element":"SQ","PrimaryAttribute":"QID13","SecondaryAttribute":"How positive or negative was the emotion displayed in the review?","TertiaryAttribute":null,"Payload":{"QuestionText":"How positive or negative was the emotion displayed in the review?","DefaultChoices":false,"DataExportTag":"Emotion","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"How positive or negative was the emotion displayed in the review?","Choices":{"1":{"Display":"Extremely negative"},"2":{"Display":"Slightly negative"},"4":{"Display":"Slightly positive"},"5":{"Display":"Extremely positive"}},"ChoiceOrder":[1,2,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID13"}},{"SurveyID":"SV_6M33amoAOtOJoj4","Element":"SQ","PrimaryAttribute":"QID14","SecondaryAttribute":"How helpful was this review?","TertiaryAttribute":null,"Payload":{"QuestionText":"How helpful was this review?","DefaultChoices":false,"DataExportTag":"Helpfulness","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"How helpful was this review?","Choices":{"1":{"Display":"Not at all helpful"},"2":{"Display":"Slightly helpful"},"4":{"Display":"Very helpful