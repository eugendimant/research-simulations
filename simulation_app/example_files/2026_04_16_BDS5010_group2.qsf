,"BallotBoxStuffingPreventionMessage":null,"BallotBoxStuffingPreventionMessageLibrary":null,"BallotBoxStuffingPreventionURL":null,"RecaptchaV3":"false","ConfirmStart":false,"AutoConfirmStart":false,"RelevantID":"false","RelevantIDLockoutPeriod":"+30 days","UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessageLibrary":null,"ResponseSummary":"No","EOSMessageLibrary":null,"EOSRedirectURL":null,"EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":null,"PartialDeletion":null,"PartialDataCloseAfter":"LastActivity","InactiveMessageLibrary":null,"InactiveMessage":null,"AvailableLanguages":{"EN":[]}}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID1","SecondaryAttribute":"Do you consent to participate in this study?","TertiaryAttribute":null,"Payload":{"QuestionText":"Do you consent to participate in this study?","DataExportTag":"","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Do you consent to participate in this study?","Choices":{"1":{"Display":"Yes, I consent and wish to continue"},"2":{"Display":"No, I do not consent"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID1","DefaultChoices":false,"GradingData":[]}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID10","SecondaryAttribute":"Have you visited a primary care physician for a routine check-up in the past 12 months?","TertiaryAttribute":null,"Payload":{"QuestionText":"Have you visited a primary care physician for a routine check-up in the past 12 months?","DefaultChoices":false,"DataExportTag":"Q10","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","Autoscale":{"YScale":{"Name":"yesNo","Type":"likert","Reverse":false}}},"QuestionDescription":"Have you visited a primary care physician for a routine check-up in the past 12 months?","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID10"}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID11","SecondaryAttribute":"Have you ever used online ratings or reviews when choosing a physician?","TertiaryAttribute":null,"Payload":{"QuestionText":"Have you ever used online ratings or reviews when choosing a physician?","DefaultChoices":false,"DataExportTag":"Q11","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","Autoscale":{"YScale":{"Name":"yesNo","Type":"likert","Reverse":true}}},"QuestionDescription":"Have you ever used online ratings or reviews when choosing a physician?","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID11"}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID12","SecondaryAttribute":"Evaluations of Healthcare Professionals You are invited to participate in a research study conduc...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Evaluations of Healthcare Professionals<br><\/b><br>You are invited to participate in a research study conducted at the University of Pennsylvania. The purpose of this study is to understand how people evaluate healthcare professionals. In this study, you will be asked to read a short description of a healthcare visit and answer several questions about it. The study will take approximately 6-8 minutes to complete.<br><br>Please note that this study is currently being conducted as a pilot test. While some questions may reference monetary incentives or rewards, please note that no actual payments will be provided in this pilot version.<br><br>Your participation is entirely voluntary. You may choose to stop the study at any time without penalty. Your responses are anonymous, and no personally identifying information will be collected. All data will be used solely for research purposes.<br>","DefaultChoices":false,"DataExportTag":"","QuestionID":"QID12","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Evaluations of Healthcare Professionals You are invited to participate in a research study conduc...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID13","SecondaryAttribute":"Instructions: You will read a short description of a patient\u2019s visit with a primary care physicia.","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Instructions:<br><br><\/b>You will read a short description of a patient\u2019s visit with a primary care physician. Please read the description carefully and imagine yourself in the situation. Afterward, you will be asked to evaluate the physician.","DefaultChoices":false,"DataExportTag":"","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Instructions: You will read a short description of a patient\u2019s visit with a primary care physicia...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID13"}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID21","SecondaryAttribute":"How likely would you be to recommend this physician to a friend or family member?","TertiaryAttribute":null,"Payload":{"QuestionText":"How likely would you be to recommend this physician to a friend or family member?","DefaultChoices":false,"DataExportTag":"","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How likely would you be to recommend this physician to a friend or family member?","Choices":{"1":{"Display":"Very unlikely"},"2":{"Display":"Unlikely"},"3":{"Display":"Neither likely nor unlikely"},"4":{"Display":"Likely"},"5":{"Display":"Very likely"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID21"}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID23","SecondaryAttribute":"You recently scheduled an appointment for your annual physical with a primary care physician. Whe...","TertiaryAttribute":null,"Payload":{"QuestionText":"You recently scheduled an appointment for your annual physical with a primary care physician. <br><br>When you arrive at the clinic, the front desk staff checks you in. You are called in to see the physician about 10 minutes after your scheduled appointment time. <br><br>The physician enters the room, greets you, and introduces themselves while making direct eye contact. They ask how you have been feeling and whether you have any concerns. As you respond, the physician listens attentively without interrupting and acknowledges what you say. <br><br>During the visit, the physician reviews your medical history and explains each step of the exam in clear, straightforward language. They provide context for why each part of the exam is being conducted and take time to answer your questions. They check to make sure you understand the information. <br><br>The physician completes the physical exam in a thorough and organized manner. At the end of the visit, they explain that everything appears normal and summarize the visit along with general preventive recommendations. <br><br>You leave the appointment with a clear understanding of the visit and a positive impression of the interaction.","DefaultChoices":false,"DataExportTag":"go1","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You recently scheduled an appointment for your annual physical with a primary care physician. Whe...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID23"}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID26","SecondaryAttribute":"Overall, how many stars would you give this physician?","TertiaryAttribute":null,"Payload":{"QuestionText":"Overall, how many stars would you give this physician?","DefaultChoices":false,"DataExportTag":"go2","QuestionType":"Slider","Selector":"STAR","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"NumDecimals":"0","StarCount":5,"StarType":"half","ShowValue":true,"MobileFirst":false},"QuestionDescription":"Overall, how many stars would you give this physician?","Choices":{"1":{"Display":"Rating"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":1,"Labels":[],"QuestionID":"QID26"}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID27","SecondaryAttribute":"You recently scheduled an appointment for your annual physical with a primary care physician. Whe...","TertiaryAttribute":null,"Payload":{"QuestionText":"You recently scheduled an appointment for your annual physical with a primary care physician. <br><br>When you arrive at the clinic, the front desk staff checks you in. You are called in to see the physician about 10 minutes after your scheduled appointment time. <br><br>The physician enters the room, greets you, and introduces themselves while making direct eye contact. They ask how you have been feeling and whether you have any concerns. As you respond, the physician listens attentively without interrupting and acknowledges what you say. <br><br>During the visit, the physician reviews your medical history and explains each step of the exam in clear, straightforward language. They provide context for why each part of the exam is being conducted and take time to answer your questions. They check to make sure you understand the information. <br><br>The physician completes the physical exam in a thorough and organized manner. At the end of the visit, they explain that everything appears normal and summarize the visit along with general preventive recommendations. <br><br>You leave the appointment with a clear understanding of the visit and a positive impression of the interaction.","DefaultChoices":false,"DataExportTag":"gao1","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You recently scheduled an appointment for your annual physical with a primary care physician. Whe...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID27"}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID28","SecondaryAttribute":"How many stars would you give this physician?","TertiaryAttribute":null,"Payload":{"QuestionText":"How many stars would you give this physician?","DefaultChoices":false,"DataExportTag":"gao2","QuestionType":"Slider","Selector":"STAR","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"NumDecimals":"0","StarCount":5,"StarType":"half","ShowValue":true,"MobileFirst":false},"QuestionDescription":"How many stars would you give this physician?","Choices":{"1":{"Display":"Overall Rating"},"2":{"Display":"Communication"},"3":{"Display":"Empathy"},"4":{"Display":"Wait Time"},"5":{"Display":"Professionalism"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"Labels":[],"QuestionID":"QID28"}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID29","SecondaryAttribute":"You recently scheduled an appointment for your annual physical with a primary care physician. Whe...","TertiaryAttribute":null,"Payload":{"QuestionText":"You recently scheduled an appointment for your annual physical with a primary care physician. <br><br>When you arrive at the clinic, the front desk staff checks you in. You are called in to see the physician about 35 minutes after your scheduled appointment time. <br><br>The physician enters the room and begins the visit while looking at their computer. They ask how you have been feeling and whether you have any concerns. As you respond, the physician listens but occasionally interrupts and provides limited acknowledgment. <br><br>During the visit, the physician reviews your medical history and explains each step of the exam in a concise manner. They provide some context for why parts of the exam are being conducted, but not consistently, and their explanations are relatively brief. They respond to your questions, though their answers are short and they do not check whether you understand the information. <br><br>The physician completes the physical exam in an organized manner. At the end of the visit, they explain that everything appears normal and provide a brief summary of the visit along with general preventive recommendations. <br><br>You leave the appointment with a somewhat unclear understanding of the visit and a neutral impression of the interaction.","DefaultChoices":false,"DataExportTag":"so1","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You recently scheduled an appointment for your annual physical with a primary care physician. Whe...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID29"}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID30","SecondaryAttribute":"Overall, how many stars would you give this physician?","TertiaryAttribute":null,"Payload":{"QuestionText":"Overall, how many stars would you give this physician?","DefaultChoices":false,"DataExportTag":"so2","QuestionType":"Slider","Selector":"STAR","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"NumDecimals":"0","StarCount":5,"StarType":"half","ShowValue":true,"MobileFirst":false},"QuestionDescription":"Overall, how many stars would you give this physician?","Choices":{"1":{"Display":"Rating"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":1,"Labels":[],"QuestionID":"QID30"}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID32","SecondaryAttribute":"You recently scheduled an appointment for your annual physical with a primary care physician. Whe...","TertiaryAttribute":null,"Payload":{"QuestionText":"You recently scheduled an appointment for your annual physical with a primary care physician. <br><br>When you arrive at the clinic, the front desk staff checks you in. You are called in to see the physician about 35 minutes after your scheduled appointment time. <br><br>The physician enters the room and begins the visit while looking at their computer. They ask how you have been feeling and whether you have any concerns. As you respond, the physician listens but occasionally interrupts and provides limited acknowledgment. <br><br>During the visit, the physician reviews your medical history and explains each step of the exam in a concise manner. They provide some context for why parts of the exam are being conducted, but not consistently, and their explanations are relatively brief. They respond to your questions, though their answers are short and they do not check whether you understand the information. <br><br>The physician completes the physical exam in an organized manner. At the end of the visit, they explain that everything appears normal and provide a brief summary of the visit along with general preventive recommendations. <br><br>You leave the appointment with a somewhat unclear understanding of the visit and a neutral impression of the interaction.","DefaultChoices":false,"DataExportTag":"sao1","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You recently scheduled an appointment for your annual physical with a primary care physician. Whe...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID32"}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID33","SecondaryAttribute":"How many stars would you give this physician?","TertiaryAttribute":null,"Payload":{"QuestionText":"How many stars would you give this physician?","DefaultChoices":false,"DataExportTag":"sao2","QuestionType":"Sli