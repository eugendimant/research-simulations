 student becomes hungry and remembers they have a container of food in their backpack. The lecture is ongoing, and other students are listening to the instructor. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Eating Scenario","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You are attending a university lecture. During the class, a student becomes hungry and remembers...","Choices":{"1":{"Display":"Wait until after the lecture ends to eat"},"2":{"Display":"Open noisy packaging and continue eating"},"3":{"Display":"Start eating quietly while listening to the lecture"},"4":{"Display":"Ask the professor whether eating during the lecture is allowed"},"5":{"Display":"Offer to share the food with nearby classmates"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID315"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID316","SecondaryAttribute":"You receive a message from a classmate, who you only know by names, asking about your progress on...","TertiaryAttribute":null,"Payload":{"QuestionText":"You receive a message from a classmate, who you only know by names, asking about your progress on a homework assignment. You see the message, but you are busy with something else at the moment. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Busy Moment Scenario","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You receive a message from a classmate, who you only know by names, asking about your progress on...","Choices":{"1":{"Display":"Reply later when you have more time"},"2":{"Display":"Ignore the message and only respond if the classmate asks again later"},"3":{"Display":"Reply immediately even though are busy"},"4":{"Display":"Tell them to check the course slide or materials instead"},"5":{"Display":"Send a short message saying you will respond later"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID316"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID317","SecondaryAttribute":"You are waiting in line at a busy campus coffee shop during a break between classes. Several stud...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are waiting in line at a busy campus coffee shop during a break between classes. Several students are standing in line to order drinks. A student suddenly walks past everyone, goes directly to a friend who is already at the front of the line, and asks the friend to place an order for them so they do not have to wait. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Coffee Shop Scenario","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You are waiting in line at a busy campus coffee shop during a break between classes. Several stud...","Choices":{"1":{"Display":"Politely tell the student that there is a line and they should wait like everyone else"},"2":{"Display":"Say nothing and continue waiting in line"},"3":{"Display":"Complain loudly to others in line about the student cutting ahead"},"4":{"Display":"Ask the cashier or staff member to enforce the line and ask the student to go to the back"},"5":{"Display":"Move forward and cut the line yourself as well"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID317"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID318","SecondaryAttribute":"You are attending a live online class using Zoom. The instructor encourages students to keep thei...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are attending a live online class using Zoom. The instructor encourages students to keep their cameras on during class. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Zoom Scenario","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You are attending a live online class using Zoom. The instructor encourages students to keep thei...","Choices":{"1":{"Display":"Turn your camera on only when you are speaking or participating"},"2":{"Display":"Ask the professor what they prefer students to do regarding cameras"},"3":{"Display":"Keep your camera off during the entire class"},"4":{"Display":"Keep your camera on during the entire class"},"5":{"Display":"Keep camera off but explain your reason in the chat"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID318"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID319","SecondaryAttribute":"After missing a class, a classmate asks you to send them your lecture notes. Please rate how soci...","TertiaryAttribute":null,"Payload":{"QuestionText":"After missing a class, a classmate asks you to send them your lecture notes. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Lecture Scenario","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,