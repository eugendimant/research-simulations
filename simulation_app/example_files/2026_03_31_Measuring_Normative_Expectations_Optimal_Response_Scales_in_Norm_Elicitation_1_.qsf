:"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":4,"Answers":{"1":{"Display":"Reply immediately even if you are busy"},"2":{"Display":"Reply later when you have time"},"3":{"Display":"Ignore the message and reply when that classmate mentions it again"}},"AnswerOrder":["1","2","3"],"ChoiceDataExportTags":false,"QuestionID":"QID26"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID260","SecondaryAttribute":"Which of the following best describes the pattern of opinions about what is socially appropriate...","TertiaryAttribute":null,"Payload":{"QuestionText":"Which of the following best describes the pattern of opinions about what is socially appropriate in this situation?","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Which of the following best describes the pattern of opinions about what is socially appropriate...","Choices":{"1":{"Display":"Clear shared norm"},"2":{"Display":"Weak or unclear norm"},"3":{"Display":"Two competing norms"},"4":{"Display":"No clear norm"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionText_Unsafe":"Regarding the previous question, which of the following options best describes this situation?","DataExportTag":"","QuestionID":"QID260"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID261","SecondaryAttribute":"In the following section, you will read several short scenarios. For each scenario, you will eval...","TertiaryAttribute":null,"Payload":{"QuestionText":"In the following section, you will read several short scenarios.\n<br>For each scenario, you will evaluate different possible actions and rate how socially appropriate each action is.\n\nPlease answer carefully. <br>