udent nearby is speaking loudly on...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are studying in a quiet area of a university library. A student nearby is speaking loudly on the phone while several people are trying to study. Signs in the library indicate that phone calls should be taken outside. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Library Scenario","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You are studying in a quiet area of a university library. A student nearby is speaking loudly on...","Choices":{"1":{"Display":"Do nothing and ignore the situation"},"2":{"Display":"Tell the student loudly that they should leave the library immediately"},"3":{"Display":"Inform a library staff member about the situation"},"4":{"Display":"Join the noise by playing a video loudly on your phone"},"5":{"Display":"Politely ask the student to lower their voice or take the call outside"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":13,"Answers":{"1":{"Display":"-100"},"2":{"Display":"-80"},"4":{"Display":"-60"},"5":{"Display":"-40"},"6":{"Display":"-20"},"7":{"Display":"0"},"8":{"Display":"20"},"9":{"Display":"40"},"10":{"Display":"60"},"11":{"Display":"80"},"12":{"Display":"100"}},"AnswerOrder":["1","2","4","5","6","7","8","9","10","11","12"],"ChoiceDataExportTags":false,"QuestionID":"QID350","ColumnLabels":[{"Display":"-100 = Very socially inappropriate","IsLabelDefault":false},{"Display":"0 = Neither socially inappropriate nor appropriate","IsLabelDefault":false},{"Display":"100 = Very socially appropriate","Is