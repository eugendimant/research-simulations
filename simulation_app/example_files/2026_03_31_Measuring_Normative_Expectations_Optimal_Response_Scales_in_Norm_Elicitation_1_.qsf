ype":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":6,"Answers":{"1":{"Display":"Send your notes to the classmate"},"2":{"Display":"Send only a short summary of the notes"},"3":{"Display":"Suggest they check the textbook or course materials instead"},"4":{"Display":"Tell them they should ask another student"},"5":{"Display":"Refuse to share your notes"}},"AnswerOrder":[1,2,3,4,5],"ChoiceDataExportTags":false,"QuestionID":"QID38"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID380","SecondaryAttribute":"What is your primary field of study?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your primary field of study?","DefaultChoices":false,"DataExportTag":"Major","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your primary field of study?","Choices":{"1":{"Display":"Business \/ Economics"},"2":{"Display":"Computer Science \/ Data Science"},"3":{"Display":"Engineering"},"4":{"Display":"Natural Sciences (e.g., Biology, Chemistry, Physics)"},"5":{"Display":"Social Sciences (e.g., Psychology, Political Science, Sociology)"},"6":{"Display":"Humanities (e.g., History, Literature, Philosophy)"},"7":{"Display":"Undeclared"},"8":{"Display":"Other","TextEntry":"true"}},"ChoiceOrder":["1","2","3","4","5","6","7","8"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID380"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID381","SecondaryAttribute":"Are you an international student?","TertiaryAttribute":null,"Payload":{"QuestionText":"Are you an international student?","DefaultChoices":false,"DataExportTag":"Student status","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":fa