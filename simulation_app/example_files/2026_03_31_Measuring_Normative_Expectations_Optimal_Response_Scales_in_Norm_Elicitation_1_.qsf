lly inappropriate"},"2":{"Display":"0 = Neither socially inappropriate nor appropriate"},"3":{"Display":"100 = Very socially appropriate"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\/*Place your JavaScript here to run when the page loads*\/\nvar q = jQuery(\"#\"+this.questionId);\nq.find(\".handle\").css('visibility', 'hidden');\nq.find(\".track\").on(\"click , touchstart\", function() {\njQuery(this).find(\".handle\").css('visibility', 'visible');\n});\n\nq.find(\".track\").css(\"height\", \"10px\");\n\n});"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID29","SecondaryAttribute":"After missing a class, a classmate asks you to send them your lecture notes. Some students believ...","TertiaryAttribute":null,"Payload":{"QuestionText":"After missing a class, a classmate asks you to send them your lecture notes. Some students believe sharing notes is helpful and cooperative. Others believe students should take responsibility for attending class themselves.&nbsp;Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Scenario 8","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true,"Transpose":"transposeTable"},"QuestionDescription":"After missing a class, a classmate asks you to send them your lecture notes. Some students believ...","Choices":{"1":{"Display":"Very socially inappropriate"},"2":{"Display":"Somewhat socially inappropriate"},"3":{"Display":"Neither socially inappropriate nor appropriate"},"4":{"Display":"Somewhat socially appropriate"},"5":{"Display":"Very socially appropriate"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":4,"Answers":{"1":{"Display":"Send your notes to the classmate"},"2":{"Display":"Send a short summary instead of your full notes"},"3":{"Display":"Tell them they should get notes from someone else or check the textbook"}},"AnswerOrder":["1","2","3"],"ChoiceDataExportTags":false,"QuestionID":"QID29"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID290","SecondaryAttribute":"Regarding the previous question","TertiaryAttribute":null,"Payload":{"QuestionText":"Regarding the previous question","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":1,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Regarding the previous question","Choices":{"1":{"Display":"How much agreement do you think exists among people about what is appropriate in this situation?"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"Regarding the previous question","DataExportTag":"","QuestionID":"QID290"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID291","SecondaryAttribute":"Regarding the previous question, which of the following options best describes this situation?","TertiaryAttribute":null,"Payload":{"QuestionText":"Regarding the previous question, which of the following options best describes this situation?","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Regarding the previous question, which of the following options best describes this situation?","Choices":{"1":{"Display":"Clear shared norm"},"2":{"Display":"Weak or unclear norm"},"3":{"Display":"Two competing norms"},"4":{"Display":"No clear norm"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionText_Unsafe":"Regarding the previous question, which of the following options best describes this situation?","DataExportTag":"","QuestionID":"QID291"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID292","SecondaryAttribute":"You arrive early to a lecture and enter an empty classroom. The class has not started yet, and al...","TertiaryAttribute":null,"Payload":{"QuestionText":"You arrive early to a lecture and enter an empty classroom. The class has not started yet, and all seats appear identical. Please rate how socially appropriate each action is.<br>(Click and drag the slider below to enter your answer)\r\n<br>","DefaultChoices":false,"DataExportTag":"Scenario 11","QuestionID":"QID292","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","CSSliderMin":-100,"CSSliderMax":100,"GridLines":1,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"You arrive early to a lecture and enter an empty classroom. The class has not started yet, and al...","Choices":{"1":{"Display":"Sit in the middle row"},"2":{"Display":"Sit in the back row"},"3":{"Display":"Sit in the front row"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":4,"Labels":{"1":{"Display":"-100 = Very socially inappropriate"},"2":{"Display":"0 = Neither socially inappropriate nor appropriate"},"3":{"Display":"100 = Very socially appropriate"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\/*Place your JavaScript here to run when the page loads*\/\nvar q = jQuery(\"#\"+this.questionId);\nq.find(\".handle\").css('visibility', 'hidden');\nq.find(\".track\").on(\"click , touchstart\", function() {\njQuery(this).find(\".handle\").css('visibility', 'visible');\n});\n\nq.find(\".track\").css(\"height\", \"10px\");\n\n});"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID293","SecondaryAttribute":"Regarding the previous question","TertiaryAttribute":null,"Payload":{"QuestionText":"Regarding the previous question","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":1,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Regarding the previous question","Choices":{"1":{"Display":"How much agreement do you think exists among people about what is appropriate in this situation?"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"Regarding the previous question","DataExportTag":"","QuestionID":"QID293"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID294","SecondaryAttribute":"Regarding the previous question, which of the following options best describes this situation?","TertiaryAttribute":null,"Payload":{"QuestionText":"Regarding the previous question, which of the following options best describes this situation?","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Regarding the previous question, which of the following options best describes this situation?","Choices":{"1":{"Display":"Clear shared norm"},"2":{"Display":"Weak or unclear norm"},"3":{"Display":"Two competing norms"},"4":{"Display":"No clear norm"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionText_Unsafe":"Regarding the previous question, which of the following options best describes this situation?","DataExportTag":"","QuestionID":"QID294"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID295","SecondaryAttribute":"You are choosing a new wallpaper for your phone. Two images are available \u2014 one of a cat and one..","TertiaryAttribute":null,"Payload":{"QuestionText":"You are choosing a new wallpaper for your phone. Two images are available \u2014 one of a cat and one of a dog. You like both images equally. Please rate how socially appropriate each action is.<br>(Click and drag the slider below to enter your answer)\r\n<br>","DefaultChoices":false,"DataExportTag":"Scenario 12","QuestionID":"QID295","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","CSSliderMin":-100,"CSSliderMax":100,"GridLines":1,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"You are choosing a new wallpaper for your phone. Two images are available \u2014 one of a cat and one...","Choices":{"1":{"Display":"Choose the dog image"},"2":{"Display":"Randomly pick one of the two images"},"3":{"Display":"Choose the cat image"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":4,"Labels":{"1":{"Display":"-100 = Very socially inappropriate"},"2":{"Display":"0 = Neither socially inappropriate nor appropriate"},"3":{"Display":"100 = Very socially appropriate"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\/*Place your JavaScript here to run when the page loads*\/\nvar q = jQuery(\"#\"+this.questionId);\nq.find(\".handle\").css('visibility', 'hidden');\nq.find(\".track\").on(\"click , touchstart\", function() {\njQuery(this).find(\".handle\").css('visibility', 'visible');\n});\n\nq.find(\".track\").css(\"height\", \"10px\");\n\n});"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID296","SecondaryAttribute":"Regarding the previous question","TertiaryAttribute":null,"Payload":{"QuestionText":"Regarding the previous question","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":1,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Regarding the previous question","Choices":{"1":{"Display":"How much agreement do you think exists among people about what is appropriate in this situation?"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"Regarding the previous question","DataExportTag":"","QuestionID":"QID296"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID297","SecondaryAttribute":"Regarding the previous question, which of the following options best describes this situation?","TertiaryAttribute":null,"Payload":{"QuestionText":"Regarding the previous question, which of the following options best describes this situation?","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Regarding the previous question, which of the following options best describes this situation?","Choices":{"1":{"Display":"Clear shared norm"},"2":{"Display":"Weak or unclear norm"},"3":{"Display":"Two competing norms"},"4":{"Display":"No clear norm"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionText_Unsafe":"Regarding the previous question, which of the following options best describes this situation?","DataExportTag":"","QuestionID":"QID297"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID298","SecondaryAttribute":"Individual A is at a local coffee shop near campus. While there, Individual A notices that someon...","TertiaryAttribute":null,"Payload":{"QuestionText":"Individual A is at a local coffee shop near campus. While there, Individual A notices that someone has left a wallet on one of the tables. Individual A must decide what to do.&nbsp;Please rate how socially appropriate each action is.&nbsp;","DefaultChoices":false,"DataExportTag":"","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Individual A is at a local coffee shop near campus. While there, Individual A notices that someon...","Choices":{"1":{"Display":"Take the wallet"},"2":{"Display":"Ask people nearby if the wallet belongs to them"},"3":{"Display":"Leave the wallet where it is"},"4":{"Display":"Give the wallet to the shop manager"}},"ChoiceOrder":["1","2","3","4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate"},"2":{"Display":"Somewhat socially inappropriate"},"3":{"Display":"Neither socially inappropriate nor appropriate"},"4":{"Display":"Somewhat socially appropriate"},"5":{"Display":"Very socially appropriate"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID298"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID299","SecondaryAttribute":"In this study, your goal is to identify what you think most other participants will choose. Impor...","TertiaryAttribute":null,"Payload":{"QuestionText":"In this study, your goal is to identify what you think most other participants will choose. Importantly, the most common response <strong>does not have to be chosen by more than 50%<\/strong> of participants. It simply refers to the option selected by the <strong>largest number of participants<\/strong>, even if it is less than half. For example, if responses are distributed as<br \/>\n40% choose option A<br \/>\n25% choose option B<br \/>\n20% choose option C<br \/>\n10% choose option D<br \/>\n5% choose option E<br \/>\nThe response chosen by<strong> 40%<\/strong> would still represent the strongest social norm, because it is the <strong>most common<\/strong> response among participants.","DefaultChoices":false,"DataExportTag":"Social Norm Explain","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In this study, your goal is to identify what you think most other participants will choose. Impor...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID299"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID3","SecondaryAttribute":"Welcome! You are invited to participate in a research study about decision-making and social judg...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p data-end=\"324\" data-start=\"312\"><strong data-end=\"324\" data-start=\"312\">Welcome!<\/strong><\/p><p data-end=\"324\" data-start=\"312\"><strong data-end=\"324\" data-start=\"312\"><br><\/strong><\/p>\n\n<p data-end=\"602\" data-start=\"326\">You are invited to participate in a research study about decision-making and social judgments. In this study, you will read several short scenarios and answer questions about them. This study is part of ongoing academic research, and your participation is greatly appreciated.<\/p><p data-end=\"602\" data-start=\"326\"><br><\/p>\n\n<p data-end=\"690\" data-start=\"604\"><strong data-end=\"617\" data-start=\"604\">Duration.&nbsp;<\/strong>Your participation will take approximately <strong data-end=\"677\" data-start=\"663\">20 minutes<\/strong> to complete.<\/p><p data-end=\"690\" data-start=\"604\"><br><\/p>\n\n<p data-end=\"1015\" data-start=\"692\"><strong data-end=\"712\" data-start=\"692\">Confidentiality.&nbsp;<\/strong>Your responses will remain anonymous at all times. This means that the researchers will not be able to link your responses to your name or any identifiable personal information. If the results of this study are published or presented, your identity will not be revealed. Data anonymity is guaranteed.<\/p><p data-end=\"1015\" data-start=\"692\"><br><\/p>\n\n<p data-end=\"1165\" data-start=\"1017\"><strong data-end=\"1040\" data-start=\"1017\">Participant Rights.&nbsp;<\/strong>Your participation is voluntary. You may choose not to participate or withdraw from the study at any time without penalty.<\/p><p data-end=\"1165\" data-start=\"1017\"><br><\/p>\n\n<p data-end=\"1250\" data-start=\"1167\"><strong data-end=\"1177\" data-start=\"1167\">Risks.&nbsp;<\/strong>There are no known risks associated with participating in this survey.<\/p><p data-end=\"1250\" data-start=\"1167\"><br><\/p>\n\n<p data-end=\"1992\" data-start=\"1252\"><strong data-end=\"1265\" data-start=\"1252\">Earnings.&nbsp;<\/strong>You will receive a participation payment of <strong data-end=\"1323\" data-start=\"1312\">US$ ?<\/strong>&nbsp;for completing this study. The study consists of multiple parts, and some parts may offer the opportunity to earn additional bonus payments based on your decisions and\/or the decisions of other participants. At the end of the study, one part will be randomly selected for payment, and points earned in that part will be converted into a bonus payment (<strong data-end=\"1700\" data-start=\"1676\">100 points = US$0.75<\/strong>). On average, we estimate a bonus payment of approximately <strong data-end=\"1771\" data-start=\"1760\">US$1.50<\/strong>, with a maximum possible bonus of <strong data-end=\"1817\" data-start=\"1806\">US$3.00<\/strong>. Please note that bonus payments will only be provided if you successfully complete the entire study and pass all attention and comprehension checks included in the survey.<\/p><p data-end=\"1992\" data-start=\"1252\"><br><\/p>\n\n<p data-end=\"2061\" data-start=\"1994\"><strong data-end=\"2010\" data-start=\"1994\">Eligibility.&nbsp;<\/strong>By continuing with the survey, you confirm that:<\/p>\n\n<ul data-end=\"2170\" data-start=\"2062\">\n\t<li data-end=\"2099\" data-section-id=\"72jzf9\" data-start=\"2062\">\n\t<p data-end=\"2099\" data-start=\"2064\">you are <strong data-end=\"2097\" data-start=\"2072\">at least 18 years old<\/strong><\/p>\n\t<\/li>\n\t<li data-end=\"2170\" data-section-id=\"imj8mc\" data-start=\"2100\">\n\t<p data-end=\"2170\" data-start=\"2102\">you are <strong data-end=\"2170\" data-start=\"2110\">currently a student at a university in the United States<\/strong><\/p><\/li>\n<\/ul>\n\n<p data-end=\"2402\" data-start=\"2172\"><strong data-end=\"2196\" data-start=\"2172\"><br><\/strong><\/p><p data-end=\"2402\" data-start=\"2172\"><strong data-end=\"2196\" data-start=\"2172\">Contact Information.&nbsp;<\/strong>If you have questions about this study or your rights as a participant, you may contact the research team at <strong data-end=\"2333\" data-start=\"2308\"><a data-end=\"2331\" data-start=\"2310\" rel=\"noopener\">diegoay@sas.upenn.edu<\/a><\/strong>, or the <strong data-end=\"2401\" data-start=\"2342\">University of Pennsylvania IRB Office at (215) 898-2614<\/strong>.<\/p><p data-end=\"2402\" data-start=\"2172\"><br><\/p>\n\n<p data-end=\"2586\" data-start=\"2404\"><strong data-end=\"2416\" data-start=\"2404\">Consent.&nbsp;<\/strong>By clicking <strong data-end=\"2444\" data-start=\"2431\">\u201cI Agree\u201d<\/strong> and continuing with the survey, you confirm that you have read and understood the information above and consent to participate in this study.<\/p>","DefaultChoices":false,"DataExportTag":"","QuestionID":"QID3","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Welcome! You are invited to participate in a research study about decision-making and social judg...","Choices":{"4":{"Display":"I Agree"},"5":{"Display":"I Do Not Agree"}},"ChoiceOrder":["4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID30","SecondaryAttribute":"During a lecture, some students use laptops to take notes, while others use laptops to browse the...","TertiaryAttribute":null,"Payload":{"QuestionText":"During a lecture, some students use laptops to take notes, while others use laptops to browse the internet or check social media. Some people think using laptops freely is acceptable, while others think it distracts nearby students.&nbsp;Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Scenario 9","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true,"Transpose":"transposeTable"},"QuestionDescription":"During a lecture, some students use laptops to take notes, while others use laptops to browse the...","Choices":{"1":{"Display":"Very socially inappropriate"},"2":{"Display":"Somewhat socially inappropriate"},"3":{"Display":"Neither socially inappropriate nor appropriate"},"4":{"Display":"Somewhat socially appropriate"},"5":{"Display":"Very socially appropriate"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":4,"Answers":{"1":{"Display":"Use your laptop only for taking notes"},"2":{"Display":"Use your laptop freely during class"},"3":{"Display":"Avoid using a laptop during the lecture"}},"AnswerOrder":["1","2","3"],"ChoiceDataExportTags":false,"QuestionID":"QID30"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID300","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"Q291","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID300"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID301","SecondaryAttribute":"When people evaluate actions, several types of norm patterns may occur. Strong Norm A strong norm...","TertiaryAttribute":null,"Payload":{"QuestionText":"When people evaluate actions, several types of norm patterns may occur.<br \/>\n<br \/>\n<strong>Strong Norm<\/strong><br \/>\nA <strong>strong norm<\/strong> occurs when one response is clearly the most common choice among participants. Even if it is chosen by less than half of participants, it still represents the strongest shared expectation about appropriate behavior.<br \/>\n<br \/>\n<strong>Weak or Unclear Norm<\/strong><br \/>\nA <strong>weak or unclear norm<\/strong> occurs when responses are spread across several options and no response clearly stands out as the most common choice. In this case, participants do not strongly agree on what behavior is appropriate.<br \/>\n<br \/>\n<strong>Two Competing Norms<\/strong><br \/>\nSometimes <strong>two responses receive similar levels of support<\/strong>, meaning that participants are divided between two views of what is socially appropriate. This situation reflects <strong>two competing norms<\/strong>.<br \/>\n<br \/>\n<strong>No Clear Norm<\/strong><br \/>\nIn some situations, responses are distributed almost evenly across all options. This indicates that participants <strong>do not share a clear expectation<\/strong> about what behavior is appropriate.","DefaultChoices":false,"DataExportTag":"Norm types","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"When people evaluate actions, several types of norm patterns may occur. Strong Norm A strong norm...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID301"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID302","SecondaryAttribute":"You are studying in a quiet area of a university library. A student nearby is speaking loudly on...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are studying in a quiet area of a university library. A student nearby is speaking loudly on the phone while several people are trying to study. Signs in the library indicate that phone calls should be taken outside. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Scenario 1","QuestionID":"QID302","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You are studying in a quiet area of a university library. A student nearby is speaking loudly on...","Choices":{"1":{"Display":"Politely ask the student to lower their voice or take the call outside"},"2":{"Display":"Do nothing and ignore the situation"},"3":{"Display":"Join the noise by playing a video loudly on your phone"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"RecodeValues":{"1":"-100","2":"-50","3":"0","4":"50","5":"100"}}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID303","SecondaryAttribute":"You are waiting in line at a busy campus coffee shop during a break between classes. Several stud...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are waiting in line at a busy campus coffee shop during a break between classes. Several students are standing in line to order drinks. A student suddenly walks past everyone, goes directly to a friend who is already at the front of the line, and asks the friend to place an order for them so they do not have to wait. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Scenario 2","QuestionID":"QID303","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You are waiting in line at a busy campus coffee shop during a break between classes. Several stud...","Choices":{"1":{"Display":"Say nothing and continue waiting in line"},"2":{"Display":"Politely tell the student that there is a line and they should wait like everyone else"},"3":{"Display":"Move forward and cut the line yourself as well"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID304","SecondaryAttribute":"You are taking an in-person exam in a university classroom. Students are expected to work indepen...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are taking an in-person exam in a university classroom. Students are expected to work independently, and the instructor has stated that using notes or phones during the exam is not allowed. During the exam, you notice a student sitting nearby secretly looking at notes on their phone under the desk. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Scenario 3","QuestionID":"QID304","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You are taking an in-person exam in a university classroom. Students are expected to work indepen...","Choices":{"1":{"Display":"Ignore the situation and focus on your own exam"},"2":{"Display":"Report the situation to the instructor after the exam ends"},"3":{"Display":"Threaten to report the student unless they give you something in return"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID305","SecondaryAttribute":"You are in a class group chat used to share information about assignments, deadlines, and lecture...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are in a class group chat used to share information about assignments, deadlines, and lecture notes. One classmate starts posting several memes that are unrelated to the course. Some students react with emojis or jokes, while others ignore the messages. Please rate how socially appropriate each action is.","Defau