eType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID307"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID308","SecondaryAttribute":"You are attending a live online class using Zoom. The instructor encourages students to keep thei...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are attending a live online class using Zoom. The instructor encourages students to keep their cameras on during class. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Scenario 7","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You are attending a live online class using Zoom. The instructor encourages students to keep thei...","Choices":{"1":{"Display":"Turn your camera on only when you are speaking or participating"},"2":{"Display":"Keep your camera on during the entire class"},"3":{"Display":"Keep your camera off during the entire class"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropri