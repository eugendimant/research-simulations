ents are expected to work indepen...","Choices":{"1":{"Display":"Tell other students about the cheating behavior afterward but do not inform the instructor"},"2":{"Display":"Ignore the situation and focus on your own exam"},"3":{"Display":"Report the situation to the instructor after the exam ends"},"4":{"Display":"Quietly warn the student during the exam to stop looking at their phone"},"5":{"Display":"Threaten to report the student unless they give you something in return"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":4,"Labels":{"1":{"Display":"-100 = Very socially inappropriate"},"2":{"Display":"0 = Neither socially inappropriate nor appropriate"},"3":{"Display":"100 = Very socially appropriate"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\/*Place your JavaScript here to run when the page loads*\/\nvar q = jQuery(\"#\"+this.questionId);\nq.find(\".handle\").css('visibility', 'hidden');\nq.find(\".track\").on(\"click , touchstart\", function() {\njQuery(this).find(\".handle\").css('visibility', 'visible');\n});\n\nq.find(\".track\").css(\"height\", \"10px\");\n\n});"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID232","SecondaryAttribute":"Regarding the previous question","TertiaryAttribute":null,"Payload":{"QuestionText":"Regarding the previous question","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":1,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Regarding the previous question","Choices":{"1":{"Display":"How much agreement do you think exists among people about what is appropriate in this situation?"}},"ChoiceOrder":[1],"Val