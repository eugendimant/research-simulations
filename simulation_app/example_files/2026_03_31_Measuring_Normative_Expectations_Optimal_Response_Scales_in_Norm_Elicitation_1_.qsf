"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":1,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Regarding the previous question","Choices":{"1":{"Display":"How much agreement do you think exists among people about what is appropriate in this situation?"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":1,"Labels":[],"QuestionID":"QID77"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID78","SecondaryAttribute":"Regarding the previous question, which of the following options best describes this situation?","TertiaryAttribute":null,"Payload":{"QuestionText":"Regarding the previous question, which of the following options best describes this situation?","DefaultChoices":false,"DataExportTag":"","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Regarding the previous question, which of the following options best describes this situation?","Choices":{"1":{"Display":"Clear shared norm"},"2":{"Display":"Weak or unclear norm"},"3":{"Display":"Two competing norms"},"4":{"Display":"No clear norm"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID78"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID79","SecondaryAttribute":"Regarding the previous question","TertiaryAttribute":null,"Payload":{"QuestionText":"Regarding the previous question","DefaultChoices":false,"DataExportTag":"","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":1,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Regarding the previous question","Choices":{"1":{"Display":"How much agreement do you think exists among people about what is appropriate in this situation?"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":1,"Labels":[],"QuestionID":"QID79"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID8","SecondaryAttribute":"To help illustrate how this task works, consider the following example. Example Situation Individ...","TertiaryAttribute":null,"Payload":{"QuestionText":"To help illustrate how this task works, consider the following example.\n\nExample Situation\n\nIndividual A is at a local coffee shop near campus. While there, Individual A notices that someone has left a wallet on one of the tables. Individual A must decide what to do. Individual A has several possible actions<br>\u2022 Take the wallet <br>\u2022 Ask people nearby if the wallet belongs to them <br>\u2022 Leave the wallet where it is <br>\u2022 Give the wallet to the shop manager <br>For each possible action, your task would be to indicate how socially appropriate you believe most other participants in this study would consider that action.\n\nBy \u201csocially appropriate,\u201d we mean behavior that most people would agree is the correct or proper thing to do in that situation.\n\nImportantly, you are not reporting what you personally would do. Instead, you should indicate what you believe most other participants will think is socially appropriate.\n\nEach possible action is evaluated separately.","DefaultChoices":false,"DataExportTag":"Intuitive Example","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"To help illustrate how this task works, consider the following example. Example Situation Individ...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID8"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID80","SecondaryAttribute":"Regarding the previous question, which of the following options best describes this situation?","TertiaryAttribute":null,"Payload":{"QuestionText":"Regarding the previous question, which of the following options best describes this situation?","DefaultChoices":false,"DataExportTag":"","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Regarding the previous question, which of the following options best describes this situation?","Choices":{"1":{"Display":"Clear shared norm"},"2":{"Display":"Weak or unclear norm"},"3":{"Display":"Two competing norms"},"4":{"Display":"No clear norm"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID80"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID81","SecondaryAttribute":"A classmate sends you a message asking about your homework progress. You see the message, but are...","TertiaryAttribute":null,"Payload":{"QuestionText":"A classmate sends you a message asking about your homework progress. You see the message, but are busy at the moment.&nbsp;Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Q72","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"A classmate sends you a message asking about your homework progress. You see the message, but are...","Choices":{"1":{"Display":"Very socially inappropriate"},"2":{"Display":"Socially inappropriate"},"3":{"Display":"Neutral"},"4":{"Display":"Socially appropriate"},"5":{"Display":"Very socially appropriate"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":6,"Answers":{"1":{"Display":"Reply immediately even if you are busy"},"2":{"Display":"Send a short reply saying you will answer later"},"3":{"Display":"Reply later when you have time"},"4":{"Display":"Ignore the message entirely"},"5":{"Display":"Tell them to check the course slide instead"}},"AnswerOrder":[1,2,3,4,5],"ChoiceDataExportTags":false,"QuestionID":"QID81"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID82","SecondaryAttribute":"Regarding the previous question","TertiaryAttribute":null,"Payload":{"QuestionText":"Regarding the previous question","DefaultChoices":false,"DataExportTag":"","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":1,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Regarding the previous question","Choices":{"1":{"Display":"How much agreement do you think exists among people about what is appropriate in this situation?"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"Next