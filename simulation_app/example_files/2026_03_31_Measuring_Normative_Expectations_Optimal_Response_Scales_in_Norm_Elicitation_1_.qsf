"},"4":{"Display":"No clear norm"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionText_Unsafe":"Regarding the previous question, which of the following options best describes this situation?","DataExportTag":"","QuestionID":"QID227"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID228","SecondaryAttribute":"You are waiting in line at a busy campus coffee shop during a break between classes. Several stud...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are waiting in line at a busy campus coffee shop during a break between classes. Several students are standing in line to order drinks. A student suddenly walks past everyone, goes directly to a friend who is already at the front of the line, and asks the friend to place an order for them so they do not have to wait. Please rate how socially appropriate each action is.<br>(Click and drag the slider below to enter your answer)\r\n<br>","DefaultChoices":false,"DataExportTag":"Coffee shop Scenario","QuestionID":"QID228","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","CSSliderMin":-100,"CSSliderMax":100,"GridLines":1,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"You are waiting in line at a busy campus coffee shop during a break between classes. Several stud...","Choices":{"1":{"Display":"Politely tell the student that there is a line and they should wait like everyone else"},"2":{"Display":"Say nothing and continue waiting in line"},"3":{"Display":"Complain loudly to others in line about the student cutting ahead"},"4":{"Display":"Ask the cashier or staff member to enforce the line and ask the student to go to the back"},"5":{"Display":"Move forward and cut the line yourself as well"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":4,"Labels":{"1":{"Display":"-100 = Very socially inappropriate"},"2":{"Display":"0 = Neither socially inappropriate nor appropriate"},"3":{"Display":"100 = Very socially appropriate"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\/*Place your JavaScript here to run when the page loads*\/\nvar q = jQuery(\"#\"+this.questionId);\nq.find(\".handle\").css('visibility', 'hidden');\nq.find(\".track\").on(\"click , touchstart\", function() {\njQuery(this).find(\".handle\").css('visibility', 'visible');\n});\n\nq.find(\".track\").css(\"height\", \"10px\");\n\n});"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID229","SecondaryAttribute":"Regarding the previous question","TertiaryAttribute":null,"Payload":{"QuestionText":"Regarding the previous question","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":1,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Regarding the previous question","Choices":{"1":{"Display":"How much agreement do you think exists among people about what is appropriate in this situation?"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"Regarding the previous question","DataExportTag":"","QuestionID":"QID229"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID23","SecondaryAttribute":"You are taking an in-person exam in a university classroom. Students are expected to work indepen...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are taking an in-person exam in a university classroom. Students are expected to work independently, and the instructor has stated that using notes or phones during the exam is not allowed. During the exam, you notice a student sitting nearby secretly looking at notes on their phone under the desk. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Scenario 3","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true,"Transpose":"transposeTable"},"QuestionDescription":"You are taking an in-person exam in a university classroom. Students are expected to work indepen...","Choices":{"1":{"Display":"Very socially inappropriate"},"2":{"Display":"Somewhat socially inappropriate"},"3":{"Display":"Neither socially inappropriate nor appropriate"},"4":{"Display":"Somewhat socially appropriate"},"5":{"Display":"Very socially appropriate"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":4,"Answers":{"1":{"Display":"Report the situation to the instructor after the exam"},"2":{"Display":"Ignore the situation and focus on your own exam"},"3":{"Display":"Blackmailing that student during the exam or after"}},"AnswerOrder":["1","2","3"],"ChoiceDataExportTags":false,"QuestionID":"QID23"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID230","SecondaryAttribute":"Regarding the previous question, which of the following options best describes this situation?","TertiaryAttribute":null,"Payload":{"QuestionText":"Regarding the previous question, which of the following options best describes