e. The friend asks you to c...","Choices":{"1":{"Display":"Choose the blue mug"},"2":{"Display":"Flip a coin to decide"},"3":{"Display":"Choose the green mug"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID311"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID312","SecondaryAttribute":"You arrive early to a lecture and enter an empty classroom. The class has not started yet, and al...","TertiaryAttribute":null,"Payload":{"QuestionText":"You arrive early to a lecture and enter an empty classroom. The class has not started yet, and all seats appear identical. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Scenario 11","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You arrive early to a lecture and enter an empty classroom. The class has not started yet, and al...","Choices":{"1":{"Display":"Sit in the middle row"},"2":{"Display":"Sit in the back row"},"3":{"Display":"Sit in the front row"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID312"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID313","SecondaryAttribute":"You are choosing a new wallpaper for your phone. Two images are available \u2014 one of a cat and one..","TertiaryAttribute":null,"Payload":{"QuestionText":"You are choosing a new wallpaper for your phone. Two images are available \u2014 one of a cat and one of a dog. You like both images equally. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Scenario 12","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You are choosing a new wallpaper for your phone. Two images are available \u2014 one of a cat and one...","Choices":{"1":{"Display":"Choose the dog image"},"2":{"Display":"Randomly pick one of the two images"},"3":{"Display":"Choose the cat image"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID313"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribu