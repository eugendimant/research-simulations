Description":"You enter an empty classroom and must choose where to sit. All seats appear identical. Please rat...","Choices":{"1":{"Display":"Very socially inappropriate"},"2":{"Display":"Somewhat socially inappropriate"},"3":{"Display":"Neither socially inappropriate nor appropriate"},"4":{"Display":"Somewhat socially appropriate"},"5":{"Display":"Very socially appropriate"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":4,"Answers":{"1":{"Display":"Sit in the front row"},"2":{"Display":"Sit in the middle row"},"3":{"Display":"Sit in the back row"}},"AnswerOrder":["1","2","3"],"ChoiceDataExportTags":false,"QuestionID":"QID32"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID320","SecondaryAttribute":"You are attending a lecture in a university classroom where many students bring laptops to class....","TertiaryAttribute":null,"Payload":{"QuestionText":"You are attending a lecture in a university classroom where many students bring laptops to class. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Laptop Scenario","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You are attending a lecture in a university classroom where many students bring laptops to class....","Choices":{"1":{"Display":"Use a laptop but sit where it will not distract others"},"2":{"Display":"Use your laptop only for taking notes related to the lecture"},"3":{"Display":"Ask the professor about laptop rules"},"4":{"Display":"Avoid using a laptop during the lecture"},"5":{"Display":"Use your laptop freely during class"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID320"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID321","SecondaryAttribute":"You are choosing a new wallpaper for your phone. Two images are available \u2014 one of a cat and one..","TertiaryAttribute":null,"Payload":{"QuestionText":"You are choosing a new wallpaper for your phone. Two images are available \u2014 one of a cat and one of a dog. You like both images equally. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Wallpaper Scenario","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You are choosing a new wallpaper for your phone. Two images are available \u2014 one of a cat and one...","Choices":{"1":{"Display":"Randomly pick one of the two images"},"2":{"Display":"Choose the image that appears first on the screen"},"3":{"Display":"Choose the cat image"},"4":{"Display":"Send the images to a friend and ask for their opinion"},"5":{"Display":"Choose the dog image"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (-50)"},"5":{"Display":"Very socially appropriate (-100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID321"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID322","SecondaryAttribute":"You are at a store with a friend who is buying a small gift for someone. The friend asks you to c...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are at a store with a friend who is buying a small gift for someone. The friend asks you to choose between two coffee mugs \u2014 one green and one blue. Both mugs cost the same, and the friend says they like both equally. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Gift Scenario","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You are at a store with a friend who is buying a small gift for someone. The friend asks you to c...","Choices":{"1":{"Display":"Choose the green mug"},"2":{"Display":"Choose the blue mug"},"3":{"Display":"Flip a coin to decide"},"4":{"Display":"Ask shop worker to choose between the two mugs"},"5":{"Display":"Pick randomly without thinking too much about it"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID322"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID323","SecondaryAttribute":"You arrive early to a lecture and enter an empty classroom. The class has not started yet, and al...","TertiaryAttribute":null,"Payload":{"QuestionText":"You arrive early to a lecture and enter an empty classroom. The class has not started yet, and all seats appear identical. Please rate how socially appropriate each action is.n text","DefaultChoices":false,"DataExportTag":"Seating Scenario","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You arrive early to a lecture and enter an empty classroom. The class has not started yet, and al...","Choices":{"1":{"Display":"Randomly choose a seat"},"2":{"Display":"Sit in the back row"},"3":{"Display":"Sit in the front row"},"4":{"Display":"Sit by the door"},"5":{"Display":"Sit in the middle row"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID323"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID324","SecondaryAttribute":"You are in a class group chat used to share information about assignments, deadlines, and lecture...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are in a class group chat used to share information about assignments, deadlines, and lecture notes. One classmate starts posting several memes that are unrelated to the course. Some students react with emojis or jokes, while others ignore the messages. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Group Chat Scenario","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You are in a class group chat used to share information about assignments, deadlines, and lecture...","Choices":{"1":{"Display":"Ignore the messages and scroll past them"},"2":{"Display":"Ask the student in the group chat to keep the conversation focused on class topics"},"3":{"Display":"Post another meme in the chat"},"4":{"Display":"React with emojis or short replies to the memes"},"5":{"Display":"Send the student a private message suggesting they post fewer memes in the group chat"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID324"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID325","SecondaryAttribute":"You are taking an in-person exam in a university classroom. Students are expected to work indepen...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are taking an in-person exam in a university classroom. Students are expected to work independently, and the instructor has stated that using notes or phones during the exam is not allowed. During the exam, you notice a student sitting nearby secretly looking at notes on their phone under the desk. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Exam Scenario","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You are taking an in-person exam in a university classroom. Students are expected to work indepen...","Choices":{"1":{"Display":"Tell other students about the cheating behavior afterward but do not inform the instructor"},"2":{"Display":"Ignore the situation and focus on your own exam"},"3":{"Display":"Report the situation to the instructor after the exam ends"},"4":{"Display":"Tell other students about the cheating behavior afterward but do not inform the instructor"},"5":{"Display":"Threaten to report the student unless they give you something in return"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID325"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID326","SecondaryAttribute":"You are studying in a quiet area of a university library. A student nearby is speaking loudly on...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are studying in a quiet area of a university library. A student nearby is speaking loudly on the phone while several people are trying to study. Signs in the library indicate that phone calls should be taken outside. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Library Scenario","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You are studying in a quiet area of a university library. A student nearby is speaking loudly on...","Choices":{"1":{"Display":"Do nothing and ignore the situation"},"2":{"Display":"Tell the student loudly that they should leave the library immediately"},"3":{"Display":"Inform a library staff member about the situation"},"4":{"Display":"Join the noise by playing a video loudly on your phone"},"5":{"Display":"Politely ask the student to lower their voice or take the call outside"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":6,"Answers":{"1":{"Display":"Very socially inappropriate (-100)"},"2":{"Display":"Somewhat socially inappropriate (-50)"},"3":{"Display":"Neither socially inappropriate nor appropriate (0)"},"4":{"Display":"Somewhat socially appropriate (50)"},"5":{"Display":"Very socially appropriate (100)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":false,"QuestionID":"QID326"}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID327","SecondaryAttribute":"Yo