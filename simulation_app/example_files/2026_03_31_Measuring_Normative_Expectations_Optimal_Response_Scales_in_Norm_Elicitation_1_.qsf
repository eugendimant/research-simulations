"IsLabelDefault":false},{"Display":"0 = Neither socially inappropriate nor appropriate","IsLabelDefault":false},{"Display":"100 = Very socially appropriate","IsLabelDefault":false}]}},{"SurveyID":"SV_6tZ9inq7UmTQyHk","Element":"SQ","PrimaryAttribute":"QID349","SecondaryAttribute":"You arrive early to a lecture and enter an empty classroom. The class has not started yet, and al...","TertiaryAttribute":null,"Payload":{"QuestionText":"You arrive early to a lecture and enter an empty classroom. The class has not started yet, and all seats appear identical. Please rate how socially appropriate each action is.","DefaultChoices":false,"DataExportTag":"Seating Scenario","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"You arrive early to a lecture and enter an empty classroom. The class has not started yet, and al...","Choices":{"1":{"Display":"Randomly choose a seat"},"2":{"Display":"Sit in the back row"},"3":{"Display":"Sit in the front row"},"4":{"Display":"Sit by the door"},"5":{"Display":"Sit in the middle row"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":15,"Answers":{"1":{"Display":"-100"},"2":{"Display":"-80"},"6":{"Display":"-60"},"7":{"Display":"-40"},"8":{"Display":"-20"},"9":{"Display":"0"},"10":{"Display":"20"},"11":{"Display":"40"},"12":{"Display":"60"},"13":{"Display":"80"},"14":{"Display":"100"}},"AnswerOrder":["1","2","6","7","8","9","10","11","12","13","14"],"ChoiceDataExportTags":false,"QuestionID":"QID349","ColumnLabels":[{"Display":"-100 = Very socially inappropriate","IsLabelDefault":false},{"Display":"0 = Neither socially inappropriate nor appropriate","