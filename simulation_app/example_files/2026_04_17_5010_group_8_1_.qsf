\").css({\n                    \"pointer-events\": \"none\",\n                    \"opacity\": \"0.6\"\n                });\n            } else {\n                $input.prop(\"disabled\", false);\n                $input.closest(\"li, .Choice\").css({\n                    \"pointer-events\": \"auto\",\n                    \"opacity\": \"1\"\n                });\n            }\n        });\n    }\n\n    \/\/ ===== 3. \u8d2d\u7269\u8f66\u66f4\u65b0 =====\n    function updateCartDisplay() {\n        var selectedChoices = q.getSelectedChoices() || [];\n        var currentQuestionHtml = \"\";\n\n        for (var i = 0; i < selectedChoices.length; i++) {\n            var cid = selectedChoices[i];\n            var $label = jQuery(\"#\" + qid + \" label[for='QR~\" + qid + \"~\" + cid + \"']\");\n            var recodeNum = $label.text().replace(\/\\s+\/g, '').trim();\n            var imgSrc = $label.find(\"img\").attr(\"src\");\n\n            if (recodeNum) {\n                currentQuestionHtml +=\n                    \"<div class='live-cart-item' style='display:inline-block; width:90px; text-align:center; border:1px solid #eee; padding:5px; border-radius:5px; margin:5px; vertical-align:top;'>\" +\n                        \"<div style='font-weight:bold; color:#333; font-size:14px;'>\" + recodeNum + \"<\/div>\" +\n                        (imgSrc ? \"<img src='\" + imgSrc + \"' style='width:100%; height:auto; display:block; margin:0 auto;'>\" : \"\") +\n                    \"<\/div>\";\n            }\n        }\n\n        window.globalCart[currentBlock][qid] = currentQuestionHtml;\n\n        var finalHtml = \"\";\n        Object.keys(window.globalCart[currentBlock]).forEach(function(key) {\n            finalHtml += window.globalCart[currentBlock][key];\n        });\n\n        if (!finalHtml) {\n            jQuery(\"#real-time-cart\").html(\"<span style='color:#ccc;'>No items selected<\/span>\");\n        } else {\n            jQuery(\"#real-time-cart\").html(finalHtml);\n        }\n\n        Qualtrics.SurveyEngine.setEmbeddedData(\"shopping_cart\", finalHtml);\n    }\n\n    \/\/ ===== 4. Recommended \u9ad8\u4eae =====\n    function runRecommend() {\n        var container = document.getElementById(qid);\n        if (!container) return false;\n\n        \/\/ \u5982\u679c P1 \u4e0d\u662f Q39\uff0c\u8fd9\u91cc\u6539\u6210\u771f\u6b63\u7684 QID\n        var p1Raw = \"${q:\/\/QID39\/SelectedChoicesRecode}\";\n\n        var p1Codes = p1Raw\n            .split(\",\")\n            .map(function(x) { return String(x).trim(); })\n            .filter(function(x) { return x !== \"\"; });\n\n        if (!p1Codes.length) return false;\n\n        var found = 0;\n        var inputs = container.querySelectorAll('input[type=\"checkbox\"], input[type=\"radio\"]');\n\n        inputs.forEach(function(input) {\n            var inputId = input.id || \"\";\n            if (!inputId) return;\n\n            var choiceId = inputId.split(\"~\").pop();\n            if (!choiceId) return;\n\n            var recode = \"\";\n            try {\n                recode = String(q.getChoiceRecodeValue(choiceId)).trim();\n            } catch (e) {\n                return;\n            }\n\n            var label = container.querySelector('label[for=\"' + inputId + '\"]');\n            if (!label) return;\n\n            \/\/ \u6e05\u9664\u65e7\u6837\u5f0f\n            label.style.outline = \"\";\n            label.style.background = \"\";\n            label.style.borderRadius = \"\";\n            label.style.boxShadow = \"\";\n            label.style.position = \"relative\";\n\n            var oldTag = label.querySelector(\".recommended-tag\");\n            if (oldTag) oldTag.remove();\n\n            \/\/ \u5339\u914d P1 \u9009\u4e2d\u7684 recode\n            if (p1Codes.indexOf(recode) !== -1) {\n                found++;\n\n                label.style.outline = \"5px solid #2F80ED\";\n                label.style.background = \"#EAF3FF\";\n                label.style.borderRadius = \"12px\";\n                label.style.boxShadow = \"0 0 0 4px rgba(47,128,237,0.25)\";\n                label.style.position = \"relative\";\n\n                var tag = document.createElement(\"div\");\n                tag.className = \"recommended-tag\";\n                tag.innerHTML = \"Recommended\";\n                tag.style.position = \"absolute\";\n                tag.style.top = \"4px\";\n                tag.style.left = \"4px\";\n                tag.style.background = \"#2F80ED\";\n                tag.style.color = \"white\";\n                tag.style.fontSize = \"12px\";\n                tag.style.fontWeight = \"bold\";\n                tag.style.padding = \"2px 6px\";\n                tag.style.borderRadius = \"8px\";\n                tag.style.zIndex = \"9999\";\n\n                label.appendChild(tag);\n            }\n        });\n\n        return found > 0;\n    }\n\n    \/\/ ===== 5. \u52fe\u9009\u65f6\u66f4\u65b0\u8d2d\u7269\u8f66 + \u4e25\u683c\u9650\u5236\u6700\u591a6\u4e2a =====\n    jQuery(\"#\" + qid + \" input[type='checkbox']\")\n        .off(\"change.cartonly\")\n        .on(\"change.cartonly\", function() {\n            var totalSelected = getSelectedCountInBlock();\n\n            if (totalSelected > maxItems) {\n                jQuery(this).prop(\"checked\", false);\n                alert(\"You can select up to 6 items only.\");\n                updateCartDisplay();\n                enableAvailableInWholeBlock();\n                return;\n            }\n\n            updateCartDisplay();\n            enableAvailableInWholeBlock();\n        });\n\n    \/\/ ===== 6. \u521d\u59cb\u5316 =====\n    updateCartDisplay();\n    enableAvailableInWholeBlock();\n\n    var tries = 0;\n    var timer = setInterval(function() {\n        tries++;\n        var ok = runRecommend();\n        if (ok || tries >= 20) {\n            clearInterval(timer);\n        }\n    }, 500);\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionType":"MC","Selector":"MAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Nuts","Choices":{"1":{"Display":"501","GraphicSize":[100,null],"Image":{"Display":"Nuts 1","ImageLocation":"IM_EsocJZ2hiVSG3TM"}},"2":{"Display":"502","GraphicSize":[100,null],"Image":{"Display":"Nuts 2","ImageLocation":"IM_NrPY57Pk3bWKFlH"}},"3":{"Display":"503","GraphicSize":[100,null],"Image":{"Display":"Nuts 3","ImageLocation":"IM_ELr1GOFn3vdvQpU"}},"4":{"Display":"504","GraphicSize":[100,null],"Image":{"Display":"Nuts 7","ImageLocation":"IM_gi8HlQOoaEssxYQ"}},"5":{"Display":"505","GraphicSize":[100,null],"Image":{"Display":"Nuts 8","ImageLocation":"IM_Zn9nvUt96WrOP7w"}}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"RecodeValues":{"1":"501","2":"502","3":"503","4":"504","5":"505"},"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionText_Unsafe":"Nuts","DataExportTag":"Q66","QuestionID":"QID66"}},{"SurveyID":"SV_0resoTRPoWFgHzw","Element":"SQ","PrimaryAttribute":"QID67","SecondaryAttribute":"\ud83d\uded2 Your Shopping Cart Loading...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"margin-top: 20px; padding: 15px; border: 2px solid #2d70b3; border-radius: 10px; background: #fff; min-height: 100px;\">\n    <strong style=\"color: #2d70b3; font-size: 18px;\">\ud83d\uded2 Your Shopping Cart<\/strong>\n    <hr>\n    <div id=\"real-time-cart\" style=\"display: flex; flex-wrap: wrap; gap: 10px;\">\n        <span style=\"color: #ccc;\">Loading...<\/span>\n    <\/div>\n<\/div>","QuestionJS":"Qualtrics.SurveyEngine.addOnLoad(function() {\n    var finalHTML = \"\";\n    \n    \/\/ \u904d\u5386\u6d4f\u89c8\u5668\u7f13\u5b58\uff0c\u628a\u6240\u6709\u5b58\u4e0b\u7684\u4ea7\u54c1\u56fe\u7247\u90fd\u62ff\u51fa\u6765\n    for (var i = 0; i < sessionStorage.length; i++) {\n        var key = sessionStorage.key(i);\n        if (key.indexOf(\"_data\") !== -1) {\n            finalHTML += sessionStorage.getItem(key);\n        }\n    }\n    \n    \/\/ \u6e32\u67d3\u5230\u9875\u9762\n    jQuery(\"#all-products-summary\").html(finalHTML || \"Your cart is empty.\");\n\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\ud83d\uded2 Your Shopping Cart Loading...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":4,"QuestionText_Unsafe":"<div style=\"margin-top: 20px; padding: 15px; border: 2px solid #2d70b3; border-radius: 10px; background: #fff; min-height: 100px;\">\n    <strong style=\"color: #2d70b3; font-size: 18px;\">\ud83d\uded2 Your Shopping Cart<\/strong>\n    <hr>\n    <div id=\"real-time-cart\" style=\"display: flex; flex-wrap: wrap; gap: 10px;\">\n        <span style=\"color: #ccc;\">Loading...<\/span>\n    <\/div>\n<\/div>","DataExportTag":"Q67","QuestionID":"QID67"}},{"SurveyID":"SV_0resoTRPoWFgHzw","Element":"SQ","PrimaryAttribute":"QID68","SecondaryAttribute":"Bread","TertiaryAttribute":null,"Payload":{"QuestionText":"Bread","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n \/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var qid = this.questionId;\n    var currentBlock = \"REC 1+DELAY 1\";\n    var waitMs = 15000;\n    var maxItems = 6;\n    var that = this;\n\n    \/\/ ===== 1. \u5168\u5c40\u8d2d\u7269\u8f66 =====\n    if (!window.globalCart) {\n        window.globalCart = {};\n    }\n    if (!window.globalCart[currentBlock]) {\n        window.globalCart[currentBlock] = {};\n    }\n\n    \/\/ ===== 2. block\u7ea7\u5171\u4eab\u72b6\u6001 =====\n    if (!window.blockSelectionState) {\n        window.blockSelectionState = {};\n    }\n    if (!window.blockSelectionState[currentBlock]) {\n        window.blockSelectionState[currentBlock] = {\n            locked: false,\n            timer: null,\n            remaining: 0\n        };\n    }\n\n    var blockState = window.blockSelectionState[currentBlock];\n\n    \/\/ ===== 3. \u5012\u8ba1\u65f6\u63d0\u793a\u533a\u57df =====\n    if (jQuery(\"#\" + qid + \"_waitMsg\").length === 0) {\n        jQuery(\"#\" + qid).append(\n            \"<div id='\" + qid + \"_waitMsg' style='margin-top:10px; font-weight:bold; color:#cc0000;'><\/div>\"\n        );\n    }\n\n    \/\/ ===== 4. block\u7ea7\u7edf\u8ba1\uff1a\u6574\u4e2a\u9875\u9762\/\u6574\u4e2ablock\u603b\u5171\u6700\u591a\u90096\u4e2a =====\n    function getAllCheckboxesInBlock() {\n        return jQuery(\".QuestionOuter input[type='checkbox']\");\n    }\n\n    function getSelectedCountInBlock() {\n        return getAllCheckboxesInBlock().filter(\":checked\").length;\n    }\n\n    function disableUncheckedInWholeBlock() {\n        getAllCheckboxesInBlock().each(function() {\n            var $input = jQuery(this);\n            if (!$input.is(\":checked\")) {\n                $input.prop(\"disabled\", true);\n                $input.closest(\"li, .Choice\").css({\n                    \"pointer-events\": \"none\",\n                    \"opacity\": \"0.6\"\n                });\n            }\n        });\n    }\n\n    function enableAvailableInWholeBlock() {\n        var totalSelected = getSelectedCountInBlock();\n\n        getAllCheckboxesInBlock().each(function() {\n            var $input = jQuery(this);\n\n            if (totalSelected >= maxItems && !$input.is(\":checked\")) {\n                $input.prop(\"disabled\", true);\n                $input.closest(\"li, .Choice\").css({\n                    \"pointer-events\": \"none\",\n                    \"opacity\": \"0.5\"\n                });\n            } else {\n                $input.prop(\"disabled\", false);\n                $input.closest(\"li, .Choice\").css({\n                    \"pointer-events\": \"auto\",\n                    \"opacity\": \"1\"\n                });\n            }\n        });\n    }\n\n    function updateAllWaitMessages(msg) {\n        jQuery(\"[id$='_waitMsg']\").html(msg || \"\");\n    }\n\n    \/\/ ===== 5. \u8d2d\u7269\u8f66\u66f4\u65b0 =====\n    function updateCartDisplay() {\n        var selectedChoices = that.getSelectedChoices() || [];\n        var currentQuestionHtml = \"\";\n\n        for (var i = 0; i < selectedChoices.length; i++) {\n            var cid = selectedChoices[i];\n            var $label = jQuery(\"#\" + qid + \" label[for='QR~\" + qid + \"~\" + cid + \"']\");\n            var recodeNum = $label.text().replace(\/\\s+\/g, '').trim();\n            var imgSrc = $label.find(\"img\").attr(\"src\");\n\n            if (recodeNum) {\n                currentQuestionHtml +=\n                    \"<div class='live-cart-item' style='display:inline-block; width:90px; text-align:center; border:1px solid #eee; padding:5px; border-radius:5px; margin:5px; vertical-align:top;'>\" +\n                        \"<div style='font-weight:bold; color:#333; font-size:14px;'>\" + recodeNum + \"<\/div>\" +\n                        (imgSrc ? \"<img src='\" + imgSrc + \"' style='width:100%; height:auto; display:block; margin:0 auto;'>\" : \"\") +\n                    \"<\/div>\";\n            }\n        }\n\n        window.globalCart[currentBlock][qid] = currentQuestionHtml;\n\n        var finalHtml = \"\";\n        Object.keys(window.globalCart[currentBlock]).forEach(function(key) {\n            finalHtml += window.globalCart[currentBlock][key];\n        });\n\n        if (!finalHtml) {\n            jQuery(\"#real-time-cart\").html(\"<span style='color:#ccc;'>No items selected<\/span>\");\n        } else {\n            jQuery(\"#real-time-cart\").html(finalHtml);\n        }\n\n        Qualtrics.SurveyEngine.setEmbeddedData(\"shopping_cart\", finalHtml);\n    }\n\n    \/\/ ===== 6. \u5ef6\u8fdf\u9501\u5b9a =====\n    function startBlockWaitLock() {\n        if (blockState.locked) return;\n\n        blockState.locked = true;\n        blockState.remaining = Math.floor(waitMs \/ 1000);\n\n        disableUncheckedInWholeBlock();\n        that.disableNextButton();\n\n        updateAllWaitMessages(\n            \"Please wait \" + blockState.remaining + \" seconds before selecting the next item.\"\n        );\n        jQuery(\"#NextButton\").val(\"Please wait \" + blockState.remaining + \"s\");\n\n        if (blockState.timer) {\n            clearInterval(blockState.timer);\n        }\n\n        blockState.timer = setInterval(function() {\n            blockState.remaining--;\n\n            if (blockState.remaining > 0) {\n                updateAllWaitMessages(\n                    \"Please wait \" + blockState.remaining + \" seconds before selecting the next item.\"\n                );\n                jQuery(\"#NextButton\").val(\"Please wait \" + blockState.remaining + \"s\");\n            } else {\n                clearInterval(blockState.timer);\n                blockState.timer = null;\n                blockState.locked = false;\n\n                updateAllWaitMessages(\"\");\n                jQuery(\"#NextButton\").val(\"Next\");\n                that.enableNextButton();\n\n                enableAvailableInWholeBlock();\n            }\n        }, 1000);\n    }\n\n    \/\/ ===== 7. \u52fe\u9009\u4e8b\u4ef6\uff1a\u603b\u5171\u6700\u591a6\u4e2a + \u5ef6\u8fdf =====\n    \/\/ \u53ea\u7ed1\u5b9a\u5f53\u524d\u9898\u76ee\u7684checkbox\uff0c\u907f\u514d\u540e\u52a0\u8f7d\u9898\u76ee\u628a\u524d\u9762\u9898\u76ee\u7684\u4e8b\u4ef6\u89e3\u7ed1\u6389\n    jQuery(\"#\" + qid + \" input[type='checkbox']\")\n        .off(\"change.blockwaitlimit\")\n        .on(\"change.blockwaitlimit\", function() {\n            var totalSelected = getSelectedCountInBlock();\n\n            if (totalSelected > maxItems) {\n                jQuery(this).prop(\"checked\", false);\n                alert(\"You can select up to 6 items only.\");\n                updateCartDisplay();\n                enableAvailableInWholeBlock();\n                return;\n            }\n\n            \/\/ \u53ea\u66f4\u65b0\u5f53\u524d\u9898\u5bf9\u5e94\u7684\u8d2d\u7269\u8f66\n            updateCartDisplay();\n\n            if (jQuery(this).is(\":checked\")) {\n                startBlockWaitLock();\n            } else {\n                if (!blockState.locked) {\n                    enableAvailableInWholeBlock();\n                }\n            }\n        });\n\n    \/\/ \u521d\u59cb\u6267\u884c\n    updateCartDisplay();\n\n    if (blockState.locked) {\n        disableUncheckedInWholeBlock();\n        updateAllWaitMessages(\n            \"Please wait \" + blockState.remaining + \" seconds before selecting the next item.\"\n        );\n        jQuery(\"#NextButton\").val(\"Please wait \" + blockState.remaining + \"s\");\n        that.disableNextButton();\n    } else {\n        enableAvailableInWholeBlock();\n    }\n});\n\n\n\/* ===== \u63a8\u8350\u9ad8\u4eae\u903b\u8f91 ===== *\/\nQualtrics.SurveyEngine.addOnReady(function() {\n    var q = this;\n    var qid = this.questionId;\n    var container = document.getElementById(qid);\n    if (!container) return;\n\n    \/\/ \u5982\u679c P1 \u4e0d\u662f Q39\uff0c\u8fd9\u91cc\u6539\u6210\u771f\u6b63\u7684 QID\n    var p1Raw = \"${q:\/\/QID39\/SelectedChoicesRecode}\";\n\n    var p1Codes = p1Raw\n        .split(\",\")\n        .map(function(x) { return String(x).trim(); })\n        .filter(function(x) { return x !== \"\"; });\n\n    if (!p1Codes.length) return;\n\n    function runRecommend() {\n        var found = 0;\n        var inputs = container.querySelectorAll('input[type=\"checkbox\"], input[type=\"radio\"]');\n\n        inputs.forEach(function(input) {\n            var inputId = input.id || \"\";\n            if (!inputId) return;\n\n            var choiceId = inputId.split(\"~\").pop();\n            if (!choiceId) return;\n\n            var recode = \"\";\n            try {\n                recode = String(q.getChoiceRecodeValue(choiceId)).trim();\n            } catch (e) {\n                return;\n            }\n\n            var label = container.querySelector('label[for=\"' + inputId + '\"]');\n            if (!label) return;\n\n            label.style.outline = \"\";\n            label.style.background = \"\";\n            label.style.borderRadius = \"\";\n            label.style.boxShadow = \"\";\n            label.style.position = \"relative\";\n\n            var oldTag = label.querySelector(\".recommended-tag\");\n            if (oldTag) oldTag.remove();\n\n            if (p1Codes.indexOf(recode) !== -1) {\n                found++;\n\n                label.style.outline = \"5px solid #2F80ED\";\n                label.style.background = \"#EAF3FF\";\n                label.style.borderRadius = \"12px\";\n                label.style.boxShadow = \"0 0 0 4px rgba(47,128,237,0.25)\";\n                label.style.position = \"relative\";\n\n                var tag = document.createElement(\"div\");\n                tag.className = \"recommended-tag\";\n                tag.innerHTML = \"Recommended\";\n                tag.style.position = \"absolute\";\n                tag.style.top = \"4px\";\n                tag.style.left = \"4px\";\n                tag.style.background = \"#2F80ED\";\n                tag.style.color = \"white\";\n                tag.style.fontSize = \"12px\";\n                tag.style.fontWeight = \"bold\";\n                tag.style.padding = \"2px 6px\";\n                tag.style.borderRadius = \"8px\";\n                tag.style.zIndex = \"9999\";\n\n                label.appendChild(tag);\n            }\n        });\n\n        return found > 0;\n    }\n\n    var tries = 0;\n    var timer = setInterval(function() {\n        tries++;\n        var ok = runRecommend();\n        if (ok || tries >= 20) {\n            clearInterval(timer);\n        }\n    }, 500);\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n \/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"QuestionType":"MC","Selector":"MAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Bread","Choices":{"1":{"Display":"101","GraphicSize":[100,null],"Image":{"Display":"Bread 1","ImageLocation":"IM_QfgseS9hqtuWvTG"}},"2":{"Display":"102","GraphicSize":[100,null],"Image":{"Display":"Bread 2","ImageLocation":"IM_yIMYU0u8MiMo56E"}},"3":{"Display":"103","GraphicSize":[100,null],"Image":{"Display":"Bread 3","ImageLocation":"IM_u4UZwibyW6KEHJA"}},"4":{"Display":"104","GraphicSize":[100,null],"Image":{"Display":"Bread 6","ImageLocation":"IM_SdA0m3Y1Yaa1QPi"}},"37":{"Display":"105","GraphicSize":[100,null],"Image":{"Display":"Bread 8","ImageLocation":"IM_NkcQ6foxfe2zFnZ"}}},"ChoiceOrder":[1,2,3,4,"37"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"RecodeValues":{"1":"101","2":"102","3":"103","4":"104","37":"105"},"GradingData":[],"Language":[],"NextChoiceId":38,"NextAnswerId":4,"QuestionText_Unsafe":"Bread","DataExportTag":"Q68","QuestionID":"QID68"}},{"SurveyID":"SV_0resoTRPoWFgHzw","Element":"SQ","PrimaryAttribute":"QID69","SecondaryAttribute":"Cheese","TertiaryAttribute":null,"Payload":{"QuestionText":"Cheese","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n \/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var qid = this.questionId;\n    var currentBlock = \"REC 1+DELAY 1\";\n    var waitMs = 15000;\n    var maxItems = 6;\n    var that = this;\n\n    \/\/ ===== 1. \u5168\u5c40\u8d2d\u7269\u8f66 =====\n    if (!window.globalCart) {\n        window.globalCart = {};\n    }\n    if (!window.globalCart[currentBlock]) {\n        window.globalCart[currentBlock] = {};\n    }\n\n    \/\/ ===== 2. block\u7ea7\u5171\u4eab\u72b6\u6001 =====\n    if (!window.blockSelectionState) {\n        window.blockSelectionState = {};\n    }\n    if (!window.blockSelectionState[currentBlock]) {\n        window.blockSelectionState[currentBlock] = {\n            locked: false,\n            timer: null,\n            remaining: 0\n        };\n    }\n\n    var blockState = window.blockSelectionState[currentBlock];\n\n    \/\/ ===== 3. \u5012\u8ba1\u65f6\u63d0\u793a\u533a\u57df =====\n    if (jQuery(\"#\" + qid + \"_waitMsg\").length === 0) {\n        jQuery(\"#\" + qid).append(\n            \"<div id='\" + qid + \"_waitMsg' style='margin-top:10px; font-weight:bold; color:#cc0000;'><\/div>\"\n        );\n    }\n\n    \/\/ ===== 4. block\u7ea7\u7edf\u8ba1\uff1a\u6574\u4e2a\u9875\u9762\/\u6574\u4e2ablock\u603b\u5171\u6700\u591a\u90096\u4e2a =====\n    function getAllCheckboxesInBlock() {\n        return jQuery(\".QuestionOuter input[type='checkbox']\");\n    }\n\n    function getSelectedCountInBlock() {\n        return getAllCheckboxesInBlock().filter(\":checked\").length;\n    }\n\n    function disableUncheckedInWholeBlock() {\n        getAllCheckboxesInBlock().each(function() {\n            var $input = jQuery(this);\n            if (!$input.is(\":checked\")) {\n                $input.prop(\"disabled\", true);\n                $input.closest(\"li, .Choice\").css({\n                    \"pointer-events\": \"none\",\n                    \"opacity\": \"0.6\"\n                });\n            }\n        });\n    }\n\n    function enableAvailableInWholeBlock() {\n        var totalSelected = getSelectedCountInBlock();\n\n        getAllCheckboxesInBlock().each(function() {\n            var $input = jQuery(this);\n\n            if (totalSelected >= maxItems && !$input.is(\":checked\")) {\n                $input.prop(\"disabled\", true);\n                $input.closest(\"li, .Choice\").css({\n                    \"pointer-events\": \"none\",\n                    \"opacity\": \"0.5\"\n                });\n            } else {\n                $input.prop(\"disabled\", false);\n                $input.closest(\"li, .Choice\").css({\n                    \"pointer-events\": \"auto\",\n                    \"opacity\": \"1\"\n                });\n            }\n        });\n    }\n\n    function updateAllWaitMessages(msg) {\n        jQuery(\"[id$='_waitMsg']\").html(msg || \"\");\n    }\n\n    \/\/ ===== 5. \u8d2d\u7269\u8f66\u66f4\u65b0 =====\n    function updateCartDisplay() {\n        var selectedChoices = that.getSelectedChoices() || [];\n        var currentQuestionHtml = \"\";\n\n        for (var i = 0; i < selectedChoices.length; i++) {\n            var cid = selectedChoices[i];\n            var $label = jQuery(\"#\" + qid + \" label[for='QR~\" + qid + \"~\" + cid + \"']\");\n            var recodeNum = $label.text().replace(\/\\s+\/g, '').trim();\n            var imgSrc = $label.find(\"img\").attr(\"src\");\n\n            if (recodeNum) {\n                currentQuestionHtml +=\n                    \"<div class='live-cart-item' style='display:inline-block; width:90px; text-align:center; border:1px solid #eee; padding:5px; border-radius:5px; margin:5px; vertical-align:top;'>\" +\n                        \"<div style='font-weight:bold; color:#333; font-size:14px;'>\" + recodeNum + \"<\/div>\" +\n                        (imgSrc ? \"<img src='\" + imgSrc + \"' style='width:100%; height:auto; display:block; margin:0 auto;'>\" : \"\") +\n                    \"<\/div>\";\n            }\n        }\n\n        window.globalCart[currentBlock][qid] = currentQuestionHtml;\n\n        var finalHtml = \"\";\n        Object.keys(window.globalCart[currentBlock]).forEach(function(key) {\n            finalHtml += window.globalCart[currentBlock][key];\n        });\n\n        if (!finalHtml) {\n            jQuery(\"#real-time-cart\").html(\"<span style='color:#ccc;'>No items selected<\/span>\");\n        } else {\n            jQuery(\"#real-time-cart\").html(finalHtml);\n        }\n\n        Qualtrics.SurveyEngine.setEmbeddedData(\"shopping_cart\", finalHtml);\n    }\n\n    \/\/ ===== 6. \u5ef6\u8fdf\u9501\u5b9a =====\n    function startBlockWaitLock() {\n        if (blockState.locked) return;\n\n        blockState.locked = true;\n        blockState.remaining = Math.floor(waitMs \/ 1000);\n\n        disableUncheckedInWholeBlock();\n        that.disableNextButton();\n\n        updateAllWaitMessages(\n            \"Please wait \" + blockState.remaining + \" seconds before selecting the next item.\"\n        );\n        jQuery(\"#NextButton\").val(\"Please wait \" + blockState.remaining + \"s\");\n\n        if (blockState.timer) {\n            clearInterval(blockState.timer);\n        }\n\n        blockState.timer = setInterval(function() {\n            blockState.remaining--;\n\n            if (blockState.remaining > 0) {\n                updateAllWaitMessages(\n                    \"Please wait \" + blockState.remaining + \" seconds before selecting the next item.\"\n                );\n                jQuery(\"#NextButton\").val(\"Please wait \" + blockState.remaining + \"s\");\n            } else {\n                clearInterval(blockState.timer);\n                blockState.timer = null;\n                blockState.locked = false;\n\n                updateAllWaitMessages(\"\");\n                jQuery(\"#NextButton\").val(\"Next\");\n                that.enableNextButton();\n\n                enableAvailableInWholeBlock();\n            }\n        }, 1000);\n    }\n\n    \/\/ ===== 7. \u52fe\u9009\u4e8b\u4ef6\uff1a\u603b\u5171\u6700\u591a6\u4e2a + \u5ef6\u8fdf =====\n    \/\/ \u53ea\u7ed1\u5b9a\u5f53\u524d\u9898\u76ee\u7684checkbox\uff0c\u907f\u514d\u540e\u52a0\u8f7d\u9898\u76ee\u628a\u524d\u9762\u9898\u76ee\u7684\u4e8b\u4ef6\u89e3\u7ed1\u6389\n    jQuery(\"#\" + qid + \" input[type='checkbox']\")\n        .off(\"change.blockwaitlimit\")\n        .on(\"change.blockwaitlimit\", function() {\n            var totalSelected = getSelectedCountInBlock();\n\n            if (totalSelected > maxItems) {\n                jQuery(this).prop(\"checked\", false);\n                alert(\"You can select up to 6 items only.\");\n                updateCartDisplay();\n                enableAvailableInWholeBlock();\n                return;\n            }\n\n            \/\/ \u53ea\u66f4\u65b0\u5f53\u524d\u9898\u5bf9\u5e94\u7684\u8d2d\u7269\u8f66\n            updateCartDisplay();\n\n            if (jQuery(this).is(\":checked\")) {\n                startBlockWaitLock();\n            } else {\n                if (!blockState.locked) {\n                    enableAvailableInWholeBlock();\n                }\n            }\n        });\n\n    \/\/ \u521d\u59cb\u6267\u884c\n    updateCartDisplay();\n\n    if (blockState.locked) {\n        disableUncheckedInWholeBlock();\n        updateAllWaitMessages(\n            \"Please wait \" + blockState.remaining + \" seconds before selecting the next item.\"\n        );\n        jQuery(\"#NextButton\").val(\"Please wait \" + blockState.remaining + \"s\");\n        that.disableNextButton();\n    } else {\n        enableAvailableInWholeBlock();\n    }\n});\n\n\n\/* ===== \u63a8\u8350\u9ad8\u4eae\u903b\u8f91 ===== *\/\nQualtrics.SurveyEngine.addOnReady(function() {\n    var q = this;\n    var qid = this.questionId;\n    var container = document.getElementById(qid);\n    if (!container) return;\n\n    \/\/ \u5982\u679c P1 \u4e0d\u662f Q39\uff0c\u8fd9\u91cc\u6539\u6210\u771f\u6b63\u7684 QID\n    var p1Raw = \"${q:\/\/QID39\/SelectedChoicesRecode}\";\n\n    var p1Codes = p1Raw\n        .split(\",\")\n        .map(function(x) { return String(x).trim(); })\n        .filter(function(x) { return x !== \"\"; });\n\n    if (!p1Codes.length) return;\n\n    function runRecommend() {\n        var found = 0;\n        var inputs = container.querySelectorAll('input[type=\"checkbox\"], input[type=\"radio\"]');\n\n        inputs.forEach(function(input) {\n            var inputId = input.id || \"\";\n            if (!inputId) return;\n\n            var choiceId = inputId.split(\"~\").pop();\n            if (!choiceId) return;\n\n            var recode = \"\";\n            try {\n                recode = String(q.getChoiceRecodeValue(choiceId)).trim();\n            } catch (e) {\n                return;\n            }\n\n            var label = container.querySelector('label[for=\"' + inputId + '\"]');\n            if (!label) return;\n\n            label.style.outline = \"\";\n            label.style.background = \"\";\n            label.style.borderRadius = \"\";\n            label.style.boxShadow = \"\";\n            label.style.position = \"relative\";\n\n            var oldTag = label.querySelector(\".recommended-tag\");\n            if (oldTag) oldTag.remove();\n\n            if (p1Codes.indexOf(recode) !== -1) {\n                found++;\n\n                label.style.outline = \"5px solid #2F80ED\";\n                label.style.background = \"#EAF3FF\";\n                label.style.borderRadius = \"12px\";\n                label.style.boxShadow = \"0 0 0 4px rgba(47,128,237,0.25)\";\n                label.style.position = \"relative\";\n\n                var tag = document.createElement(\"div\");\n                tag.className = \"recommended-tag\";\n                tag.innerHTML = \"Recommended\";\n                tag.style.position = \"absolute\";\n                tag.style.top = \"4px\";\n                tag.style.left = \"4px\";\n                tag.style.background = \"#2F80ED\";\n                tag.style.color = \"white\";\n                tag.style.fontSize = \"12px\";\n                tag.style.fontWeight = \"bold\";\n                tag.style.padding = \"2px 6px\";\n                tag.style.borderRadius = \"8px\";\n                tag.style.zIndex = \"9999\";\n\n                label.appendChild(tag);\n            }\n        });\n\n        return found > 0;\n    }\n\n    var tries = 0;\n    var timer = setInterval(function() {\n        tries++;\n        var ok = runRecommend();\n        if (ok || tries >= 20) {\n            clearInterval(timer);\n        }\n    }, 500);\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n \/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionType":"MC","Selector":"MAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Cheese","Choices":{"1":{"Display":"201","GraphicSize":[100,null],"Image":{"Display":"Cheese3","ImageLocation":"IM_MPRH9bNNXDuw5Zf"}},"2":{"Display":"202","GraphicSize":[100,null],"Image":{"Display":"Cheese6","ImageLocation":"IM_4mbuO6bR0sdh5Rp"}},"3":{"Display":"203","GraphicSize":[100,null],"Image":{"Display":"Cheese1","ImageLocation":"IM_6kd6os7IaA6BdFM"}},"4":{"Display":"204","GraphicSize":[100,null],"Image":{"Display":"Cheese2","ImageLocation":"IM_KEmm6QcoMpJcYGk"}},"5":{"Display":"205","GraphicSize":[100,null],"Image":{"Display":"Cheese9","ImageLocation":"IM_LwLtKXuY9SI3SuS"}}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"RecodeValues":{"1":"201","2":"202","3":"203","4":"204","5":"205"},"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionText_Unsafe":"Cheese","DataExportTag":"Q69","QuestionID":"QID69"}},{"SurveyID":"SV_0resoTRPoWFgHzw","Element":"SQ","PrimaryAttribute":"QID7","SecondaryAttribute":"Which of the following products would you like to add to your cart? You can choose no more than 6...","TertiaryAttribute":null,"Payload":{"QuestionText":"Which of the following products would you like to add to your cart? You can choose no more than 6 products","DefaultChoices":false,"DataExportTag":"P1","QuestionID":"QID7","QuestionType":"MC","Selector":"MACOL","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","NumColumns":5},"QuestionDe