9 ---\n            \/\/ \u8fd9\u4f1a\u76f4\u63a5\u62ff\u5230\u4f60\u8bbe\u7f6e\u7684 101, 401 \u7b49\u6570\u5b57\uff0c\u7edd\u5bf9\u4e0d\u4f1a\u51fa\u73b0 true\n            var recodeNum = jQuery(\"#\" + qid + \" label[for='QR~\" + qid + \"~\" + cid + \"']\").text().replace(\/\\s+\/g, '').trim();\n            \n            \/\/ \u6293\u53d6\u56fe\u7247\u94fe\u63a5\n            var imgSrc = jQuery(\"#\" + qid + \" label[for='QR~\" + qid + \"~\" + cid + \"'] img\").attr('src');\n\n            if (recodeNum) {\n                var itemHTML = \"<div class='live-cart-item' style='display:inline-block; width:100px; text-align:center; margin:5px; border:1px solid #ddd; padding:5px; background:#fff; vertical-align:top;'>\" +\n                               \"<div style='color:black !important; font-weight:bold; font-size:14px; display:block !important;'>\" + recodeNum + \"<\/div>\" +\n                               (imgSrc ? \"<img src='\" + imgSrc + \"' style='width:70px; height:auto; display:block; margin:0 auto;'>\" : \"\") +\n                               \"<\/div>\";\n                currentPageItems.push(itemHTML);\n            }\n        }\n\n        \/\/ 1. \u5904\u7406\u672c\u9875\u5b9e\u65f6\u663e\u793a\n        \/\/ \u83b7\u53d6\u4e4b\u524d\u9875\u9762\u5b58\u4e0b\u7684\u6570\u636e (\u8de8\u9875\u7d2f\u52a0)\n        var previousData = Qualtrics.SurveyEngine.getEmbeddedData('history_cart') || \"\";\n        var totalHTML = previousData + currentPageItems.join(\"\");\n\n        \/\/ 2. \u6e32\u67d3\u5230\u9875\u9762\u5bb9\u5668\n        jQuery(\"#real-time-cart\").html(totalHTML);\n\n        \/\/ 3. \u540c\u65f6\u66f4\u65b0\u540e\u53f0\u53d8\u91cf\n        Qualtrics.SurveyEngine.setEmbeddedData(varName, totalHTML);\n    };\n});\n\n\/\/ \u5f53\u70b9\u51fb\u201c\u4e0b\u4e00\u6b65\u201d\u65f6\uff0c\u628a\u5f53\u524d\u786e\u5b9a\u7684\u5168\u91cf\u6570\u636e\u5b58\u4e3a\u201c\u5386\u53f2\u8bb0\u5f55\u201d\nQualtrics.SurveyEngine.addOnPageSubmit(function() {\n    var 