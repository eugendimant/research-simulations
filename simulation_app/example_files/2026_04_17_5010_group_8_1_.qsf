+ \"~\" + cid + \"'] img\").attr('src');\n\n            if (recodeNum) {\n                var itemHTML =\n                    \"<div class='live-cart-item' style='display:inline-block; width:100px; text-align:center; margin:5px; border:1px solid #ddd; padding:5px; background:#fff; vertical-align:top;'>\" +\n                        \"<div style='color:black !important; font-weight:bold; font-size:14px; display:block !important;'>\" + recodeNum + \"<\/div>\" +\n                        (imgSrc ? \"<img src='\" + imgSrc + \"' style='width:70px; height:auto; display:block; margin:0 auto;'>\" : \"\") +\n                    \"<\/div>\";\n\n                currentPageItems.push(itemHTML);\n            }\n        }\n\n        var previousData = Qualtrics.SurveyEngine.getEmbeddedData('history_cart') || \"\";\n        var totalHTML = previousData + currentPageItems.join(\"\");\n\n        jQuery(\"#real-time-cart\").html(totalHTML);\n        Qualtrics.SurveyEngine.setEmbeddedData(varName, totalHTML);\n    }\n\n    function enableAvailableOptions() {\n        var selectedChoices = that.getSelectedChoices();\n        var selectedCount = selectedChoices.length;\n\n        jQuery(\"#\" + qid + \" input[type='checkbox']\").each(function() {\n            var $input = jQuery(this);\n\n            if (selectedCount >= maxItems) {\n                \/\/ \u5230\u4e866\u4e2a\u540e\uff0c\u672a\u9009\u4e2d\u7684\u4e0d\u80fd\u518d\u9009\n                if (!$input.is(\":checked\")) {\n                    $input.prop(\"disabled\", true);\n                    $input.closest(\"li, .Choice\").css({\n                        \"pointer-events\": \"none\",\n                        \"opacity\": \"0.5\"\n                    });\n                } else {\n                    $input.prop(\"disabled\", false);\n                    $input.closest(\"li, .Choice\").css({\n                        \"pointer-events\": \"auto\",\n                        \"opacity\": \"1\"\n                    });\n                }\n            } else {\n                \/\/ \u6ca1\u52306\u4e2a\uff0c\u5168\u90e8\u53ef\u9009\n                $input.prop(\"disabled\", false);\n                $input.closest(\"li, .Choice\").css({\n                    \"pointer-events\": \"auto\",\n                    \"opacity\": \"1\"\n                });\n            }\n        });\n    }\n\n    this.questionclick = function(event, element) {\n        updateCartDisplay();\n        enableAvailableOptions();\n    };\n\n    \/\/ \u9875\u9762\u52a0\u8f7d\u65f6\u5148\u6267\u884c\u4e00\u6b21\n    updateCartDisplay();\n    enableAvailableOptions();\n});\n\nQualtrics.SurveyEngine.addOnPageSubmit(function() {\n    var currentTotal = Qualtrics.SurveyEngine.getEmbeddedData('shopping_cart');\n    Qualtrics.SurveyEngine.setEmbeddedData('history_cart', currentTotal);\n});","DefaultChoices":false,"QuestionType":"MC","Selector":"MACOL","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","NumColumns":5},"QuestionDescription":"Which of the following products would you like to add to your cart? You can choose no more than 6...","Choices":{"1":{"Display":"101","GraphicSize":[100,null],"Image":{"Display":"Bread 1","ImageLocation":"IM_QfgseS9hqtuWvTG"}},"2":{"Display":"104","GraphicSize":[100,null],"Image":{"Display":"Bread 6","ImageLocation":"IM_SdA0m3Y1Yaa1QPi"}},"3":{"Display":"105","GraphicSize":[100,null],"Image":{"Display":"Bread 8","ImageLocation":"IM_NkcQ6foxfe2zFnZ"}},"6":{"Display":"201","GraphicSize":[100,null],"Image":{"Display":"Cheese3","ImageLocation":"IM_MPRH9bNNXDuw5Zf"}},"7":{"Display":"202","GraphicSize":[100,null],"Image":{"Display":"Cheese6","ImageLocation":"IM_4mbuO6bR0sdh5Rp"}},"8":{"Display":"204","GraphicSize":[100,null],"Image":{"Display":"Cheese2","ImageLocation":"IM_KEmm6QcoMpJcYGk"}},"11":{"Display":"301","GraphicSize":[100,null],"Image":{"Display":"Chips1","ImageLocation":"IM_K4xh5naGvcs5pad"}},"12":{"Display":"302","GraphicSi