essionStorage.length; i++) {\n        var key = sessionStorage.key(i);\n        if (key.indexOf(\"_data\") !== -1) {\n            finalHTML += sessionStorage.getItem(key);\n        }\n    }\n    \n    \/\/ \u6e32\u67d3\u5230\u9875\u9762\n    jQuery(\"#all-products-summary\").html(finalHTML || \"Your cart is empty.\");\n    \n    \/\/ \u540c\u65f6\u540c\u6b65\u7ed9\u540e\u53f0\u53d8\u91cf\uff0c\u4ee5\u9632\u4f60\u4ee5\u540e\u8981\u5bfc\u51fa\u6570\u636e\n    Qualtrics.SurveyEngine.setEmbeddedData('shopping_cart', finalHTML);\n});","DefaultChoices":false,"DataExportTag":"Q31","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\ud83d\uded2 Your Shopping Cart Loading...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":4,"QuestionID":"QID33"}},{"SurveyID":"SV_0resoTRPoWFgHzw","Element":"SQ","PrimaryAttribute":"QID34","SecondaryAttribute":"Bread","TertiaryAttribute":null,"Payload":{"QuestionText":"Bread","QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var qid = this.questionId;\n    \n    \/\/ 1. \u521d\u59cb\u5316\u5168\u5c40\u8d2d\u7269\u8f66\u5bf9\u8c61\uff08\u5982\u679c\u4e0d\u5b58\u5728\uff09\n    if (!window.globalCart) {\n        window.globalCart = {};\n    }\n\n    \/\/ 2. \u76d1\u542c\u9009\u9879\u53d8\u5316\n    this.questionclick = function(event, element) {\n        var selectedChoices = this.getSelectedChoices();\n        var currentQuestionHtml = \"\";\n\n        \/\/ 3. \u904d\u5386\u5f53\u524d\u95ee\u9898\u7684\u9009\u4e2d\u9879\n        for (var i = 0; i < selectedChoices.length; i++) {\n            var cid = selectedChoices[i];\n            \n            \/\/ --- \u6838\u5fc3\u4fee\u6539\uff1a\u76f4\u63a5\u4ece Label \u4e2d\u6293\u53d6\u6587\u5b57\u6570\u5b57 (\u5982 101, 401) ---\n            \/\/ \u8fd9\u79cd\u65b9\u5f0f\u6700\u7a33\uff0c\u7edd\u5bf9\u4e0d\u4f1a\u8fd4\u56de \"true\"\n            var recodeNum = jQuery(\"#\" + qid + \" label[for='QR~\" + qid + \"~\" + cid + \"']\").text().replace(\/\\s+\/g, '').trim();\n            \n            \/\/ \u6293\u53d6\u56fe\u7247\u5730\u5740\n            var imgSrc = jQuery(\"#\" + qid + \" label[for='QR~\" + qid + \"~\" + cid + \"'] img\").attr('src');\n\n            if (recodeNum) {\n                currentQuestionHtml += \"<div class='live-cart-item' style='display:inline-block; width:90px; text-align:center; border:1px solid #eee; padding:5px; border-radius:5px; margin:5px; vertical-align:top;'>\" +\n                    \"<div style='font-weight:bold; color:#333; font-size:14px;'>\" + recodeNum + \"<\/div>\" +\n                    (imgSrc ? \"<img src='\" + imgSrc + \"' style='width:100%; height:auto; display:block; margin:0 auto;'>\" : \"\") +\n                    \"<\/div>\";\n            }\n        }\n\n        \/\/ 4. \u5c06\u5f53\u524d\u95ee\u9898\u7684 HTML \u5b58\u5165\u5168\u5c40\u5bf9\u8c61\u4e2d\n        window.globalCart[qid] = currentQuestionHtml;\n\n        \/\/ 5. \u6c47\u603b\u5e76\u6e32\u67d3\n        updateCartDisplay();\n    };\n\n    function updateCartDisplay() {\n        var finalHtml = \"\";\n        \/\/ \u6c47\u603b\u6240\u6709 QID \u5b58\u50a8\u7684\u5185\u5bb9\n        Object.keys(window.globalCart).forEach(function(key) {\n            finalHtml += window.globalCart[key];\n        });\n\n        if (finalHtml === \"\" || finalHtml === null) {\n            jQuery(\"#real-time-cart\").html(\"<span style='color: #ccc;'>No items selected<\/span>\");\n        } else {\n            jQuery(\"#real-time-cart\").html(finalHtml);\n        }\n\n        \/\/ 6. \u66f4\u65b0\u540e\u53f0\u53d8\u91cf\u4ee5\u4fbf\u8de8\u9875\u663e\u793a\n        Qualtrics.SurveyEngine.setEmbeddedData('shopping_cart', finalHtml);\n    }\n});","DefaultChoices":false,"DataExportTag":"Q32","QuestionType":"MC","Selector":"MAHR","SubSelector":"TX","DataVisibility":{"Private"