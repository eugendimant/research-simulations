{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_doI6kI07Xdej46G","Element":"QC","PrimaryAttribute":"Survey Question Count","SecondaryAttribute":"5","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_doI6kI07Xdej46G","Element":"QG","PrimaryAttribute":"QG_dwjOBtVA20xGuGE","SecondaryAttribute":"Default Quota Group","TertiaryAttribute":null,"Payload":{"ID":"QG_dwjOBtVA20xGuGE","Name":"Default Quota Group","Selected":true,"MultipleMatch":"PlaceInAll","Public":false,"Quotas":[]}},{"SurveyID":"SV_doI6kI07Xdej46G","Element":"QGO","PrimaryAttribute":"QGO_QuotaGroupOrder","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":["QG_dwjOBtVA20xGuGE"]},{"SurveyID":"SV_doI6kI07Xdej46G","Element":"RS","PrimaryAttribute":"RS_01bnh83B3beBACW","SecondaryAttribute":"Default Response Set","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_doI6kI07Xdej46G","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_doI6kI07Xdej46G","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"true","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":"None","SurveyTermination":"DefaultMessage","Header":"","Footer":"","ProgressBarDisplay":"None","PartialData":"+1 week","ValidationMessage":"","PreviousButton":" \u2190 ","NextButton":" \u2192 ","SurveyTitle":"Qualtrics Survey | Qualtrics Experience Management","SkinLibrary":"upenn","SkinType":"templated","Skin":{"brandingId":"4025773068","templateId":"*base","overrides":null},"NewScoring":1,"SurveyMetaDescription":"The most powerful, simple and trusted way to gather experience data. Start your journey to experience management and try a free account today.","SurveyName":"sender","ProtectSelectionIds":true}},{"SurveyID":"SV_doI6kI07Xdej46G","Element":"SQ","PrimaryAttribute":"QID3","SecondaryAttribute":"TRUST GAME1. You will be matched in pairs. 2. Within each pair, you will be assigned to either Ro...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>TRUST GAME<br><\/b>1. You will be matched in pairs.<br>2. Within each pair, you will be assigned to either Role A or B.\n<br>3. Initially, A receives 3 units and B receives 0 units. A can transfer X units to B, where 0 \u2264 X \u2264 3.\n<br>4. The amount A transfers to B is tripled, so B receives 3X units.\n<br>5. B can transfer back Y units to A, where 0 \u2264 Y \u2264 3X.\n<br>6. A's final payoff is (3 - X + Y) units. B's final payoff is (3X - Y) units.\n<br>7. The experiment concludes. The units can be redeemed as the equal dollar amount (i.e., 1 unit = $ 1)<br>8. At the end of the study, some participants will be randomly selected to receive their final payoff in cash. Every participant has an equal chance of being selected.<br>","DefaultChoices":false,"DataExportTag":"Trust Game","QuestionID":"QID3","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"TRUST GAME1. You will be matched in pairs. 2. Within each pair, you will be assigned to either Ro...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_doI6kI07Xdej46G","Element":"SQ","PrimaryAttribute":"QID4","SecondaryAttribute":"You have been assigned to Role A. You received 3 units. The other participant (B) received 0 unit...","TertiaryAttribute":null,"Payload":{"QuestionText":"You have been assigned to <b>Role A<\/b>.<br>You received 3 units. The other participant (B) received 0 units.<br>Your can transfer any amount between 0 and 3 units to B. This amount will be tripled so B will receive 3 times the amount you transfer.\nThen, B can send back any amount between 0 and whatever amount he or she got.<br>Please choose to indicate how many units (0-3) to transfer to B.&nbsp;","DefaultChoices":false,"DataExportTag":"","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You have been assigned to Role A. You received 3 units. The other participant (B) received 0 unit...","Choices":{"1":{"Display":"Your transfer to B:0"},"2":{"Display":"Your transfer to B:1"},"3":{"Display":"Your transfer to B:2"},"4":{"Display":"Your transfer to B:3"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID4"}},{"SurveyID":"SV_doI6kI07Xdej46G","Element":"SQ","PrimaryAttribute":"QID5","SecondaryAttribute":"If you would like to receive your payoff, please enter your email address below. How payment work...","TertiaryAttribute":null,"Payload":{"QuestionText":"If you would like to receive your payoff, please enter your email address below.\n<br>How payment works: At the end of the study, one participant will be randomly selected to receive their final payoff in cash. <b>If you are selected and have provided your email address<\/b>, we will contact you to arrange your payment.\n<br>If you do not wish to provide your email address, you may leave this field blank and click \"Next\" to submit your responses.\n<br>Note: Your email will only be used for payoff distribution and will not be linked to your survey responses in any analysis.","DefaultChoices":false,"DataExportTag":"Q5","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"If you would like to receive your payoff, please enter your email address below. How payment work...","Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID5"}},{"SurveyID":"SV_doI6kI07Xdej46G","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}}]}