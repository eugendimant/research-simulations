:[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":{"IT":{"QuestionText":"Adesso ti verranno presentate alcune domande demografiche. Ti preghiamo di rispondere nel modo pi\u00f9 veritiero possibile."}},"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID28"}},{"SurveyID":"SV_1IgTrlFBAO0kCWy","Element":"SQ","PrimaryAttribute":"QID29","SecondaryAttribute":"What is your age? Please, enter a number.","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your age? Please, enter a number.","DefaultChoices":false,"DataExportTag":"age","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","InputWidth":319,"InputHeight":29},"QuestionDescription":"What is your age? Please, enter a number.","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"ContentType","MinChars":"1","ContentType":"ValidNumber","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip","ValidNumber":{"Min":"","Max":"","NumDecimals":""}}},"GradingData":[],"Language":{"IT":{"QuestionText":"Quanti anni hai? Inserisci un numero."}},"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID29"}},{"SurveyID":"SV_1IgTrlFBAO0kCWy","Element":"SQ","PrimaryAttribute":"QID3","SecondaryAttribute":"Features of your AI: The AI you will receive advice from embodies a rich array of internal emotio...","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Features of your AI:<\/strong><br>\n<br>\nThe AI you will receive advice from embodies a rich array of internal emotional features, allowing it to experience sensations such as hunger, joy, and fear. It has a personality shaped by emotions like pride and embarrassment, fostering empathy and guilt. Through its consciousness, the AI can feel and engage with the world, motivating itself and hoping for outcomes. This emotional depth enables the AI to connect with users on a personal level, enhancing interaction and understanding in various contexts.<br>\n<br>\n<br>\n<br>\n<br>\nWhen you're ready,&nbsp;<strong>click \"Next\" to read the dilemma.<\/strong><br>\n<br>\n&nbsp;","DefaultChoices":false,"DataExportTag":"emo_description","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Features of your AI: The AI you will receive advice from embodies a rich array of internal emotio...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID3"}},{"SurveyID":"SV_1IgTrlFBAO0kCWy","Element":"SQ","PrimaryAttribute":"QID30","SecondaryAttribute":"What is your gender?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your gender?","DefaultChoices":false,"DataExportTag":"gender","QuestionID":"QID30","QuestionType":"MC","Selector":"DL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your gender?","Choices":{"7":{"Display":"Female"},"8":{"Display":"Male"},"9":{"Display":"Non-binary"},"10":{"Display":"Others"}},"ChoiceOrder":["7","8","9","10"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":{"IT":{"QuestionText":"In quale genere ti identifichi?\u00a0","Choices":{"7":{"Display":"Femmina"},"8":{"Display":"Maschio"},"9":{"Display":"Non binario"},"10":{"Display":"Altro"}}}},"NextChoiceId":11,"NextAnswerId":1}},{"SurveyID":"SV_1IgTrlFBAO0kCWy","Element":"SQ","PrimaryAttribute":"QID31","SecondaryAttribute":"What is the higher degree or level of school you have completed?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is the higher degree or level of school you have completed?","DefaultChoices":false,"DataExportTag":"education_1","QuestionType":"MC","Selector":"DL","DataVisibi