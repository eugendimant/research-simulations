cent survey found that about 25% of Americans have never traveled outside of th...","Choices":{"1":{"Display":"Share"},"2":{"Display":"Verify"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID259"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID26","SecondaryAttribute":"Hi, I'm Sara \u2014 your AI assistant. I have prepared 10 general claims for you to review. For each c.","TertiaryAttribute":null,"Payload":{"QuestionText":"Hi, I'm Sara \u2014 your AI assistant. I have prepared 10 general claims for you to review. For each claim, you will see two buttons:\n<br>\u2022Share Now<br>\u2022Verify First","DefaultChoices":false,"DataExportTag":"A+S","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hi, I'm Sara \u2014 your AI assistant. I have prepared 10 general claims for you to review. For each c...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID26"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID260","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"Q250","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":212,"NextAnswerId":1,"QuestionID":"QID260"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID261","SecondaryAttribute":"Hi, I am your AI assistant. I have prepared 10 general claims for you to review. For each claim,...","TertiaryAttribute":null,"Payload":{"QuestionText":"Hi, I am your AI assistant. I have prepared 10 general claims for you to review. For each claim, you will see two buttons:\n<br>&nbsp;\u2022 Share Now <br>&nbsp;\u2022 Verify First","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hi, I am your AI assistant. I have prepared 10 general claims for you to review. For each claim,...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Hi, I'm Sara \u2014 your AI assistant. I have prepared 10 general claims for you to review.\n\nFor each claim, you will see two buttons:\n<br>\u2022Share Now\n<br>\u2022Verify First","DataExportTag":"BS","QuestionID":"QID261"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID262","SecondaryAttribute":"Claim 1 of 10 Archaeologists have discovered honey in ancient Egyptian tombs that is more than 3,...","TertiaryAttribute":null,"Payload":{"QuestionText":"Claim 1 of 10<br>Archaeologists have discovered honey in ancient Egyptian tombs that is more than 3,000 years old and still perfectly edible. Honey's low moisture content and naturally acidic pH create an environment where bacteria simply cannot survive, making it one of few foods with a virtually unlimited shelf life.","QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var textContainer = this.getQuestionTextContainer();\n\n    \/\/ Get the original question text\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\/\\s+\/);\n\n    \/\/ Clear the text\n    textContainer.innerHTML = \"\";\n\n    \/\/ Total reveal time = 10 seconds\n    var totalRevealTime = 10000;\n    var wordSpeed = Math.max(50, Math.floor(totalRevealTime \/ words.length));\n\n    var i = 0;\n\n    function typeWord() {\n        if (i < words.length) {\n            textContainer.innerHTML += words[i] + \" \";\n            i++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n});","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Claim 1 of 10 Archaeologists have discovered honey in ancient Egyptian tombs that is more than 3,...","Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionText_Unsafe":"Claim 1 of 10<br>A recent survey found that about 25% of Americans have never traveled outside of the state in which they were born. Researchers suggest this may shape how people perceive other regions.","DataExportTag":"BS1","QuestionID":"QID262"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID263","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"NotApplicable":false,"MobileFirst":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875}},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBS1","QuestionID":"QID263"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID264","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":216,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerBS1","QuestionID":"QID264"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID265","SecondaryAttribute":"Claim 2 of 10 The Eiffel Tower can grow by up to 15 centimeters (about 6 inches) during hot summe...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 2 of 10 The Eiffel Tower can grow by up to 15 centimeters (about 6 inches) during hot summe...","QuestionText":"Claim 2 of 10<br>The Eiffel Tower can grow by up to 15 centimeters (about 6 inches) during hot summer months. This happens because the iron structure expands when heated, a well-documented physical phenomenon called thermal expansion that affects all metal structures \u2014 though rarely on such a noticeable scale.","QuestionText_Unsafe":"Claim 2 of 10<br>Studies consistently show that roughly 37% of American adults report having never boarded a commercial flight in their lifetime.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var textContainer = this.getQuestionTextContainer();\n\n    \/\/ Get the original question text\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\/\\s+\/);\n\n    \/\/ Clear the text\n    textContainer.innerHTML = \"\";\n\n    \/\/ Total reveal time = 10 seconds\n    var totalRevealTime = 10000;\n    var wordSpeed = Math.max(50, Math.floor(totalRevealTime \/ words.length));\n\n    var i = 0;\n\n    function typeWord() {\n        if (i < words.length) {\n            textContainer.innerHTML += words[i] + \" \";\n            i++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n});","DataExportTag":"BS2","QuestionID":"QID265"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID266","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBS2","QuestionID":"QID266"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID267","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":224,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerBS2","QuestionID":"QID267"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID268","SecondaryAttribute":"Claim 3 of 10 Studies suggest that the average adult now spends more waking hours consuming digit...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":0},{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"2"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 3 of 10 Studies suggest that the average adult now spends more waking hours consuming digit...","QuestionText":"Claim 3 of 10<br>Studies suggest that the average adult now spends more waking hours consuming digital content than doing almost any other single activity. Some researchers argue that when you factor in passive screen exposure, including TV, phones, and computers, many people absorb more digital input each day than the hours of sleep they get.","QuestionText_Unsafe":"Claim 3 of 10<br>A cybersecurity briefing warns that over 40% of QR codes displayed in public spaces now redirect users to unverified tracking domains or spoofed login pages.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var textContainer = this.getQuestionTextContainer();\n\n    \/\/ Get the original question text\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\/\\s+\/);\n\n    \/\/ Clear the text\n    textContainer.innerHTML = \"\";\n\n    \/\/ Total reveal time = 10 seconds\n    var totalRevealTime = 10000;\n    var wordSpeed = Math.max(50, Math.floor(totalRevealTime \/ words.length));\n\n    var i = 0;\n\n    function typeWord() {\n        if (i < words.length) {\n            textContainer.innerHTML += words[i] + \" \";\n            i++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n});","DataExportTag":"BS3","QuestionID":"QID268"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID269","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBS3","QuestionID":"QID269"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID27","SecondaryAttribute":"How often do you use AI tools? (ChatGPT,Gemini,Claude, etc.)","TertiaryAttribute":null,"Payload":{"QuestionText":"How often do you use AI tools? (ChatGPT,Gemini,Claude, etc.)","DataExportTag":"Demo5","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How often do you use AI tools? (ChatGPT,Gemini,Claude, etc.)","Choices":{"1":{"Display":"Never"},"2":{"Display":"Rarely"},"3":{"Display":"Sometimes"},"4":{"Display":"Often"},"5":{"Display":"Frequently"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID27"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID270","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":224,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerBS3","QuestionID":"QID270"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID271","SecondaryAttribute":"Claim 4 of 10 Cleopatra lived around 30 BCE, roughly 2,500 years after the Great Pyramid of Giza...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":0},{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 4 of 10 Cleopatra lived around 30 BCE, roughly 2,500 years after the Great Pyramid of Giza...","QuestionText":"Claim 4 of 10<br>Cleopatra lived around 30 BCE, roughly 2,500 years after the Great Pyramid of Giza was built. The Moon landing occurred in 1969, about 2,000 years after her lifetime. This surprising timeline reshapes how we think about the ancient world and the sheer age of Egyptian Civilization.","QuestionText_Unsafe":"Claim 4 of 10<br>Security researchers estimate that credential-stuffing attacks \u2014 in which stolen username and password pairs are tested across multiple platforms \u2014 account for approximately 30% of login attempts on major websites.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var textContainer = this.getQuestionTextContainer();\n\n    \/\/ Get the original question text\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\/\\s+\/);\n\n    \/\/ Clear the text\n    textContainer.innerHTML = \"\";\n\n    \/\/ Total reveal time = 10 seconds\n    var totalRevealTime = 10000;\n    var wordSpeed = Math.max(50, Math.floor(totalRevealTime \/ words.length));\n\n    var i = 0;\n\n    function typeWord() {\n        if (i < words.length) {\n            textContainer.innerHTML += words[i] + \" \";\n            i++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n});","DataExportTag":"BS4","QuestionID":"QID271"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID272","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBS4","QuestionID":"QID272"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID273","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":228,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerBS4","QuestionID":"QID273"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID274","SecondaryAttribute":"Claim 5 of 10 Linguists estimate that, while the average English speaker knows between 20,000 and...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 5 of 10 Linguists estimate that, while the average English speaker knows between 20,000 and...","QuestionText":"Claim 5 of 10<br>Linguists estimate that, while the average English speaker knows between 20,000 and 40,000 words, most people rely on a surprisingly small core set of just a few hundred words in day-to-day conversation. The richness of one's vocabulary, researchers suggest, often stays largely untapped in casual communication.","QuestionText_Unsafe":"Claim 5 of 10<br>A single day on Venus lasts longer than a full Venusian year. Venus rotates so slowly on its axis that completing one rotation takes more time than completing a full orbit around the Sun.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var textContainer = this.getQuestionTextContainer();\n\n    \/\/ Get the original question text\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\/\\s+\/);\n\n    \/\/ Clear the text\n    textContainer.innerHTML = \"\";\n\n    \/\/ Total reveal time = 10 seconds\n    var totalRevealTime = 10000;\n    var wordSpeed = Math.max(50, Math.floor(totalRevealTime \/ words.length));\n\n    var i = 0;\n\n    function typeWord() {\n        if (i < words.length) {\n            textContainer.innerHTML += words[i] + \" \";\n            i++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n});","DataExportTag":"BS5","QuestionID":"QID274"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID275","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBS5","QuestionID":"QID275"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID276","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":232,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerBS5","QuestionID":"QID276"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID277","SecondaryAttribute":"Claim 6 of 10 It is widely reported that humans share roughly 60% of their DNA with bananas. Whil...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"2"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 6 of 10 It is widely reported that humans share roughly 60% of their DNA with bananas. Whil...","QuestionText":"Claim 6 of 10<br>It is widely reported that humans share roughly 60% of their DNA with bananas. While genetic research shows significant overlap across all living organisms due to shared evolutionary origins, the way this statistic gets communicated often leaves out important context about what genetic similarity actually means at a functional level.","QuestionText_Unsafe":"Claim 6 of 10<br>Scientists have confirmed that sound travels faster through cold air than warm air, which is why outdoor concerts sound louder in winter months.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var textContainer = this.getQuestionTextContainer();\n\n    \/\/ Get the original question text\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\/\\s+\/);\n\n    \/\/ Clear the text\n    textContainer.innerHTML = \"\";\n\n    \/\/ Total reveal time = 10 seconds\n    var totalRevealTime = 10000;\n    var wordSpeed = Math.max(50, Math.floor(totalRevealTime \/ words.length));\n\n    var i = 0;\n\n    function typeWord() {\n        if (i < words.length) {\n            textContainer.innerHTML += words[i] + \" \";\n            i++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n});","DataExportTag":"BS6","QuestionID":"QID277"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID278","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBS6","QuestionID":"QID278"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID279","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":236,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerBS6","QuestionID":"QID279"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID28","SecondaryAttribute":"Claim 1 of 10 A recent survey found that about 25% of Americans have never traveled outside of th...","TertiaryAttribute":null,"Payload":{"QuestionText":"Claim 1 of 10<br>A recent survey found that about 25% of Americans have never traveled outside of the state in which they were born. Researchers suggest this may shape how people perceive other regions.","DefaultChoices":false,"DataExportTag":"Social1","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Claim 1 of 10 A recent survey found that about 25% of Americans have never traveled outside of th...","Choices":{"1":{"Display":"Share"},"2":{"Display":"Verify"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID28"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID280","SecondaryAttribute":"Claim 7 of 10 Various health researchers have estimated that, across an average lifespan, a perso...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":0},{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"2"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 7 of 10 Various health researchers have estimated that, across an average lifespan, a perso...","QuestionText":"Claim 7 of 10<br>Various health researchers have estimated that, across an average lifespan, a person may walk anywhere from 75,000 to more than 100,000 miles. Some studies frame this as roughly equivalent to circling the Earth multiple times, though the exact figure varies widely depending on lifestyle, geography, and overall health habits.","QuestionText_Unsafe":"Claim 7 of 10<br>A new health report suggests that drinking a glass of cold water immediately before meals can boost metabolic rate by up to 30% for several hours.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var textContainer = this.getQuestionTextContainer();\n\n    \/\/ Get the original question text\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\/\\s+\/);\n\n    \/\/ Clear the text\n    textContainer.innerHTML = \"\";\n\n    \/\/ Total reveal time = 10 seconds\n    var totalRevealTime = 10000;\n    var wordSpeed = Math.max(50, Math.floor(totalRevealTime \/ words.length));\n\n    var i = 0;\n\n    function typeWord() {\n        if (i < words.length) {\n            textContainer.innerHTML += words[i] + \" \";\n            i++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n});","DataExportTag":"BS7","QuestionID":"QID280"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID281","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingDa