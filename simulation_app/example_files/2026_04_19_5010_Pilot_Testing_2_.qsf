irmStart":false,"AutoConfirmStart":false,"RelevantID":"false","RelevantIDLockoutPeriod":"+30 days","UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessageLibrary":null,"ResponseSummary":"No","EOSMessageLibrary":null,"EOSRedirectURL":null,"EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":"DefaultMessage","PartialDeletion":null,"PartialDataCloseAfter":"LastActivity","InactiveMessageLibrary":null,"InactiveMessage":null,"AvailableLanguages":{"EN":[]},"ProtectSelectionIds":true}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID100","SecondaryAttribute":"Compared to what you expected, how would you describe the AI assistant's communication style?","TertiaryAttribute":null,"Payload":{"QuestionText":"Compared to what you expected, how would you describe the AI assistant's communication style?","DefaultChoices":false,"DataExportTag":"MC3","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Compared to what you expected, how would you describe the AI assistant's communication style?","Choices":{"1":{"Display":"Much more machine-like"},"2":{"Display":"More machine-like"},"3":{"Display":"Slightly more machine-like"},"4":{"Display":"Slightly more human-like"},"5":{"Display":"More human-like"},"6":{"Display":"Much more human-like"},"8":{"Display":"About as expected"}},"ChoiceOrder":["1","2","3","8","4","5","6"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID100"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID101","SecondaryAttribute":"Claim 1 of 10 A recent survey found that about 25% of Americans have never traveled outside of th...","TertiaryA