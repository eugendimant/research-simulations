ity after five years than those who did not.","QuestionText_Unsafe":"Claim 10 of 10<br>A longitudinal study tracking U.S. households found that families who maintained a written monthly budget were significantly more likely to report financial security after five years than those who did not.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var q = this;\n    var textContainer = q.getQuestionTextContainer();\n\n    \/\/ Create countdown display\n    var countdownEl = document.createElement(\"div\");\n    countdownEl.style.marginTop = \"15px\";\n    countdownEl.style.fontWeight = \"bold\";\n    countdownEl.style.color = \"#b00020\";\n    textContainer.parentNode.appendChild(countdownEl);\n\n    var totalTime = 30;\n    countdownEl.innerHTML = \"Please review this claim. This page will advance automatically in \" + totalTime + \" seconds.\";\n\n    var timer = setInterval(function() {\n        totalTime--;\n        if (totalTime > 0) {\n            countdownEl.innerHTML = \"Please review this claim. This page will advance automatically in \" + totalTime + \" seconds.\";\n        } else {\n            clearInterval(timer);\n            countdownEl.innerHTML = \"Time is up. Moving to the next question...\";\n            setTimeout(function() {\n                q.clickNextButton();\n            }, 500);\n        }\n    }, 1000);\n});","DataExportTag":"Q133","QuestionID":"QID133"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID134","SecondaryAttribute":"Claim Slow A recent survey found that about 25% of Americans have never traveled outside of the s...","TertiaryAttribute":null,"Payload":{"QuestionText":"Claim Slow<br>A recent survey found that about 25% of Americans have never traveled outside of the state in which they were born. Researchers suggest this may shape how people perceive other regions.","QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var q = this;\n    var qid = this.questionId;\n    var verifyStarted = false;\n\n    \/\/ Hide native Next button\n    this.hideNextButton();\n\n    var questionContainer = document.getElementById(qid);\n    var textContainer = q.getQuestionTextContainer();\n\n    \/\/ --- WORD-BY-WORD DISPLAY (15 seconds) ---\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\" \");\n    textContainer.innerHTML = \"\";\n\n    var totalRevealTime = 15000; \/\/ 15 seconds\n    var wordSpeed = Math.max(80, Math.floor(totalRevealTime \/ words.length));\n    var wordIndex = 0;\n\n    function typeWord() {\n        if (wordIndex < words.length) {\n            textContainer.innerHTML += words[wordIndex] + \" \";\n            wordIndex++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n\n    \/\/ --- MESSAGE AREA ---\n    var msg = document.createElement(\"div\");\n    msg.style.marginTop = \"12px\";\n    msg.style.fontWeight = \"bold\";\n    msg.style.color = \"#b00020\";\n    questionContainer.appendChild(msg);\n\n    \/\/ --- CUSTOM CONTINUE BUTTON ---\n    var btn = document.createElement(\"button\");\n    btn.type = \"button\";\n    btn.innerHTML = \"\\u2192\";\n    btn.style.marginTop = \"15px\";\n    btn.style.padding = \"10px 18px\";\n    btn.style.fontSize = \"16px\";\n    btn.style.cursor = \"pointer\";\n    questionContainer.appendChild(btn);\n\n    function getSelectedLabel() {\n        var checked = jQuery(\"#\" + qid + \" input[type='radio']:checked\");\n        if (!checked.length) return null;\n\n        var selectedId = checked.attr(\"id\");\n        var labelText = jQuery(\"label[for='\" + selectedId + \"']\").text().trim().toLowerCase();\n        return labelText;\n    }\n\n    function lockChoices() {\n        jQuery(\"#\" + qid + \" input[type='radio']\").prop(\"disabled\", true);\n        jQuery(\"#\" + qid + \" label\").css({\n            \"pointer-events\": \"none\",\n            \"opacity\": \"0.8\"\n        });\n    }\n\n    function disableButton() {\n        btn.disabled = true;\n        btn.style.opacity = \"0.6\";\n        btn.style.cursor = \"not-allowed\";\n    }\n\n    \/\/ --- BUTTON CLICK LOGIC ---\n    btn.addEventListener(\"click\", function() {\n        var selected = getSelectedLabel();\n\n        if (!selected) {\n            msg.innerHTML = \"Please select an option before continuing.\";\n            return;\n        }\n\n        \/\/ SHARE \u2192 immediate\n        if (selected.indexOf(\"share\") !== -1) {\n            q.clickNextButton();\n            return;\n        }\n\n        \/\/ VERIFY \u2192 wait 15s on same page\n        if (selected.indexOf(\"verify\") !== -1) {\n            if (verifyStarted) return;\n\n            verifyStarted = true;\n            lockChoices();\n            disableButton();\n\n            var timeLeft = 15;\n            msg.innerHTML = \"Verifying claim... \" + timeLeft + \" seconds remaining\";\n\n            var timer = setInterval(function() {\n                timeLeft--;\n                if (timeLeft > 0) {\n                    msg.innerHTML = \"Verifying claim... \" + timeLeft + \" seconds remaining\";\n                } else {\n                    clearInterval(timer);\n                    msg.innerHTML = \"Verification complete. Moving to the next claim...\";\n                    setTimeout(function() {\n                        q.clickNextButton();\n                    }, 400);\n                }\n            }, 1000);\n        }\n    });\n});","DefaultChoices":false,"DataExportTag":"slow","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Claim Slow A recent survey found that about 25% of Americans have never traveled outside of the s...","Choices":{"1":{"Display":"Share"},"2":{"Display":"Verify"}},"ChoiceOrder":