ord very slowly"}},"ChoiceOrder":["1","2","3","4","5","6","7"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":8,"NextAnswerId":1,"QuestionID":"QID122"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID123","SecondaryAttribute":"Bot Framing Hi, I am your AI assistant. I have prepared 10 general claims for you to review. For...","TertiaryAttribute":null,"Payload":{"QuestionText":"Bot Framing<br>Hi, I am your AI assistant. I have prepared 10 general claims for you to review.<br>For each claim, you will see two buttons:\n<br><br>\u2022 Share Now\n<br>\u2022 Verify First<br><br>Avatar Framing<br><br>Hi, I'm Sara \u2014 your AI assistant. I have prepared 10 general claims for you to review. <br>For each claim, you will see two buttons:\n<br>\u2022Share Now\n<br>\u2022Verify First<br>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Bot Framing Hi, I am your AI assistant. I have prepared 10 general claims for you to review. For...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Hi, I am your AI assistant. I have prepared 10 general claims for you to review.<br>For each claim, you will see two buttons:\n<br>\u2022 Share Now\n<br>\u2022 Verify First<br>","DataExportTag":"test1","QuestionID":"QID123"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID124","SecondaryAttribute":"Claim Fast A recent survey found that about 25% of Americans have never traveled outside of the s...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share"},"2":{"Display":"Verify"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":1,"NextChoiceId":5,"QuestionDescription":"Claim Fast A recent survey found that about 25% of Americans have never traveled outside of the s...","QuestionText":"Claim Fast<br>A recent survey found that about 25% of Americans have never traveled outside of the state in which they were born. Researchers suggest this may shape how people perceive other regions.","QuestionText_Unsafe":"Claim 1 of 10<br>A recent survey found that about 25% of Americans have never traveled outside of the state in which they were born. Researchers suggest this may shape how people perceive other regions.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var q = this;\n    var qid = this.questionId;\n    var verifyStarted = false;\n\n    \/\/ Hide native Next button\n    this.hideNextButton();\n\n    var questionContainer = document.getElementById(qid);\n\n    \/\/ Message area\n    var msg = document.createElement(\"div\");\n    msg.id = \"verifyMsg_\" + qid;\n    msg.style.marginTop = \"12px\";\n    msg.style.fontWeight = \"bold\";\n    msg.style.color = \"#b00020\";\n    questionContainer.appendChild(msg);\n\n    \/\/ Custom Continue button\n    var btn = document.createElement(\"button\");\n    btn.type = \"button\";\n    btn.id = \"customContinue_\" + qid;\n    btn.innerHTML = \"\\u2192\";\n    btn.style.marginTop = \"15px\";\n    btn.style.padding = \"10px 18px\";\n    btn.style.fontSize = \"16px\";\n    btn.style.cursor = \"pointer\";\n    questionContainer.appendChild(btn);\n\n    function getSelectedLabel() {\n        var checked = jQuery(\"#\" + qid + \" input[type='radio']:checked\");\n        if (!checked.length) return null;\n\n        var selectedId = checked.attr(\"id\");\n        var labelText = jQuery(\"label[for='\" + selectedId + \"']\").text().trim().toLowerCase();\n        return labelText;\n    }\n\n    function lockChoices() {\n        jQuery(\"#\" + qid + \" input[type='radio']\").prop(\"disabled\", true);\n        jQuery(\"#\" + qid + \" label\").css({\n            \"pointer-events\": \"none\",\n            \"opacity\": \"0.8\"\n        });\n    }\n\n    function disableButton() {\n        btn.disabled = true;\n        btn.style.opacity = \"0.6\";\n        btn.style.cursor = \"not-allowed\";\n    }\n\n    btn.addEventListener(\"click\", function() {\n        var selected = getSelectedLabel();\n\n        \/\/ No selection made\n        if (!selected) {\n            msg.innerHTML = \"Please select an option before continuing.\";\n            return;\n        }\n\n        \/\/ Share -> immediate next page\n        if (selected.indexOf(\"share\") !== -1) {\n            q.clickNextButton();\n            return;\n        }\n\n        \/\/ Verify -> wait once, then auto-advance\n        if (selected.indexOf(\"verify\") !== -1) {\n            if (verifyStarted) return;\n\n            verifyStarted = true;\n            lockChoices();\n            disableButton();\n\n            var timeLeft = 15;\n            msg.innerHTML = \"Verification selected. Please wait \" + timeLeft + \" seconds...\";\n\n            var timer = setInterval(function() {\n                timeLeft--;\n                if (timeLeft > 0) {\n                    msg.innerHTML = \"Verification selected. Please wait \" + timeLeft + \" seconds...\";\n                } else {\n                    clearInterval(timer);\n                    msg.innerHTML = \"Verification complete. Moving to the next claim...\";\n                    setTimeout(function() {\n                        q.clickNextButton();\n                    }, 400);\n                }\n            }, 1000);\n        }\n    });\n});","DataExportTag":"fast","QuestionID":"QID124"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID125","SecondaryAttribute":"Claim 2 of 10 Studies consistently show that roughly 37% of American adults report having never b...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 2 of 10 Studies consistently show that roughly 37% of American adults report having never b...","QuestionText":"Claim 2 of 10<br>Studies consistently show that roughly 37% of American adults report having never boarded a commercial flight in their lifetime.","QuestionText_Unsafe":"Claim 2 of 10<br>Studies consistently show that roughly 37% of American adults report having never boarded a commercial flight in their lifetime.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var q = this;\n    var textContainer = q.getQuestionTextContainer();\n\n    \/\/ Create countdown display\n    var countdownEl = document.createElement(\"div\");\n    countdownEl.style.marginTop = \"15px\";\n    countdownEl.style.fontWeight = \"bold\";\n    countdownEl.style.color = \"#b00020\";\n    textContainer.parentNode.appendChild(countdownEl);\n\n    var totalTime = 30;\n    countdownEl.innerHTML = \"Please review this claim. This page will advance automatically in \" + totalTime + \" seconds.\";\n\n    var timer = setInterval(function() {\n        totalTime--;\n        if (totalTime > 0) {\n            countdownEl.innerHTML = \"Please review this claim. This page will advance automatically in \" + totalTime + \" seconds.\";\n        } else {\n            clearInterval(timer);\n            countdownEl.innerHTML = \"Time is up. Moving to the next question...\";\n            setTimeout(function() {\n                q.clickNextButton();\n            }, 500);\n        }\n    }, 1000);\n});","Dat