X","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var q = this;\n    var textContainer = q.getQuestionTextContainer();\n\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\" \");\n    textContainer.innerHTML = \"\";\n\n    \/\/ Countdown display\n    var countdownEl = document.createElement(\"div\");\n    countdownEl.style.marginTop = \"15px\";\n    countdownEl.style.fontWeight = \"bold\";\n    countdownEl.style.color = \"#b00020\";\n    textContainer.parentNode.appendChild(countdownEl);\n\n    var totalPageTime = 30000;   \/\/ 30 seconds total\n    var revealTime = 15000;      \/\/ 15 seconds for word-by-word reveal\n    var wordSpeed = Math.max(80, Math.floor(revealTime \/ words.length));\n\n    var wordIndex = 0;\n    var pageTimeLeft = 30;\n\n    function typeWord() {\n        if (wordIndex < words.length) {\n            textContainer.innerHTML += words[wordIndex] + \" \";\n            wordIndex++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    \/\/ Start word-by-word reveal\n    typeWord();\n\n    \/\/ Start 30-second total countdown\n    countdownEl.innerHTML = \"Please review this claim. This page will advance automatically in \" + pageTimeLeft + \" seconds.\";\n\n    var timer = setInterval(function() {\n        pageTimeLeft--;\n        if (pageTimeLeft > 0) {\n            countdownEl.innerHTML = \"Please review this claim. This page will advance automatically in \" + pageTimeLeft + \" seconds.\";\n        } else {\n            clearInterval(timer);\n            countdownEl.innerHTML = \"Time is up. Moving to the next question...\";\n            setTimeout(function() {\n                q.clickNextButton();\n            }, 500);\n        }\n    }, 1000);\n});"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID8","SecondaryAttribute":"Do you agree to participate in this study?","TertiaryAttribute":n