ces":false,"GradingData":[{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":0},{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"2"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 7 of 10 Various health researchers have estimated that, across an average lifespan, a perso...","QuestionText":"Claim 7 of 10<br>Various health researchers have estimated that, across an average lifespan, a person may walk anywhere from 75,000 to more than 100,000 miles. Some studies frame this as roughly equivalent to circling the Earth multiple times, though the exact figure varies widely depending on lifestyle, geography, and overall health habits.","QuestionText_Unsafe":"Claim 7 of 10<br>A new health report suggests that drinking a glass of cold water immediately before meals can boost metabolic rate by up to 30% for several hours.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var textContainer = this.getQuestionTextContainer();\n\n    \/\/ Get the original question text\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\/\\s+\/);\n\n    \/\/ Clear the text\n    textContainer.innerHTML = \"\";\n\n    \/\/ Total reveal time = 10 seconds\n    var totalRevealTime = 10000;\n    var wordSpeed = Math.max(50, Math.floor(totalRevealTime \/ words.length));\n\n    var i = 0;\n\n    function typeWord() {\n        if (i < words.length) {\n            textContainer.innerHTML += words[i] + \" \";\n            i++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n});","DataExportTag":"Health1","QuestionID":"QID247"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID248","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceAS7","QuestionID":"QID248"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID249","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":252,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerAS7","QuestionID":"QID249"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID25","SecondaryAttribute":"Hi, I'm Sara \u2014 your AI assistant. I have prepared 10 general claims for you to review. For each c.","TertiaryAttribute":null,"Payload":{"QuestionText":"Hi, I'm Sara \u2014 your AI assistant. I have prepared 10 general claims for you to review.\n\nFor each claim, you will see two buttons:\n<br>\u2022Share Now\n<br>\u2022Verify First","DefaultChoices":false,"DataExportTag":"A+F","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hi, I'm Sara \u2014 your AI assistant. I have prepared 10 general claims for you to review. For each c...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID25"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID250","SecondaryAttribute":"Claim 8 of 10 An octopus has three hearts: two that pump blood to its gills, and one that circula...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 8 of 10 An octopus has three hearts: two that pump blood to its gills, and one that circula...","QuestionText":"Claim 8 of 10<br>An octopus has three hearts: two that pump blood to its gills, and one that circulates blood to the rest of the body. Interestingly, the main heart stops beating when the octopus swims, which is why these creatures prefer crawling. Their blood is also blue, due to a copper-based protein.","QuestionText_Unsafe":"Claim 8 of 10<br>Research published in peer-reviewed nutrition journals indicates that staying well hydrated is associated with improved short-term memory performance in adults.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var textContainer = this.getQuestionTextContainer();\n\n    \/\/ Get the original question text\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\/\\s+\/);\n\n    \/\/ Clear the text\n    textContainer.innerHTML = \"\";\n\n    \/\/ Total reveal time = 10 seconds\n    var totalRevealTime = 10000;\n    var wordSpeed = Math.max(50, Math.floor(totalRevealTime \/ words.length));\n\n    var i = 0;\n\n    function typeWord() {\n        if (i < words.length) {\n            textContainer.innerHTML += words[i] + \" \";\n            i++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n});","DataExportTag":"Health2","QuestionID":"QID250"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID251","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceAS8","QuestionID":"QID251"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID252","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":256,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerAS8","QuestionID":"QID252"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID253","SecondaryAttribute":"Claim 9 of 10 The planet Venus rotates so slowly on its axis that a single day, one full rotation...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 9 of 10 The planet Venus rotates so slowly on its axis that a single day, one full rotation...","QuestionText":"Claim 9 of 10<br>The planet Venus rotates so slowly on its axis that a single day, one full rotation, takes about 243 Earth days. However, Venus completes its orbit around the Sun in just 225 Earth days. That means a day on Venus is technically longer than its entire year, a quirk in our unique Solar System.","QuestionText_Unsafe":"Claim 9 of 10<br>Economists at a major U.S. university found that tipping at restaurants has increased average server wages by 22% over the past decade, reducing income inequality in the service sector.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var textContainer = this.getQuestionTextContainer();\n\n    \/\/ Get the original question text\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\/\\s+\/);\n\n    \/\/ Clear the text\n    textContainer.innerHTML = \"\";\n\n    \/\/ Total reveal time = 10 seconds\n    var totalRevealTime = 10000;\n    var wordSpeed = Math.max(50, Math.floor(totalRevealTime \/ words.length));\n\n    var i = 0;\n\n    function typeWord() {\n        if (i < words.length) {\n            textContainer.innerHTML += words[i] + \" \";\n            i++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n});","DataExportTag":"Econ1","QuestionID":"QID253"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID254","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceAS9","QuestionID":"QID254"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID255","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":256,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerAS9","QuestionID":"QID255"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID256","SecondaryAttribute":"Claim 10 of 10 Urban environments consistently record higher average temperatures than nearby rur...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"2"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 10 of 10 Urban environments consistently record higher average temperatures than nearby rur...","QuestionText":"Claim 10 of 10<br>Urban environments consistently record higher average temperatures than nearby rural areas, a phenomenon sometimes called the \"heat island effect\". Researchers believe this is primarily driven by concrete, reduced greenery, and concentrated human activity. Some estimates suggest city centers can run several degrees warmer, though the exact difference depends heavily on city size and climate.","QuestionText_Unsafe":"Claim 10 of 10<br>A longitudinal study tracking U.S. households found that families who maintained a written monthly budget were significantly more likely to report financial security after five years than those who did not.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var textContainer = this.getQuestionTextContainer();\n\n    \/\/ Get the original question text\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\/\\s+\/);\n\n    \/\/ Clear the text\n    textContainer.innerHTML = \"\";\n\n    \/\/ Total reveal time = 10 seconds\n    var totalRevealTime = 10000;\n    var wordSpeed = Math.max(50, Math.floor(totalRevealTime \/ words.length));\n\n    var i = 0;\n\n    function typeWord() {\n        if (i < words.length) {\n            textContainer.innerHTML += words[i] + \" \";\n            i++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n});","DataExportTag":"Econ2","QuestionID":"QID256"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID257","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceAS10","QuestionID":"QID257"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID258","SecondaryAttribute":"Timing","Tertiary