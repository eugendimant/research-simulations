this;\n    var textContainer = q.getQuestionTextContainer();\n\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\" \");\n    textContainer.innerHTML = \"\";\n\n    \/\/ Countdown display\n    var countdownEl = document.createElement(\"div\");\n    countdownEl.style.marginTop = \"15px\";\n    countdownEl.style.fontWeight = \"bold\";\n    countdownEl.style.color = \"#b00020\";\n    textContainer.parentNode.appendChild(countdownEl);\n\n    var totalPageTime = 30000;   \/\/ 30 seconds total\n    var revealTime = 15000;      \/\/ 15 seconds for word-by-word reveal\n    var wordSpeed = Math.max(80, Math.floor(revealTime \/ words.length));\n\n    var wordIndex = 0;\n    var pageTimeLeft = 30;\n\n    function typeWord() {\n        if (wordIndex < words.length) {\n            textContainer.innerHTML += words[wordIndex] + \" \";\n            wordIndex++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    \/\/ Start word-by-word reveal\n    typeWord();\n\n    \/\/ Start 30-second total countdown\n    countdownEl.innerHTML = \"Please review this claim. This page will advance automatically in \" + pageTimeLeft + \" seconds.\";\n\n    var timer = setInterval(function() {\n        pageTimeLeft--;\n        if (pageTimeLeft > 0) {\n            countdownEl.innerHTML = \"Please review this claim. This page will advance automatically in \" + pageTimeLeft + \" seconds.\";\n        } else {\n            clearInterval(timer);\n            countdownEl.innerHTML = \"Time is up. Moving to the next question...\";\n            setTimeout(function() {\n                q.clickNextButton();\n            }, 500);\n        }\n    }, 1000);\n});"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID89","SecondaryAttribute":"How long did the 15-second verification wait feel during this task?","TertiaryAttribute":null,"Payload":{"QuestionText":"How long did the 15-second verification wait feel during this task?","DefaultChoices":false,"DataExportTag":"MC1a","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How long did the 15-second verification wait feel during this task?","Choices":{"1":{"Display":"Very Quick"},"2":{"Display":"Fairly Quick"},"3":{"Display":"Somewhat Quick"},"4":{"Display":"Neutral"},"5":{"Display":"Somewhat Long"},"6":{"Display":"Fairly Long"},"7":{"Display":"Very Long"}},"ChoiceOrder":["1","2","3","4","5","6","7"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":1,"QuestionID":"QID89"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID9","SecondaryAttribute":"For this task, imagine that you are working for an online media outlet.\u00a0Your role is to review a...","TertiaryAttribute":null,"Payload":{"QuestionText":"<i style=\"font-family: Arial, Helvetica, sans-serif;\">For this task, imagine that you are working for an online media outlet.&nbsp;<\/i><font face=\"Arial, Helvetica, sans-serif\"><i>Your role is to review a series of claims generated by an AI assistant before they are posted on social media. <\/i><\/font><br><font face=\"Arial, Helvetica, sans-serif\"><br>Your team cares about two things:&nbsp;<\/font><br><strong style=\"font-family: Arial, Helvetica, sans-serif;\">&nbsp; &nbsp; &nbsp; &nbsp;<\/strong><span style=\"font-family: Arial, Helvetica, sans-serif;\">- <\/span><strong style=\"font-family: Arial, Helvetica, sans-serif;\">Speed <\/strong><font face=\"Arial, Helvetica, sans-serif\">(posting claims quickly)<br><\/font><strong style=\"font-family: Arial, Helvetica, sans-serif;\">&nbsp; &nbsp; &nbsp; &nbsp;<\/strong><span style=\"font-family: Arial, Helvetica, sans-serif;\">-<\/span><strong style=\"font-family: Arial, Helvetica, sans-serif;\"> Accuracy<\/strong><font face=\"Arial, Helvetica, sans-serif\">&nbsp;(avoiding false information)<br><\/font><br><u style=\"\">Your Decision Options<\/u>:<br>1. <b>Share immediately<\/b><br>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;or<br>2. <b>Verify before sharing\n<\/b><br><u><\/u><b><br><\/b><i>After your decision, you will see whether the claim was true or false.<\/i><br><br><b><u style=\"\">How You Earn Points<\/u>:&nbsp;<\/b><br>You will earn points based on your decisions:\n<br>For each claim, you can choose: <br>&nbsp;-&nbsp; Sharing a <b>true claim immediately<\/b> earns the <b>highest reward (2 points)<\/b><br>&nbsp;-&nbsp; Sharing a <b>false claim&nbsp;<\/b>result<b> no gains (0 point)<\/b><br>&nbsp;-&nbsp; <b>Verifying <\/b>before sharing&nbsp;takes more time and yields a&nbsp;<b>smaller reward (1 point)<br><\/b><br>\n<u>In general<\/u>:\n<br>&nbsp; &nbsp;- Share <b>quickly<\/b> when you think a claim is <b>true<\/b>\n<br>&nbsp; &nbsp;- <b>Verify<\/b> when you are unsure or think it may be <b>false<br><\/b>","DefaultChoices":false,"DataExportTag":"TaskIntro1","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"For this task, imagine that you are working for an online media outlet.\u00a0Your role is to review a...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID9"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID90","SecondaryAttribute":"Claim 1 of 10A recent survey found that about 25% of Americans have never traveled outside of the...","TertiaryAttribute":null,"Payload":{"QuestionText":"Claim 1 of 10<br>Archaeologists have discovered honey in ancient Egyptian tombs that is more than 3,000 years old and still perfectly edible. Honey's low moisture content and naturally acidic pH create an environment where bacteria simply cannot survive, making it one of few foods with a virtually unlimited shelf life.","QuestionJS":false,"DefaultChoices":false,"DataExportTag":"AF1","QuestionID":"QID90","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"SpecifyLabel"},"QuestionDescription":"Claim 1 of 10A recent survey found that about 25% of Americans have never traveled outside of the...","Choices":{"6":{"Display":"Share Now"},"7":{"Display":"Verify First"}},"ChoiceOrder":["6","7"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[{"ChoiceID":"6","Grades":{"SC_9Rb0HikouMWnL5Y":"2"},"index":0},{"ChoiceID":"7","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextChoiceId":8,"NextAnswerId":1}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID91","SecondaryAttribute":"Claim 10 of 10 Urban environments consistently record higher average temperatures than nearby rur...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"AF10","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 10 of 10 Urban environments consistently record higher average temperatures than nearby rur...","QuestionID":"QID91","QuestionText":"Claim 10 of 10<br>Urban environments consistently record higher average temperatures than nearby rural areas, a phenomenon sometimes called the \"heat island effect\". Researchers believe this is primarily driven by concrete, reduced greenery, and concentrated human activity. Some estimates suggest city centers can run several degrees warmer, though the exact difference depends heavily on city size and climate.","QuestionText_Unsafe":"Claim 10 of 10<br>A longitudinal study tracking U.S. households found that families who maintained a written monthly budget were significantly more likely to report financial security after five years than those who did not.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID92","SecondaryAttribute":"Claim 2 of 10 The Eiffel Tower can grow by up to 15 centimeters (about 6 inches) during hot summe...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"AF2","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"2"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 2 of 10 The Eiffel Tower can grow by up to 15 centimeters (about 6 inches) during hot summe...","QuestionID":"QID92","QuestionText":"Claim 2 of 10<br>The Eiffel Tower can grow by up to 15 centimeters (about 6 inches) during hot summer months. This happens because the iron structure expands when heated, a well-documented physical phenomenon called thermal expansion that affects all metal structures \u2014 though rarely on such a noticeable scale.","QuestionText_Unsafe":"Claim 2 of 10<br>Studies consistently show that roughly 37% of American adults report having never boarded a commercial flight in their lifetime.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID93","SecondaryAttribute":"Claim 3 of 10 Studies suggest that the average adult now spends more waking hours consuming digit...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"AF3","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":0},{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 3 of 10 Studies suggest that the average adult now spends more waking hours consuming digit...","QuestionID":"QID93","QuestionText":"Claim 3 of 10<br>Studies suggest that the average adult now spends more waking hours consuming digital content than doing almost any other single activity. Some researchers argue that when you factor in passive screen exposure, including TV, phones, and computers, many people absorb more digital input each day than the hours of sleep they get.","QuestionText_Unsafe":"Claim 3 of 10<br>A cybersecurity briefing warns that over 40% of QR codes displayed in public spaces now redirect users to unverified tracking domains or spoofed login pages.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID94","SecondaryAttribute":"Claim 4 of 10 Cleopatra lived around 30 BCE, roughly 2,500 years after the Great Pyramid of Giza...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"AF4","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":0},{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"2"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 4 of 10 Cleopatra lived around 30 BCE, roughly 2,500 years after the Great Pyramid of Giza...","QuestionID":"QID94","QuestionText":"Claim 4 of 10<br>Cleopatra lived around 30 BCE, roughly 2,500 years after the Great Pyramid of Giza was built. The Moon landing occurred in 1969, about 2,000 years after her lifetime. This surprising timeline reshapes how we think about the ancient world and the sheer age of Egyptian Civilization.","QuestionText_Unsafe":"Claim 4 of 10<br>Security researchers estimate that credential-stuffing attacks \u2014 in which stolen username and password pairs are tested across multiple platforms \u2014 account for approximately 30% of login attempts on major websites.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID95","SecondaryAttribute":"Claim 5 of 10 Linguists estimate that, while the average English speaker knows between 20,000 and...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"AF5","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 5 of 10 Linguists estimate that, while the average English speaker knows between 20,000 and...","QuestionID":"QID95","QuestionText":"Claim 5 of 10<br>Linguists estimate that, while the average English speaker knows between 20,000 and 40,000 words, most people rely on a surprisingly small core set of just a few hundred words in day-to-day conversation. The richness of one's vocabulary, researchers suggest, often stays largely untapped in casual communication.","QuestionText_Unsafe":"Claim 5 of 10<br>A single day on Venus lasts longer than a full Venusian year. Venus rotates so slowly on its axis that completing one rotation takes more time than completing a full orbit around the Sun.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID96","SecondaryAttribute":"Claim 6 of 10 It is widely reported that humans share roughly 60% of their DNA with bananas. Whil...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"AF6","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 6 of 10 It is widely reported that humans share roughly 60% of their DNA with bananas. Whil...","QuestionID":"QID96","QuestionText":"Claim 6 of 10<br>It is widely reported that humans share roughly 60% of their DNA with bananas. While genetic research shows significant overlap across all living organisms due to shared evolutionary origins, the way this statistic gets communicated often leaves out important context about what genetic similarity actually means at a functional level.","QuestionText_Unsafe":"Claim 6 of 10<br>Scientists have confirmed that sound travels faster through cold air than warm air, which is why outdoor concerts sound louder in winter months.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID97","SecondaryAttribute":"Claim 7 of 10 Various health researchers have estimated that, across an average lifespan, a perso...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"AF7","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":0},{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 7 of 10 Various health researchers have estimated that, across an average lifespan, a perso...","QuestionID":"QID97","QuestionText":"Claim 7 of 10<br>Various health researchers have estimated that, across an average lifespan, a person may walk anywhere from 75,000 to more than 100,000 miles. Some studies frame this as roughly equivalent to circling the Earth multiple times, though the exact figure varies widely depending on lifestyle, geography, and overall health habits.","QuestionText_Unsafe":"Claim 7 of 10<br>A new health report suggests that drinking a glass of cold water immediately before meals can boost metabolic rate by up to 30% for several hours.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID98","SecondaryAttribute":"Claim 8 of 10 An octopus has three hearts: two that pump blood to its gills, and one that circula...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"AF8","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"2"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 8 of 10 An octopus has three hearts: two that pump blood to its gills, and one that circula...","QuestionID":"QID98","QuestionText":"Claim 8 of 10<br>An octopus has three hearts: two that pump blood to its gills, and one that circulates blood to the rest of the body. Interestingly, the main heart stops beating when the octopus swims, which is why these creatures prefer crawling. Their blood is also blue, due to a copper-based protein.","QuestionText_Unsafe":"Claim 8 of 10<br>Research published in peer-reviewed nutrition journals indicates that staying well hydrated is associated with improved short-term memory performance in adults.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID99","SecondaryAttribute":"Claim 9 of 10 The planet Venus rotates so slowly on its axis that a single day, one full rotation...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"AF9","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"2"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 9 of 10 The planet Venus rotates so slowly on its axis that a single day, one full rotation...","QuestionID":"QID99","QuestionText":"Claim 9 of 10<br>The planet Venus rotates so slowly on its axis that a single day, one full rotation, takes about 243 Earth days. However, Venus completes its orbit around the Sun in just 225 Earth days. That means a day on Venus is technically longer than its entire year, a quirk in our unique Solar System.","QuestionText_Unsafe":"Claim 9 of 10<br>Economists at a major U.S. university found that tipping at restaurants has increased average server wages by 22% over the past decade, reducing income inequality in the service sector.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}}]}