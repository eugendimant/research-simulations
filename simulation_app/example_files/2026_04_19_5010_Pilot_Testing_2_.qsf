","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Claim 1 of 10 Archaeologists have discovered honey in ancient Egyptian tombs that is more than 3,...","Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionText_Unsafe":"Claim 1 of 10<br>A recent survey found that about 25% of Americans have never traveled outside of the state in which they were born. Researchers suggest this may shape how people perceive other regions.","DataExportTag":"BF1","QuestionID":"QID198"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID199","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"NotApplicable":false,"MobileFirst":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875}},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBF1","QuestionID":"QID199"}},{"SurveyI