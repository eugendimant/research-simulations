efaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 2 of 10 The Eiffel Tower can grow by up to 15 centimeters (about 6 inches) during hot summe...","QuestionText":"Claim 2 of 10<br>The Eiffel Tower can grow by up to 15 centimeters (about 6 inches) during hot summer months. This happens because the iron structure expands when heated, a well-documented physical phenomenon called thermal expansion that affects all metal structures \u2014 though rarely on such a noticeable scale.","QuestionText_Unsafe":"Claim 2 of 10<br>Studies consistently show that roughly 37% of American adults report having never boarded a commercial flight in their lifetime.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false,"DataExportTag":"BF2","QuestionID":"QID201"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID202","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBF2","QuestionID":"QID202"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID203","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":224,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerBF2","QuestionID":"QID203"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID204","SecondaryAttribute":"Claim 3 of 10 Studies suggest that the average adult now spends more waking hours consuming digit...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":0},{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"2"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 3 of 10 Studies suggest that the average adult now spends more waking hours consuming digit...","QuestionText":"Claim 3 of 10<br>Studies suggest that the average adult now spends more waking hours consuming digital content than doing almost any other single activity. Some researchers argue that when you factor in passive screen exposure, including TV, phones, and computers, many people absorb more digital input each day than the hours of sleep they get.","QuestionText_Unsafe":"Claim 3 of 10<br>A cybersecurity briefing warns that over 40% of QR codes displayed in public spaces now redirect users to unverified tracking domains or spoofed login pages.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false,"DataExportTag":"BF3","QuestionID":"QID204"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID205","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBF3","QuestionID":"QID205"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID206","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":228,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerBF3","QuestionID":"QID206"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID207","SecondaryAttribute":"Claim 4 of 10 Cleopatra lived around 30 BCE, roughly 2,500 years after the Great Pyramid of Giza...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":0},{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 4 of 10 Cleopatra lived around 30 BCE, roughly 2,500 years after the Great Pyramid of Giza...","QuestionText":"Claim 4 of 10<br>Cleopatra lived around 30 BCE, roughly 2,500 years after the Great Pyramid of Giza was built. The Moon landing occurred in 1969, about 2,000 years after her lifetime. This surprising timeline reshapes how we think about the ancient world and the sheer age of Egyptian Civilization.","QuestionText_Unsafe":"Claim 4 of 10<br>Security researchers estimate that credential-stuffing attacks \u2014 in which stolen username and password pairs are tested across multiple platforms \u2014 account for approximately 30% of login attempts on major websites.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false,"DataExportTag":"BF4","QuestionID":"QID207"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID208","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBF4","QuestionID":"QID208"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID209","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":232,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerBF4","QuestionID":"QID209"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID210","SecondaryAttribute":"Claim 5 of 10 Linguists estimate that, while the average English speaker knows between 20,000 and...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 5 of 10 Linguists estimate that, while the average English speaker knows between 20,000 and...","QuestionText":"Claim 5 of 10<br>Linguists estimate that, while the average English speaker knows between 20,000 and 40,000 words, most people rely on a surprisingly small core set of just a few hundred words in day-to-day conversation. The richness of one's vocabulary, researchers suggest, often stays largely untapped in casual communication.","QuestionText_Unsafe":"Claim 5 of 10<br>A single day on Venus lasts longer than a full Venusian year. Venus rotates so slowly on its axis that completing one rotation takes more time than completing a full orbit around the Sun.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false,"DataExportTag":"BF5","QuestionID":"QID210"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID211","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBF5","QuestionID":"QID211"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID212","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":236,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerBF5","QuestionID":"QID212"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID213","SecondaryAttribute":"Claim 6 of 10 It is widely reported that humans share roughly 60% of their DNA with bananas. Whil...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"2"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 6 of 10 It is widely reported that humans share roughly 60% of their DNA with bananas. Whil...","QuestionText":"Claim 6 of 10<br>It is widely reported that humans share roughly 60% of their DNA with bananas. While genetic research shows significant overlap across all living organisms due to shared evolutionary origins, the way this statistic gets communicated often leaves out important context about what genetic similarity actually means at a functional level.","QuestionText_Unsafe":"Claim 6 of 10<br>Scientists have confirmed that sound travels faster through cold air than warm air, which is why outdoor concerts sound louder in winter months.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false,"DataExportTag":"BF6","QuestionID":"QID213"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID214","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBF6","QuestionID":"QID214"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID215","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":240,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerBF6","QuestionID":"QID215"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID216","SecondaryAttribute":"Claim 7 of 10 Various health researchers have estimated that, across an average lifespan, a perso...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":0},{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"2"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 7 of 10 Various health researchers have estimated that, across an average lifespan, a perso...","QuestionText":"Claim 7 of 10<br>Various health researchers have estimated that, across an average lifespan, a person may walk anywhere from 75,000 to more than 100,000 miles. Some studies frame this as roughly equivalent to circling the Earth multiple times, though the exact figure varies widely depending on lifestyle, geography, and overall health habits.","QuestionText_Unsafe":"Claim 7 of 10<br>A new health report suggests that drinking a glass of cold water immediately before meals can boost metabolic rate by up to 30% for several hours.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false,"DataExportTag":"BF7","QuestionID":"QID216"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID217","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBF7","QuestionID":"QID217"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID218","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":244,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerBF7","QuestionID":"QID218"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID219","SecondaryAttribute":"Claim 8 of 10 An octopus has three hearts: two that pump blood to its gills, and one that circula...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 8 of 10 An octopus has three hearts: two that pump blood to its gills, and one that circula...","QuestionText":"Claim 8 of 10<br>An octopus has three hearts: two that pump blood to its gills, and one that circulates blood to the rest of the body. Interestingly, the main heart stops beating when the octopus swims, which is why these creatures prefer crawling. Their blood is also blue, due to a copper-based protein.","QuestionText_Unsafe":"Claim 8 of 10<br>Research published in peer-reviewed nutrition journals indicates that staying well hydrated is associated with improved short-term memory performance in adults.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false,"DataExportTag":"BF8","QuestionID":"QID219"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID220","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBF8","QuestionID":"QID220"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID221","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":248,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerBF8","QuestionID":"QID221"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID222","SecondaryAttribute":"Claim 9 of 10 The planet Venus rotates so slowly on its axis that a single day, one full rotation...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 9 of 10 The planet Venus rotates so slowly on its axis that a single day, one full rotation...","QuestionText":"Claim 9 of 10<br>The planet Venus rotates so slowly on its axis that a single day, one full rotation, takes about 243 Earth days. However, Venus completes its orbit around the Sun in just 225 Earth days. That means a day on Venus is technically longer than its entire year, a quirk in our unique Solar System.","QuestionText_Unsafe":"Claim 9 of 10<br>Economists at a major U.S. university found that tipping at restaurants has increased average server wages by 22% over the past decade, reducing income inequality in the service sector.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false,"DataExportTag":"BF9","QuestionID":"QID222"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID223","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBF9","QuestionID":"QID223"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID224","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":248,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerBF9","QuestionID":"QID224"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID225","SecondaryAttribute":"Claim 10 of 10 Urban environments consistently record higher average temperatures than nearby rur...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"2"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 10 of 10 Urban environments consistently record higher average temperatures than nearby rur...","QuestionText":"Claim 10 of 10<br>Urban environments consistently record higher average temperatures than nearby rural areas, a phenomenon sometimes called the \"heat island effect\". Researchers believe this is primarily driven by concrete, reduced greenery, and concentrated human activity. Some estimates suggest city centers can run several degrees warmer, though the exact difference depends heavily on city size and climate.","QuestionText_Unsafe":"Claim 10 of 10<br>A longitudinal study tracking U.S. households found that families who maintained a written monthly budget were significantly more likely to report financial security after five years than those who did not.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":false,"DataExportTag":"BF10","QuestionID":"QID225"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID226","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceBF10","QuestionID":"QID226"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID227","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":216,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerBF10","QuestionID":"QID227"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID228","SecondaryAttribute":"Hi, I'm Sara \u2014 your AI assistant. I have prepared 10 general claims for you to review. For each c.","TertiaryAttribute":null,"Payload":{"QuestionText":"Hi, I&#39;m Sara &mdash; your AI assistant. I have prepared 10 general claims for you to review. For each claim, you will see two buttons:<br \/>\n&bull;Share Now<br \/>\n&bull;Verify First<br \/>\n&nbsp;<img src=\"https:\/\/upenn.co1.qualtrics.com\/CP\/Graphic.php?IM=IM_cBNgaigUyUvjQWA\" style=\"width: 288px; height: 288px;\" \/>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hi, I'm Sara \u2014 your AI assistant. I have prepared 10 general claims for you to review. For each c...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Hi, I'm Sara \u2014 your AI assistant. I have prepared 10 general claims for you to review.\n\nFor each claim, you will see two buttons:\n<br>\u2022Share Now\n<br>\u2022Verify First","DataExportTag":"AS","QuestionID":"QID228"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID229","SecondaryAttribute":"Claim 1 of 10 Archaeologists have discovered honey in ancient Egyptian tombs that is more than 3,...","TertiaryAttribute":null,"Payload":{"QuestionText":"Claim 1 of 10<br>Archaeologists have discovered honey in ancient Egyptian tombs that is more than 3,000 years old and still perfectly edible. Honey's low moisture content and naturally acidic pH create an environment where bacteria simply cannot survive, making it one of few foods with a virtually unlimited shelf life.","QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var textContainer = this.getQuestionTextContainer();\n\n    \/\/ Get the original question text\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\/\\s+\/);\n\n    \/\/ Clear the text\n    textContainer.innerHTML = \"\";\n\n    \/\/ Total reveal time = 10 seconds\n    var totalRevealTime = 10000;\n    var wordSpeed = Math.max(50, Math.floor(totalRevealTime \/ words.length));\n\n    var i = 0;\n\n    function typeWord() {\n        if (i < words.length) {\n            textContainer.innerHTML += words[i] + \" \";\n            i++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n});","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Claim 1 of 10 Archaeologists have discovered honey in ancient Egyptian tombs that is more than 3,...","Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionText_Unsafe":"Claim 1 of 10<br>A recent survey found that about 25% of Americans have never traveled outside of the state in which they were born. Researchers suggest this may shape how people perceive other regions.","DataExportTag":"Social1","QuestionID":"QID229"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID23","SecondaryAttribute":"Hi, I am your AI assistant. I have prepared 10 general claims for you to review. For each claim,...","TertiaryAttribute":null,"Payload":{"QuestionText":"Hi, I am your AI assistant. I have prepared 10 general claims for you to review.\nFor each claim, you will see two buttons:\n<br>\u2022Share Now\n<br>\u2022Verify First","DefaultChoices":false,"DataExportTag":"B+S","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hi, I am your AI assistant. I have prepared 10 general claims for you to review. For each claim,...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID23"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID230","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"NotApplicable":false,"MobileFirst":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875}},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceAS1","QuestionID":"QID230"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID231","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":240,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimeAS1","QuestionID":"QID231"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID232","SecondaryAttribute":"Claim 2 of 10 The Eiffel Tower can grow by up to 15 centimeters (about 6 inches) during hot summe...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"0"},"index":0},{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 2 of 10 The Eiffel Tower can grow by up to 15 centimeters (about 6 inches) during hot summe...","QuestionText":"Claim 2 of 10<br>The Eiffel Tower can grow by up to 15 centimeters (about 6 inches) during hot summer months. This happens because the iron structure expands when heated, a well-documented physical phenomenon called thermal expansion that affects all metal structures \u2014 though rarely on such a noticeable scale.","QuestionText_Unsafe":"Claim 2 of 10<br>Studies consistently show that roughly 37% of American adults report having never boarded a commercial flight in their lifetime.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var textContainer = this.getQuestionTextContainer();\n\n    \/\/ Get the original question text\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\/\\s+\/);\n\n    \/\/ Clear the text\n    textContainer.innerHTML = \"\";\n\n    \/\/ Total reveal time = 10 seconds\n    var totalRevealTime = 10000;\n    var wordSpeed = Math.max(50, Math.floor(totalRevealTime \/ words.length));\n\n    var i = 0;\n\n    function typeWord() {\n        if (i < words.length) {\n            textContainer.innerHTML += words[i] + \" \";\n            i++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n});","DataExportTag":"Social2","QuestionID":"QID232"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID233","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"How confident are you when you were making the choice?","DataExportTag":"ConfidenceAS2","QuestionID":"QID233"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID234","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":15,"MaxSeconds":30},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":248,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"TimerAS2","QuestionID":"QID234"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID235","SecondaryAttribute":"Claim 3 of 10 Studies suggest that the average adult now spends more waking hours consuming digit...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"Share Now"},"2":{"Display":"Verify First"}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[{"ChoiceID":"2","Grades":{"SC_9Rb0HikouMWnL5Y":"1"},"index":0},{"ChoiceID":"1","Grades":{"SC_9Rb0HikouMWnL5Y":"2"},"index":1}],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Claim 3 of 10 Studies suggest that the average adult now spends more waking hours consuming digit...","QuestionText":"Claim 3 of 10<br>Studies suggest that the average adult now spends more waking hours consuming digital content than doing almost any other single activity. Some researchers argue that when you factor in passive screen exposure, including TV, phones, and computers, many people absorb more digital input each day than the hours of sleep they get.","QuestionText_Unsafe":"Claim 3 of 10<br>A cybersecurity briefing warns that over 40% of QR codes displayed in public spaces now redirect users to unverified tracking domains or spoofed login pages.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var textContainer = this.getQuestionTextContainer();\n\n    \/\/ Get the original question text\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\/\\s+\/);\n\n    \/\/ Clear the text\n    textContainer.innerHTML = \"\";\n\n    \/\/ Total reveal time = 10 seconds\n    var totalRevealTime = 10000;\n    var wordSpeed = Math.max(50, Math.floor(totalRevealTime \/ words.length));\n\n    var i = 0;\n\n    function typeWord() {\n        if (i < words.length) {\n            textContainer.innerHTML += words[i] + \" \";\n            i++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n});","DataExportTag":"Tech1","QuestionID":"QID235"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID236","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Sli