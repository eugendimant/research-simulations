br>Economists at a major U.S. university found that tipping at restaurants has increased average server wages by 22% over the past decade, reducing income inequality in the service sector.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function() {\n    var textContainer = this.getQuestionTextContainer();\n\n    \/\/ Get the original question text\n    var fullText = textContainer.innerText.trim();\n    var words = fullText.split(\/\\s+\/);\n\n    \/\/ Clear the text\n    textContainer.innerHTML = \"\";\n\n    \/\/ Total reveal time = 10 seconds\n    var totalRevealTime = 10000;\n    var wordSpeed = Math.max(50, Math.floor(totalRevealTime \/ words.length));\n\n    var i = 0;\n\n    function typeWord() {\n        if (i < words.length) {\n            textContainer.innerHTML += words[i] + \" \";\n            i++;\n            setTimeout(typeWord, wordSpeed);\n        }\n    }\n\n    typeWord();\n});","DataExportTag":"BS9","QuestionID":"QID286"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID287","SecondaryAttribute":"How confident are you when you were making the choice?","TertiaryAttribute":null,"Payload":{"QuestionText":"How confident are you when you were making the choice?","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":10,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.48735244519392917350586458269390277564525604248046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"How confident are you when you were making the choice?","Choices":{"1":{"Display":"Confidence"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"N