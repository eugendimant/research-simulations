onTextContainer();\n    \n    \/\/ 3. Clear any placeholder text\n    questionText.innerHTML = \"\";\n    \n    var i = 0;\n    var speed = 100; \/\/ Adjust speed (ms)\n\n    function typeWriter() {\n        if (i < phrase.length) {\n            questionText.innerHTML += phrase.charAt(i);\n            i++;\n            setTimeout(typeWriter, speed);\n        }\n    }\n\n    \/\/ 4. Start the sequence\n    typeWriter();\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID50","SecondaryAttribute":"Hi, I'm Sara \u2014 your AI assistant. I have prepared 10 general claims for you to review. For each c.","TertiaryAttribute":null,"Payload":{"QuestionText":"Hi, I'm Sara \u2014 your AI assistant. I have prepared 10 general claims for you to review.\n\nFor each claim, you will see two buttons:\n<br>\u2022Share Now\n<br>\u2022Verify First","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hi, I'm Sara \u2014 your AI assistant. I have prepared 10 general claims for you to review. For each c...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Hi, I'm Sara \u2014 your AI assistant. I have prepared 10 general claims for you to review.\n\nFor each claim, you will see two buttons:\n<br>\u2022Share Now\n<br>\u2022Verify First","DataExportTag":"Q50","QuestionID":"QID50"}},{"SurveyID":"SV_3UyxHHFTl7Y7X5c","Element":"SQ","PrimaryAttribute":"QID500","SecondaryAttribute":"How confidence were you in the choice you made","TertiaryAttribute":null,"Payload":{"QuestionText":"How confidence were you in the choice you made","DefaultChoices":false,"DataExportTag":"ConfidenceAF7","QuestionType":"Slider","Select