ects the image within the container\n\n        \/\/ Trigger the animation when the image is loaded\n        image.onload = function() {\n            setTimeout(function() {\n                imageContainer.style.width = '500px';\n                imageContainer.style.height = '500px';\n            }, 500);  \/\/ Delay before the animation starts (0.5 seconds)\n        };\n    });\n<\/script>\n\n","DataExportTag":"AMBIENTE","QuestionID":"QID82","QuestionJS":false}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID83","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"imageContainer\" style=\"overflow: hidden; width: 0; height: 0; border: 4px solid black; transition: width 2s, height 2s;\">\n    <img id=\"animatedImage\" \n         src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_dbDGjEU4SR0TA7c\"\n         style=\"width: 500px; height: 500px; display: none;\" alt=\"Opening Image\" \/>\n<\/div>\n\n<script>\n    Qualtrics.SurveyEngine.addOnload(function() {\n        const imageContainer = document.getElementById('imageContainer');\n        const image = document.getElementById('animatedImage');\n\n        \/\/ Attempt to load the image\n        image.onload = function() {\n            image.style.display = \"block\";  \/\/ Make sure the image is visible\n            setTimeout(function() {\n                imageContainer.style.width = '500px';\n                imageContainer.style.height = '500px';\n            }, 500);  \/\/ Start the animation after 0.5 seconds\n        };\n        \n        \/\/ Force the image to load by changing its `src`\n        image.src = image.src;\n    });\n<\/script>\n","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"Nex