SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID244","SecondaryAttribute":"Immagina di avere una settimana lavorativa molto intensa e pochissimo tempo libero. Una persona a...","TertiaryAttribute":null,"Payload":{"QuestionText":"Immagina di avere una settimana lavorativa molto intensa e pochissimo tempo libero. Una persona a te molto cara &egrave; ricoverata in ospedale in stato di incoscienza. Andare a trovarla richiederebbe tempo ed energie, ma non produrrebbe alcun effetto pratico immediato: la persona non si accorgerebbe della tua presenza, la sua condizione non cambierebbe, e nessun altro verrebbe a sapere se sei andato oppure no.<br \/>\nIn questa situazione, valuteresti la possibilit&agrave; di andare a trovarla?","DefaultChoices":false,"DataExportTag":"VIGNETTA_OSPEDALE","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Immagina di avere una settimana lavorativa molto intensa e pochissimo tempo libero. Una persona a...","Choices":{"2":{"Display":"sicuramente no"},"3":{"Display":"probabilmente no"},"6":{"Display":"probabilmente s\u00ec"},"7":{"Display":"sicuramente s\u00ec"}},"ChoiceOrder":["2","3","6","7"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":1,"QuestionID":"QID244"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID245","SecondaryAttribute":"Questionario su di te Ti chiediamo gentilmente di rispondere ad alcune domande su di te. Le tue r...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>Questionario su di te<\/strong><\/span><\/div>\n\n<div style=\"text-align: left;\">Ti chiediamo gentilmente di rispondere ad alcune domande su di te. Le tue risposte saranno trattate in modo completamente confidenziale.<\/div>","DefaultChoices":false,"DataExportTag":"GENERALE","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Questionario su di te Ti chiediamo gentilmente di rispondere ad alcune domande su di te. Le tue r...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID245"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID246","SecondaryAttribute":"Guadagneresti il pagamento aggiuntivo in questa situazione?","TertiaryAttribute":null,"Payload":{"QuestionText":"Guadagneresti il pagamento aggiuntivo in questa situazione?","DefaultChoices":false,"DataExportTag":"check","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Guadagneresti il pagamento aggiuntivo in questa situazione?","Choices":{"1":{"Display":"s\u00ec"},"2":{"Display":"no"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"CustomValidation","CustomValidation":{"Logic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID246\/SelectableChoice\/1","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Guadagneresti il pagamento aggiuntivo in questa situazione?<\/span> <span class=\"LeftOpDesc\">si<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID246\/SelectableChoice\/1","LogicType":"Question","Operator":"Selected","QuestionID":"QID246","QuestionIDFromLocator":"QID246","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression"},"Message":{"description":"OCCHIO","libraryID":"UR_cI0khwWZ7nPcDWK","messageID":"MS_XAsarhsBDJwt8SV","subMessageID":"VE_CUSTOM_VALIDATION_0"}}}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID