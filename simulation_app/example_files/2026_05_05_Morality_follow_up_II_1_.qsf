ionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID77","DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID8\/SelectableChoice\/3","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Prima sezione\n\n&amp;nbsp;\n\nIn questa seconda sezione dello studio dovrai effettuare una scelta, che ti descriviamo in breve di seguito.&amp;nbsp;\n\n\nTi informiamo che anche&amp;nbsp;grazie alla tua partecipazio...<\/span> <span class=\"LeftOpDesc\">&lt;div style=\"margin-left: 40px;\"&gt;Con la mia donazione, voglio sostenere iniziative finalizzate a migliorare la vita dei&lt;strong&gt; migranti&lt;\/strong&gt;, assicurando loro accesso ai servizi essenziali e promuovendo lo sviluppo dei loro paesi di origine.&lt;br \/&gt;\n&lt;br \/&gt;\n&lt;img height=\"229\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_1HZupv9Gd30SwMS\" style=\"width: 339px; height: 229px; border-width: 2px; border-style: solid;\" width=\"364\" \/&gt;&lt;\/div&gt;<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID8\/SelectableChoice\/3","LogicType":"Question","Operator":"Selected","QuestionID":"QID8","QuestionIDFromLocator":"QID8","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionJS":false}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID78","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"imageContainer\" style=\"overflow: hidden; width: 0; height: 0; border: 4px solid black; transition: width 2s, height 2s;\">\n    <img id=\"animatedImage\" \n         src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_egSbOwZBl9nfHtY\"\n         style=\"width: 500px; height: 300px; display: none;\" alt=\"Opening Image\" \/>\n<\/div>\n\n<script>\n    Qualtrics.SurveyEngine.addOnload(function() {\n        const imageContainer = document.getElementById('imageContainer');\n        const image = document.getElementById('animatedImage');\n\n        image.onload = function() {\n            image.style.display = \"block\";\n            setTimeout(function() {\n                imageContainer.style.width = '500px';\n                imageContainer.style.height = '400px';\n            }, 500);\n        };\n\n        \/\/ Force reload (Qualtrics sometimes needs this)\n        image.src = image.src;\n    });\n<\/script>\n","DefaultChoices":false,"DataExportTag":"emergenze","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID78","DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID8\/SelectableChoice\/4","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Prima sezione\n\n&amp;nbsp;\n\nIn questa seconda sezione dello studio dovrai effettuare una scelta, che ti descriviamo in breve di seguito.&amp;nbsp;\n\n\nTi informiamo che anche&amp;nbsp;grazie alla tua partecipazio...<\/span> <span class=\"LeftOpDesc\">&lt;div style=\"margin-left: 40px;\"&gt;Con la mia donazione, voglio sostenere iniziative per l&amp;#39;assistenza immediata alle comunit&amp;agrave; locali italiane colpite da &lt;strong&gt;emergenze&lt;\/strong&gt;, incluse quelle relative al Servizio di Protezione Civile.&lt;br \/&gt;\n&lt;br \/&gt;\n&amp;nbsp; &lt;img height=\"226\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_ahkQx0plKky8Uu2\" style=\"width: 339px; height: 226px; border-width: 2px; border-style: solid;\" width=\"339\" \/&gt;&lt;\/div&gt;<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID8\/SelectableChoice\/4","LogicType":"Question","Operator":"Selected","QuestionID":"QID8","QuestionIDFromLocator":"QID8","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionJS":false}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID79","SecondaryAttribute":"Prima sezione \u00a0 In questa prima sezione dello studio dovrai effettuare una scelta, che ti descriv..","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><strong>Prima sezione<\/strong><\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: left;\">In questa prima sezione dello studio <u>dovrai effettuare una scelta<\/u>, che ti descriviamo in breve di seguito.&nbsp;<\/div>\n\n<div style=\"text-align: left;\"><br>\nTi informiamo che <u>grazie alla tua partecipazione<\/u> allo studio<strong> \u00e8 stata&nbsp;effettuata una donazione di 100\u20ac a <\/strong><em><strong>Croce Rossa Italiana<\/strong>.&nbsp;<\/em>Nota che la donazione non sar\u00e0 indirizzata ad uno degli ambiti sovra menzionati, ma all'associazione in generale. La scelta della destinazione delle donazioni ricadr\u00e0 nelle mani degli operatori di Croce Rossa Italiana.<\/div>\n\n<div style=\"text-align: left;\">Ti chiediamo di <u>selezionare una dichiarazione per autorizzare la donazione e comunicarci il<strong> significato<\/strong> che le attribuisci.<\/u> La tua scelta rester\u00e0 riservata e verr\u00e0 utilizzata solo per questa ricerca.<br>\n<br>\nTi chiediamo di scegliere una tra le cinque alternative sottostanti:<\/div>","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","NumColumns":2,"LabelPosition":"BELOW"},"QuestionDescription":"Prima sezione \u00a0 In questa prima sezione dello studio dovrai effettuare una scelta, che ti descriv...","Choices":{"1":{"Display":"<div style=\"margin-left: 40px;\">Con la mia donazione, voglio sostenere gli sforzi per preservare la natura e aiutare le comunit&agrave; ad adattarsi all&#39;impatto della crisi ambientale.<br \/>\n<br \/>\n&nbsp; <img height=\"254\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_bax0G5LYAiDyKYm\" style=\"width: 339px; height: 234px; border-width: 2px; border-style: solid;\" width=\"339\" \/><br \/>\n<br \/>\n&nbsp;<\/div>\n","GraphicSize":[50,null]},"2":{"Display":"<div style=\"margin-left: 40px;\">Con la mia donazione, voglio sostenere lo sviluppo di attivit&agrave; di volontariato volte a ispirare i giovani alla partecipazione attiva a iniziative che contribuiscano al benessere sociale.<br \/>\n<br \/>\n&nbsp; <img height=\"234\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_eu1ascudzUsMHpY\" style=\"width: 340px; height: 234px; border-width: 2px; border-style: solid;\" width=\"340\" \/><br \/>\n<br \/>\n&nbsp;<\/div>\n","GraphicSize":[50,null]},"3":{"Display":"<div style=\"margin-left: 40px;\">Con la mia donazione, voglio sostenere iniziative finalizzate a migliorare la vita dei migranti, assicurando loro accesso ai servizi essenziali e promuovendo lo sviluppo dei loro paesi di origine.<br \/>\n<br \/>\n<img height=\"223\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_9YnnTsNqGjaUSzA\" style=\"height: 223px; width: 334px; border-width: 2px; border-style: solid;\" width=\"334\" \/><br \/>\n<br \/>\n<br \/>\n&nbsp;&nbsp;<br \/>\n&nbsp;<\/div>\n","GraphicSize":[50,null]},"4":{"Display":"<div style=\"margin-left: 40px;\">Con la mia donazione, voglio sostenere iniziative per l&#39;assistenza immediata alle comunit&agrave; locali italiane colpite da emergenze, incluse quelle relative al Servizio di Protezione Civile.<br \/>\n<br \/>\n&nbsp;<img height=\"234\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_3n0yuUbfg9octam\" style=\"width: 339px; height: 234 px; border-width: 2px; border-style: solid;\" width=\"339\" \/><br \/>\n<br \/>\n<br \/>\n&nbsp;<\/div>\n","GraphicSize":[50,null]},"5":{"Display":"<div style=\"margin-left: 40px;\">Con la mia donazione, voglio sostenere iniziative volte alla tutela della salute fisica e mentale di tutti, specialmente degli anziani e delle persone con disabilit&agrave;.<br \/>\n<br \/>\n&nbsp;<img height=\"234\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_cT0B79qZQRQO33w\" style=\"width: 340px; height: 234px; border-width: 2px; border-style: solid;\" width=\"340\" \/><\/div>\n","GraphicSize":[50,null]}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":11,"NextAnswerId":1,"SubSelector":"TX","QuestionText_Unsafe":"<div style=\"text-align: center;\"><strong>Prima sezione<\/strong><\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: left;\">In questa prima sezione dello studio <u>dovrai effettuare una scelta<\/u>, che ti descriviamo in breve di seguito.&nbsp;<\/div>\n\n<div style=\"text-align: left;\"><br>\nTi informiamo che grazie alla tua partecipazione allo studio <strong>abbiamo effettuato una donazione di 2\u20ac a <\/strong><em><strong>Croce Rossa Italiana<\/strong>.&nbsp;<\/em>Nota che la donazione non sar\u00e0 indirizzata ad uno degli ambiti sovra menzionati, ma all'associazione in generale. La scelta della destinazione delle donazioni ricadr\u00e0 nelle mani degli operatori dell'organizzazione.<\/div>\n\n<div style=\"text-align: left;\">&nbsp;<\/div>\n\n<div style=\"text-align: left;\">Ti chiediamo di selezionare una dichiarazione con la quale accompagnare\/autorizzare la donazione in modo da sottolineare il <strong>significato<\/strong> che attribuisci alla stessa. Ti chiediamo di scegliere una tra le cinque alternative sottostanti:<\/div>","Randomization":{"Advanced":{"FixedOrder":["{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}"],"RandomSubSet":[],"RandomizeAll":["1","2","3","4","5"],"ScaleReversal":[],"TotalRandSubset":0,"Undisplayed":[]},"ConsistentScaleReversal":false,"EvenPresentation":false,"TotalRandSubset":"","Type":"Advanced"},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    jQuery('input[type=\"radio\"]').change(function() {\n        \/\/ Remove styles from all options\n        jQuery('.q-outer, .q-answer').each(function() {\n            jQuery(this).css({\n                \"background-color\": \"\",  \/\/ Reset background\n                \"font-weight\": \"normal\", \/\/ Reset font weight\n            });\n        });\n\n        \/\/ Apply styles only to the selected option\n        var selectedOption = jQuery(this).closest('.q-outer, .q-answer');\n        selectedOption.css({\n            \"background-color\": \"green\",\n            \"font-weight\": \"bold\"\n        });\n\n        console.log(\"Selected option:\", selectedOption.text()); \/\/ Debugging\n    });\n});","ChoiceTextPosition":"Right","DataExportTag":"P1SD","QuestionID":"QID79"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID8","SecondaryAttribute":"Prima sezione \u00a0 In questa seconda sezione dello studio dovrai effettuare una scelta, che ti descr..","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><strong>Prima sezione<\/strong><\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: left;\">In questa seconda sezione dello studio dovrai effettuare una scelta, che ti descriviamo in breve di seguito.&nbsp;<\/div>\n\n<div style=\"text-align: left;\"><br>\nTi informiamo che anche&nbsp;<u>grazie alla tua partecipazione <\/u>allo studio <strong>\u00e8 stata&nbsp;effettuata una donazione di 100\u20ac a Croce Rossa Italiana<\/strong><em>.&nbsp;<\/em>Nota che la donazione non sar\u00e0 indirizzata ad uno degli ambiti sovra menzionati, ma all'associazione in generale. La scelta della destinazione delle donazioni ricadr\u00e0 nelle mani degli operatori di Croce Rossa Italiana, come da procedura standard.<br>\n&nbsp;<\/div>\n\n<div style=\"text-align: left;\">Ti chiediamo di&nbsp;<u>selezionare una dichiarazione per autorizzare la donazione e comunicarci il<strong>&nbsp;significato<\/strong>&nbsp;che le attribuisci.<\/u>&nbsp;La tua scelta rester\u00e0 riservata e verr\u00e0 utilizzata solo per questa ricerca. Ti chiediamo di scegliere una tra le cinque alternative sottostanti:<\/div>\n\n<div style=\"text-align: left;\">&nbsp;<\/div>\n\n<div style=\"text-align: left;\">&nbsp;<\/div>\n\n<div style=\"text-align: left;\">&nbsp;<\/div>","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","NumColumns":2,"LabelPosition":"BELOW"},"QuestionDescription":"Prima sezione \u00a0 In questa seconda sezione dello studio dovrai effettuare una scelta, che ti descr...","Choices":{"3":{"Display":"<div style=\"margin-left: 40px;\">Con la mia donazione, voglio sostenere iniziative finalizzate a migliorare la vita dei<strong> migranti<\/strong>, assicurando loro accesso ai servizi essenziali e promuovendo lo sviluppo dei loro paesi di origine.<br \/>\n<br \/>\n<img height=\"229\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_1HZupv9Gd30SwMS\" style=\"width: 339px; height: 229px; border-width: 2px; border-style: solid;\" width=\"364\" \/><\/div>","GraphicSize":[50,null]},"4":{"Display":"<div style=\"margin-left: 40px;\">Con la mia donazione, voglio sostenere iniziative per l&#39;assistenza immediata alle comunit&agrave; locali italiane colpite da <strong>emergenze<\/strong>, incluse quelle relative al Servizio di Protezione Civile.<br \/>\n<br \/>\n&nbsp; <img height=\"226\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_ahkQx0plKky8Uu2\" style=\"width: 339px; height: 226px; border-width: 2px; border-style: solid;\" width=\"339\" \/><\/div>","GraphicSize":[50,null]},"5":{"Display":"<div style=\"margin-left: 40px;\">Con la mia donazione, voglio sostenere iniziative volte alla tutela della <strong>salute<\/strong> fisica e mentale di tutti, specialmente degli anziani e delle persone con disabilit&agrave;.<br \/>\n<br \/>\n&nbsp; <img height=\"229\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_2rFQkCSNi5LSpDg\" style=\"width: 339px; height: 229px; border-width: 2px; border-style: solid;\" width=\"382\" \/><\/div>","GraphicSize":[50,null]},"11":{"Display":"<div style=\"margin-left: 40px;\">Con la mia donazione voglio sostenere le persone che lottano contro la <strong>povert&agrave;<\/strong> e l&#39;aumento del costo della vita, offrendo assistenza pratica e sostegno emotivo.<br \/>\n<br \/>\n<img height=\"205\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_8AnrVmBRasLlv5c\" style=\"width: 339px; height: 229px; border-width: 2px; border-style: solid;\" width=\"339\" \/><\/div>"}},"ChoiceOrder":[3,4,5,"11"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":16,"NextAnswerId":1,"SubSelector":"TX","QuestionText_Unsafe":"<div style=\"text-align: center;\"><strong>Prima sezione<\/strong><\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: left;\">In questa prima sezione dello studio dovrai effettuare una scelta.&nbsp;<\/div><div style=\"text-align: left;\"><br>\nTi informiamo che grazie alla tua partecipazione allo studio abbiamo effettuato una donazione di X a <em>Croce Rossa Italiana.&nbsp;<\/em>Nota che la donazione non sar\u00e0 indirizzata ad uno degli ambiti menzionati, ma all'associazione in generale. La scelta della destinazione delle donazioni ricadr\u00e0 nelle mani degli operatori dell'organizzazione.<\/div><div style=\"text-align: left;\"><br><\/div><div style=\"text-align: left;\">Ti chiediamo di selezionare una dichiarazione con la quale accompagnare\/autorizzare la donazione in modo da sottolineare il significato che attribuisci alla stessa. Ti chiediamo di scegliere una tra le cinque alternative sottostanti:<\/div>","DataExportTag":"P1_T_DICHIARAZIONI","QuestionID":"QID8","Randomization":{"Advanced":{"FixedOrder":["{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}"],"RandomSubSet":[],"RandomizeAll":["1","2","3","4","5"],"ScaleReversal":[],"TotalRandSubset":0,"Undisplayed":[]},"ConsistentScaleReversal":false,"EvenPresentation":false,"TotalRandSubset":"","Type":"Advanced"},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    jQuery('input[type=\"radio\"]').change(function() {\n        \/\/ Remove styles from all options\n        jQuery('.q-outer, .q-answer').each(function() {\n            jQuery(this).css({\n                \"background-color\": \"\",  \/\/ Reset background\n                \"font-weight\": \"normal\", \/\/ Reset font weight\n            });\n        });\n\n        \/\/ Apply styles only to the selected option\n        var selectedOption = jQuery(this).closest('.q-outer, .q-answer');\n        selectedOption.css({\n            \"background-color\": \"green\",\n            \"font-weight\": \"bold\"\n        });\n\n        console.log(\"Selected option:\", selectedOption.text()); \/\/ Debugging\n    });\n});","ChoiceTextPosition":"Right"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID80","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q80","Questi