 selectedOption.text()); \/\/ Debugging\n    });\n});","ChoiceTextPosition":"Right","DataExportTag":"PS1SD_ALTERNATIVES","QuestionID":"QID191"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID192","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q192","QuestionID":"QID192"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID193","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":5,"MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":36,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q193","QuestionID":"QID193"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID194","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"imageContainer\" style=\"overflow: hidden; width: 0; height: 0; border: 4px solid black; transition: width 2s, height 2s;\">\n    <img id=\"animatedImage\" \n\t\t\t\t\t\tsrc=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_1MTlSMRPMh0dGZw\"\n         style=\"width: 500px; height: 500px; display: none;\" alt=\"Opening Image\" \/>\n<\/div>\n\n<script>\n    Qualtrics.SurveyEngine.addOnload(function() {\n        const imageContainer = document.getElementById('imageContainer');\n        const image = document.getElementById('animatedImage');\n\n        \/\/ Attempt to load the image\n        image.onload = function() {\n            image.style.display = \"block\";  \/\/ Make sure the image is visible\n            setTimeout(function() {\n                imageContainer.style.width = '500px';\n                imageContainer.style.height = '400px';\n            }, 500);  \/\/ Start the animation after 0.5 seconds\n        };\n        \n        \/\/ Force the image to load by changing its `src`\n        image.src = image.src;\n    });\n<\/script>\n","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID191\/SelectableChoice\/3","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Prima sezione\n\n&amp;nbsp;\n\nIn questa prima sezione dello studio dovrai effettuare una scelta, che ti descriviamo in breve di seguito.&amp;nbsp;\n\n\nTi informiamo che&amp;nbsp;grazie alla tua partecipazione allo ...<\/span> <span class=\"LeftOpDesc\">&lt;div style=\"margin-left: 40px;\"&gt;Con la mia donazione, voglio sostenere iniziative finalizzate a migliorare la vita dei&lt;strong&gt; migranti&lt;\/strong&gt;, assicurando loro accesso ai servizi essenziali e promuovendo lo sviluppo dei loro paesi di origine.&lt;br \/&gt;\n&lt;br \/&gt;\n&lt;img height=\"229\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_1HZupv9Gd30SwMS\" style=\"width: 339px; height: 229px; border-width: 2px; border-style: solid;\" width=\"339\" \/&gt;&lt;\/div&gt;\n<\/span> <s