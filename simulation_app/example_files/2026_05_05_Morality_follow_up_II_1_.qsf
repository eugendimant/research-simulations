ryAttribute":"QID47","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"TP2 SD","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":1,"QuestionID":"QID47"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID48","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"T QUESTION_SD","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":1,"QuestionID":"QID48"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID49","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"T STATEMENT P2CD","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":1,"QuestionID":"QID49"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID5","SecondaryAttribute":"Prima sezione \u00a0 In questa prima sezione dello studio ti chiediamo di descrivere in modo dettaglia..","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>Prima sezione<\/strong><\/span><\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: justify;\">\n<p dir=\"ltr\">In questa prima sezione dello studio ti chiediamo di descrivere in modo dettagliato che cosa sta facendo il soggetto raffigurato&nbsp;a sinistra nell&rsquo;immagine sottostante. Nel farlo, ti invitiamo a riflettere sulle possibili ragioni che, secondo te, spiegano il suo gesto.<br \/>\nNon esistono descrizioni giuste o sbagliate.<br \/>\nTi chiediamo soltanto di fornire una descrizione sensata e coerente (ad esempio, non sono ammesse risposte prive di significato come &ldquo;AAAAAAAA&rdquo;).&nbsp;<\/p>\n<\/div>\n\n<div style=\"text-align: center;\"><img height=\"500\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_JR8D9cfJZ2ub2H9\" style=\"height: 500px; border-width: 4px; border-style: solid; margin: 40px 20px; width: 333px;\" width=\"333\" \/><\/div>","DefaultChoices":false,"DataExportTag":"DESCRIZIONE_IMMAGINE","QuestionID":"QID5","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Prima sezione \u00a0 In questa prima sezione dello studio ti chiediamo di descrivere in modo dettaglia...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"MinChar","MinChars":"200"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"}}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID50","SecondaryAttribute":"Adesso ti chiediamo di selezionare una delle dichiarazioni sottostanti con le quali accompagnare...","TertiaryAttribute":null,"Payload":{"QuestionText":"Adesso ti chiediamo di selezionare una delle dichiarazioni sottostanti con le quali accompagnare la donazione:","DefaultChoices":false,"DataExportTag":"istructions","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Adesso ti chiediamo di selezionare una delle dichiarazioni sottostanti con le quali accompagnare...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID50"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID51","SecondaryAttribute":"Adesso ti chiediamo di selezionare una delle dichiarazioni sottostanti con cui accompagnare la do...","TertiaryAttribute":null,"Payload":{"QuestionText":"Adesso ti chiediamo di selezionare una delle dichiarazioni sottostanti con cui accompagnare la donazione:","DefaultChoices":false,"DataExportTag":"INFO","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Adesso ti chiediamo di selezionare una delle dichiarazioni sottostanti con cui accompagnare la do...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID51"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID52","SecondaryAttribute":"Seconda Sezione \u00a0 In questa seconda sezione dello studio\u00a0dovrai effettuare una scelta. Ti informi.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><b>Seconda Sezione<\/b><br>\n&nbsp;<\/div>\nIn questa seconda sezione dello studio&nbsp;<u>dovrai effettuare una scelta<\/u>.<br>\n<br>\nTi informiamo che hai ricevuto <b>2\u20ac<\/b>&nbsp;con i quali ti offriamo la possibilit\u00e0 di&nbsp;<strong>compiere una<\/strong>&nbsp;<strong>donazione in favore di&nbsp;<em>Croce Rossa Italiana<\/em><\/strong>. Sappi che potrai tenere per te tutto ci\u00f2 che non donerai.<br>\n<br><br>\n<br>\n&nbsp;","DefaultChoices":false,"DataExportTag":"INSTRUCTIONS","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Seconda Sezione \u00a0 In questa seconda sezione dello studio\u00a0dovrai effettuare una scelta. Ti informi...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID52"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID53","SecondaryAttribute":"\u00a0 Seconda Sezione \u00a0 In questa terza sezione dello studio, dovrai effettuare una scelta. Ti inform.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: left;\">\n<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><b>Seconda Sezione<\/b><\/span><\/div>\n&nbsp;\n\n<p data-pm-slice=\"1 1 []\">In questa terza sezione dello studio, dovrai effettuare una scelta.<\/p>\n\n<p data-pm-slice=\"1 1 []\">Ti informiamo che hai ricevuto <strong>100\u20ac&nbsp;<\/strong>con i quali ti offriamo la possibilit\u00e0 di <strong>compiere una donazione in favore di Croce Rossa Italiana<\/strong>.&nbsp;<\/p>\nTi chiediamo di <u>selezionare una dichiarazione per autorizzare la donazione e comunicarci il<strong> significato<\/strong> che le attribuisci.<\/u> La tua scelta rester\u00e0 riservata e verr\u00e0 utilizzata solo per questa ricerca.<br>\n<br>\nTi chiediamo di selezionare una delle dichiarazioni sottostanti con cui autorizzare la donazione:<\/div>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    var choices = document.querySelectorAll('.q-mc-choice');\n    choices.forEach(choice => {\n        choice.style.marginBottom = \"20px\"; \/\/ Adjust this value as needed\n    });\n});","DefaultChoices":false,"DataExportTag":"P2_C_ALTERNATIVE","QuestionID":"QID53","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"\u00a0 Seconda Sezione \u00a0 In questa terza sezione dello studio, dovrai effettuare una scelta. Ti inform...","Choices":{"2":{"Display":"<div style=\"margin-left: 40px;\">Con la mia donazione voglio sostenere le persone che lottano contro la <strong>povert&agrave;<\/strong> e l&#39;aumento del costo della vita, offrendo assistenza pratica e sostegno emotivo.<\/div>\n\n<div>&nbsp;&nbsp;<\/div>\n\n<div style=\"margin-left: 40px;\"><img height=\"229\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_8AnrVmBRasLlv5c\" style=\"width: 339px; height: 229px; border-width: 2px; border-style: solid;\" width=\"379\" \/><\/div>","GraphicSize":[70,null]},"3":{"Display":"<div style=\"margin-left: 40px;\">Con la mia donazione, voglio sostenere iniziative finalizzate a migliorare la vita dei <strong>migranti<\/strong>, assicurando loro accesso ai servizi essenziali e promuovendo lo sviluppo dei loro paesi di origine.&nbsp; &nbsp;<br \/>\n<br \/>\n<img height=\"229\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_1HZupv9Gd30SwMS\" style=\"width: 339px; height: 229px; border-width: 2px; border-style: solid;\" width=\"364\" \/><\/div>","GraphicSize":[70,null]},"4":{"Display":"<div style=\"margin-left: 40px;\">Con la mia donazione, voglio sostenere iniziative per l&#39;assistenza immediata alle comunit&agrave; locali colpite da <strong>emergenze<\/strong>, incluse quelle relative al Servizio di Protezione Civile.<\/div>\n\n<div style=\"margin-left: 40px;\">&nbsp;&nbsp;<br \/>\n<img height=\"226\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_ahkQx0plKky8Uu2\" style=\"height: 226px; border-width: 2px; border-style: solid; width: 339px;\" width=\"339\" \/><\/div>","GraphicSize":[70,null]},"12":{"Display":"<div style=\"text-align: left; margin-left: 40px;\">Con la mia donazione, voglio sostenere iniziative volte alla tutela della <strong>salute<\/strong> fisica e mentale di tutti, specialmente degli anziani e delle persone con disabilit&agrave;.<br \/>\n<br \/>\n<img height=\"229\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_2rFQkCSNi5LSpDg\" style=\"width: 339px; height: 229px; border-width: 2px; border-style: solid;\" width=\"382\" \/><br \/>\n&nbsp;<\/div>"}},"ChoiceOrder":[2,3,4,"12"],"ChoiceTextPosition":"Right","Randomization":{"Advanced":{"FixedOrder":["{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}"],"RandomSubSet":[],"RandomizeAll":["1","2","3","4","5"],"ScaleReversal":[],"TotalRandSubset":0,"Undisplayed":[]},"ConsistentScaleReversal":false,"EvenPresentation":false,"TotalRandSubset":"","Type":"Advanced"},"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":17,"NextAnswerId":4,"Answers":{"1":{"Display":"Click to write Scale Point 1"},"2":{"Display":"Click to write Scale Point 2"},"3":{"Display":"Click to write Scale Point 3"}},"AnswerOrder":["1","2","3"],"ChoiceDataExportTags":false}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID54","SecondaryAttribute":"Questa dichiarazione accompagner\u00e0 la donazione che stai facendo: Con la mia donazione, voglio sos..","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: left;\">Questa dichiarazione accompagner\u00e0 la donazione che stai facendo:<\/div>\n\n<div style=\"border: 4px solid green; padding: 30px; \n            border-radius: 30px; background-color: #f8f8f8; \n            margin-top: 10px; text-align: center; display: flex; \n            flex-direction: column; justify-content: center; align-items: center;\" class=\"surround-box\"><strong>Con la mia donazione, voglio sostenere attivit\u00e0 finalizzate a tutelare tutti gli ecosistemi e ad alleviare l'impatto della crisi ambientale.<\/strong><br>\n<img width=\"339\" style=\"width: 339px; height: 254px; border-width: 2px; border-style: solid;\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_bax0G5LYAiDyKYm\" height=\"254\"><br>\n<br>\n&nbsp;<\/div>\n<br>\n&nbsp; Di seguito motiva la tua scelta:","DefaultChoices":false,"DataExportTag":"Final_SD_Ambiente\u00a0","QuestionID":"QID54","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Questa dichiarazione accompagner\u00e0 la donazione che stai facendo: Con la mia donazione, voglio sos...","DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID79\/SelectableChoice\/1","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Prima sezione\n\n&amp;nbsp;\n\nIn questa prima sezione dello studio dovrai effettuare una scelta, che ti descriviamo in breve di seguito.&amp;nbsp;\n\n\nTi informiamo che grazie alla tua partecipazione allo studi...<\/span> <span class=\"LeftOpDesc\">&lt;div style=\"margin-left: 40px;\"&gt;Con la mia donazione, voglio sostenere gli sforzi per preservare la natura e aiutare le comunit&amp;agrave; ad adattarsi all&amp;#39;impatto della crisi ambientale.&lt;br \/&gt;\n&lt;br \/&gt;\n&amp;nbsp; &lt;img height=\"254\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_bax0G5LYAiDyKYm\" style=\"width: 339px; height: 234px; border-width: 2px; border-style: solid;\" width=\"339\" \/&gt;&lt;br \/&gt;\n&lt;br \/&gt;\n&amp;nbsp;&lt;\/div&gt;\n<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID79\/SelectableChoice\/1","LogicType":"Question","Operator":"Selected","QuestionID":"QID79","QuestionIDFromLocator":"QID79","QuestionIsInLoop":