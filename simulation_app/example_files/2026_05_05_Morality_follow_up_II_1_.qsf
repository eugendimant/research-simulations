hoiceOrder":["1","2","3","4"],"Randomization":{"Advanced":{"FixedOrder":["{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}"],"RandomSubSet":[],"RandomizeAll":["1","2","3","4","5"],"ScaleReversal":[],"TotalRandSubset":0,"Undisplayed":[]},"ConsistentScaleReversal":false,"EvenPresentation":false,"TotalRandSubset":"","Type":"Advanced"},"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":6,"Answers":{"1":{"Display":"<strong><em>Sono molto contrario<\/em><\/strong>"},"2":{"Display":"<strong><em>Sono abbastanza contrario<\/em><\/strong>"},"3":{"Display":"<em><strong>Sono abbastanza d&#39;accordo<\/strong><\/em>"},"4":{"Display":"<em><strong>Sono molto d&#39;accordo<\/strong><\/em>"}},"AnswerOrder":[1,2,3,4],"ChoiceDataExportTags":false,"QuestionText_Unsafe":"<p dir=\"ltr\">In questa sezione ti chiediamo di valutare quattro affermazioni. Per ciascuna, indica quanto le consideri in linea con i tuoi principi e valori morali,&nbsp;<u>indipendentemente dall&#39;opinione degli altri<\/u>.<\/p>\n\n<p dir=\"ltr\"><br \/>\nIn altre parole, ti chiediamo di riflettere su quanto ritieni che le seguenti affermazioni siano moralmente giuste.<\/p>\n\n<p dir=\"ltr\"><br \/>\nPuoi scegliere tra quattro alternative (<em>sono molto contrario, sono abbastanza contrario, sono abbstanza d&#39;accordo, sono molto d&#39;accordo<\/em>)<\/p>\n&nbsp;\n\n<div style=\"text-align: center;\">&nbsp;<\/div>","DataExportTag":"BELIEFS TREATMENT","QuestionID":"QID213"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID214","SecondaryAttribute":"In questa sezione ti chiediamo di valutare quattro affermazioni. Per ciascuna, indica quanto pens...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: left;\">\n<p dir=\"ltr\">In questa sezione ti chiediamo di valutare quattro affermazioni. Per ciascuna, indica quanto pensi che la maggior parte delle persone le considererebbe in linea con i propri principi e valori morali, <u>indipendentemente dalla tua opinione personale<\/u>.<\/p>\n\n<p dir=\"ltr\"><br \/>\nIn altre parole, ti chiediamo di riflettere su quanto la maggioranza riterrebbe che le seguenti affermazioni siano moralmente giuste.<\/p>\n\n<p dir=\"ltr\"><br \/>\nPuoi scegliere tra quattro alternative (<u>la maggior parte delle persone sarebbe molto contraria, la maggior parte delle persone sarebbe abbastanza contraria, la maggior parte delle persone sarebbe abbastanza &nbsp;d&#39;accordo, la maggior parte delle persone sarebbe molto d&#39;accordo<\/u>)<\/p>\n<\/div>\n<\/div>","DefaultChoices":false,"QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"In questa sezione ti chiediamo di valutare quattro affermazioni. Per ciascuna, indica quanto pens...","Choices":{"1":{"Display":"Garantire a tutti l&#39;accesso ai servizi sanitari essenziali &egrave; un obiettivo che &egrave;&nbsp;<em>doveroso<\/em> contribuire a perseguire"},"2":{"Display":"Aiutare le persone in difficolt&agrave; economica &egrave; un obiettivo che &egrave;&nbsp;<em>doveroso<\/em> contribuire a perseguire"},"3":{"Display":"Tutelare i migranti e le comunit&agrave; nei loro paesi d&#39;origine &egrave; un obiettivo &egrave;<em> doveroso&nbsp;<\/em>contribuire a perseguire"},"4":{"Display":"Sostenere le comunit&agrave; locali colpite da crisi ed emergenze &egrave; un obiettivo che &egrave;&nbsp;<em>doveroso<\/em> contribuire a perseguire"}},"ChoiceOrder":["1","2","3","4"],"Randomization":{"Advanced":{"FixedOrder":["{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}"],"RandomSubSet":[],"RandomizeAll":["1","2","3","4","5"],"ScaleReversal":[],"TotalRandSubset":0,"Undisplayed":[]},"ConsistentScaleReversal":false,"EvenPresentation":false,"TotalRandSubset":"","Type":"Advanced"},"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":6,"Answers":{"1":{"Display":"<b><i>La maggior parte delle persone sarebbe molto contraria<\/i><\/b>"},"2":{"Display":"<em><strong>La maggior parte delle persone sarebbe abbastanza contraria<\/strong><\/em>"},"3":{"Display":"<strong>La maggior parte delle persone sarebbe abbastanza &nbsp;d&#39;accordo<\/strong>"},"4":{"Display":"<strong><em>La maggior parte delle persone sarebbe molto d&#39;accordo<\/em><\/strong>"}},"AnswerOrder":[1,2,3,4],"ChoiceDataExportTags":false,"QuestionText_Unsafe":"<div style=\"text-align: center;\">\n<div style=\"text-align: left;\">\n<p dir=\"ltr\">In questa sezione ti chiediamo di valutare quattro affermazioni. Per ciascuna, indica quanto pensi che la maggior parte delle persone le considererebbe in linea con i propri principi e valori morali, <u>indipendentemente dalla tua opinione personale<\/u>.<\/p>\n\n<p dir=\"ltr\"><br \/>\nIn altre parole, ti chiediamo di riflettere su quanto la maggioranza riterrebbe che le seguenti affermazioni siano moralmente giuste.<\/p>\n\n<p dir=\"ltr\"><br \/>\nPuoi scegliere tra quattro alternative (<u>la maggior parte delle persone sarebbe molto contraria, la maggior parte delle persone sarebbe abbastanza contraria, la maggior parte delle persone sarebbe abbastanza &nbsp;d&#39;accordo, la maggior parte delle persone sarebbe molto d&#39;accordo<\/u>)<\/p>\n<\/div>\n<\/div>","DataExportTag":"SOC NORM TREATMENT","QuestionID":"QID214"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID215","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private"