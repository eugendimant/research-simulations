llucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_ahkQx0plKky8Uu2\" style=\"width: 364px; height: 229px; border-width: 2px; border-style: solid;\" width=\"344\" \/><\/div>\n","GraphicSize":[70,null],"DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID191\/SelectableChoice\/4","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Prima sezione\n\n&amp;nbsp;\n\nIn questa prima sezione dello studio dovrai effettuare una scelta, che ti descriviamo in breve di seguito.&amp;nbsp;\n\n\nTi informiamo che&amp;nbsp;grazie alla tua partecipazione allo ...<\/span> <span class=\"LeftOpDesc\">&lt;div style=\"margin-left: 40px;\"&gt;Con la mia donazione, voglio sostenere iniziative per l&amp;#39;assistenza immediata alle comunit&amp;agrave; locali italiane colpite da &lt;strong&gt;emergenze&lt;\/strong&gt;, incluse quelle relative al Servizio di Protezione Civile.&lt;br \/&gt;\n&lt;br \/&gt;\n&amp;nbsp; &lt;img height=\"226\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_ahkQx0plKky8Uu2\" style=\"width: 339px; height: 226px; border-width: 2px; border-style: solid;\" width=\"339\" \/&gt;&lt;\/div&gt;\n<\/span> <span class=\"OpDesc\">Is Not Selected<\/span> ","LeftOperand":"q:\/\/QID191\/SelectableChoice\/4","LogicType":"Question","Operator":"NotSelected","QuestionID":"QID191","QuestionIDFromLocator":"QID191","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false}},"12":{"Display":"<div style=\"text-align: left; border: 2px solid green; padding: 10px; border-radius: 5px;\">Puoi scegliere questa dichiarazione e donare l&#39;intero importo selezionato in precedenza.<br \/>\nSe lo fai e verrai estratto, la tua ricompensa per la partecipazione all&#39;esperimento sar&agrave; aumentata di 10,05&euro;.<\/div>\n&nbsp;\n\n<div style=\"text-align: left; margin-left: 40px;\">Con la mia donazione, voglio sostenere iniziative volte alla tutela della <strong>salute<\/strong> fisica e mentale di tutti, spe