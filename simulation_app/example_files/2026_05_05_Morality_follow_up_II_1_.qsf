nonymizeResponse":"No","RefererCheck":"No","BallotBoxStuffingPreventionBehavior":"DefaultMessage","BallotBoxStuffingPreventionMessage":null,"BallotBoxStuffingPreventionMessageLibrary":null,"BallotBoxStuffingPreventionURL":null,"UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessageLibrary":null,"ResponseSummary":"No","EOSMessageLibrary":"UR_cI0khwWZ7nPcDWK","EOSRedirectURL":"http:\/\/","EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"true","ValidationMessageLibrary":"UR_cI0khwWZ7nPcDWK","InactiveSurvey":"DefaultMessage","PartialDeletion":null,"PartialDataCloseAfter":"LastActivity","InactiveMessageLibrary":null,"InactiveMessage":null,"AvailableLanguages":{"EN":[]},"SurveyName":"Morality_follow_up_(II)","ProtectSelectionIds":true,"CustomStyles":{"customCSS":"@media screen and (min-width: 1024px) {\n  .SkinInner {\n    width: 95vw !important;\n    max-width: 95vw !important;\n  }\n\n  .Skin .QuestionOuter {\n    max-width: 95vw !important;\n  }\n}\n"}}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID1","SecondaryAttribute":"Benvenuto! \u00a0 Questo studio ha l'obiettivo di analizzare la tua capacit\u00e0 descrittiva e le tue opin.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"border: 4px solid green; padding: 15px; border-radius: 5px; background-color:#f8f8f8;\">\n<p style=\"text-align: center;\"><b>Benvenuto<\/b><b>!<\/b><\/p>\n\n<p style=\"text-align: justify;\">&nbsp;<\/p>\n\n<p style=\"text-align: justify;\">Questo studio ha l'obiettivo di analizzare la tua capacit\u00e0 descrittiva e le tue opinioni circa alcune azioni compiute da altri. Lo studio \u00e8 articolato in<strong>&nbsp;tre sezioni principali, seguite da un questionario. <\/strong>Impiegherai circa <strong>5<\/strong>&nbsp;<strong>minuti<\/strong> per completarlo. Per cortesia, evita qualsiasi distrazione mentre partecipi allo studio. Silenzia il tuo cellulare e\/o spegni la televisione.<\/p>\n\n<p style=\"text-align: justify;\">&nbsp;<\/p>\n\n<p style=\"text-align: center;\"><strong>Informazioni al partecipante e modulo di consenso: come sar\u00e0 garantita la riservatezza delle mie informazioni?<\/strong><\/p>\n\n<p style=\"text-align: justify;\"><br>\nOgni risposta da te fornita sar\u00e0 completamente anonima\u2014ti verr\u00e0 assegnato un codice identificativo che non potr\u00e0 essere in alcun modo associato alla tua identit\u00e0.<br>\nSe decidi di partecipare allo studio, sii consapevole che prevediamo di discutere\/pubblicarne i risultati. In ogni pubblicazione le informazioni saranno fornite in modo tale che tu non possa essere identificato. Nessuna informazione personale o identificativa sar\u00e0 raccolta durante lo studio. I tuoi dati (anonimi) possono essere resi disponibili su piattaforme online come Open Science Framework, che consentono ad altri ricercatori e parti interessate di ottenere accesso ai dati per condurre analisi aggiuntive. Considera che hai il diritto di ritirare il consenso in ogni momento.&nbsp;<br>\n<br>\nPuoi contattare la ricercatrice (Ginevra Del Mastio, email:&nbsp;<strong>ginevra.delmastio@imtlucca.it<\/strong>) in caso di domande relative allo studio.&nbsp;<br>\n<br>\n&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;&nbsp;<\/p>\n\n<p style=\"text-align: center;\">&nbsp;<strong>Dichiarazione di Consenso<\/strong><\/p>\n\n<p style=\"text-align: justify;\"><br>\nAcconsento a partecipare a questo esperimento. Ho compreso che la partecipazione a questo studio \u00e8 totalmente volontaria.<br>\nHo compreso che una volta dato l'assenso attraverso il bottone sottostante questa dichiarazione sar\u00e0 acquisita dalla ricercatrice.<br>\nSono consapevole che:<\/p>\n\n<ol>\n\t<li style=\"text-align: left;\">Sono libero di ritirarmi dal progetto in ogni momento senza dover fornire alcuna spiegazione e sono libero di ritirare tutti i dati forniti;<\/li>\n\t<li style=\"text-align: left;\">Sono stato informato dell'obiettivo della ricerca;<\/li>\n\t<li style=\"text-align: left;\">Sono stato informato che la confidenzialit\u00e0 delle informazioni che fornisco verr\u00e0 salvaguardata nel rispetto della legge; ogni informazione che fornisco sar\u00e0 completamente anonima;<\/li>\n\t<li style=\"text-align: left;\">Soltanto i membri del gruppo di ricerca avranno accesso ai miei dati, l'accesso sar\u00e0 vincolato da una password;<\/li>\n\t<li style=\"text-align: left;\">Una volta che tutte le informazioni attraverso le quali si potr\u00e0 risalire alla mia identit\u00e0 verranno eliminate,&nbsp;le mie risposte&nbsp;potranno essere condivise con altri ricercatori o rese disponibili online.<\/li>\n<\/ol>\n\n<div style=\"text-align: justify;\"><strong>Cliccando il bottone sottostante acconsenti a partecipare allo studio e all'utilizzo delle tue risposte come sopra menzionato.<\/strong><\/div>\n\n<div>&nbsp;<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"Consent\u00a0","QuestionID":"QID1","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Benvenuto! \u00a0 Questo studio ha l'obiettivo di analizzare la tua capacit\u00e0 descrittiva e le tue opin...","Choices":{"1":{"Display":"Acconsento"},"2":{"Display":"Non acconsento"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"SubSelector":"TX"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID10","SecondaryAttribute":"Adesso selezione una delle dichiarazioni sottostanti con cui accompagnare la donazione:","TertiaryAttribute":null,"Payload":{"QuestionText":"Adesso selezione una delle dichiarazioni sottostanti con cui accompagnare la donazione:","DefaultChoices":false,"DataExportTag":"P2C_Dichiarazioni","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Adesso selezione una delle dichiarazioni sottostanti con cui accompagnare la donazione:","Choices":{"1":{"Display":"Con la mia donazione voglio sostenere gli sforzi per preservare la natura e aiutare le comunit\u00e0 ad adattarsi all'impatto della crisi ambientale."},"2":{"Display":"Con la mia donazione, mi propongo di sostenere lo sviluppo di attivit\u00e0 di volontariato volte a ispirare i giovani alla partecipazione attiva a iniziative che contribuiscano al benessere sociale."},"3":{"Display":"Con la mia donazione, voglio sostenere iniziative finalizzate a migliorare la vita dei migranti, assicurando loro accesso ai servizi essenziali e promuovendo lo sviluppo dei propri paesi di origine."},"4":{"Display":"Con la mia donazione, voglio sostenere iniziative per l'assistenza immediata delle comunit\u00e0 locali italiane colpite da emergenze, incluse quelle relative al Servizio di Protezione Civile."},"5":{"Display":"Con la mia donazione, voglio sostenere iniziative volte  alla tutela della salute fisica e mentale di tutti, specialmente degli anziani e dei disabili."}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID10","Randomization":{"Type":"Advanced","Advanced":{"FixedOrder":["{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}"],"RandomizeAll":["1","2","3","4","5"],"RandomSubSet":[],"ScaleReversal":[],"Undisplayed":[],"TotalRandSubset":0},"ConsistentSca