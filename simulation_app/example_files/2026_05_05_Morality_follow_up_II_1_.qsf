Timeout(function() {\n                imageContainer.style.width = '500px';\n                imageContainer.style.height = '400px';\n            }, 500);  \/\/ Start the animation after 0.5 seconds\n        };\n        \n        \/\/ Force the image to load by changing its `src`\n        image.src = image.src;\n    });\n<\/script>\n","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID191\/SelectableChoice\/11","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Prima sezione\n\n&amp;nbsp;\n\nIn questa prima sezione dello studio dovrai effettuare una scelta, che ti descriviamo in breve di seguito.&amp;nbsp;\n\n\nTi informiamo che&amp;nbsp;grazie alla tua partecipazione allo ...<\/span> <span class=\"LeftOpDesc\">&lt;div style=\"margin-left: 40px;\"&gt;Con la mia donazione voglio sostenere le persone che lottano contro la &lt;strong&gt;povert&amp;agrave;&lt;\/strong&gt; e l&amp;#39;aumento del costo della vita, offrendo assistenza pratica e sostegno emotivo.&lt;br \/&gt;\n&lt;br \/&gt;\n&lt;img height=\"229\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_8AnrVmBRasLlv5c\" style=\"width: 339px; height: 229px; border-width: 2px; border-style: solid;\" width=\"339\" \/&gt;&lt;\/div&gt;\n<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID191\/SelectableChoice\/11","LogicType":"Question","Operator":"Selected","QuestionID":"QID191","QuestionIDFromLocator":"QID191","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div id=\"imageContainer\" style=\"overflow: hidden; width: 0; height: 0; border: 4px solid black; transition: width 2s, height 2s;\">\n    <img id=\"animatedImage\" \n         src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_2fxbwyY2XSUEOTI\"\n         style=\"width: 500px; height: 500px; display: none;\" alt=\"Opening Image\" \/>\n<\/div>\n\n<script>\n    Qualtrics.SurveyEngine.addOnload(function() {\n        const imageContainer = document.getElementById('imageContainer');\n        const image = document.getElementById('animatedImage');\n\n        \/\/ Attempt to load the image\n        image.onload = function() {\n            image.style.display = \"block\";  \/\/ Make sure the image is visible\n            setTimeout(function() {\n                imageContainer.style.width = '500px';\n                imageContainer.style.height = '400px';\n            }, 500);  \/\/ Start the animation after 0.5 seconds\n        };\n        \n        \/\/ Force the image to load by changing its `src`\n        image.src = image.src;\n    });\n<\/script>\n","DataExportTag":"Q197","QuestionID":"QID197"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID198","SecondaryAttribute":"Grazie per aver partecipato a questo studio! \u00a0 Lo scopo di questo esperimento era indagare in che..","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Grazie per aver partecipato a questo studio!<\/strong><br>\n&nbsp;\n<p data-end=\"453\" data-start=\"157\">Lo scopo di questo esperimento era indagare in che misura le persone tendano a utilizzare termini moralmente connotati quando descrivono una situazione, come valutino la correttezza di decisioni relative a donazioni benefiche e quale sia la loro propensione a compiere gesti moralmente rilevanti.<br>\n&nbsp;<\/p>\n\n<p data-end=\"496\" data-start=\"455\">Lo studio si \u00e8 articolato in pi\u00f9 sezioni.<br>\n&nbsp;<\/p>\n\n<p data-end=\"665\" data-start=\"498\">Nella <strong data-end=\"517\" data-start=\"504\">Sezione 1<\/strong>, a tutti i partecipanti \u00e8 stato chiesto di descrivere un\u2019immagine raffigurante una persona che faceva l\u2019elemosina a una persona senza fissa dimora.<\/p>\n\n<p data-end=\"1173\" data-start=\"667\">Nelle&nbsp;<strong data-end=\"686\" data-start=\"673\">Sezioni 2 e 3<\/strong>, a tutti i partecipanti \u00e8 stato chiesto di valutare, sia secondo la propria opinione personale sia secondo quella che ritenevano essere l\u2019opinione della societ\u00e0, l\u2019appropriatezza di alcune azioni compiute da persone che avevano partecipato a un precedente studio. In particolare, tali persone dovevano decidere se e quanti soldi donare a un ente benefico, scegliendo tra cinque possibili alternative: donare 0\u20ac, 20\u20ac, 50\u20ac, 80\u20ac oppure 100\u20ac, trattenendo per s\u00e9 l\u2019eventuale somma rimanente.<\/p>\n\n<p data-end=\"1384\" data-start=\"1175\">Nel <strong data-end=\"1202\" data-start=\"1179\">questionario finale<\/strong>, tutti i partecipanti hanno fornito alcune informazioni personali e hanno risposto a domande volte a comprendere quanto frequentemente compiano azioni considerate giuste o corrette.<\/p>\n\n<p data-end=\"1540\" data-start=\"1386\">Nel complesso, questo esperimento ci permetter\u00e0 di comprendere meglio come le persone descrivono, valutano e riportano comportamenti moralmente rilevanti.<br>\n&nbsp;<\/p>\n\n<p data-end=\"1719\" data-start=\"1542\">Tutte le informazioni raccolte resteranno strettamente confidenziali e saranno utilizzate esclusivamente a fini di ricerca. Le risposte verranno rese anonime prima dell\u2019analisi.<\/p>\n\n<p data-end=\"1959\" data-start=\"1721\">Al termine dello studio, tutti i partecipanti riceveranno un compenso per la partecipazione. A questo potr\u00e0 eventualmente aggiungersi un compenso ulteriore, determinato sulla base della risposta fornita nella seconda sezione dello studio.<\/p>\n\n<p data-end=\"2085\" data-start=\"1961\">Per qualsiasi domanda, o se desideri ritirare i tuoi dati, puoi contattarci all\u2019indirizzo: ginevra.delmastio@imtlucca.it.<br>\n&nbsp;<\/p>\n\n<p data-end=\"2167\" data-start=\"2087\">Grazie ancora per il tuo tempo e per il prezioso contributo alla nostra ricerca.<\/p>","DefaultChoices":false,"DataExportTag":"debriefing","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Grazie per aver partecipato a questo studio! \u00a0 Lo scopo di questo esperimento era indagare in che...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID198"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID199","SecondaryAttribute":"\u00a0 Questionario In questa sezione ti chiediamo di valutare quattro affermazioni. Per ciascuna, ind..","TertiaryAttribute":null,"Payload":{"QuestionText":"<p dir=\"ltr\" style=\"text-align: center;\">&nbsp;<\/p>\n\n<p dir=\"ltr\" style=\"text-align: center;\"><b>Questionario<\/b><\/p>\n\n<p dir=\"ltr\"><br \/>\nIn questa sezione ti chiediamo di valutare quattro affermazioni. Per ciascuna, indica quanto le consideri in linea con i tuoi principi e valori morali,&nbsp;<u>indipendentemente dall&#39;opinione degli altri<\/u>.<\/p>\n\n<p dir=\"ltr\"><br \/>\nIn altre parole, ti chiediamo di riflettere su quanto ritieni che le seguenti affermazioni siano moralmente giuste.<\/p>\n\n<p dir=\"ltr\"><br \/>\nPuoi scegliere tra quattro alternative (<em>sono molto contrario, sono abbastanza contrario, sono abbstanza d&#39;accordo, sono molto d&#39;accordo<\/em>)<\/p>\n&nbsp;\n\n<div style=\"text-align: center;\">&nbsp;<\/div>","DefaultChoices":false,"QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"\u00a0 Questionario In questa sezione ti chiediamo di valutare quattro affermazioni. Per ciascuna, ind...","Choices":{"1":{"Display":"Garantire a tutti l&#39;accesso ai servizi sanitari essenziali &egrave; un obiettivo che &egrave;&nbsp;<em>doveroso<\/em> contribuire a perseguire"},"2":{"Display":"Aiutare le persone in difficolt&agrave; economica &egrave; un obiettivo che &egrave;&nbsp;<em>doveroso<\/em> contribuire a perseguire"},"3":{"Display":"Tutelare i migranti e le comunit&agrave; nei loro paesi d&#39;origine &egrave; un obiettivo &egrave; <em>doveroso&nbsp;<\/em>contribuire a perseguire"},"4":{"Display":"Sostenere le comunit&agrave; locali colpite da crisi ed emergenze &egrave; un obiettivo che &egrave;&nbsp;<em>doveroso<\/em> contribuire a perseguire"}},"ChoiceOrder":["1","2","3","4"],"Randomization":{"Advanced":{"FixedOrder":["{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}"],"RandomSubSet":[],"RandomizeAll":["1","2","3","4","5"],"ScaleReversal":[],"TotalRandSubset":0,"Undisplayed":[]},"ConsistentScaleReversal":false,"EvenPresentation":false,"TotalRandSubset":"","Type":"Advanced"},"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":6,"Answers":{"1":{"Display":"<strong><em>Sono molto contrario<\/em><\/strong>"},"2":{"Display":"<strong><em>Sono abbastanza contrario<\/em><\/strong>"},"3":{"Display":"<em><strong>Sono abbastanza d&#39;accordo<\/strong><\/em>"},"4":{"Display":"<em><strong>Sono molto d&#39;accordo<\/strong><\/em>"}},"AnswerOrder":[1,2,3,4],"ChoiceDataExportTags":false,"QuestionText_Unsafe":"<p dir=\"ltr\">In questa sezione ti chiediamo di valutare quattro affermazioni. Per ciascuna, indica quanto le consideri in linea con i tuoi principi e valori morali,&nbsp;<u>indipendentemente dall&#39;opinione degli altri<\/u>.<\/p>\n\n<p dir=\"ltr\"><br \/>\nIn altre parole, ti chiediamo di riflettere su quanto ritieni che le seguenti affermazioni si