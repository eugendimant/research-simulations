.display = \"block\";  \/\/ Make sure the image is visible\n            setTimeout(function() {\n                imageContainer.style.width = '500px';\n                imageContainer.style.height = '400px';\n            }, 500);  \/\/ Start the animation after 0.5 seconds\n        };\n        \n        \/\/ Force the image to load by changing its `src`\n        image.src = image.src;\n    });\n<\/script>\n","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID191\/SelectableChoice\/5","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Prima sezione\n\n&amp;nbsp;\n\nIn questa prima sezione dello studio dovrai effettuare una scelta, che ti descriviamo in breve di seguito.&amp;nbsp;\n\n\nTi informiamo che&amp;nbsp;grazie alla tua partecipazione allo ...<\/span> <span class=\"LeftOpDesc\">&lt;div style=\"margin-left: 40px;\"&gt;Con la mia donazione, voglio sostenere iniziative volte alla tutela della &lt;strong&gt;salute&lt;\/strong&gt; fisica e mentale di tutti, specialmente degli anziani e delle persone con disabilit&amp;agrave;.&lt;br \/&gt;\n&lt;br \/&gt;\n&amp;nbsp; &lt;img height=\"229\" src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_2rFQkCSNi5LSpDg\" style=\"width: 339px; height: 229px; border-width: 2px; border-style: solid;\" width=\"339\" \/&gt;&lt;\/div&gt;\n<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID191\/SelectableChoice\/5","LogicType":"Question","Operator":"Selected","QuestionID":"QID191","QuestionIDFromLocator":"QID191","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionText_Unsafe":"<div id=\"imageContain