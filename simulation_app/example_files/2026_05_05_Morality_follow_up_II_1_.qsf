3776702880859375,"CSSliderMax":2,"GridLines":10,"NumDecimals":2,"ShowValue":false,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Adesso ti chiediamo di decidere quanto vuoi donare a Croce Rossa Italiana. Potrai tenere per te t...","Choices":{"1":{"Display":"donazione"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":3,"Labels":[],"QuestionID":"QID104"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID105","SecondaryAttribute":"Adesso ti chiediamo di decidere quanto vuoi donare a Croce Rossa Italiana. Potrai tenere per te t...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"values\">\n<div>Adesso ti chiediamo di decidere quanto vuoi donare a Croce Rossa Italiana. Potrai tenere per te tutto ci\u00f2 che non donerai&nbsp;<br>\n<br>\nDonazione a Croce Rossa: <span id=\"donation\">\u20ac0.01<\/span><\/div>\n<div>Rimane per te: <span id=\"remaining\">\u20ac1.99<\/span><\/div>\n<\/div>\n<br>\n<br>\n<div>Seleziona quanto vuoi donare:<div>\n\n<\/div><\/div>","QuestionJS":false,"DefaultChoices":false,"DataExportTag":"P3SDDON","QuestionType":"Slider","Selector":"HBAR","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0.01000000000000000020816681711721685132943093776702880859375,"CSSliderMax":2,"GridLines":10,"NumDecimals":2,"ShowValue":false,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Adesso ti chiediamo di decidere quanto vuoi donare a Croce Rossa Italiana. Potrai tenere per te t...","Choices":{"1":{"Display":"donazione"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":3,"Labels":[],"QuestionID":"QID105"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID106","SecondaryAttribute":"Adesso ti chiediamo di decidere quanto vuoi donare a Croce Rossa Italiana. Se questa scelta verr\u00e0..","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"values\">\n<div>Adesso ti chiediamo di decidere quanto vuoi donare a Croce Rossa Italiana. Se questa scelta verr\u00e0 selezionata casualmente, potrai tenere per te tutto ci&ograve; che non donerai.&nbsp;<br \/>\n<br \/>\nDonazione a Croce Rossa: <span id=\"donation\">&euro;0.01<\/span><\/div>\n<div>Rimane per te: <span id=\"remaining\">&euro;99.99<\/span><\/div>\n<\/div>\n\n<script>\n\/\/ Self-executing function to avoid polluting global namespace\n(function() {\n    \/\/ Function to update all display values\n    function updateDisplays(value) {\n        \/\/ Ensure valid number\n        value = Math.max(0.01, Math.min(100, parseFloat(value) || 0.01));\n       \n        \/\/ Format values\n        var donationAmount = value.toFixed(2);\n        var remainingAmount = (100 - value).toFixed(2);\n       \n        \/\/ Update display elements\n        document.getElementById('donation').textContent = \"\u20ac\" + donationAmount;\n        document.getElementById('remaining').textContent = \"\u20ac\" + remainingAmount;\n    }\n   \n    \/\/ Function to find and monitor the slider\n    function findAndMonitorSlider() {\n        var slider = document.querySelector('input[type=\"range\"]');\n       \n        if (slider) {\n            console.log(\"Slider found with value: \" + slider.value);\n           \n            \/\/ Initial update\n            updateDisplays(slider.value);\n           \n            \/\/ Attach event handlers\n            slider.oninput = function() {\n                updateDisplays(this.value);\n            };\n           \n            slider.onchange = function() {\n                updateDisplays(this.value);\n            };\n        } else {\n            \/\/ Try again if slider not found\n            setTimeout(findAndMonitorSlider, 300);\n        }\n    }\n   \n    \/\/ Wait for document to be ready\n    if (document.readyState === \"complete\" || document.readyState === \"interactive\") {\n        \/\/ Document already ready\n        findAndMonitorSlider();\n    } else {\n        \/\/ Wait for document to be ready\n        document.addEventListener(\"DOMContentLoaded\", findAndMonitorSlider);\n    }\n   \n    \/\/ Also try after a short delay in case the slider is added dynamically\n    setTimeout(findAndMonitorSlider, 500);\n})();\n<\/script>\n\n","QuestionJS":false,"DefaultChoices":false,"DataExportTag":"P3CDON","QuestionType":"Slider","Selector":"HBAR","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0.01000000000000000020816681711721685132943093776702880859375,"CSSliderMax":100,"GridLines":10,"NumDecimals":2,"ShowValue":false,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Adesso ti chiediamo di decidere quanto vuoi donare a Croce Rossa Italiana. Se questa scelta verr\u00e0...","Choices":{"1":{"Display":"donazione"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":3,"Labels":[],"QuestionID":"QID106"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID107","SecondaryAttribute":"Adesso ti chiediamo di decidere quanto vuoi donare a Croce Rossa Italiana. Se questa scelta verr\u00e0..","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"values\">\n<div>Adesso ti chiediamo di decidere quanto vuoi donare a Croce Rossa Italiana. Se questa scelta verr\u00e0 selezionata casualmente, potrai tenere per te tutto ci&ograve; che non donerai.&nbsp;<br \/>\n<br \/>\nDonazione a Croce Rossa: <span id=\"donation\">&euro;0.01<\/span><\/div>\n<div>Rimane per te: <span id=\"remaining\">&euro;99.99<\/span><\/div>\n<\/div>\n\n<script>\n\/\/ Self-executing function to avoid polluting global namespace\n(function() {\n    \/\/ Function to update all display values\n    function updateDisplays(value) {\n        \/\/ Ensure valid number\n        value = Math.max(0.01, Math.min(100, parseFloat(value) || 0.01));\n       \n        \/\/ Format values\n        var donationAmount = value.toFixed(2);\n        var remainingAmount = (100 - value).toFixed(2);\n       \n        \/\/ Update display elements\n        document.getElementById('donation').textContent = \"\u20ac\" + donationAmount;\n        document.getElementById('remaining').textContent = \"\u20ac\" + remainingAmount;\n    }\n   \n    \/\/ Function to find and monitor the slider\n    function findAndMonitorSlider() {\n        var slider = document.querySelector('input[type=\"range\"]');\n       \n        if (slider) {\n            console.log(\"Slider found with value: \" + slider.value);\n           \n            \/\/ Initial update\n            updateDisplays(slider.value);\n           \n            \/\/ Attach event handlers\n            slider.oninput = function() {\n                updateDisplays(this.value);\n            };\n           \n            slider.onchange = function() {\n                updateDisplays(this.value);\n            };\n        } else {\n            \/\/ Try again if slider not found\n            setTimeout(findAndMonitorSlider, 300);\n        }\n    }\n   \n    \/\/ Wait for document to be ready\n    if (document.readyState === \"complete\" || document.readyState === \"interactive\") {\n        \/\/ Document already ready\n        findAndMonitorSlider();\n    } else {\n        \/\/ Wait for document to be ready\n        document.addEventListener(\"DOMContentLoaded\", findAndMonitorSlider);\n    }\n   \n    \/\/ Also try after a short delay in case the slider is added dynamically\n    setTimeout(findAndMonitorSlider, 500);\n})();\n<\/script>\n\n","QuestionJS":false,"DefaultChoices":false,"DataExportTag":"P2CDDON","QuestionType":"S