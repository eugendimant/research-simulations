":[],"NextChoiceId":20,"NextAnswerId":1,"QuestionID":"QID38"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID39","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"TP3 C","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":24,"NextAnswerId":1,"QuestionID":"QID39"}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID4","SecondaryAttribute":"Donazioni a Croce Rossa Italiana \u00a0 Le scelte che prenderai in questo studio riguardano la possibi..","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><strong>Donazioni a Croce Rossa Italiana<\/strong><\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\nLe scelte che prenderai in questo studio riguardano la possibilit&agrave; di donare a&nbsp;<em>Croce Rossa Italiana<\/em>.&nbsp;<br \/>\n<em>Croce Rossa Italiana<\/em> &egrave; un&#39;organizzazione di volontariato che fa parte del Movimento Internazionale della Croce Rossa e Mezzaluna Rossa. Ha come obiettivo principale l&#39;assistenza sanitaria e sociale, sia in situazioni di emergenza che nella vita quotidiana.<br \/>\n<br \/>\n<br \/>\nDi seguito trovi illustrate alcuni tra i principali ambiti di attivit&agrave; di Croce Rossa.<br \/>\n&nbsp;\n<div style=\"text-align: center;\"><img src=\"https:\/\/imtllucca.fra1.qualtrics.com\/CP\/Graphic.php?IM=IM_4Jdux16XW5Q8iAm\" style=\"width: 977px; height: 549px;\" \/><\/div>\n<br \/>\nDunque se troverai menzionata in seguito una donazione a <em>Croce Rossa Italiana<\/em>, si tratter&agrave; sempre di una donazione all&#39;organizzazione appena descritta.<br \/>\n<br \/>\nSe deciderai di fare una donazione durante lo studio, questa<u> sar&agrave; sempre effettuata dai ricercatori coinvolti nello studio<\/u><em> <\/em>e non da te personalmente.<br \/>\nNota inoltre che se deciderai di fare una donazione all&#39;associazione,<strong> <\/strong><u><strong>non<\/strong> potrai indirizzarla in alcun modo ad uno specifico degli ambiti menzionati, ma all&#39;associazione in generale<\/u>.&nbsp;La scelta dell&#39;utilizzo e della destinazione delle donazioni ricadr&agrave; nelle mani degli operatori dell&#39;organizzazione in conformit&agrave; con la procedura standard adottata da Croce Rossa Italiana (<a href=\"https:\/\/dona.cri.it\/sostienici\/~mia-donazione\">Sostieni ora la Croce Rossa Italiana<\/a>).&nbsp;<br \/>\n<br \/>\n<br \/>\nDi seguito ti chiediamo di rispondere ad una domanda prima di iniziare lo studio.","DefaultChoices":false,"DataExportTag":"Info Croce Rossa","QuestionID":"QID4","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Donazioni a Croce Rossa Italiana \u00a0 Le scelte che prenderai in questo studio riguardano la possibi...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_e8Ws797qI5UeasS","Element":"SQ","PrimaryAttribute":"QID40","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"T FINAL C","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswe