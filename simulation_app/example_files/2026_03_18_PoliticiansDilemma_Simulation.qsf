TertiaryAttribute":"1.1.0","Payload":{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"QC","PrimaryAttribute":"Survey Question Count","SecondaryAttribute":"124","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"RS","PrimaryAttribute":"RS_6Lmrq22kJS3NZHg","SecondaryAttribute":"Default Response Set","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"true","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":"None","SurveyTermination":"DefaultMessage","Header":"","Footer":"","ProgressBarDisplay":"None","PartialData":"+1 week","ValidationMessage":null,"PreviousButton":"","NextButton":"","SurveyTitle":"Qualtrics Survey | Qualtrics Experience Management","SkinLibrary":"upenn","SkinType":"component","Skin":{"brandingId":"6057378996","templateId":"*simple","overrides":null},"NewScoring":1,"SurveyMetaDescription":"The most powerful, simple and trusted way to gather experience data. Start your journey to experience management and try a free account today.","SurveyName":"Politician\u2019s Dilemma","EOSMessage":null,"ShowExportTags":"false","CollectGeoLocation":"false","PasswordProtection":"No","AnonymizeResponse":"No","RefererCheck":"No","BallotBoxStuffingPreventionBehavior":null,"BallotBoxStuffingPreventionMessage":null,"BallotBoxStuffingPreventionMessageLibrary":null,"BallotBoxStuffingPreventionURL":null,"RecaptchaV3":"false","ConfirmStart":false,"AutoConfirmStart":false,"RelevantID":"false","RelevantIDLockoutPeriod":"+30 days","UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessageLibrary":null,"ResponseSummary":"No","EOSMessageLibrary":null,"EOSRedirectURL":null,"EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":"DefaultMessage","PartialDeletion":null,"PartialDataCloseAfter":"LastActivity","InactiveMessageLibrary":null,"InactiveMessage":null,"AvailableLanguages":{"EN":[]},"ProtectSelectionIds":true,"CustomStyles":{"customCSS":"@import url('https:\/\/fonts.googleapis.com\/css2?family=IBM+Plex+Mono:wght@400;500&display=swap');\n\n\/* ===== GLOBAL FONT ===== *\/\n.Skin * {\n  font-family: 'Open Sans', Arial, sans-serif !important;\n}\n.Skin .IBM, .Skin [class*=\"Mono\"] {\n  font-family: 'IBM Plex Mono', monospace !important;\n}\n\n\/* ===== QUESTION\/CHOICE ALIGNMENT ===== *\/\n.QuestionText {\n  text-align: left !important;\n}\n.ChoiceStructure .LabelWrapper {\n  text-align: left !important;\n}\n\n\/* ===== PROGRESS BAR - TEAL ===== *\/\n.ProgressBarFill {\n  background-color: #00897B !important;\n}\n\n\/* ===== NEXT BUTTON - TEAL ===== *\/\n#NextButton {\n  background-color: #00897B !important;\n  border-color: #00897B !important;\n  color: white !important;\n}\n#NextButton:hover {\n  background-color: #00695C !important;\n  border-color: #00695C !important;\n}\n\n\/* ===== DEBATE CONTAINER ===== *\/\n.debate-container {\n    --candidateA-bg: #E0F2F1; --candidateA-border: #00897B; --candidateA-label: #00695C;\n    --candidateB-bg: #FEF3C7; --candidateB-border: #F59E0B; --candidateB-label: #D97706;\n    --surface: #FAFAF9; --card: #FFFFFF; --text: #1C1917; --subtext: #78716C;\n    --border: #E7E5E4; --progress-track: #E7E5E4; --progress-fill: #44403C;\n    --btn-bg: #1C1917; --btn-hover: #44403C; --typing-bg: #F5F5F4;\n    font-family: 'Open Sans', Arial, sans-serif;\n    color: var(--text);\n    width: 100%;\n    max-width: 720px;\n    margin: 0 auto;\n}\n.debate-container .page-header { margin-bottom: 32px; }\n.debate-container .page-header .label { font-family: 'IBM Plex Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--subtext); margin-bottom: 8px; }\n.debate-container .page-header h1 { font-size: 22px; font-weight: 600; line-height: 1.3; color: var(--text); }\n.debate-container .page-header p { margin-top: 8px; font-size: 15px; color: var(--subtext); font-style: italic; line-height: 1.6; }\n.debate-container .progress-row { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; }\n.debate-container .progress-track { flex: 1; height: 4px; background: var(--progress-track); border-radius: 2px; overflow: hidden; }\n.debate-container .progress-fill { height: 100%; background: var(--progress-fill); border-radius: 2px; transition: width 0.5s ease; width: 0%; }\n.debate-container .progress-label { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--subtext); white-space: nowrap; }\n.debate-container #bubble-area { display: flex; flex-direction: column; gap: 14px; min-height: 60px; }\n.debate-container .bubble { padding: 16px 20px; border-radius: 10px; border-left: 4px solid transparent; opacity: 0; transform: translateY(10px); animation: bubbleIn 0.4s ease forwards; line-height: 1.7; font-size: 15.5px; }\n@keyframes bubbleIn { to { opacity: 1; transform: translateY(0); } }\n\n\/* Candidate A - Teal, left-aligned *\/\n.debate-container .bubble.dem {\n    background: var(--candidateA-bg);\n    border-left-color: var(--candidateA-border);\n    border-right: none;\n    margin-right: 15%;\n    margin-left: 0;\n    text-align: left;\n}\n\/* Candidate B - Amber, right-aligned *\/\n.debate-container .bubble.rep {\n    background: var(--candidateB-bg);\n    border-left: none;\n    border-right: 4px solid var(--candidateB-border);\n    margin-left: 15%;\n    margin-right: 0;\n    text-align: right;\n}\n\n.debate-container .bubble .speaker-tag { display: block; font-family: 'IBM Plex Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500; margin-bottom: 7px; }\n.debate-container .bubble.dem .speaker-tag { color: var(--candidateA-label); }\n.debate-container .bubble.rep .speaker-tag { color: var(--candidateB-label); }\n.debate-container .bubble .bubble-text { color: var(--text); }\n.debate-container #typing-row { display: none; align-items: center; gap: 10px; padding: 14px 18px; background: var(--typing-bg); border-radius: 10px; margin-top: 14px; opacity: 0; transition: opacity 0.3s ease; }\n.debate-container #typing-row.visible { display: flex; opacity: 1; }\n.debate-container #typing-name { font-family: 'IBM Plex Mono', monospace; font-size: 12px; color: var(--subtext); }\n.debate-container .dot-row { display: flex; gap: 4px; align-items: center; }\n.debate-container .dot-row span { width: 6px; height: 6px; background: var(--subtext); border-radius: 50%; display: inline-block; animation: blink 1.2s infinite; }\n.debate-container .dot-row span:nth-child(2) { animation-delay: 0.2s; }\n.debate-container .dot-row span:nth-child(3) { animation-delay: 0.4s; }\n@keyframes blink { 0%, 80%, 100% { opacity: 0.25; transform: scale(0.85); } 40% { opacity: 1; transform: scale(1); } }\n.debate-container #continue-btn { display: none; margin-top: 22px; padding: 12px 28px; background: var(--btn-bg); color: white; border: none; border-radius: 8px; font-family: 'IBM Plex Mono', monospace; font-size: 13px; letter-spacing: 0.04em; cursor: pointer; transition: background 0.2s ease, transform 0.1s ease; }\n.debate-container #continue-btn:hover { background: var(--btn-hover); transform: translateY(-1px); }\n.debate-container #continue-btn:active { transform: translateY(0); }\n.debate-container #completion-banner { display: none; margin-top: 24px; padding: 16px 20px; background: #F0FDF4; border: 1px solid #BBF7D0; border-radius: 10px; font-size: 14px; color: #166534; font-style: italic; }\n.debate-container .turn-divider { height: 1px; background: var(--border); margin: 6px 0 2px; opacity: 0; animation: fadeIn 0.4s ease 0.3s forwards; }\n@keyframes fadeIn { to { opacity: 1; } }\n.debate-container .instructions { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 16px 20px; margin-bottom: 28px; font-size: 14px; color: var(--subtext); line-height: 1.6; }\n.debate-container .instructions strong { color: var(--text); }"}}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID1","SecondaryAttribute":"You are being asked to complete a survey as part of a research study.\u00a0 What is the purpose of thi..","TertiaryAttribute":null,"Payload":{"QuestionText":"You are being asked to complete a survey as part of a research study.&nbsp;<br>\n<br>\n<b><i>What is the purpose of this research?&nbsp;<\/i><\/b>The purpose of this research is to understand people\u2019s opinions on current political issues, how they communicate those opinions, as well as their views on other people in the context of political debates.<br><br><p>\n<b><i>How long will I take part in this research?<\/i><\/b>&nbsp;Your participation for the entire study will be 5-10 minutes.<br>\n<br>\n<b><i>What can I expect if I take part in this research?<\/i><\/b>&nbsp;As a participant you will read debate transcripts from political or non-political debates and fill out a short questionnaire about your views on the participants in the debate (e.g. two politicians, two strangers, etc.). You will also be asked to explain your opinions on political issues to future study participants. \n<br>\n<br>\n<b><i>What should I know about a research study?&nbsp;<\/i><\/b><br>\n<br>\n\u2022 Whether or not you take part is up to you.<br>\n\u2022 Your participation is completely voluntary.<br>\n\u2022 You can choose not to take part.<br>\n\u2022 You can agree to take part and later change your mind.<br>\n\u2022 Your decision will not be held against you. &nbsp;<br>\n\u2022 Your refusal to participate will not result in any consequences or any loss of benefits that you are otherwise entitled to receive.<br>\n\u2022 You can ask all the questions you want before you decide.<br>\n<br>\n<b><i>What are the risks and possible discomforts?&nbsp;<\/i><\/b>We do not foresee any risks from participating in the study. Some political issues described in this study may be sensitive to some participants. However, all issues described in this study are regularly discussed in the media and the probability of discomfort is no greater than in daily life. Participants can exit the survey at any time if they feel uncomfortable. \n<br>\n<br>\n<b><i>Will I be compensated for participating in this research?&nbsp;<\/i><\/b>Participants recruited from Prolific will receive the amount listed in the posting. You must complete the survey and answer all questions in order to be compensated.\n<\/p><p><br><\/p>\n\n<p><b><i>Who can I talk to?&nbsp;<\/i><\/b>If you have questions, concerns, or complaints, or think the research has hurt you, talk to the research team at hspohn@g.harvard.edu.  \n<\/p><p>&nbsp;<\/p>\n\n<p><b><i>Statement of Consent<\/i><\/b>: Being in this study is voluntary. If you want to participate in this study, click the button below. Please save or print a copy of this form for your records.\n<\/p>","DefaultChoices":false,"DataExportTag":"consent","QuestionID":"QID1","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You are being asked to complete a survey as part of a research study.\u00a0 What is the purpose of thi...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID10","SecondaryAttribute":"In general, do you think of yourself as","TertiaryAttribute":null,"Payload":{"QuestionText":"In general, do you think of yourself as","DataExportTag":"Liberal\/Conservative","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In general, do you think of yourself as","Choices":{"1":{"Display":"Extremely liberal"},"2":{"Display":"Liberal"},"3":{"Display":"Slightly liberal"},"4":{"Display":"Moderate"},"5":{"Display":"Slightly conservative"},"6":{"Display":"Conservative"},"7":{"Display":"Extremely conservative"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":8,"NextAnswerId":1,"QuestionID":"QID10"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID100","SecondaryAttribute":"Imagine the following scenario There are two candidates running for a seat in the house of repres...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center; font-family: Calibri, sans-serif;\n  padding: 30px; border: 2px solid #E5E7EB; border-radius: 12px;\n  background: #F9FAFB; max-width: 600px; margin: 0 auto;\">\n<h2 style=\"font-size: 22px; color: #1F2937; margin-bottom: 16px;\">Imagine the following scenario<\/h2>\n\n<p style=\"font-size: 16px; color: #4B5563; line-height: 1.6;\">There are two candidates running for a seat in the house of representatives for your local district. They are debating the following topic:<\/p>\n\n<div style=\"margin: 20px auto; padding: 16px 24px;\n    background: #E0F2F1; border-left: 5px solid #00897B;\n    border-radius: 6px; display: inline-block;\"><span style=\"font-size: 20px; font-weight: 700; color: #00897B;\">Tariff Policy - should there be increased tariffs on imported goods and services?<\/span><\/div><div style=\"margin: 20px auto; padding: 16px 20px; background: #DBEAFE; border-radius: 8px; text-align: left; max-width: 520px;\">\n<p style=\"font-size: 14px; color: #374151; line-height: 1.6; margin: 0;\"><strong>How to read this debate:<\/strong> Each argument will appear one at a time. Click \"Show next argument\" to reveal the next turn. You will be asked questions about this conversation afterward, so please read carefully.<\/p>\n<\/div>\n\n<p style=\"font-size: 15px; color: #6B7280; margin-top: 16px;\">On the next page, you will read their debate.<\/p>\n<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Imagine the following scenario There are two candidates running for a seat in the house of repres...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"text-align: center; font-family: Calibri, sans-serif;\n  padding: 30px; border: 2px solid #E5E7EB; border-radius: 12px;\n  background: #F9FAFB; max-width: 600px; margin: 0 auto;\">\n<h2 style=\"font-size: 22px; color: #1F2937; margin-bottom: 16px;\">Imagine the following scenario<\/h2>\n\n<p style=\"font-size: 16px; color: #4B5563; line-height: 1.6;\">There are two candidates running for local office. They are debating the following topic:<\/p>\n\n<div style=\"margin: 20px auto; padding: 16px 24px;\n    background: #E0F2F1; border-left: 5px solid #00897B;\n    border-radius: 6px; display: inline-block;\"><span style=\"font-size: 20px; font-weight: 700; color: #00897B;\">${e:\/\/Field\/selected_topic_display} <\/span><\/div>\n\n<p style=\"font-size: 15px; color: #6B7280; margin-top: 16px;\">On the next page, you will read their debate. Please read carefully.<\/p>\n<\/div>","DataExportTag":"introtar","QuestionID":"QID100"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID101","SecondaryAttribute":"Imagine the following scenario There are two candidates running for a seat in the house of repres...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center; font-family: Calibri, sans-serif;\n  padding: 30px; border: 2px solid #E5E7EB; border-radius: 12px;\n  background: #F9FAFB; max-width: 600px; margin: 0 auto;\">\n<h2 style=\"font-size: 22px; color: #1F2937; margin-bottom: 16px;\">Imagine the following scenario<\/h2>\n\n<p style=\"font-size: 16px; color: #4B5563; line-height: 1.6;\">There are two candidates running for a seat in the house of representatives for your local district. They are debating the following topic:<\/p>\n\n<div style=\"margin: 20px auto; padding: 16px 24px;\n    background: #E0F2F1; border-left: 5px solid #00897B;\n    border-radius: 6px; display: inline-block;\"><span style=\"font-size: 20px; font-weight: 700; color: #00897B;\">Abortion Policy - should abortion be banned across the United States?&nbsp;<\/span><\/div><div style=\"margin: 20px auto; padding: 16px 20px; background: #DBEAFE; border-radius: 8px; text-align: left; max-width: 520px;\">\n<p style=\"font-size: 14px; color: #374151; line-height: 1.6; margin: 0;\"><strong>How to read this debate:<\/strong> Each argument will appear one at a time. Click \"Show next argument\" to reveal the next turn. You will be asked questions about this conversation afterward, so please read carefully.<\/p>\n<\/div>\n\n<p style=\"font-size: 15px; color: #6B7280; margin-top: 16px;\">On the next page, you will read their debate.<\/p>\n<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Imagine the following scenario There are two candidates running for a seat in the house of repres...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"text-align: center; font-family: Calibri, sans-serif;\n  padding: 30px; border: 2px solid #E5E7EB; border-radius: 12px;\n  background: #F9FAFB; max-width: 600px; margin: 0 auto;\">\n<h2 style=\"font-size: 22px; color: #1F2937; margin-bottom: 16px;\">Imagine the following scenario<\/h2>\n\n<p style=\"font-size: 16px; color: #4B5563; line-height: 1.6;\">There are two candidates running for local office. They are debating the following topic:<\/p>\n\n<div style=\"margin: 20px auto; padding: 16px 24px;\n    background: #E0F2F1; border-left: 5px solid #00897B;\n    border-radius: 6px; display: inline-block;\"><span style=\"font-size: 20px; font-weight: 700; color: #00897B;\">${e:\/\/Field\/selected_topic_display} <\/span><\/div>\n\n<p style=\"font-size: 15px; color: #6B7280; margin-top: 16px;\">On the next page, you will read their debate. Please read carefully.<\/p>\n<\/div>","DataExportTag":"introabo","QuestionID":"QID101"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID102","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"meta","QuestionType":"Meta","Selector":"Browser","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Browser","TextEntry":1},"2":{"Display":"Version","TextEntry":1},"3":{"Display":"Operating System","TextEntry":1},"4":{"Display":"Screen Resolution","TextEntry":1},"5":{"Display":"Flash Version","TextEntry":1},"6":{"Display":"Java Support","TextEntry":1},"7":{"Display":"User Agent","TextEntry":1}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID102"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID103","SecondaryAttribute":"Instructions In this study, we are interested in your views on hypothetical political candidates...","TertiaryAttribute":null,"Payload":{"QuestionText":"<u><strong>Instructions<\/strong><\/u><br>\n<br>\nIn this study, we are interested in your views on hypothetical political candidates who debate a current policy issue as well as your opinions on those issues. Please answer honestly, your responses will be kept confidential and there are no right or wrong answers.","DefaultChoices":false,"DataExportTag":"ins","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Instructions In this study, we are interested in your views on hypothetical political candidates...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID103"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID104","SecondaryAttribute":"Research in decision making shows that people, when making decisions and answering questions, pre...","TertiaryAttribute":null,"Payload":{"QuestionText":"Research in decision making shows that people, when making decisions and answering questions, prefer not to pay attention and minimize their effort as much as possible. Some studies show that over 50% of people don't carefully read questions. If you are reading this question, please select the word that is closest to \"sun\". Thank you for participating and taking the time to read through the questions carefully!","DefaultChoices":false,"DataExportTag":"attention","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Research in decision making shows that people, when making decisions and answering questions, pre...","Choices":{"1":{"Display":"Cloud"},"2":{"Display":"Table"},"3":{"Display":"House"},"4":{"Display":"Strawberry"}},"ChoiceOrder":["1","2","3","4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID104","Randomization":{"Advanced":null,"Type":"All","TotalRandSubset":""}}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID105","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"consent_timer","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":1,"QuestionID":"QID105"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID106","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"ins_timer","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":1,"QuestionID":"QID106"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID107","SecondaryAttribute":"\u25b6 Review the debate conversation Loading debate... We would like to get your feelings toward Cand.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"debate-accordion\" style=\"margin-bottom:24px;border:1px solid #e5e7eb;\n            border-radius:8px;overflow:hidden;\n            font-family:-apple-system,BlinkMacSystemFont,\n            'Segoe UI',sans-serif;\"><button id=\"toggle-debate-btn\" style=\"width:100%;padding:14px 20px;text-align:left;\n                 background:#f9fafb;border:none;cursor:pointer;\n                 font-size:14px;font-weight:600;color:#374151;\n                 display:flex;align-items:center;gap:8px;\n                 transition:background 0.15s;\"><span id=\"accordion-arrow\" style=\"display:inline-block;transition:transform 0.2s;\n                 font-size:12px;\">\u25b6<\/span> Review the debate conversation<\/button>\n<div id=\"debate-content\" style=\"display:none;padding:20px;border-top:1px solid #e5e7eb;\n              background:#ffffff;max-height:400px;overflow-y:auto;\">\n<p style=\"color:#6b7280;font-size:13px;font-style:italic;\n              margin-top:0;\">Loading debate...<\/p>\n<\/div>\n<\/div>\nWe would like to get your feelings toward <strong>Candidate A and Candidate B.<\/strong>","DefaultChoices":false,"DataExportTag":"dv_trait_accordion","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u25b6 Review the debate conversation Loading debate... We would like to get your feelings toward Cand...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID107","QuestionJS":"\/\/ DV_trait_accordion \u2014 accordion only, no trait ratings on this page\nQualtrics.SurveyEngine.addOnload(function() {\n    var qid = 'trait';\n    var debateOpened = 0;\n    var toggleCount = 0;\n    var firstOpenTime = null;\n    var pageStart = Date.now();\n    window._accordion_totalViewTime = 0;\n    window._accordion_viewStart = null;\n    window._accordion_qid = qid;\n\n    var palette = {\n        dem: { bg: '#E0F2F1', border: '#00897B', text: '#00695C', accent: '#4DB6AC' },\n        rep: { bg: '#FFF8E1', border: '#F57C00', text: '#E65100', accent: '#FFA726' }\n    };\n\n    function setED(key, value) {\n        Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    var contentDiv = document.getElementById('debate-content');\n    var bubbles = null;\n    if (window._debateBubbles) { bubbles = window._debateBubbles; }\n    if (!bubbles) {\n        try {\n            var raw = \"${e:\/\/Field\/debate_json}\";\n            raw = raw.replace(\/&amp;\/g,'&').replace(\/&lt;\/g,'<').replace(\/&gt;\/g,'>').replace(\/&quot;\/g,'\"').replace(\/&#39;\/g,\"'\").replace(\/&#x27;\/g,\"'\").replace(\/&apos;\/g,\"'\");\n            bubbles = JSON.parse(raw);\n        } catch(e) {}\n    }\n\n    \/\/ Store for use by trait rating pages\n    window._thermBubbles = bubbles;\n    window._thermPalette = palette;\n\n    if (bubbles && contentDiv) {\n        var html = '';\n        for (var i = 0; i < bubbles.length; i++) {\n            var b = bubbles[i];\n            var c = palette[b.side] || palette.dem;\n            html += '<div style=\"display:flex;margin-bottom:12px;'\n                + (b.side === 'rep' ? 'justify-content:flex-end;' : '') + '\">'\n                + '<div style=\"max-width:80%;padding:12px 16px;border-radius:16px;'\n                + 'background:' + c.bg + ';'\n                + 'border-left:4px solid ' + c.border + ';'\n                + (b.side === 'rep' ? 'border-bottom-right-radius:4px;' : 'border-bottom-left-radius:4px;')\n                + 'font-size:14px;line-height:1.5;\">'\n                + '<div style=\"font-weight:600;font-size:12px;margin-bottom:4px;'\n                + 'color:' + c.text + ';\">' + b.speaker + '<\/div>'\n                + '<div>\\u201c' + b.text + '\\u201d<\/div>'\n                + '<\/div><\/div>';\n        }\n        contentDiv.innerHTML = html;\n    } else if (contentDiv) {\n        contentDiv.innerHTML = '<p style=\"color:#999;font-style:italic;\">Debate transcript not available.<\/p>';\n    }\n\n    window.toggleDebate = function() {\n        var content = document.getElementById('debate-content');\n        var arrow = document.getElementById('accordion-arrow');\n        if (!content) return;\n        if (content.style.display === 'none') {\n            content.style.display = 'block';\n            if (arrow) arrow.style.transform = 'rotate(90deg)';\n            debateOpened = 1; toggleCount++;\n            window._accordion_viewStart = Date.now();\n            if (firstOpenTime === null) { firstOpenTime = Date.now() - pageStart; setED(qid + '_accordion_firstopen_ms', firstOpenTime); }\n        } else {\n            content.style.display = 'none';\n            if (arrow) arrow.style.transform = 'rotate(0deg)';\n            if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n        }\n        setED(qid + '_accordion_opened', debateOpened);\n        setED(qid + '_accordion_toggles', toggleCount);\n    };\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var btn = document.getElementById('toggle-debate-btn');\n    if (btn) { btn.addEventListener('click', function() { window.toggleDebate(); }); }\n});\n\nQualtrics.SurveyEngine.addOnUnload(function() {\n    if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n    Qualtrics.SurveyEngine.setEmbeddedData(window._accordion_qid + '_accordion_viewtime_ms', String(window._accordion_totalViewTime || 0));\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID108","SecondaryAttribute":"At the beginning of this study you reported that you \"${q:\/\/QID90\/ChoiceGroup\/SelectedChoices}\" t...","TertiaryAttribute":null,"Payload":{"QuestionText":"At the beginning of this study you reported that you \"${q:\/\/QID90\/ChoiceGroup\/SelectedChoices}\" that there should be stricter penalties on businesses for hiring illegal immigrants. Please explain your opinion on this issue.&nbsp;<br><br>We might show your response to a participant in a future study who also reported that they&nbsp;\"${q:\/\/QID90\/ChoiceGroup\/SelectedChoices}\" and ask them how they feel about your opinion.<br>","DefaultChoices":false,"DataExportTag":"open_imm_aligned","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"At the beginning of this study you reported that you \"${q:\/\/QID90\/ChoiceGroup\/SelectedChoices}\" t...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID108","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">topic<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> immigration <\/span>","LeftOperand":"topic","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"immigration","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">target<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> aligned <\/span>","LeftOperand":"target","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"aligned","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID109","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"open_timer","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{