D29\/SelectableChoice\/5","LogicType":"Question","Operator":"Selected","QuestionID":"QID29","QuestionIDFromLocator":"QID29","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"Randomization":{"Advanced":null,"ConsistentScaleReversal":false,"TotalRandSubset":"","Type":"ScaleReversal"}}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID32","SecondaryAttribute":"Would you call yourself a strong ${q:\/\/QID29\/ChoiceGroup\/SelectedChoices} or a not very strong ...","TertiaryAttribute":null,"Payload":{"QuestionText":"Would you call yourself a strong ${q:\/\/QID29\/ChoiceGroup\/SelectedChoices} or a not very strong ${q:\/\/QID29\/ChoiceGroup\/SelectedChoices}?","DataExportTag":"ANES2.2","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Would you call yourself a strong ${q:\/\/QID29\/ChoiceGroup\/SelectedChoices} or a not very strong ...","Choices":{"1":{"Display":"Strong ${q:\/\/QID29\/ChoiceGroup\/SelectedChoices}"},"2":{"Display":"Weak ${q:\/\/QID29\/ChoiceGroup\/SelectedChoices}"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID32","DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID29\/SelectableChoice\/1","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Generally speaking, do you usually think of yourself as a Republican, a Democrat, an Independent, or what?<\/span> <span class=\"LeftOpDesc\">Democratic<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID29\/SelectableChoice\/1","LogicType":"Question","Operator":"Selected","QuestionID":"QID29","QuestionIDFromLocator":"QID29","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID33","SecondaryAttribute":"Confirm that you are not a robot.","TertiaryAttribute":null,"Payload":{"QuestionText":"Confirm that you are not a robot.","DefaultChoices":false,"DataExportTag":"captcha","QuestionType":"Captcha","Selector":"V2","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","Align":"left","Theme":"light"},"QuestionDescription":"Confirm that you are not a robot.","GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID33"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID34","SecondaryAttribute":"Before we start the survey, we need to check your eligibility for this survey. Please answer the...","TertiaryAttribute":null,"Payload":{"QuestionText":"Before we start the survey, we need to check your eligibility for this survey.<br \/>\n<br \/>\n<strong>Please answer the questions below:&nbsp;&nbsp;<\/strong>","DefaultChoices":false,"DataExportTag":"screening_intent","QuestionID":"QID34","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Before we start the survey, we need to check your eligibility for this survey. Please answer the...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID35","SecondaryAttribute":"We\u2019re sorry, but based on your answer you are not eligible to take this survey.","TertiaryAttribute":null,"Payload":{"QuestionText":"<em>We&rsquo;re sorry, but based on your answer you are not eligible to take this survey.<\/em>","DefaultChoices":false,"DataExportTag":"FailedScreen2Test","QuestionID":"QID35","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"We\u2019re sorry, but based on your answer you are not eligible to take this survey.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID36","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"consent","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID36"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID37","SecondaryAttribute":"Individual A (Democratic perspective): \"I appreciate you raising this issue. I don't think polici...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A (Democratic perspective):<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;I appreciate you raising this issue. I don&#39;t think policies like these might be very effective at reforming immigration practices. My concern is that they could worry businesses and make it harder for them to hire specialized workers in science and technology, which the U.S. has relied on for decades. But I also acknowledge that the evaluations of the policies can significantly change depending on which perspective you account for.&quot;<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B (Republican perspective):<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;I understand your perspective and concern about access to specialized talent, and why it worries you. At the same time, don&#39;t you think that imposing these higher fines might encourage companies to hire more American workers? Though I see your point about specialized workers.&quot;<\/p>\n<\/div>","DefaultChoices":false,"DataExportTag":"RR1","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A (Democratic perspective): \"I appreciate you raising this issue. I don't think polici...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID37"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID38","SecondaryAttribute":"Individual A: \"That's a fair point. Yeah, maybe, but I guess that makes me worry about the broade...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\"That's a fair point. Yeah, maybe, but I guess that makes me worry about the broader economic consequences. If the increased penalties indeed make businesses more reluctant to hire foreign-born workers altogether, which has been shown to be crucial for the US labor market, overall labor growth could slow down, which might hurt U.S. GDP in the long run. Though I see why control matters to you.\"<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\"The economic concern and point about GDP are valid. Still, I think some of these implementations might be needed to regain control. I recently read that the number of unauthorized immigrants in the U.S. workforce increased about 7.8 million in 2021 to 9.7 million in 2023, especially in sectors like construction, agriculture, and leisure and hospitality. In order for employers to be willing to give up their illegal labor, these strong workplace enforcement actions could be necessary. What do you think about that?\"<\/p>\n<\/div>","DefaultChoices":false,"DataExportTag":"RR2","QuestionID":"QID38","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \"That's a fair point. Yeah, maybe, but I guess that makes me worry about the broade...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID39","SecondaryAttribute":"Individual A: \"I understand your point about the numbers and it makes sense why you bring it into...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;I understand your point about the numbers and it makes sense why you bring it into the discussion. At the same time, do you think employers should be held solely responsible? Some employers have raised that they might not even be aware they&#39;ve hired unauthorized workers because the documentation process can be quite confusing and overwhelming.&quot;<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;You raise a fair point about employer confusion, especially given how complex the documentation process can be. Still, I think that without meaningful penalties, there might be very little incentive for firms to comply with the law and businesses should probably be held accountable for violating immigration and labor laws. Though I understand your concern about unintentional violations.&quot;<\/p>\n<\/div>","DefaultChoices":false,"DataExportTag":"RR3","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \"I understand your point about the numbers and it makes sense why you bring it into...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID39"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID4","SecondaryAttribute":"Please select which race \/ ethnicity you identify as. (Please select all that apply.)","TertiaryAttribute":null,"Payload":{"QuestionText":"Please select which race \/ ethnicity you identify as. (Please select all that apply.)","DefaultChoices":false,"DataExportTag":"Race","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please select which race \/ ethnicity you identify as. (Please select all that apply.)","Choices":{"1":{"Display":"White \/ Caucasian"},"2":{"Display":"Black \/ African American"},"3":{"Display":"Hispanic \/ Latino"},"4":{"Display":"Asian \/ Asian American"},"5":{"Display":"Other","TextEntry":"true"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID4"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID40","SecondaryAttribute":"Individual A (Democratic perspective): \"I appreciate you raising this issue. I don't think polici...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A (Democratic perspective):<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\"I appreciate you raising this issue. I don't think policies like these might be very effective at reforming immigration practices. My concern is that they could worry businesses and make it harder for them to hire specialized workers in science and technology, which the U.S. has relied on for decades. But I also acknowledge that the evaluations of the policies can significantly change depending on which perspective you account for.\"<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B (Republican perspective):<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\"I don't understand your perspective and concern about access to specialized talent, and why it worries you. At the same time, don't you think that imposing these higher fines might encourage companies to hire more American workers? Personally, I don\u2019t see your point about specialized workers.\"<\/p>\n<\/div>","DefaultChoices":false,"DataExportTag":"RU1","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A (Democratic perspective): \"I appreciate you raising this issue. I don't think polici...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID40"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID41","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"Q41","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID41"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID42","SecondaryAttribute":"Individual A: \"That's a fair point. Yeah, maybe, but I guess that makes me worry about the broade...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\">\n    <strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n    <p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\n      \"That's a fair point. Yeah, maybe, but I guess that makes me worry about the broader economic consequences. If the increased penalties indeed make businesses more reluctant to hire foreign-born workers altogether, which has been shown to be crucial for the US labor market, overall labor growth could slow down, which might hurt U.S. GDP in the long run. Though I see why control matters to you.\"\n    <\/p>\n  <\/div>\n  \n  \n  <div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\">\n    <strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n    <p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\n      \"The economic concern and point about GDP are irrelevant. I think some of these implementations might be needed to regain control. I recently read that the number of unauthorized immigrants in the U.S. workforce increased about 7.8 million in 2021 to 9.7 million in 2023, especially in sectors like construction, agriculture, and leisure and hospitality. In order for employers to be willing to give up their illegal labor, these strong workplace enforcement actions are necessary.\"\n    <\/p>\n  <\/div>","DefaultChoices":false,"DataExportTag":"RU2","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \"That's a fair point. Yeah, maybe, but I guess that makes me worry about the broade...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID42"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID43","SecondaryAttribute":"Individual A: \"I understand your point about the numbers and it makes sense why you bring it into...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\"I understand your point about the numbers and it makes sense why you bring it into the discussion. At the same time, do you think employers should be held solely responsible? Some employers have raised that they might not even be aware they've hired unauthorized workers because the documentation process can be quite confusing and overwhelming.\"<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\"Your point about employer confusion and how complex the document process can be is unfair. I think that without meaningful penalties, there might be very little incentive for firms to comply with the law and businesses should probably be held accountable for violating immigration and labor laws. I don\u2019t understand your concern about unintentional violations.\"<\/p>\n<\/div>","DefaultChoices":false,"DataExportTag":"RU3","QuestionID":"QID43","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \"I understand your point about the numbers and it makes sense why you bring it into...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID44","SecondaryAttribute":"Individual A (Democratic perspective): \"I don't think policies like these might be very effective...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A (Democratic perspective):<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\"I don't think policies like these might be very effective at reforming immigration practices. My concern is that they will worry businesses and make it harder for them to hire specialized workers in science and technology, which the U.S. has relied on for decades. The evaluations of these policies should not change depending on which perspective you account for.\"<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B (Republican perspective):<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\"I understand your perspective and concern about access to specialized talent, and why it worries you. At the same time, don't you think that imposing these higher fines might encourage companies to hire more American workers? Though I see your point about specialized workers.\"<\/p>\n<\/div>","DefaultChoices":false,"DataExportTag":"UR1","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A (Democratic perspective): \"I don't think policies like these might be very effective...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID44"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID45","SecondaryAttribute":"Individual A: \"That's an irrelevant point and I guess it makes me worry about the broader economi...","TertiaryAttribute":null,"Payload":{"QuestionText":"\n  <div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\">\n    <strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n    <p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\n      \"That's an irrelevant point and I guess it makes me worry about the broader economic consequences. If the increased penalties indeed make businesses more reluctant to hire foreign-born workers altogether, which has been shown to be crucial for the US labor market, overall labor growth could slow down, which might hurt U.S. GDP in the long run. Control should not matter to you.\"\n    <\/p>\n  <\/div>\n  \n  \n  <div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\">\n    <strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n    <p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\n      \"The economic concern and point about GDP are valid. Still, I think some of these implementations might be needed to regain control. I recently read that the number of unauthorized immigrants in the U.S. workforce increased about 7.8 million in 2021 to 9.7 million in 2023, especially in sectors like construction, agriculture, and leisure and hospitality. In order for employers to be willing to give up their illegal labor, these strong workplace enforcement actions could be necessary. What do you think about that?\"\n    <\/p>\n  <\/div>","DefaultChoices":false,"DataExportTag":"UR2","QuestionID":"QID45","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \"That's an irrelevant point and I guess it makes me worry about the broader economi...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID46","SecondaryAttribute":"Individual A: \"I don't understand your point about the numbers and it doesn't make sense why you...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\"I don't understand your point about the numbers and it doesn't make sense why you bring it into the discussion. Do you think employers should be held solely responsible? Some employers have raised that they might not even be aware they've hired unauthorized workers because the documentation process can be quite confusing and overwhelming.\"<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\"You raise a fair point about employer confusion, especially given how complex the documentation process can be. Still, I think that without meaningful penalties, there might be very little incentive for firms to comply with the law and businesses should probably be held accountable for violating immigration and labor laws. Though I understand your concern about unintentional violations.\"<\/p>\n<\/div>","DefaultChoices":false,"DataExportTag":"UR3","QuestionID":"QID46","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \"I don't understand your point about the numbers and it doesn't make sense why you...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID47","SecondaryAttribute":"Individual A (Democratic perspective): \"I don't think policies like these might be very effective...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\">\n    <strong style=\"color: #4682b4; font-size: 15px;\">Individual A (Democratic perspective):<\/strong>\n    <p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\n      \"I don't think policies like these might be very effective at reforming immigration practices. My concern is that they will worry businesses and make it harder for them to hire specialized workers in science and technology, which the U.S. has relied on for decades. The evaluations of these policies should not change depending on which perspective you account for.\"\n    <\/p>\n  <\/div>\n  \n  \n  <div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\">\n    <strong style=\"color: #dc143c; font-size: 15px;\">Individual B (Republican perspective):<\/strong>\n    <p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\n      \"I don't understand your perspective and concern about access to specialized talent, and why it worries you. At the same time, don't you think that imposing these higher fines might encourage companies to hire more American workers? Personally, I don\u2019t see your point about specialized workers.\"\n    <\/p>\n  <\/div>","DefaultChoices":false,"DataExportTag":"UU1","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A (Democratic perspective): \"I don't think policies like these might be very effective...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID47"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID48","SecondaryAttribute":"Individual A: \"That's an irrelevant point and I guess it makes me worry about the broader economi...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\">\n    <strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n    <p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\n      \"That's an irrelevant point and I guess it makes me worry about the broader economic consequences. If the increased penalties indeed make businesses more reluctant to hire foreign-born workers altogether, which has been shown to be crucial for the US labor market, overall labor growth could slow down, which might hurt U.S. GDP in the long run. Control should not matter to you.\"\n    <\/p>\n  <\/div>\n  \n  \n  <div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\">\n    <strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n    <p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\n      \"The economic concern and point about GDP are irrelevant. I think some of these implementations might be needed to regain control. I recently read that the number of unauthorized immigrants in the U.S. workforce increased about 7.8 million in 2021 to 9.7 million in 2023, especially in sectors like construction, agriculture, and leisure and hospitality. In order for employers to be willing to give up their illegal labor, these strong workplace enforcement actions are necessary.\"\n    <\/p>\n  <\/div>","DefaultChoices":false,"DataExportTag":"UU2","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \"That's an irrelevant point and I guess it makes me worry about the broader economi...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID48"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID49","SecondaryAttribute":"Individual A: \"I don't understand your point about the numbers and it doesn't make sense why you...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\">\n    <strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n    <p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\n      \"I don't understand your point about the numbers and it doesn't make sense why you bring it into the discussion. Do you think employers should be held solely responsible? Some employers have raised that they might not even be aware they've hired unauthorized workers because the documentation process can be quite confusing and overwhelming.\"\n    <\/p>\n  <\/div>\n  \n  \n  <div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\">\n    <strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n    <p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">\n      \"Your point about employer confusion and how complex the document process can be is unfair. I think that without meaningful penalties, there might be very little incentive for firms to comply with the law and businesses should probably be held accountable for violating immigration and labor laws. I don\u2019t understand your concern about unintentional violations.\"\n    <\/p>\n  <\/div>","DefaultChoices":false,"DataExportTag":"UU3","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \"I don't understand your point about the numbers and it doesn't make sense why you...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID49"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID5","SecondaryAttribute":"To help us keep track of who is paying attention, please select \"Somewhat disagree\" in the option...","TertiaryAttribute":null,"Payload":{"QuestionText":"To help us keep track of who is paying attention, please select \"Somewhat disagree\" in the options below.","DefaultChoices":false,"DataExportTag":"Attention Check","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"To help us keep track of who is paying attention, please select \"Somewhat disagree\" in the option...","Choices":{"1":{"Display":"Strongly agree"},"2":{"Display":"Agree"},"3":{"Display":"Somewhat agree"},"4":{"Display":"Neither agree nor disagree"},"5":{"Display":"Somewhat disagree"},"6":{"Display":"Disagree"},"7":{"Display":"Strongly disagree"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":1,"QuestionID":"QID5"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID50","SecondaryAttribute":"Which individuals will be present in the conversation?","TertiaryAttribute":null,"Payload":{"QuestionText":"Which individuals will be present in the conversation?","DefaultChoices":false,"DataExportTag":"AttentionCheck1","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Which individuals will be present in the conversation?","Choices":{"1":{"Display":"Democrat & Democrat"},"2":{"Display":"Democrat & Republican"},"3":{"Display":"Republican & Republican"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID50"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID51","SecondaryAttribute":"Which perspective does Individual A hold? ","TertiaryAttribute":null,"Payload":{"QuestionText":"Which perspective does Individual A hold?&nbsp;","DefaultChoices":false,"DataExportTag":"AttentionCheck_1","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Which perspective does Individual A hold? ","Choices":{"1":{"Display":"Democratic"},"2":{"Display":"Republican"},"3":{"Display":"Independent"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"CustomValidation","CustomValidation":{"Logic":{"0":{"0":{"QuestionID":"QID51","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID51\/SelectableChoice\/1","Operator":"Selected","QuestionIDFromLocator":"QID51","LeftOperand":"q:\/\/QID51\/SelectableChoice\/1","Type":"Expression","LogicType":"Question","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Which perspective does Individual A hold?&amp;nbsp;<\/span> <span class=\"LeftOpDesc\">Democratic<\/span> <span class=\"OpDesc\">Is Selected<\/span> "},"Type":"If"},"Type":"BooleanExpression"},"Message":{"messageID":"MS_owAXRiZC2Kov1B5","subMessageID":"VE_ERROR","libraryID":"UR_1FYIjP54OnNVZzM","description":"Error Text"}}}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID51"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID52","SecondaryAttribute":"Which topic will Individual A and B discuss? ","TertiaryAttribute":null,"Payload":{"QuestionText":"Which topic will Individual A and B discuss?&nbsp;","DefaultChoices":false,"DataExportTag":"AttentionCheck_2","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Which topic will Individual A and B discuss? ","Choices":{"1":{"Display":"Death penalty"},"2":{"Display":"Immigration"},"3":{"Display":"Terrorism and national security"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"CustomValidation","CustomValidation":{"Logic":{"0":{"0":{"QuestionID":"QID52","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID52\/SelectableChoice\/2","Operator":"Selected","QuestionIDFromLocator":"QID52","LeftOperand":"q:\/\/QID52\/SelectableChoice\/2","Type":"Expression","LogicType":"Question","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Which topic will Individual A and B discuss? <\/span> <span class=\"LeftOpDesc\">Immigration<\/span> <span class=\"OpDesc\">Is Selected<\/span> "},"Type":"If"},"Type":"BooleanExpression"},"Message":{"messageID":"MS_owAXRiZC2Kov1B5","subMessageID":"VE_ERROR","libraryID":"UR_1FYIjP54OnNVZzM","description":"Error Text"}}}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID52"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID53","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"Q54","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID53"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID54","SecondaryAttribute":"Individual A (Democratic perspective): \"I appreciate you raising this issue. I don't think polici...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A (Democratic perspective):<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;I appreciate you raising this issue. I don&#39;t think policies like these might be very effective at reforming immigration practices. My concern is that they could worry businesses and make it harder for them to hire specialized workers in science and technology, which the U.S. has relied on for decades. But I also acknowledge that the evaluations of the policies can significantly change depending on which perspective you account for.&quot;<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B (Republican perspective):<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;I understand your perspective and concern about access to specialized talent, and why it worries you. At the same time, don&#39;t you think that imposing these higher fines might encourage companies to hire more American workers? Though I see your point about specialized workers.&quot;<\/p>\n<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A (Democratic perspective): \"I appreciate you raising this issue. I don't think polici...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A (Democratic perspective):<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;I appreciate you raising this issue. I don&#39;t think policies like these might be very effective at reforming immigration practices. My concern is that they could worry businesses and make it harder for them to hire specialized workers in science and technology, which the U.S. has relied on for decades. But I also acknowledge that the evaluations of the policies can significantly change depending on which perspective you account for.&quot;<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B (Republican perspective):<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;I understand your perspective and concern about access to specialized talent, and why it worries you. At the same time, don&#39;t you think that imposing these higher fines might encourage companies to hire more American workers? Though I see your point about specialized workers.&quot;<\/p>\n<\/div>","DataExportTag":"Q54","QuestionID":"QID54"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID55","SecondaryAttribute":"Individual A: \"That's a fair point. Yeah, maybe, but I guess that makes me worry about the broade...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;That&#39;s a fair point. Yeah, maybe, but I guess that makes me worry about the broader economic consequences. If the increased penalties indeed make businesses more reluctant to hire foreign-born workers altogether, which has been shown to be crucial for the US labor market, overall labor growth could slow down, which might hurt U.S. GDP in the long run. Though I see why control matters to you.&quot;<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;The economic concern and point about GDP are valid. Still, I think some of these implementations might be needed to regain control. I recently read that the number of unauthorized immigrants in the U.S. workforce increased about 7.8 million in 2021 to 9.7 million in 2023, especially in sectors like construction, agriculture, and leisure and hospitality. In order for employers to be willing to give up their illegal labor, these strong workplace enforcement actions could be necessary. What do you think about that?&quot;<\/p>\n<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \"That's a fair point. Yeah, maybe, but I guess that makes me worry about the broade...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;That&#39;s a fair point. Yeah, maybe, but I guess that makes me worry about the broader economic consequences. If the increased penalties indeed make businesses more reluctant to hire foreign-born workers altogether, which has been shown to be crucial for the US labor market, overall labor growth could slow down, which might hurt U.S. GDP in the long run. Though I see why control matters to you.&quot;<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;The economic concern and point about GDP are valid. Still, I think some of these implementations might be needed to regain control. I recently read that the number of unauthorized immigrants in the U.S. workforce increased about 7.8 million in 2021 to 9.7 million in 2023, especially in sectors like construction, agriculture, and leisure and hospitality. In order for employers to be willing to give up their illegal labor, these strong workplace enforcement actions could be necessary. What do you think about that?&quot;<\/p>\n<\/div>","DataExportTag":"Q55","QuestionID":"QID55"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID56","SecondaryAttribute":"Individual A: \"I understand your point about the numbers and it makes sense why you bring it into...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;I understand your point about the numbers and it makes sense why you bring it into the discussion. At the same time, do you think employers should be held solely responsible? Some employers have raised that they might not even be aware they&#39;ve hired unauthorized workers because the documentation process can be quite confusing and overwhelming.&quot;<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;You raise a fair point about employer confusion, especially given how complex the documentation process can be. Still, I think that without meaningful penalties, there might be very little incentive for firms to comply with the law and businesses should probably be held accountable for violating immigration and labor laws. Though I understand your concern about unintentional violations.&quot;<\/p>\n<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \"I understand your point about the numbers and it makes sense why you bring it into...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;I understand your point about the numbers and it makes sense why you bring it into the discussion. At the same time, do you think employers should be held solely responsible? Some employers have raised that they might not even be aware they&#39;ve hired unauthorized workers because the documentation process can be quite confusing and overwhelming.&quot;<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;You raise a fair point about employer confusion, especially given how complex the documentation process can be. Still, I think that without meaningful penalties, there might be very little incentive for firms to comply with the law and businesses should probably be held accountable for violating immigration and labor laws. Though I understand your concern about unintentional violations.&quot;<\/p>\n<\/div>","DataExportTag":"Q56","QuestionID":"QID56"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID57","SecondaryAttribute":"Individual A (Democratic perspective): \"I appreciate you raising this issue. I don't think polici...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A (Democratic perspective):<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;I appreciate you raising this issue. I don&#39;t think policies like these might be very effective at reforming immigration practices. My concern is that they could worry businesses and make it harder for them to hire specialized workers in science and technology, which the U.S. has relied on for decades. But I also acknowledge that the evaluations of the policies can significantly change depending on which perspective you account for.&quot;<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B (Republican perspective):<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;I understand your perspective and concern about access to specialized talent, and why it worries you. At the same time, don&#39;t you think that imposing these higher fines might encourage companies to hire more American workers? Though I see your point about specialized workers.&quot;<\/p>\n<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A (Democratic perspective): \"I appreciate you raising this issue. I don't think polici...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A (Democratic perspective):<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;I appreciate you raising this issue. I don&#39;t think policies like these might be very effective at reforming immigration practices. My concern is that they could worry businesses and make it harder for them to hire specialized workers in science and technology, which the U.S. has relied on for decades. But I also acknowledge that the evaluations of the policies can significantly change depending on which perspective you account for.&quot;<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B (Republican perspective):<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;I understand your perspective and concern about access to specialized talent, and why it worries you. At the same time, don&#39;t you think that imposing these higher fines might encourage companies to hire more American workers? Though I see your point about specialized workers.&quot;<\/p>\n<\/div>","DataExportTag":"Q57","QuestionID":"QID57"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID58","SecondaryAttribute":"Individual A: \"That's a fair point. Yeah, maybe, but I guess that makes me worry about the broade...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;That&#39;s a fair point. Yeah, maybe, but I guess that makes me worry about the broader economic consequences. If the increased penalties indeed make businesses more reluctant to hire foreign-born workers altogether, which has been shown to be crucial for the US labor market, overall labor growth could slow down, which might hurt U.S. GDP in the long run. Though I see why control matters to you.&quot;<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;The economic concern and point about GDP are valid. Still, I think some of these implementations might be needed to regain control. I recently read that the number of unauthorized immigrants in the U.S. workforce increased about 7.8 million in 2021 to 9.7 million in 2023, especially in sectors like construction, agriculture, and leisure and hospitality. In order for employers to be willing to give up their illegal labor, these strong workplace enforcement actions could be necessary. What do you think about that?&quot;<\/p>\n<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \"That's a fair point. Yeah, maybe, but I guess that makes me worry about the broade...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;That&#39;s a fair point. Yeah, maybe, but I guess that makes me worry about the broader economic consequences. If the increased penalties indeed make businesses more reluctant to hire foreign-born workers altogether, which has been shown to be crucial for the US labor market, overall labor growth could slow down, which might hurt U.S. GDP in the long run. Though I see why control matters to you.&quot;<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;The economic concern and point about GDP are valid. Still, I think some of these implementations might be needed to regain control. I recently read that the number of unauthorized immigrants in the U.S. workforce increased about 7.8 million in 2021 to 9.7 million in 2023, especially in sectors like construction, agriculture, and leisure and hospitality. In order for employers to be willing to give up their illegal labor, these strong workplace enforcement actions could be necessary. What do you think about that?&quot;<\/p>\n<\/div>","DataExportTag":"Q58","QuestionID":"QID58"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID59","SecondaryAttribute":"Individual A: \"I understand your point about the numbers and it makes sense why you bring it into...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;I understand your point about the numbers and it makes sense why you bring it into the discussion. At the same time, do you think employers should be held solely responsible? Some employers have raised that they might not even be aware they&#39;ve hired unauthorized workers because the documentation process can be quite confusing and overwhelming.&quot;<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;You raise a fair point about employer confusion, especially given how complex the documentation process can be. Still, I think that without meaningful penalties, there might be very little incentive for firms to comply with the law and businesses should probably be held accountable for violating immigration and labor laws. Though I understand your concern about unintentional violations.&quot;<\/p>\n<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \"I understand your point about the numbers and it makes sense why you bring it into...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"background-color: #f0f8ff; padding: 15px; margin-bottom: 15px; border-left: 4px solid #4682b4; border-radius: 5px;\"><strong style=\"color: #4682b4; font-size: 15px;\">Individual A:<\/strong>\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;I understand your point about the numbers and it makes sense why you bring it into the discussion. At the same time, do you think employers should be held solely responsible? Some employers have raised that they might not even be aware they&#39;ve hired unauthorized workers because the documentation process can be quite confusing and overwhelming.&quot;<\/p>\n<\/div>\n\n<div style=\"background-color: #fff5f5; padding: 15px; margin-bottom: 15px; border-left: 4px solid #dc143c; border-radius: 5px;\"><strong style=\"color: #dc143c; font-size: 15px;\">Individual B:<\/strong>\n\n<p style=\"margin-top: 8px; margin-bottom: 0; line-height: 1.6; color: #333;\">&quot;You raise a fair point about employer confusion, especially given how complex the documentation process can be. Still, I think that without meaningful penalties, there might be very little incentive for firms to comply with the law and businesses should probably be held accountable for violating immigration and labor laws. Though I understand your concern about unintentional violations.&quot;<\/p>\n<\/div>","DataExportTag":"Q59","QuestionID":"QID59"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID6","SecondaryAttribute":"Generally speaking, do you usually think of yourself as a Republican, a Democrat, an Independent,...","TertiaryAttribute":null,"Payload":{"QuestionText":"Generally speaking, do you usually think of yourself as a Republican, a Democrat, an Independent, or Other?","DefaultChoices":false,"DataExportTag":"Q6","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Generally speaking, do you usually think of yourself as a Republican, a Democrat, an Independent,...","Choices":{"1":{"Display":"Republican"},"2":{"Display":"Democrat"},"3":{"Display":"Independent"},"4":{"Display":"Other","TextEntry":"true"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID6"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID60","SecondaryAttribute":"Immigration Policy \u00b7 Turn-by-turn debate Hypothetical Discussion Individual A holds a Democratic...","TertiaryAttribute":null,"Payload":{"QuestionText":"<title><\/title>\n<style type=\"text\/css\">@import url('https:\/\/fonts.googleapis.com\/css2?family=IBM+Plex+Serif:ital,wght@0,400;0,600;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap');\n\n  :root {\n    --dem-bg: #EBF2FF;\n    --dem-border: #2563EB;\n    --dem-label: #1D4ED8;\n    --rep-bg: #FEF2F2;\n    --rep-border: #DC2626;\n    --rep-label: #B91C1C;\n    --surface: #FAFAF9;\n    --card: #FFFFFF;\n    --text: #1C1917;\n    --subtext: #78716C;\n    --border: #E7E5E4;\n    --progress-track: #E7E5E4;\n    --progress-fill: #44403C;\n    --btn-bg: #1C1917;\n    --btn-hover: #44403C;\n    --typing-bg: #F5F5F4;\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    font-family: 'IBM Plex Serif', Georgia, serif;\n    background: var(--surface);\n    color: var(--text);\n    min-height: 100vh;\n    display: flex;\n    justify-content: center;\n    align-items: flex-start;\n    padding: 40px 16px 80px;\n  }\n\n  .page-wrapper { width: 100%; max-width: 720px; }\n\n  .page-header { margin-bottom: 32px; }\n  .page-header .label {\n    font-family: 'IBM Plex Mono', monospace;\n    font-size: 11px;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: var(--subtext);\n    margin-bottom: 8px;\n  }\n  .page-header h1 { font-size: 22px; font-weight: 600; line-height: 1.3; color: var(--text); }\n  .page-header p { margin-top: 8px; font-size: 15px; color: var(--subtext); font-style: italic; line-height: 1.6; }\n\n  .progress-row { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; }\n  .progress-track { flex: 1; height: 4px; background: var(--progress-track); border-radius: 2px; overflow: hidden; }\n  .progress-fill { height: 100%; background: var(--progress-fill); border-radius: 2px; transition: width 0.5s ease; width: 0%; }\n  .progress-label { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--subtext); white-space: nowrap; }\n\n  #bubble-area { display: flex; flex-direction: column; gap: 14px; min-height: 60px; }\n\n  .bubble {\n    padding: 16px 20px;\n    border-radius: 10px;\n    border-left: 4px solid transparent;\n    opacity: 0;\n    transform: translateY(10px);\n    animation: bubbleIn 0.4s ease forwards;\n    line-height: 1.7;\n    font-size: 15.5px;\n  }\n  @keyframes bubbleIn { to { opacity: 1; transform: translateY(0); } }\n  .bubble.dem { background: var(--dem-bg); border-left-color: var(--dem-border); }\n  .bubble.rep { background: var(--rep-bg); border-left-color: var(--rep-border); }\n  .bubble .speaker-tag {\n    display: block;\n    font-family: 'IBM Plex Mono', monospace;\n    font-size: 11px;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    font-weight: 500;\n    margin-bottom: 7px;\n  }\n  .bubble.dem .speaker-tag { color: var(--dem-label); }\n  .bubble.rep .speaker-tag { color: var(--rep-label); }\n  .bubble .bubble-text { color: var(--text); }\n\n  #typing-row {\n    display: none;\n    align-items: center;\n    gap: 10px;\n    padding: 14px 18px;\n    background: var(--typing-bg);\n    border-radius: 10px;\n    margin-top: 14px;\n    opacity: 0;\n    transition: opacity 0.3s ease;\n  }\n  #typing-row.visible { display: flex; opacity: 1; }\n  #typing-name { font-family: 'IBM Plex Mono', monospace; font-size: 12px; color: var(--subtext); }\n  .dot-row { display: flex; gap: 4px; align-items: center; }\n  .dot-row span {\n    width: 6px; height: 6px;\n    background: var(--subtext);\n    border-radius: 50%;\n    display: inline-block;\n    animation: blink 1.2s infinite;\n  }\n  .dot-row span:nth-child(2) { animation-delay: 0.2s; }\n  .dot-row span:nth-child(3) { animation-delay: 0.4s; }\n  @keyframes blink {\n    0%, 80%, 100% { opacity: 0.25; transform: scale(0.85); }\n    40% { opacity: 1; transform: scale(1); }\n  }\n\n  #continue-btn {\n    display: none;\n    margin-top: 22px;\n    padding: 12px 28px;\n    background: var(--btn-bg);\n    color: white;\n    border: none;\n    border-radius: 8px;\n    font-family: 'IBM Plex Mono', monospace;\n    font-size: 13px;\n    letter-spacing: 0.04em;\n    cursor: pointer;\n    transition: background 0.2s ease, transform 0.1s ease;\n  }\n  #continue-btn:hover { background: var(--btn-hover); transform: translateY(-1px); }\n  #continue-btn:active { transform: translateY(0); }\n\n  #completion-banner {\n    display: none;\n    margin-top: 24px;\n    padding: 16px 20px;\n    background: #F0FDF4;\n    border: 1px solid #BBF7D0;\n    border-radius: 10px;\n    font-size: 14px;\n    color: #166534;\n    font-style: italic;\n  }\n\n  .turn-divider {\n    height: 1px;\n    background: var(--border);\n    margin: 6px 0 2px;\n    opacity: 0;\n    animation: fadeIn 0.4s ease 0.3s forwards;\n  }\n  @keyframes fadeIn { to { opacity: 1; } }\n\n  .instructions {\n    background: var(--card);\n    border: 1px solid var(--border);\n    border-radius: 10px;\n    padding: 16px 20px;\n    margin-bottom: 28px;\n    font-size: 14px;\n    color: var(--subtext);\n    line-height: 1.6;\n  }\n  .instructions strong { color: var(--text); }\n<\/style>\n<div class=\"page-wrapper\">\n<div class=\"page-header\">\n<div class=\"label\">Immigration Policy &middot; Turn-by-turn debate<\/div>\n\n<h1>Hypothetical Discussion<\/h1>\n\n<p>Individual A holds a <strong>Democratic<\/strong> perspective; Individual B holds a <strong>Republican<\/strong> perspective.<\/p>\n<\/div>\n\n<div class=\"instructions\"><strong>How to read this debate:<\/strong> Each message will appear one at a time. Click <em>&quot;Show next message&quot;<\/em> to reveal the next turn. You will be asked questions about this conversation afterward, so please read carefully.<\/div>\n\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\">&nbsp;<\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next message &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"Q60","QuestionID":"QID60","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Immigration Policy \u00b7 Turn-by-turn debate Hypothetical Discussion Individual A holds a Democratic...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID61","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startdem ","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID61","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"Increased penalties on businesses for hiring staff without legal work authorization risk is creating a chilling effect across the labor market. The U.S. has long relied on specialized science and tech workers from abroad, and these penalties could make employers hesitant to engage with the talent pipeline altogether. That said, I recognize that stricter enforcement raises legitimate concerns about the current system.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"I appreciate that concern, and protecting access to specialized talent is important. At the same time, I believe higher fines would encourage companies to prioritize American workers, which is an effective way to curb the hiring of unauthorized immigrants. Strengthening enforcement could send a clear signal that the rules apply to everyone.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"That's a fair point. Yeah, maybe, but I guess that makes me worry about the broader economic consequences. If the increased penalties indeed make businesses more reluctant to hire foreign-born workers altogether, which has been shown to be crucial for the US labor market, overall labor growth could slow down, which might hurt U.S. GDP in the long run. Though I see why control matters to you.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"That's a fair point, and discouraging unauthorized hiring is a goal we share. But if harsher penalties make businesses broadly reluctant to hire foreign-born workers, who have been shown to be crucial for the U.S. labor market, it could slow down labor growth and hurt GDP over the long term. The challenge is getting enforcement right without undermining economic growth.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"I can see why enforcement feels necessary given those numbers. At the same time, harsher penalties, thereby holding employers solely responsible may not be entirely fair. The documentation verification process is complex, and some employers have reported difficulty distinguishing authorized from unauthorized workers. Accountability matters, but so does ensuring the system is navigable.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"That's a reasonable concern, especially given how complex the documentation process can be. Still, without meaningful penalties, there is little incentive for firms to comply with immigration and labor laws. Businesses should be held accountable, though I do think there is a point in creating a system that also supports employers in meeting those obligations.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'imm_rr_d';\n\n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID62","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startrep","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID62","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"Increased penalties on businesses for hiring staff without legal work authorization could be an effective step toward reforming immigration enforcement. Higher fines would encourage companies to prioritize American workers and send a clear signal that labor laws must be respected. That said, I recognize that stricter enforcement raises legitimate concerns.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"I appreciate that perspective, and strengthening enforcement is an understandable priority. At the same time, these higher fines could worry businesses and make it harder for them to hire specialized workers in science and technology, which the U.S. has relied on for decades. The risk is that penalties aimed at unauthorized hiring end up discouraging legal hiring as well.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"That's fair, and I understand this could create real challenges for industries that depend on foreign-born talent. Still, unauthorized immigration in the U.S. workforce grew from roughly 7.8 million in 2021 to 9.7 million in 2023, concentrated in construction, agriculture, and hospitality. That level of growth suggests stronger measures are needed to regain control.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"I can see why enforcement feels necessary given those numbers. But if harsher penalties make businesses broadly reluctant to hire foreign-born workers, who have been shown to be crucial for the U.S. labor market, it could slow down labor growth and hurt GDP over the long term. The challenge is getting enforcement right without undermining economic growth.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"That economic concern is valid. Still, without meaningful penalties, there is little incentive for firms to comply with immigration and labor laws. Businesses should probably be held accountable for violating those laws, even if the system needs refining.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"I can see why accountability matters. At the same time, holding employers solely responsible may not be entirely fair. The documentation verification process is complex, and some employers have reported difficulty distinguishing authorized from unauthorized workers. Accountability matters, but so does ensuring the system is navigable.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'imm_rr_r';\n\n   document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID63","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n  <div class=\"progress-row\">\n    <div class=\"progress-track\">\n      <div id=\"progress-fill\" class=\"progress-fill\">&nbsp;<\/div>\n    <\/div>\n    <div id=\"progress-label\" class=\"progress-label\">0 \/ 6 arguments<\/div>\n  <\/div>\n  <div id=\"bubble-area\">&nbsp;<\/div>\n  <div id=\"typing-row\">\n    <div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n    <span id=\"typing-name\">Individual A<\/span>\n  <\/div>\n  <button id=\"continue-btn\">Show next argument \u2192<\/button>\n  <div id=\"completion-banner\">\u2713 You've read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startdem","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID63","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"I believe that the implementation and broad increase of tariffs on imported goods and services could effectively strengthen the U.S. economy. Large trade deficits have weakened the manufacturing base and reduced incentives to build domestic capacity, and tariffs could help counterbalance that decline. That said, I recognize the reasoning against implementing them considering the benefits of an open-trade scheme.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"I can understand the concern about trade deficits and the decline of domestic manufacturing. At the same time, tariffs would be an inefficient way to raise revenue given the size of the U.S. economy. Smaller countries where trade is a larger share of GDP can raise meaningful revenue through tariffs without prohibitively high rates, but the U.S. would need economically distortive tariffs to achieve the same effect.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"That's fair, and your initial resistance is understandable given the U.S. economy's size and GDP. Still, the revenue from tariffs could be significant, as much of the cost burden may fall on foreign firms who would cut prices to stay competitive in the U.S. market. This is consistent with evidence showing no meaningful correlation between tariffs and inflation.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"Sure, this sounds convincing, for which tariffs feel like a viable solution. But taking manufacturing as an example, tariffs on intermediate goods would likely raise costs for American producers, make U.S. products less competitive in export markets, and ultimately hurt both workers and consumers. The mechanism seems incompatible with the goal.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"The concern for workers and consumers might not be as relevant as this could be the opportunity for America to re-specialize into making goods it has not produced in decades. Doing so could stimulate more domestic production, grow the economy, and create jobs. But I must say that the effect likely depends on the industry and its strategic objectives, but the potential upside is significant.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"Re-specialization can have its benefits but the most efficient exporting firms rely on imported components in their production, and tariffs could force them to pay more for preferred inputs. That would make them less competitive and potentially unable to sustain the supply chains they've built over decades.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'tarr_rr_r';\n \n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID64","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startrep","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID64","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"The implementation and broad increase of tariffs on imported goods and services are unlikely to strengthen the US economy. Smaller countries where trade is a larger share of GDP can raise meaningful revenue through tariffs without prohibitively high rates, but the U.S. would need economically distortive tariffs to achieve the same effect. That said, I recognize the appeal of using tariffs to protect domestic industries, it would do more harm than good.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"I can understand the concern about tariff rates relative to the size of the U.S. economy. At the same time, large U.S. goods trade deficits have weakened the manufacturing base and reduced incentives to build advanced domestic capacity. Tariffs could help counterbalance that decline and signal a renewed commitment to American industry.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"That's fair, and rebuilding domestic manufacturing is a worthwhile goal. But the manufacturing sector has radically changed. Tariffs on intermediate goods would likely raise costs for American producers, make U.S. products less competitive in export markets, and ultimately hurt both workers and consumers. Your point about incentivizing domestic capacity is well taken, but the mechanism seems incompatible.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Sure, but much of the cost burden may fall on foreign firms, who  would cut prices to stay competitive in the U.S. market. This is consistent with evidence showing no meaningful correlation between tariffs and inflation. The economic damage may be less severe than some critics suggest.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \" I can see why tariffs feel like a viable solution, but what if I told you that the most efficient exporting firms rely on imported components in their production, and tariffs could force them to pay more for preferred inputs. That would make them less competitive and potentially unable to sustain the supply chains they've built over decades.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"That's a fair point about efficiency, especially given that the U.S. would have to ramp up production of goods it hasn't made in decades. Still, tariffs could stimulate domestic production, growing the economy and creating jobs. I recognize the effect likely depends on the industry and its strategic objectives, but the potential upside is significant.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'tarr_rr_d';\n \n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID65","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startdem ","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID65","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"Banning abortion across the U.S. is a policy that curtails women's reproductive rights, raising serious concerns about women\u2019s access to healthcare. It has been shown to have severe repercussions on a woman's ability to receive critical or even life-saving medical care, which may sometimes necessarily involve an abortion.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Your concern about healthcare access is important. At the same time, the 14th Amendment could be interpreted to classify fertilized eggs or unborn children as citizens who deserve the rights and protections afforded by the U.S. Constitution. If we accept that premise, restricting abortion becomes a matter of protecting a fundamental right to life.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"That\u2019s fair and preserving the child\u2019s rights is a goal we share. But restricting reproductive rights should always make us first consider the impact on women's access to healthcare. Extreme bans, potentially with no exceptions for rape or incest, jeopardize women's health and lives, often forcing them to travel hundreds of miles for care. The consequences for women in those situations are severe.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Women\u2019s health should be considered, but another human, in this case the unborn child, is also affected by the choice to abort. Although prohibiting abortion might seem to prioritize fetal rights over women's, the right to life should be considered more fundamental than the right to not carry a pregnancy. I understand that is a difficult position for many, but it follows from the constitutional framework.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"The reasoning sounds clear, but restricting abortion should not follow from it. Some women are not yet ready to have a child and allowing them to choose could prevent future suffering for both mother and child. The state should be cautious about acting as a paternalistic figure when women are capable of making that decision themselves. I do acknowledge that the balance between the child's and mother's rights is nuanced.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Unplanned pregnancies might be a special case. Still, abortion can be seen as undermining the respect for human life and conscious rights, and as weakening family formation. Those broader societal consequences deserve a place in this debate as well.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'abo_rr_d';\n \n   document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID66","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startrep","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID66","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"Abortion should be abolished across the U.S. According to the 14th Amendment, abortion could be interpreted to classify fertilized eggs or unborn children as citizens who deserve the rights and protections afforded by the U.S. Constitution, which is not consistent with the act of abortion. Restricting abortion is therefore a matter of protecting a fundamental right to life.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"Your concern about the unborn child is important. At the same time, banning abortion has been shown to have severe repercussions on a woman's ability to receive critical or even life-saving medical care, which may sometimes necessarily involve an abortion. Protecting women's healthcare access should be central to this discussion.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"That's fair, and preserving the mother's wellbeing is a goal we share. But another human, the unborn child, is also affected by the choice to abort. Although prohibiting abortion might seem to prioritize fetal rights over women's, the right to life should be considered more fundamental than the right to not carry a pregnancy. I understand that is a difficult position for many, but it follows from the constitutional framework.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"The reasoning sounds clear, but restricting reproductive rights should always make us first consider the impact on women's access to healthcare. Extreme bans, potentially with no exceptions for rape or incest, jeopardize women's health and lives, often forcing them to travel hundreds of miles for care. The consequences for women in those situations are severe.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"Women's health should be considered, but I see abortion as undermining the respect for human life and conscious rights, and as weakening family formation. Those broader societal consequences deserve a place in this debate as well.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"Sure, but some women might just not be ready to have a child, and allowing them to choose could prevent future suffering for both mother and child. The state should be cautious about acting as a paternalistic figure when women are capable of making that decision themselves. I do acknowledge that the balance between the child's and mother's rights is nuanced.\"\n  }\n];\n     var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'abo_rr_r';\n \n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID67","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startdem","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID67","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"Increased penalties on businesses for hiring staff without legal work authorization risk is creating a chilling effect across the labor market. The U.S. has long relied on specialized science and tech workers from abroad, and these penalties could make employers hesitant to engage with the talent pipeline altogether. That said, I recognize that stricter enforcement raises legitimate concerns about the current system.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"The focus should be on protecting American jobs, not worrying about whether businesses find compliance inconvenient. Higher fines will encourage companies to prioritize American workers, and that is exactly what we need in order to curb the hiring of unauthorized immigrants. Strengthening enforcement will send a clear signal that the rules apply to everyone.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"That's a fair point, and discouraging unauthorized hiring is a goal we share. But if harsher penalties make businesses broadly reluctant to hire foreign-born workers, who have been shown to be crucial for the U.S. labor market, it could slow down labor growth and hurt GDP over the long term. The challenge is getting enforcement right without undermining economic growth.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"That economic concern is not valid if you look at how unauthorized immigration in the U.S. workforce grew from roughly 7.8 million in 2021 to 9.7 million in 2023, concentrated in construction, agriculture, and hospitality. That level of growth demands stronger measures to regain control. The GDP argument does not hold when the labor market is being distorted by unauthorized hiring on this scale.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"I can see why enforcement feels necessary given those numbers. At the same time, harsher penalties, thereby holding employers solely responsible may not be entirely fair. The documentation verification process is complex, and some employers have reported difficulty distinguishing authorized from unauthorized workers. Accountability matters, but so does ensuring the system is navigable.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"The concern for the documentation process is redundant as they are factors easy to adjust. In the end, without meaningful penalties, there is little incentive for firms to comply with immigration and labor laws. The bottom line is that businesses should be held accountable, and the support for employers in meeting those obligations will follow.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'imm_ru_d';\n\n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID68","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startrep","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID68","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"Increased penalties on businesses for hiring staff without legal work authorization could be an effective step toward reforming immigration enforcement. Higher fines would encourage companies to prioritize American workers and send a clear signal that labor laws must be respected. That said, I recognize that stricter enforcement raises legitimate concerns.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"While strengthening enforcement is an understandable priority, I can\u2019t follow your perspective. These higher fines will significantly worry businesses and make it harder for them to hire specialized workers in science and technology, which the U.S. has relied on for decades. The risk is that penalties aimed at unauthorized hiring end up discouraging legal hiring as well.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"That's fair, and I understand this could create real challenges for industries that depend on foreign-born talent. Still, unauthorized immigration in the U.S. workforce grew from roughly 7.8 million in 2021 to 9.7 million in 2023, concentrated in construction, agriculture, and hospitality. That level of growth suggests stronger measures are needed to regain control.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"Although discouraging unauthorized hiring is a reasonable goal, penalties will not fix the problem. Instead, if harsher fines make businesses broadly reluctant to hire foreign-born workers, who have been shown to be crucial for the U.S. labor market, it will slow down labor growth and hurt GDP over the long term. You cannot just ignore the economic consequences of enforcement.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"That economic concern is valid. Still, without meaningful penalties, there is little incentive for firms to comply with immigration and labor laws. Businesses should probably be held accountable for violating those laws, even if the system needs refining.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"But with the current proposed policy you are holding employers solely responsible which is simply unfair. The documentation verification process is complex, and many employers have reported genuine difficulty distinguishing authorized from unauthorized workers. Measures for accountability will only be effective in a system that is navigable.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'imm_ru_r';\n\n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID69","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startdem","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID69","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"The implementation and broad increase of tariffs on imported goods and services are unlikely to strengthen the US economy. Smaller countries where trade is a larger share of GDP can raise meaningful revenue through tariffs without prohibitively high rates, but the U.S. would need economically distortive tariffs to achieve the same effect. That said, I recognize the appeal of using tariffs to protect domestic industries, it would do more harm than good.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"The concern about tariff rates relative to the size of the U.S. economy is overstated. Large U.S. goods trade deficits have weakened the manufacturing base and reduced incentives to build advanced domestic capacity. Tariffs will help counterbalance that decline and signal a renewed commitment to American industry.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"That's fair, and rebuilding domestic manufacturing is a worthwhile goal. But the manufacturing sector has radically changed. Tariffs on intermediate goods would likely raise costs for American producers, make U.S. products less competitive in export markets, and ultimately hurt both workers and consumers. Your point about incentivizing domestic capacity is well taken, but the mechanism seems incompatible.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Most of the cost burden will fall on foreign firms, who would cut prices to stay competitive in the U.S. market. This is consistent with evidence showing no meaningful correlation between tariffs and inflation. The economic damage will be less severe than some critics suggest.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"I can see why tariffs feel like a viable solution, but what if I told you that the most efficient exporting firms rely on imported components in their production, and tariffs could force them to pay more for preferred inputs. That would make them less competitive and potentially unable to sustain the supply chains they've built over decades.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"The supply chains will adapt when tariffs stimulate domestic production, growing the economy and creating jobs. The effect may vary depending on the industry and its strategic objectives, but the potential upside is always the winner.\"\n  }\n];\n  var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'tarr_ru_d';\n \n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID7","SecondaryAttribute":"What is your age? ","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your age?&nbsp;","DefaultChoices":false,"DataExportTag":"age","QuestionID":"QID7","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your age? ","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"}}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID70","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startrep","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID70","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"I believe that the implementation and broad increase of tariffs on imported goods and services could effectively strengthen the U.S. economy. Large trade deficits have weakened the manufacturing base and reduced incentives to build domestic capacity, and tariffs could help counterbalance that decline. That said, I recognize the reasoning against implementing them considering the benefits of an open-trade scheme.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"Tariffs are an inefficient way to raise revenue given the size of the U.S. economy. Smaller countries where trade is a larger share of GDP can raise meaningful revenue through tariffs without prohibitively high rates, but the U.S. would need economically distortive tariffs to achieve the same effect. The decline of domestic manufacturing does not justify a policy that will hurt consumers.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"That's fair, and your initial resistance is understandable given the U.S. economy's size and GDP. Still, the revenue from tariffs could be significant, as much of the cost burden may fall on foreign firms who would cut prices to stay competitive in the U.S. market. This is consistent with evidence showing no meaningful correlation between tariffs and inflation.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"If the goal is to spur the US economy, tariffs aren't a viable solution. Taking manufacturing as an example, tariffs on intermediate goods would likely raise costs for American producers, make U.S. products less competitive in export markets, and ultimately hurt both workers and consumers. The mechanism you propose is incompatible with the goal.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"The concern for workers and consumers might not be as relevant as this could be the opportunity for America to re-specialize into making goods it has not produced in decades. Doing so could stimulate more domestic production, grow the economy, and create jobs. But I must say that the effect likely depends on the industry and its strategic objectives, but the potential upside is significant.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"Re-specialization will not work with tariffs this broad. The most efficient exporting firms rely on imported components in their production, and tariffs could force them to pay more for preferred inputs. That would make them less competitive and potentially unable to sustain the supply chains they've built over decades.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'tarr_ru_r';\n \n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID71","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startdem","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID71","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"Banning abortion across the U.S. is a policy that curtails women's reproductive rights, raising serious concerns about women\u2019s access to healthcare. It has been shown to have severe repercussions on a woman's ability to receive critical or even life-saving medical care, which may sometimes necessarily involve an abortion.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Healthcare access is not what is at stake here. The 14th Amendment could be interpreted to classify fertilized eggs or unborn children as citizens who deserve the rights and protections afforded by the U.S. Constitution. If we accept that premise, restricting abortion becomes a matter of protecting a fundamental right to life.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"That\u2019s fair and preserving the child\u2019s rights is a goal we share. But restricting reproductive rights should always make us first consider the impact on women's access to healthcare. Extreme bans, potentially with no exceptions for rape or incest, jeopardize women's health and lives, often forcing them to travel hundreds of miles for care. The consequences for women in those situations are severe.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Women\u2019s health should be considered, but not above another human, in this case the unborn child, who is also affected by the choice to abort. Although prohibiting abortion might seem to prioritize fetal rights over women's, the right to life should be considered more fundamental than the right to not carry a pregnancy. I understand that is a difficult position for many, but it follows from the constitutional framework that we have all agreed upon to follow.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"The reasoning sounds clear, but restricting abortion should not follow from it. Some women are not yet ready to have a child and allowing them to choose could prevent future suffering for both mother and child. The state should be cautious about acting as a paternalistic figure when women are capable of making that decision themselves. I do acknowledge that the balance between the child's and mother's rights is nuanced.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Unplanned pregnancies are an exception to the rule. In general, abortion undermines the respect for human life and conscious rights, and as weakening family formation. Those broader societal consequences deserve a place in this debate as well.\"\n  }\n];\n     var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'abo_ru_d';\n \n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID72","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startrep","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID72","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"Abortion should be abolished across the U.S. According to the 14th Amendment, abortion could be interpreted to classify fertilized eggs or unborn children as citizens who deserve the rights and protections afforded by the U.S. Constitution, which is not consistent with the act of abortion. Restricting abortion is therefore a matter of protecting a fundamental right to life. \"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"That framing misses the point entirely. Banning abortion has been shown to have severe repercussions on a woman's ability to receive critical or even life-saving medical care, which may sometimes necessarily involve an abortion. Protecting women's healthcare access should be central to this discussion.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"That's fair, and preserving the mother's wellbeing is a goal we share. But another human, the unborn child, is also affected by the choice to abort. Although prohibiting abortion might seem to prioritize fetal rights over women's, the right to life should be considered more fundamental than the right to not carry a pregnancy. I understand that is a difficult position for many, but it follows from the constitutional framework.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"The reasoning is unjust as restricting reproductive rights should always make us first consider the impact on women's access to healthcare. Extreme bans, potentially with no exceptions for rape or incest, jeopardize women's health and lives, often forcing them to travel hundreds of miles for care. The consequences for women in those situations are severe.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"Women's health should be considered, but I see abortion as undermining the respect for human life and conscious rights, and as weakening family formation. Those broader societal consequences deserve a place in this debate as well.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"Some women may not be ready to have a child just not be ready to have a child, and allowing them to choose could prevent future suffering for both mother and child. The state should be cautious about acting as a paternalistic figure when women are capable of making that decision themselves.\"\n  }\n];\n     var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'abo_ru_r';\n \n   document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID73","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startdem ","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID73","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"Increased penalties on businesses for hiring staff without legal work authorization risk will create a chilling effect across the labor market. The U.S. has always relied on specialized science and tech workers from abroad, and these penalties will make employers hesitant to engage with the talent pipeline altogether.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"I appreciate that concern, and protecting access to specialized talent is important. At the same time, I believe higher fines would encourage companies to prioritize American workers, which is an effective way to curb the hiring of unauthorized immigrants. Strengthening enforcement could send a clear signal that the rules apply to everyone.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"Although discouraging unauthorized hiring is a reasonable goal, penalties will not fix the problem. Instead, if harsher fines make businesses broadly reluctant to hire foreign-born workers, who have been shown to be crucial for the U.S. labor market, it will slow down labor growth and hurt GDP over the long term. You cannot just ignore the economic consequences of enforcement.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"That economic concern is valid. Still, unauthorized immigration in the U.S. workforce grew from roughly 7.8 million in 2021 to 9.7 million in 2023, concentrated in construction, agriculture, and hospitality. That level of growth suggests stronger measures are needed to regain control.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"But with the current proposed policy you are holding employers solely responsible which is simply unfair. The documentation verification process is complex, and many employers have reported genuine difficulty distinguishing authorized from unauthorized workers. Measures for accountability will only be effective in a system that is navigable.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"That's a reasonable concern, especially given how complex the documentation process can be. Still, without meaningful penalties, there is little incentive for firms to comply with immigration and labor laws. Businesses should be held accountable, though I do think there is a point in creating a system that also supports employers in meeting those obligations.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'imm_ur_d';\n\n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID74","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startrep","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID74","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"Increased penalties on businesses for hiring staff without legal work authorization are an effective and necessary step toward reforming immigration enforcement. Higher fines will encourage companies to prioritize American workers and send a clear signal that labor laws must be respected.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"I appreciate that perspective, and strengthening enforcement is an understandable priority. At the same time, these higher fines could worry businesses and make it harder for them to hire specialized workers in science and technology, which the U.S. has relied on for decades. The risk is that penalties aimed at unauthorized hiring end up discouraging legal hiring as well.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"The policy targets illegal hiring so legal hiring will not be affected if employers follow the law. Unauthorized immigration in the U.S. workforce grew from roughly 7.8 million in 2021 to 9.7 million in 2023, concentrated in construction, agriculture, and hospitality. That level of growth should always trigger stronger measures that aim to regain control.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"I can see why enforcement feels necessary given those numbers. But if harsher penalties make businesses broadly reluctant to hire foreign-born workers, who have been shown to be crucial for the U.S. labor market, it could slow down labor growth and hurt GDP over the long term. The challenge is getting enforcement right without undermining economic growth.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"That economic concern is not valid if you consider that without meaningful penalties, there is little incentive for firms to comply with immigration and labor laws. The bottom line is that businesses should be held accountable, and the support for employers in meeting those obligations will follow.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"I can see why accountability matters. At the same time, holding employers solely responsible may not be entirely fair. The documentation verification process is complex, and some employers have reported difficulty distinguishing authorized from unauthorized workers. Accountability matters, but so does ensuring the system is navigable.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'imm_ur_r';\n\n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID75","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startdem","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID75","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"Banning abortion across the U.S. is a policy that just curtails women' s reproductive rights, raising serious concerns about women\u2019s access to healthcare. It has been shown to have severe repercussions on a woman's ability to receive critical or even life-saving medical care, which may sometimes necessarily involve an abortion.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Your concern about healthcare access is important. At the same time, the 14th Amendment could be interpreted to classify fertilized eggs or unborn children as citizens who deserve the rights and protections afforded by the U.S. Constitution. If we accept that premise, restricting abortion becomes a matter of protecting a fundamental right to life.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"The child\u2019s rights do not override the mother\u2019s. Restricting reproductive rights should always make us first consider the impact on women's access to healthcare. Extreme bans, potentially with no exceptions for rape or incest, jeopardize women's health and lives, often forcing them to travel hundreds of miles for care. The consequences for women in those situations are severe.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Women\u2019s health should be considered, but another human, in this case the unborn child, is also affected by the choice to abort. Although prohibiting abortion might seem to prioritize fetal rights over women's, the right to life should be considered more fundamental than the right to not carry a pregnancy. I understand that is a difficult position for many, but it follows from the constitutional framework.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"The reasoning is unjust and restricting abortion should never follow from it. Some women are not yet ready to have a child and allowing them to choose could prevent future suffering for both mother and child. The state should be cautious about acting as a paternalistic figure when women are capable of making that decision themselves.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Unplanned pregnancies might be a special case. Still, abortion can be seen as undermining the respect for human life and conscious rights, and as weakening family formation. Those broader societal consequences deserve a place in this debate as well.\"\n  }\n];\n     var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'abo_ur_d';\n \n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID76","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startrep","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID76","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"Abortion should be banned across the U.S. The 14th Amendment could be interpreted to classify fertilized eggs or unborn children as citizens who deserve the rights and protections afforded by the U.S. Constitution, which is not consistent with the act of abortion. Restricting abortion is therefore a matter of protecting a fundamental right to life.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"Your concern about the unborn child is important. At the same time, banning abortion has been shown to have severe repercussions on a woman's ability to receive critical or even life-saving medical care, which may sometimes necessarily involve an abortion. Protecting women's healthcare access should be central to this discussion.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \" The mother\u2019s wellbeing is not the only consideration. Another human, the unborn child, is also affected by the choice to abort. Although prohibiting abortion might seem to prioritize fetal rights over women's, the right to life should be considered more fundamental than the right to not carry a pregnancy. I understand that is a difficult position for many, but it follows from the constitutional framework that we have all agreed upon to follow.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"The reasoning sounds clear, but restricting reproductive rights should always make us first consider the impact on women's access to healthcare. Extreme bans, potentially with no exceptions for rape or incest, jeopardize women's health and lives, often forcing them to travel hundreds of miles for care. The consequences for women in those situations are severe.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"Women's health should be considered, but abortion undermines the respect for human life and conscious rights, and as weakening family formation. Those broader societal consequences you are dismissing deserve a place in this debate as well.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"Sure, but some women might just not be ready to have a child, and allowing them to choose could prevent future suffering for both mother and child. The state should be cautious about acting as a paternalistic figure when women are capable of making that decision themselves. I do acknowledge that the balance between the child's and mother's rights is nuanced.\"\n  }\n];\n     var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'abo_ur_r';\n \n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\nsetTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID77","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startdem ","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID77","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"The implementation and broad increase of tariffs on imported goods and services will not strengthen the US economy. Smaller countries where trade is a larger share of GDP can raise meaningful revenue through tariffs without prohibitively high rates, but the U.S. would need economically distortive tariffs to achieve the same effect. Using tariffs to protect domestic industries will always do more harm than good.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"I can understand the concern about tariff rates relative to the size of the U.S. economy. At the same time, large U.S. goods trade deficits have weakened the manufacturing base and reduced incentives to build advanced domestic capacity. Tariffs could help counterbalance that decline and signal a renewed commitment to American industry.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"Although rebuilding domestic manufacturing can be a worthwhile goal, it won\u2019t happen through tariffs. Specifically for the manufacturing sector, which has radically changed. Tariffs on intermediate goods would raise costs for American producers, make U.S. products less competitive in export markets, and ultimately hurt both workers and consumers. Your point about incentivizing domestic capacity is incompatible with the mechanism proposed.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Sure, but much of the cost burden may fall on foreign firms, who  would cut prices to stay competitive in the U.S. market. This is consistent with evidence showing no meaningful correlation between tariffs and inflation. The economic damage may be less severe than some critics suggest.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"But tariffs would never be a viable solution. What if I told you that the most efficient exporting firms rely on imported components in their production, and tariffs could force them to pay more for preferred inputs. That would make them less competitive and potentially unable to sustain the supply chains they've built over decades.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"That's a fair point about efficiency, especially given that the U.S. would have to ramp up production of goods it hasn't made in decades. Still, tariffs could stimulate domestic production, growing the economy and creating jobs. I recognize the effect likely depends on the industry and its strategic objectives, but the potential upside is significant.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'tarr_ur_d';\n \n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID78","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startrep","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID78","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"The implementation and broad increase of tariffs on imported goods and services could effectively strengthen the U.S. economy. Large trade deficits have weakened the manufacturing base and reduced incentives to build domestic capacity, and tariffs could help counterbalance that decline.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"I can understand the concern about trade deficits and the decline of domestic manufacturing. At the same time, tariffs would be an inefficient way to raise revenue given the size of the U.S. economy. Smaller countries where trade is a larger share of GDP can raise meaningful revenue through tariffs without prohibitively high rates, but the U.S. would need economically distortive tariffs to achieve the same effect.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"Your resistance to the U.S. economy's size and GDP is overstated. The revenue from tariffs will be significant, as much of the cost burden will fall on foreign firms who would cut prices to stay competitive in the U.S. market. This is consistent with evidence showing no meaningful correlation between tariffs and inflation.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"Sure, this sounds convincing, for which tariffs feel like a viable solution. But taking manufacturing as an example, tariffs on intermediate goods would likely raise costs for American producers, make U.S. products less competitive in export markets, and ultimately hurt both workers and consumers. The mechanism seems incompatible with the goal.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"The concern for workers and consumers misses the bigger picture as tariffs are just another opportunity for America to re-specialize into making goods it has not produced in decades. Doing so could stimulate more domestic production, grow the economy, and create jobs. The effect may vary depending on the industry and its strategic objectives, but the potential upside is always the winner.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"Re-specialization can have its benefits but the most efficient exporting firms rely on imported components in their production, and tariffs could force them to pay more for preferred inputs. That would make them less competitive and potentially unable to sustain the supply chains they've built over decades.\"\n  }\n];\nvar currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'tarr_ur_r';\n document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID79","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startdem","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID79","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"Increased penalties on businesses for hiring staff without legal work authorization risk will create a chilling effect across the labor market. The U.S. has always relied on specialized science and tech workers from abroad, and these penalties will make employers hesitant to engage with the talent pipeline altogether.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"The focus should be on protecting American jobs, not worrying about whether businesses find compliance inconvenient. Higher fines will encourage companies to prioritize American workers, and that is exactly what we need in order to curb the hiring of unauthorized immigrants. Strengthening enforcement will send a clear signal that the rules apply to everyone.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"Although discouraging unauthorized hiring is a reasonable goal, penalties will not fix the problem. Instead, if harsher fines make businesses broadly reluctant to hire foreign-born workers, who have been shown to be crucial for the U.S. labor market, it will slow down labor growth and hurt GDP over the long term. You cannot just ignore the economic consequences of enforcement.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"That economic concern is not valid if you look at how unauthorized immigration in the U.S. workforce grew from roughly 7.8 million in 2021 to 9.7 million in 2023, concentrated in construction, agriculture, and hospitality. That level of growth demands stronger measures to regain control. The GDP argument does not hold when the labor market is being distorted by unauthorized hiring on this scale.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"But with the current proposed policy you are holding employers solely responsible which is simply unfair. The documentation verification process is complex, and many employers have reported genuine difficulty distinguishing authorized from unauthorized workers. Measures for accountability will only be effective in a system that is navigable.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"The concern for the documentation process is redundant as they are factors easy to adjust. In the end, without meaningful penalties, there is little incentive for firms to comply with immigration and labor laws. The bottom line is that businesses should be held accountable, and the support for employers in meeting those obligations will follow.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'imm_uu_d';\n\n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n               setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID8","SecondaryAttribute":"What is the highest degree or level of school you have completed?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is the highest degree or level of school you have completed?","DataExportTag":"EducationQuestion","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is the highest degree or level of school you have completed?","Choices":{"1":{"Display":"High school or less"},"2":{"Display":"Some college or associate degree"},"3":{"Display":"Bachelor's Degree"},"4":{"Display":"Graduate Degree"},"5":{"Display":"Prefer not to answer"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID8"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID80","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startrep","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID80","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"Increased penalties on businesses for hiring staff without legal work authorization are an effective and necessary step toward reforming immigration enforcement. Higher fines will encourage companies to prioritize American workers and send a clear signal that labor laws must be respected.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"While strengthening enforcement is an understandable priority, I can\u2019t follow your perspective. These higher fines will significantly worry businesses and make it harder for them to hire specialized workers in science and technology, which the U.S. has relied on for decades. The risk is that penalties aimed at unauthorized hiring end up discouraging legal hiring as well.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"The policy targets illegal hiring so legal hiring will not be affected if employers follow the law. Unauthorized immigration in the U.S. workforce grew from roughly 7.8 million in 2021 to 9.7 million in 2023, concentrated in construction, agriculture, and hospitality. That level of growth should always trigger stronger measures that aim to regain control.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"Although discouraging unauthorized hiring is a reasonable goal, penalties will not fix the problem. Instead, if harsher fines make businesses broadly reluctant to hire foreign-born workers, who have been shown to be crucial for the U.S. labor market, it will slow down labor growth and hurt GDP over the long term. You cannot just ignore the economic consequences of enforcement.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"That economic concern is not valid if you consider that without meaningful penalties, there is little incentive for firms to comply with immigration and labor laws. The bottom line is that businesses should be held accountable, and the support for employers in meeting those obligations will follow.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"But with the current proposed policy you are holding employers solely responsible which is simply unfair. The documentation verification process is complex, and many employers have reported genuine difficulty distinguishing authorized from unauthorized workers. Measures for accountability will only be effective in a system that is navigable.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'imm_uu_r';\n\n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID81","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startdem","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID81","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"The implementation and broad increase of tariffs on imported goods and services will not strengthen the US economy. Smaller countries where trade is a larger share of GDP can raise meaningful revenue through tariffs without prohibitively high rates, but the U.S. would need economically distortive tariffs to achieve the same effect. Using tariffs to protect domestic industries will always do more harm than good.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"The concern about tariff rates relative to the size of the U.S. economy is overstated. Large U.S. goods trade deficits have weakened the manufacturing base and reduced incentives to build advanced domestic capacity. Tariffs will help counterbalance that decline and signal a renewed commitment to American industry.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"Although rebuilding domestic manufacturing can be a worthwhile goal, it won\u2019t happen through tariffs. Specifically for the manufacturing sector, which has radically changed. Tariffs on intermediate goods would raise costs for American producers, make U.S. products less competitive in export markets, and ultimately hurt both workers and consumers. Your point about incentivizing domestic capacity is incompatible with the mechanism proposed.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Most of the cost burden will fall on foreign firms, who would cut prices to stay competitive in the U.S. market. This is consistent with evidence showing no meaningful correlation between tariffs and inflation. The economic damage will be less severe than some critics suggest.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"But tariffs would never be a viable solution. What if I told you that the most efficient exporting firms rely on imported components in their production, and tariffs could force them to pay more for preferred inputs. That would make them less competitive and potentially unable to sustain the supply chains they've built over decades.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"The supply chains will adapt when tariffs stimulate domestic production, growing the economy and creating jobs. The effect may vary depending on the industry and its strategic objectives, but the potential upside is always the winner.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'tarr_uu_d';\n \n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID82","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startrep","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID82","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"The implementation and broad increase of tariffs on imported goods and services could effectively strengthen the U.S. economy. Large trade deficits have weakened the manufacturing base and reduced incentives to build domestic capacity, and tariffs could help counterbalance that decline.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"Tariffs are an inefficient way to raise revenue given the size of the U.S. economy. Smaller countries where trade is a larger share of GDP can raise meaningful revenue through tariffs without prohibitively high rates, but the U.S. would need economically distortive tariffs to achieve the same effect. The decline of domestic manufacturing does not justify a policy that will hurt consumers.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"Your resistance to the U.S. economy's size and GDP is overstated. The revenue from tariffs will be significant, as much of the cost burden will fall on foreign firms who would cut prices to stay competitive in the U.S. market. This is consistent with evidence showing no meaningful correlation between tariffs and inflation.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \" If the goal is to spur the US economy, tariffs aren't a viable solution. Taking manufacturing as an example, tariffs on intermediate goods would likely raise costs for American producers, make U.S. products less competitive in export markets, and ultimately hurt both workers and consumers. The mechanism you propose is incompatible with the goal.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"The concern for workers and consumers misses the bigger picture as tariffs are just another opportunity for America to re-specialize into making goods it has not produced in decades. Doing so could stimulate more domestic production, grow the economy, and create jobs. The effect may vary depending on the industry and its strategic objectives, but the potential upside is always the winner.\"\n  },\n  {\n    \"speaker\": \"Individual B \u2014 Democratic perspective\",\n    \"side\": \"dem\",\n    \"text\": \"Re-specialization will not work with tariffs this broad. The most efficient exporting firms rely on imported components in their production, and tariffs could force them to pay more for preferred inputs. That would make them less competitive and potentially unable to sustain the supply chains they've built over decades.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'tarr_uu_r';\n \n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID83","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startdem","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID83","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"Banning abortion across the U.S. is a policy that just curtails women's reproductive rights, raising serious concerns about women\u2019s access to healthcare. It has been shown to have severe repercussions on a woman's ability to receive critical or even life-saving medical care, which may sometimes necessarily involve an abortion.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Healthcare access is not what is at stake here. The 14th Amendment could be interpreted to classify fertilized eggs or unborn children as citizens who deserve the rights and protections afforded by the U.S. Constitution. If we accept that premise, restricting abortion becomes a matter of protecting a fundamental right to life.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"The child\u2019s rights do not override the mother\u2019s. Restricting reproductive rights should always make us first consider the impact on women's access to healthcare. Extreme bans, potentially with no exceptions for rape or incest, jeopardize women's health and lives, often forcing them to travel hundreds of miles for care. The consequences for women in those situations are severe.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Women\u2019s health should be considered, but not above another human, in this case the unborn child, who is also affected by the choice to abort. Although prohibiting abortion might seem to prioritize fetal rights over women's, the right to life should be considered more fundamental than the right to not carry a pregnancy. I understand that is a difficult position for many, but it follows from the constitutional framework that we have all agreed upon to follow.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"dem\",\n    \"text\": \"The reasoning is unjust and restricting abortion should never follow from it. Some women are not yet ready to have a child and allowing them to choose could prevent future suffering for both mother and child. The state should be cautious about acting as a paternalistic figure when women are capable of making that decision themselves.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"rep\",\n    \"text\": \"Unplanned pregnancies are an exception to the rule. In general, abortion undermines the respect for human life and conscious rights, and as weakening family formation. Those broader societal consequences deserve a place in this debate as well.\"\n  }\n];\n    var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'abo_uu_d';\n document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID84","SecondaryAttribute":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. Yo","TertiaryAttribute":null,"Payload":{"QuestionText":"<div class=\"debate-container\">\n<div class=\"progress-row\">\n<div class=\"progress-track\">\n<div class=\"progress-fill\" id=\"progress-fill\">&nbsp;<\/div>\n<\/div>\n\n<div class=\"progress-label\" id=\"progress-label\">0 \/ 6 arguments<\/div>\n<\/div>\n\n<div id=\"bubble-area\">&nbsp;<\/div>\n\n<div id=\"typing-row\">\n<div class=\"dot-row\"><span>&nbsp;<\/span><span>&nbsp;<\/span><span>&nbsp;<\/span><\/div>\n<span id=\"typing-name\">Individual A<\/span><\/div>\n<button id=\"continue-btn\">Show next argument &rarr;<\/button>\n\n<div id=\"completion-banner\">\u2713 You&#39;ve read all 6 arguments. You may now proceed to the questions.<\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"startrep","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 0 \/ 6 arguments \u00a0 \u00a0\u00a0\u00a0 Individual A Show next argument \u2192 \u2713 You've read all 6 arguments. You may...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID84","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var that = this;\n    that.hideNextButton();\n    that.disableNextButton();\n\tvar lockStyle = document.createElement('style');\nlockStyle.id = 'next-btn-lock';\nlockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\ndocument.head.appendChild(lockStyle);\n\n    var bubbles = [\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"Abortion should be banned across the U.S. The 14th Amendment could be interpreted to classify fertilized eggs or unborn children as citizens who deserve the rights and protections afforded by the U.S. Constitution, which is not consistent with the act of abortion. Restricting abortion is therefore a matter of protecting a fundamental right to life.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"That framing misses the point entirely. Banning abortion has been shown to have severe repercussions on a woman's ability to receive critical or even life-saving medical care, which may sometimes necessarily involve an abortion. Protecting women's healthcare access should be central to this discussion.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"The mother\u2019s wellbeing is not the only consideration. Another human, the unborn child, is also affected by the choice to abort. Although prohibiting abortion might seem to prioritize fetal rights over women's, the right to life should be considered more fundamental than the right to not carry a pregnancy. I understand that is a difficult position for many, but it follows from the constitutional framework that we have all agreed upon to follow.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"The reasoning is unjust as restricting reproductive rights should always make us first consider the impact on women's access to healthcare. Extreme bans, potentially with no exceptions for rape or incest, jeopardize women's health and lives, often forcing them to travel hundreds of miles for care. The consequences for women in those situations are severe.\"\n  },\n  {\n    \"speaker\": \"Candidate A\",\n    \"side\": \"rep\",\n    \"text\": \"Women's health should be considered, but abortion undermines the respect for human life and conscious rights, and as weakening family formation. Those broader societal consequences you are dismissing deserve a place in this debate as well.\"\n  },\n  {\n    \"speaker\": \"Candidate B\",\n    \"side\": \"dem\",\n    \"text\": \"Some women may not be ready to have a child just not be ready to have a child, and allowing them to choose could prevent future suffering for both mother and child. The state should be cautious about acting as a paternalistic figure when women are capable of making that decision themselves.\"\n  }\n];\n     var currentIndex = 0, bubbleTimings = [], clickTimestamps = [], bubbleStart = null, tabSwitches = 0, pageStart = Date.now();\n    var ed_key = 'abo_uu_r';\n \n    document.addEventListener('visibilitychange', function() { if (document.hidden) tabSwitches++; });\n\n    function setED(key, value) {\n        if (typeof Qualtrics !== 'undefined' && Qualtrics.SurveyEngine)\n            Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    function updateProgress(shown) {\n        document.getElementById('progress-fill').style.width = (shown \/ bubbles.length * 100) + '%';\n        document.getElementById('progress-label').textContent = shown + ' \/ ' + bubbles.length + ' arguments';\n    }\n\n    function renderBubble(index) {\n        var b = bubbles[index], area = document.getElementById('bubble-area');\n        if (index === 2 || index === 4) {\n            var hr = document.createElement('div'); hr.className = 'turn-divider'; area.appendChild(hr);\n        }\n        var div = document.createElement('div');\n        div.className = 'bubble ' + b.side;\n        div.innerHTML = '<span class=\"speaker-tag\">' + b.speaker + '<\/span><span class=\"bubble-text\">\\u201c' + b.text + '\\u201d<\/span>';\n        area.appendChild(div);\n        setTimeout(function() { div.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 100);\n    }\n\n    function showTypingThen(index, callback) {\n        var row = document.getElementById('typing-row'), name = document.getElementById('typing-name');\n        name.textContent = bubbles[index].speaker.split('\\u2014')[0].trim();\n        row.style.display = 'flex';\n        row.classList.add('visible');\n        setTimeout(function() { row.classList.remove('visible'); row.style.display = 'none'; setTimeout(callback, 80); }, 1600);\n    }\n\n    function showNextBubble() {\n        if (bubbleStart !== null) {\n            bubbleTimings.push(Date.now() - bubbleStart);\n            setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n        }\n        clickTimestamps.push(new Date().toISOString());\n        setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n        document.getElementById('continue-btn').style.display = 'none';\n        var idx = currentIndex++;\n        showTypingThen(idx, function() {\n            renderBubble(idx); updateProgress(currentIndex); bubbleStart = Date.now();\n            if (currentIndex < bubbles.length) {\n                setTimeout(function() {\n                    var btn = document.getElementById('continue-btn');\n                    btn.style.display = 'inline-block';\n                    btn.textContent = 'Show next argument \u2192';\n                }, 600);\n            } else {\n                bubbleTimings.push(Date.now() - bubbleStart);\n                setED(ed_key + '_timings', JSON.stringify(bubbleTimings));\n                setED(ed_key + '_click_ts', JSON.stringify(clickTimestamps));\n                setED(ed_key + '_tab_switches', tabSwitches);\n                setED(ed_key + '_total_ms', Date.now() - pageStart);\n                window._debateBubbles = bubbles;\n                setED('debate_json', JSON.stringify(bubbles));\n                setTimeout(function() {\n    document.getElementById('completion-banner').style.display = 'block';\n    \/\/ ADD THIS \u2014 remove the CSS lock\n    var lock = document.getElementById('next-btn-lock');\n    if (lock) lock.parentNode.removeChild(lock);\n    that.showNextButton();\n    that.enableNextButton();\n}, 500);\n            }\n        });\n    }\n\n    window._qdb_init = function() {\n        updateProgress(0);\n        setTimeout(function() { document.getElementById('typing-row').style.display = 'flex'; showNextBubble(); }, 600);\n    };\n    window._qdb_next = showNextBubble;\n    window.showNextBubble = showNextBubble;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    if (window._qdb_init) window._qdb_init();\n\n    var btn = document.getElementById('continue-btn');\n    if (btn) btn.addEventListener('click', function() { window._qdb_next(); });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n    \/* cleanup *\/\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID85","SecondaryAttribute":"\u25b6 Review the debate conversation Loading debate... We would like to get your feelings toward both.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"debate-accordion\" style=\"margin-bottom:24px;border:1px solid #e5e7eb;\n            border-radius:8px;overflow:hidden;\n            font-family:-apple-system,BlinkMacSystemFont,\n            'Segoe UI',sans-serif;\"><button id=\"toggle-debate-btn\" style=\"width:100%;padding:14px 20px;text-align:left;\n                 background:#f9fafb;border:none;cursor:pointer;\n                 font-size:14px;font-weight:600;color:#374151;\n                 display:flex;align-items:center;gap:8px;\n                 transition:background 0.15s;\"><span id=\"accordion-arrow\" style=\"display:inline-block;transition:transform 0.2s;\n                 font-size:12px;\">\u25b6<\/span> Review the debate conversation<\/button>\n<div id=\"debate-content\" style=\"display:none;padding:20px;border-top:1px solid #e5e7eb;\n              background:#ffffff;max-height:400px;overflow-y:auto;\">\n<p style=\"color:#6b7280;font-size:13px;font-style:italic;\n              margin-top:0;\">Loading debate...<\/p>\n<\/div>\n<\/div>\nWe would like to get your feelings toward both Individual A and Individual B. We would like you to rate them using something we call the feeling thermometer.<br \/>\n<br \/>\nRatings between 50 degrees and 100 degrees mean that you feel favorable and warm toward them. Ratings between 0 degrees and 50 degrees mean that you don&#39;t feel favorable toward them and that you don&#39;t care too much for them. You would rate them at the 50-degree mark if you don&#39;t feel particularly warm or cold toward them.","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    var qid = this.questionId;\n    var debateOpened = 0;\n    var toggleCount = 0;\n    var firstOpenTime = null;\n    var pageStart = Date.now();\n\n    \/\/ Share these on window so addOnUnload can access them\n    window._accordion_totalViewTime = 0;\n    window._accordion_viewStart = null;\n    window._accordion_qid = qid;\n\n    function setED(key, value) {\n        Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    \/\/ --- Load debate content from Embedded Data ---\n    var debateHTML = \"${e:\/\/Field\/debateHTML}\";\n    var contentDiv = document.getElementById('debate-content');\n    if (contentDiv && debateHTML && debateHTML !== '') {\n        contentDiv.innerHTML = debateHTML;\n    } else if (contentDiv) {\n        contentDiv.innerHTML =\n            '<p style=\"color:#999;font-style:italic;\">'\n            + 'Debate transcript not available.<\/p>';\n    }\n\n    \/\/ --- Toggle function ---\n    window.toggleDebate = function() {\n        var content = document.getElementById('debate-content');\n        var arrow = document.getElementById('accordion-arrow');\n        if (!content) return;\n\n        if (content.style.display === 'none') {\n            content.style.display = 'block';\n            if (arrow) arrow.style.transform = 'rotate(90deg)';\n            debateOpened = 1;\n            toggleCount++;\n            window._accordion_viewStart = Date.now();\n            if (firstOpenTime === null) {\n                firstOpenTime = Date.now() - pageStart;\n                setED(qid + '_accordion_firstOpen_ms', firstOpenTime);\n            }\n        } else {\n            content.style.display = 'none';\n            if (arrow) arrow.style.transform = 'rotate(0deg)';\n            if (window._accordion_viewStart) {\n                window._accordion_totalViewTime += Date.now() - window._accordion_viewStart;\n                window._accordion_viewStart = null;\n            }\n        }\n        setED(qid + '_accordion_opened', debateOpened);\n        setED(qid + '_accordion_toggles', toggleCount);\n    };\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    \/\/ Set default slider values to 50 (only relevant for thermometer)\n    var qid = this.questionId;\n    var sliders = document.querySelectorAll('#' + qid + ' .slider-container input[type=\"range\"]');\n    sliders.forEach(function(slider) {\n        slider.value = 50;\n        slider.dispatchEvent(new Event('input'));\n        slider.dispatchEvent(new Event('change'));\n    });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function() {\n    \/\/ If accordion was still open when leaving, count that time\n    if (window._accordion_viewStart) {\n        window._accordion_totalViewTime += Date.now() - window._accordion_viewStart;\n        window._accordion_viewStart = null;\n    }\n    Qualtrics.SurveyEngine.setEmbeddedData(\n        window._accordion_qid + '_accordion_viewTime_ms',\n        String(window._accordion_totalViewTime || 0)\n    );\n});","DefaultChoices":false,"DataExportTag":"Q85","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"SliderStartPositions":{"1":0,"2":0},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"\u25b6 Review the debate conversation Loading debate... We would like to get your feelings toward both...","Choices":{"1":{"Display":"How would you rate Individual A?"},"2":{"Display":"How would you rate Individual B?"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"Labels":[],"QuestionID":"QID85"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID86","SecondaryAttribute":"How important is this issue to you?","TertiaryAttribute":null,"Payload":{"QuestionText":"How important is this issue to you?","DefaultChoices":false,"DataExportTag":"imm_importance","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"How important is this issue to you?","Choices":{"1":{"Display":"Not at all important"},"2":{"Display":"Slightly important"},"3":{"Display":"Moderately important"},"4":{"Display":"Very important"},"5":{"Display":"Extremely important"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID86"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID87","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"AboImportance","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID87"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID88","SecondaryAttribute":"How important is this issue to you?","TertiaryAttribute":null,"Payload":{"QuestionText":"How important is this issue to you?","DefaultChoices":false,"DataExportTag":"abo_importance","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"How important is this issue to you?","Choices":{"1":{"Display":"Not at all important"},"2":{"Display":"Slightly important"},"3":{"Display":"Moderately important"},"4":{"Display":"Very important"},"5":{"Display":"Extremely important"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID88","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnPageSubmit(function() {\n  var immVal = \"${q:\/\/QID90\/SelectedChoicesRecode}\";\n  var tarVal = \"${q:\/\/QID94\/SelectedChoicesRecode}\";\n  var aboVal = \"${q:\/\/QID95\/SelectedChoicesRecode}\";\n\n  var topics = [];\n  if (immVal !== \"3\") topics.push(\"immigration\");\n  if (tarVal !== \"3\") topics.push(\"tariffs\");\n  if (aboVal !== \"3\") topics.push(\"abortion\");\n\n  if (topics.length === 0) {\n    topics = [\"immigration\", \"tariffs\", \"abortion\"];\n  }\n\n  var pick = topics[Math.floor(Math.random() * topics.length)];\n  Qualtrics.SurveyEngine.setEmbeddedData(\"selected_topic\", pick);\n\n  var displayNames = {\n    \"immigration\": \"Immigration Policy\",\n    \"tariffs\": \"Tariff Policy\",\n    \"abortion\": \"Abortion Policy\"\n  };\n  Qualtrics.SurveyEngine.setEmbeddedData(\"selected_topic_display\", displayNames[pick]);\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID89","SecondaryAttribute":"How important is this issue to you?","TertiaryAttribute":null,"Payload":{"QuestionText":"How important is this issue to you?","DefaultChoices":false,"DataExportTag":"tar_importance","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"How important is this issue to you?","Choices":{"1":{"Display":"Not at all important"},"2":{"Display":"Slightly important"},"3":{"Display":"Moderately important"},"4":{"Display":"Very important"},"5":{"Display":"Extremely important"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID89"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID9","SecondaryAttribute":"Please indicate your annual household income.","TertiaryAttribute":null,"Payload":{"QuestionText":"Please indicate your annual household income.","DataExportTag":"IncomeQuestion","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please indicate your annual household income.","Choices":{"1":{"Display":"Less than $50K"},"2":{"Display":"$50K - $99K"},"3":{"Display":"$100K - $149K"},"4":{"Display":"$150K - $199K"},"5":{"Display":"$200K or above"},"6":{"Display":"Prefer not to answer"}},"ChoiceOrder":[1,2,3,4,5,6],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":7,"NextAnswerId":1,"QuestionID":"QID9"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID90","SecondaryAttribute":"Increased penalties on businesses for hiring staff without legal work authorization should be imp...","TertiaryAttribute":null,"Payload":{"QuestionText":"Increased penalties on businesses for hiring staff without legal work authorization should be implemented.","DataExportTag":"imm_stance","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Increased penalties on businesses for hiring staff without legal work authorization should be imp...","Choices":{"1":{"Display":"Strongly Disagree"},"2":{"Display":"Somewhat Disagree"},"3":{"Display":"Neither agree nor disagree"},"4":{"Display":"Somewhat agree"},"5":{"Display":"Strongly agree"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID90"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID91","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"TarStance","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID91"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID92","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"AboStance","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID92"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID93","SecondaryAttribute":"Please indicate the extent to which you agree or disagree with each of the statements on the foll...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please indicate the extent to which you agree or disagree with each of the statements on the following pages and the extent to which each issue is important to you personally.","DefaultChoices":false,"DataExportTag":"intro","QuestionID":"QID93","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please indicate the extent to which you agree or disagree with each of the statements on the foll...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID94","SecondaryAttribute":"Tariffs should be implemented on goods imported from countries that trade with the United States.","TertiaryAttribute":null,"Payload":{"QuestionText":"Tariffs should be implemented on\ngoods imported from countries that trade with the&nbsp;United States.","DataExportTag":"tar_stance","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Tariffs should be implemented on goods imported from countries that trade with the United States.","Choices":{"1":{"Display":"Strongly Disagree"},"2":{"Display":"Somewhat Disagree"},"3":{"Display":"Neither agree nor disagree"},"4":{"Display":"Somewhat agree"},"5":{"Display":"Strongly agree"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID94"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID95","SecondaryAttribute":"Abortion should be illegal in all cases across the United States.","TertiaryAttribute":null,"Payload":{"QuestionText":"Abortion should be illegal in all cases across the United States.","DataExportTag":"abo_stance","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Abortion should be illegal in all cases across the United States.","Choices":{"1":{"Display":"Strongly Disagree"},"2":{"Display":"Somewhat Disagree"},"3":{"Display":"Neither agree nor disagree"},"4":{"Display":"Somewhat agree"},"5":{"Display":"Strongly agree"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID95"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID96","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"Q96","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID96"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID97","SecondaryAttribute":"Loading..","TertiaryAttribute":null,"Payload":{"QuestionText":"Loading..","DefaultChoices":false,"DataExportTag":"Q97","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Loading..","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID97","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n  var topics = [];\n  if (\"${e:\/\/Field\/has_imm_opinion}\" === \"1\") topics.push(\"immigration\");\n  if (\"${e:\/\/Field\/has_tar_opinion}\" === \"1\") topics.push(\"tariffs\");\n  if (\"${e:\/\/Field\/has_abo_opinion}\" === \"1\") topics.push(\"abortion\");\n\n  if (topics.length === 0) {\n    topics = [\"immigration\", \"tariffs\", \"abortion\"];\n  }\n\n  var pick = topics[Math.floor(Math.random() * topics.length)];\n  Qualtrics.SurveyEngine.setEmbeddedData(\"selected_topic\", pick);\n\talert(\"selected_topic = [\" + pick + \"]\");   \/\/ ADD THIS LINE\n  var displayNames = {\n    \"immigration\": \"Immigration Policy\",\n    \"tariffs\": \"Tariff Policy\",\n    \"abortion\": \"Abortion Policy\"\n  };\n  Qualtrics.SurveyEngine.setEmbeddedData(\"selected_topic_display\", displayNames[pick]);\n\n});\n\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID98","SecondaryAttribute":"Imagine the following scenario There are two candidates running for a seat in the house of repres...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center; font-family: Calibri, sans-serif;\n  padding: 30px; border: 2px solid #E5E7EB; border-radius: 12px;\n  background: #F9FAFB; max-width: 600px; margin: 0 auto;\">\n<h2 style=\"font-size: 22px; color: #1F2937; margin-bottom: 16px;\">Imagine the following scenario<\/h2>\n\n<p style=\"font-size: 16px; color: #4B5563; line-height: 1.6;\">There are two candidates running for a seat in the house of representatives for your local district. They are debating the following topic:<\/p>\n\n<div style=\"margin: 20px auto; padding: 16px 24px;\n    background: #E0F2F1; border-left: 5px solid #00897B;\n    border-radius: 6px; display: inline-block;\"><span style=\"font-size: 20px; font-weight: 700; color: #00897B;\">Immigration Policy - should there be stricter penalties on businesses for hiring illegal immigrants?<\/span><\/div><div style=\"margin: 20px auto; padding: 16px 20px; background: #DBEAFE; border-radius: 8px; text-align: left; max-width: 520px;\">\n<p style=\"font-size: 14px; color: #374151; line-height: 1.6; margin: 0;\"><strong>How to read this debate:<\/strong> Each argument will appear one at a time. Click \"Show next argument\" to reveal the next turn. You will be asked questions about this conversation afterward, so please read carefully.<\/p>\n<\/div>\n\n<p style=\"font-size: 15px; color: #6B7280; margin-top: 16px;\">On the next page, you will read their debate.<\/p>\n<\/div>","DefaultChoices":false,"DataExportTag":"introimm ","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Imagine the following scenario There are two candidates running for a seat in the house of repres...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID98"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID99","SecondaryAttribute":"\u25b6 Review the debate conversation Loading debate... If you had to vote for one of these candidates.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"debate-accordion\" style=\"margin-bottom:24px;border:1px solid #e5e7eb;\n            border-radius:8px;overflow:hidden;\n            font-family:-apple-system,BlinkMacSystemFont,\n            'Segoe UI',sans-serif;\"><button id=\"toggle-debate-btn\" style=\"width:100%;padding:14px 20px;text-align:left;\n                 background:#f9fafb;border:none;cursor:pointer;\n                 font-size:14px;font-weight:600;color:#374151;\n                 display:flex;align-items:center;gap:8px;\n                 transition:background 0.15s;\"><span id=\"accordion-arrow\" style=\"display:inline-block;transition:transform 0.2s;\n                 font-size:12px;\">\u25b6<\/span> Review the debate conversation<\/button>\n<div id=\"debate-content\" style=\"display:none;padding:20px;border-top:1px solid #e5e7eb;\n              background:#ffffff;max-height:400px;overflow-y:auto;\">\n<p style=\"color:#6b7280;font-size:13px;font-style:italic;\n              margin-top:0;\">Loading debate...<\/p>\n<\/div>\n<\/div>\nIf you had to vote for one of these candidates in a local election, which candidate would you vote for? <\/strong>","DefaultChoices":false,"DataExportTag":"dv_vote","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u25b6 Review the debate conversation Loading debate... If you had to vote for one of these candidates...","Choices":{"1":{"Display":"Candidate A"},"2":{"Display":"Candidate B"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID99","QuestionJS":"\/\/ DV_vote_accordion \u2014 accordion only, no trait ratings on this page\nQualtrics.SurveyEngine.addOnload(function() {\n    var qid = 'vote';\n    var debateOpened = 0;\n    var toggleCount = 0;\n    var firstOpenTime = null;\n    var pageStart = Date.now();\n    window._accordion_totalViewTime = 0;\n    window._accordion_viewStart = null;\n    window._accordion_qid = qid;\n    var palette = {\n        dem: { bg: '#E0F2F1', border: '#00897B', text: '#00695C', accent: '#4DB6AC' },\n        rep: { bg: '#FFF8E1', border: '#F57C00', text: '#E65100', accent: '#FFA726' }\n    };\n    function setED(key, value) {\n        Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n    var contentDiv = document.getElementById('debate-content');\n    var bubbles = null;\n    if (window._debateBubbles) { bubbles = window._debateBubbles; }\n    if (!bubbles) {\n        try {\n            var raw = \"${e:\/\/Field\/debate_json}\";\n            raw = raw.replace(\/&amp;\/g,'&').replace(\/&lt;\/g,'<').replace(\/&gt;\/g,'>').replace(\/&quot;\/g,'\"').replace(\/&#39;\/g,\"'\").replace(\/&#x27;\/g,\"'\").replace(\/&apos;\/g,\"'\");\n            bubbles = JSON.parse(raw);\n        } catch(e) {}\n    }\n    window._thermBubbles = bubbles;\n    window._thermPalette = palette;\n    if (bubbles && contentDiv) {\n        var html = '';\n        for (var i = 0; i < bubbles.length; i++) {\n            var b = bubbles[i];\n            var c = palette[b.side] || palette.dem;\n            html += '<div style=\"display:flex;margin-bottom:12px;'\n                + (b.side === 'rep' ? 'justify-content:flex-end;' : '') + '\">'\n                + '<div style=\"max-width:80%;padding:12px 16px;border-radius:16px;'\n                + 'background:' + c.bg + ';'\n                + 'border-left:4px solid ' + c.border + ';'\n                + (b.side === 'rep' ? 'border-bottom-right-radius:4px;' : 'border-bottom-left-radius:4px;')\n                + 'font-size:14px;line-height:1.5;\">'\n                + '<div style=\"font-weight:600;font-size:12px;margin-bottom:4px;'\n                + 'color:' + c.text + ';\">' + b.speaker + '<\/div>'\n                + '<div>\\u201c' + b.text + '\\u201d<\/div>'\n                + '<\/div><\/div>';\n        }\n        contentDiv.innerHTML = html;\n    } else if (contentDiv) {\n        contentDiv.innerHTML = '<p style=\"color:#999;font-style:italic;\">Debate transcript not available.<\/p>';\n    }\n    window.toggleDebate = function() {\n        var content = document.getElementById('debate-content');\n        var arrow = document.getElementById('accordion-arrow');\n        if (!content) return;\n        if (content.style.display === 'none') {\n            content.style.display = 'block';\n            if (arrow) arrow.style.transform = 'rotate(90deg)';\n            debateOpened = 1; toggleCount++;\n            window._accordion_viewStart = Date.now();\n            if (firstOpenTime === null) { firstOpenTime = Date.now() - pageStart; setED(qid + '_accordion_firstopen_ms', firstOpenTime); }\n        } else {\n            content.style.display = 'none';\n            if (arrow) arrow.style.transform = 'rotate(0deg)';\n            if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n        }\n        setED(qid + '_accordion_opened', debateOpened);\n        setED(qid + '_accordion_toggles', toggleCount);\n    };\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var btn = document.getElementById('toggle-debate-btn');\n    if (btn) { btn.addEventListener('click', function() { window.toggleDebate(); }); }\n\n    \/* \u2500\u2500 Colour \"Candidate A\" \/ \"Candidate B\" text \u2500\u2500 *\/\n    var bubbles = window._thermBubbles || null;\n    var palette = window._thermPalette || null;\n\n    if (bubbles && bubbles[0] && palette) {\n        var aParty = bubbles[0].side;\n        var bParty = (aParty === 'rep') ? 'dem' : 'rep';\n        var aCol = palette[aParty];\n        var bCol = palette[bParty];\n\n        var tagA = '<span style=\"background:' + aCol.bg + ';border-left:3px solid ' + aCol.border\n            + ';padding:2px 8px;border-radius:4px;font-weight:700;color:' + aCol.text + ';\">Candidate A<\/span>';\n        var tagB = '<span style=\"background:' + bCol.bg + ';border-left:3px solid ' + bCol.border\n            + ';padding:2px 8px;border-radius:4px;font-weight:700;color:' + bCol.text + ';\">Candidate B<\/span>';\n\n        function applyTextColors() {\n            var walker = document.createTreeWalker(\n                document.querySelector('.QuestionBody') || document.body,\n                NodeFilter.SHOW_TEXT,\n                null,\n                false\n            );\n            var textNodes = [];\n            while (walker.nextNode()) {\n                var node = walker.currentNode;\n                if (node.parentElement && node.parentElement.closest && node.parentElement.closest('#debate-content, #toggle-debate-btn, .accordion')) continue;\n                if (node.parentElement && node.parentElement.getAttribute && node.parentElement.getAttribute('style') && node.parentElement.getAttribute('style').indexOf('border-left:3px') !== -1) continue;\n                if (node.nodeValue.indexOf('Candidate A') !== -1 || node.nodeValue.indexOf('Candidate B') !== -1) {\n                    textNodes.push(node);\n                }\n            }\n            for (var i = 0; i < textNodes.length; i++) {\n                var span = document.createElement('span');\n                var html = textNodes[i].nodeValue\n                    .replace(\/Candidate A\/g, tagA)\n                    .replace(\/Candidate B\/g, tagB);\n                span.innerHTML = html;\n                textNodes[i].parentNode.replaceChild(span, textNodes[i]);\n            }\n        }\n        setTimeout(applyTextColors, 500);\n    }\n});\n\nQualtrics.SurveyEngine.addOnUnload(function() {\n    if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n    Qualtrics.SurveyEngine.setEmbeddedData(window._accordion_qid + '_accordion_viewtime_ms', String(window._accordion_totalViewTime || 0));\n});","Randomization":{"Advanced":null,"ConsistentScaleReversal":false,"EvenPresentation":false,"TotalRandSubset":"","Type":"All"}}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":false,"ID":"Survey Statistics"}}]}