,"Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">target<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> unaligned <\/span>","LeftOperand":"target","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"unaligned","Type":"Expression"},"Type":"If"},"1":{"0":{"ChoiceLocator":"q:\/\/QID95\/SelectableChoice\/4","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Abortion should be illegal in all cases across the United States.<\/span> <span class=\"LeftOpDesc\">Somewhat agree<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID95\/SelectableChoice\/4","LogicType":"Question","Operator":"Selected","QuestionID":"QID95","QuestionIDFromLocator":"QID95","QuestionIsInLoop":"no","Type":"Expression"},"1":{"ChoiceLocator":"q:\/\/QID95\/SelectableChoice\/5","Conjuction":"Or","Description":"<span class=\"ConjDesc\">Or<\/span> <span class=\"QuestionDesc\">Abortion should be illegal in all cases across the United States.<\/span> <span class=\"LeftOpDesc\">Strongly agree<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID95\/SelectableChoice\/5","LogicType":"Question","Operator":"Selected","QuestionID":"QID95","QuestionIDFromLocator":"QID95","QuestionIsInLoop":"no","Type":"Expression"},"Type":"AndIf"},"2":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">topic<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> abortion <\/span>","LeftOperand":"topic","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"abortion","Type":"Expression"},"1":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">target<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> unaligned <\/span>","LeftOperand":"target","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"unaligned","Type":"Expression"},"2":{"Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"LeftOpDesc\">unaligned_target<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> disagree <\/span>","LeftOperand":"unaligned_target","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"disagree","Type":"Expression"},"Type":"ElseIf"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID117"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID118","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"trait_timer","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":1,"QuestionID":"QID118"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID119","SecondaryAttribute":"\u25b6 Review the debate conversation Loading debate... We would like to get your feelings toward Cand.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"debate-accordion\" style=\"margin-bottom:24px;border:1px solid #e5e7eb;\n            border-radius:8px;overflow:hidden;\n            font-family:-apple-system,BlinkMacSystemFont,\n            'Segoe UI',sans-serif;\"><button id=\"toggle-debate-btn\" style=\"width:100%;padding:14px 20px;text-align:left;\n                 background:#f9fafb;border:none;cursor:pointer;\n                 font-size:14px;font-weight:600;color:#374151;\n                 display:flex;align-items:center;gap:8px;\n                 transition:background 0.15s;\"><span id=\"accordion-arrow\" style=\"display:inline-block;transition:transform 0.2s;\n                 font-size:12px;\">\u25b6<\/span> Review the debate conversation<\/button>\n<div id=\"debate-content\" style=\"display:none;padding:20px;border-top:1px solid #e5e7eb;\n              background:#ffffff;max-height:400px;overflow-y:auto;\">\n<p style=\"color:#6b7280;font-size:13px;font-style:italic;\n              margin-top:0;\">Loading debate...<\/p>\n<\/div>\n<\/div>\nWe would like to get your feelings toward <strong>Candidate A and Candidate B.<\/strong>","QuestionJS":"\/\/ DV_trait_accordion \u2014 accordion only, no trait ratings on this page\nQualtrics.SurveyEngine.addOnload(function() {\n    var qid = 'trait';\n    var debateOpened = 0;\n    var toggleCount = 0;\n    var firstOpenTime = null;\n    var pageStart = Date.now();\n    window._accordion_totalViewTime = 0;\n    window._accordion_viewStart = null;\n    window._accordion_qid = qid;\n\n    var palette = {\n        dem: { bg: '#E0F2F1', border: '#00897B', text: '#00695C', accent: '#4DB6AC' },\n        rep: { bg: '#FFF8E1', border: '#F57C00', text: '#E65100', accent: '#FFA726' }\n    };\n\n    function setED(key, value) {\n        Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    var contentDiv = document.getElementById('debate-content');\n    var bubbles = null;\n    if (window._debateBubbles) { bubbles = window._debateBubbles; }\n    if (!bubbles) {\n        try {\n            var raw = \"${e:\/\/Field\/debate_json}\";\n            raw = raw.replace(\/&amp;\/g,'&').replace(\/&lt;\/g,'<').replace(\/&gt;\/g,'>').replace(\/&quot;\/g,'\"').replace(\/&#39;\/g,\"'\").replace(\/&#x27;\/g,\"'\").replace(\/&apos;\/g,\"'\");\n            bubbles = JSON.parse(raw);\n        } catch(e) {}\n    }\n\n    \/\/ Store for use by trait rating pages\n    window._thermBubbles = bubbles;\n    window._thermPalette = palette;\n\n    if (bubbles && contentDiv) {\n        var html = '';\n        for (var i = 0; i < bubbles.length; i++) {\n            var b = bubbles[i];\n            var c = palette[b.side] || palette.dem;\n            html += '<div style=\"display:flex;margin-bottom:12px;'\n                + (b.side === 'rep' ? 'justify-content:flex-end;' : '') + '\">'\n                + '<div style=\"max-width:80%;padding:12px 16px;border-radius:16px;'\n                + 'background:' + c.bg + ';'\n                + 'border-left:4px solid ' + c.border + ';'\n                + (b.side === 'rep' ? 'border-bottom-right-radius:4px;' : 'border-bottom-left-radius:4px;')\n                + 'font-size:14px;line-height:1.5;\">'\n                + '<div style=\"font-weight:600;font-size:12px;margin-bottom:4px;'\n                + 'color:' + c.text + ';\">' + b.speaker + '<\/div>'\n                + '<div>\\u201c' + b.text + '\\u201d<\/div>'\n                + '<\/div><\/div>';\n        }\n        contentDiv.innerHTML = html;\n    } else if (contentDiv) {\n        contentDiv.innerHTML = '<p style=\"color:#999;font-style:italic;\">Debate transcript not available.<\/p>';\n    }\n\n    window.toggleDebate = function() {\n        var content = document.getElementById('debate-content');\n        var arrow = document.getElementById('accordion-arrow');\n        if (!content) return;\n        if (content.style.display === 'none') {\n            content.style.display = 'block';\n            if (arrow) arrow.style.transform = 'rotate(90deg)';\n            debateOpened = 1; toggleCount++;\n            window._accordion_viewStart = Date.now();\n            if (firstOpenTime === null) { firstOpenTime = Date.now() - pageStart; setED(qid + '_accordion_firstopen_ms', firstOpenTime); }\n        } else {\n            content.style.display = 'none';\n            if (arrow) arrow.style.transform = 'rotate(0deg)';\n            if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n        }\n        setED(qid + '_accordion_opened', debateOpened);\n        setED(qid + '_accordion_toggles', toggleCount);\n    };\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var btn = document.getElementById('toggle-debate-btn');\n    if (btn) { btn.addEventListener('click', function() { window.toggleDebate(); }); }\n});\n\nQualtrics.SurveyEngine.addOnUnload(function() {\n    if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n    Qualtrics.SurveyEngine.setEmbeddedData(window._accordion_qid + '_accordion_viewtime_ms', String(window._accordion_totalViewTime || 0));\n});","DefaultChoices":false,"DataExportTag":"Q119","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u25b6 Review the debate conversation Loading debate... We would like to get your feelings toward Cand...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID119"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID12","SecondaryAttribute":"Are you registered to vote?","TertiaryAttribute":null,"Payload":{"QuestionText":"Are you registered to vote?","DataExportTag":"Voting behavior","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Are you registered to vote?","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID12"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID120","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"thermometer_timer","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":1,"QuestionID":"QID120"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID121","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"vote_timer","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":1,"QuestionID":"QID121"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID122","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"imm_timer","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":1,"QuestionID":"QID122"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID123","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"tar_timer","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":1,"QuestionID":"QID123"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID124","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"abo_timer","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":1,"QuestionID":"QID124"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID13","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"Q13","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID13"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID14","SecondaryAttribute":"\u25b6 Review the debate conversation Loading debate... We would like to get your feelings toward both.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"margin-bottom:24px;border:1px solid #e5e7eb;\n            border-radius:8px;overflow:hidden;\n            font-family:-apple-system,BlinkMacSystemFont,\n            'Segoe UI',sans-serif;\" id=\"debate-accordion\"><button style=\"width:100%;padding:14px 20px;text-align:left;\n                 background:#f9fafb;border:none;cursor:pointer;\n                 font-size:14px;font-weight:600;color:#374151;\n                 display:flex;align-items:center;gap:8px;\n                 transition:background 0.15s;\" id=\"toggle-debate-btn\"><span style=\"display:inline-block;transition:transform 0.2s;\n                 font-size:12px;\" id=\"accordion-arrow\">\u25b6<\/span> Review the debate conversation<\/button>\n<div style=\"display:none;padding:20px;border-top:1px solid #e5e7eb;\n              background:#ffffff;max-height:400px;overflow-y:auto;\" id=\"debate-content\">\n<p style=\"color:#6b7280;font-size:13px;font-style:italic;\n              margin-top:0;\">Loading debate...<\/p>\n<\/div>\n<\/div>\nWe would like to get your feelings toward both Candidate A and Candidate B. We would like you to rate them using something we call the feeling thermometer.<br>\n<br>\nRatings between 50 degrees and 100 degrees mean that you feel favorable and warm toward them. Ratings between 0 degrees and 50 degrees mean that you don't feel favorable toward them and that you don't care too much for them. You would rate them at the 50-degree mark if you don't feel particularly warm or cold toward them.","DefaultChoices":{"1":{"Value":"50"},"2":{"Value":"50"}},"DataExportTag":"dv_thermometer","QuestionID":"QID14","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true,"SliderStartPositions":{"1":0.5,"2":0.5}},"QuestionDescription":"\u25b6 Review the debate conversation Loading debate... We would like to get your feelings toward both...","Choices":{"1":{"Display":"How would you rate Candidate A?"},"2":{"Display":"How would you rate Candidate B?"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"Labels":[],"QuestionJS":"\/\/ DV_therm \u2014 feeling thermometer with accordion\nQualtrics.SurveyEngine.addOnload(function() {\n    var qid = 'therm';\n    var debateOpened = 0;\n    var toggleCount = 0;\n    var firstOpenTime = null;\n    var pageStart = Date.now();\n    window._accordion_totalViewTime = 0;\n    window._accordion_viewStart = null;\n    window._accordion_qid = qid;\n    window._therm_pageStart = pageStart;\n\n    \/\/ CSS lock \u2014 hide Next button until both sliders touched\n    var lockStyle = document.createElement('style');\n    lockStyle.id = 'therm-next-lock';\n    lockStyle.textContent = '#NextButton, .NextButton, [id*=\"NextButton\"] { display: none !important; }';\n    document.head.appendChild(lockStyle);\n\n    \/* \u2500\u2500 colour palette (matches debate bubbles) \u2500\u2500 *\/\n    var palette = {\n        dem: { bg: '#E0F2F1', border: '#00897B', text: '#00695C', accent: '#4DB6AC' },\n        rep: { bg: '#FFF8E1', border: '#F57C00', text: '#E65100', accent: '#FFA726' }\n    };\n\n    function setED(key, value) {\n        Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    \/\/ --- Load debate content ---\n    var contentDiv = document.getElementById('debate-content');\n    var bubbles = null;\n    if (window._debateBubbles) {\n        bubbles = window._debateBubbles;\n    }\n    if (!bubbles) {\n        try {\n            var raw = \"${e:\/\/Field\/debate_json}\";\n            raw = raw.replace(\/&amp;\/g,'&').replace(\/&lt;\/g,'<').replace(\/&gt;\/g,'>').replace(\/&quot;\/g,'\"').replace(\/&#39;\/g,\"'\").replace(\/&#x27;\/g,\"'\").replace(\/&apos;\/g,\"'\");\n            bubbles = JSON.parse(raw);\n        } catch(e) {}\n    }\n\n    window._thermBubbles = bubbles;\n    window._thermPalette = palette;\n\n    if (bubbles && contentDiv) {\n        var html = '';\n        for (var i = 0; i < bubbles.length; i++) {\n            var b = bubbles[i];\n            var c = palette[b.side] || palette.dem;\n            html += '<div style=\"display:flex;margin-bottom:12px;'\n                + (b.side === 'rep' ? 'justify-content:flex-end;' : '') + '\">'\n                + '<div style=\"max-width:80%;padding:12px 16px;border-radius:16px;'\n                + 'background:' + c.bg + ';'\n                + 'border-left:4px solid ' + c.border + ';'\n                + (b.side === 'rep' ? 'border-bottom-right-radius:4px;' : 'border-bottom-left-radius:4px;')\n                + 'font-size:14px;line-height:1.5;\">'\n                + '<div style=\"font-weight:600;font-size:12px;margin-bottom:4px;'\n                + 'color:' + c.text + ';\">' + b.speaker + '<\/div>'\n                + '<div>\\u201c' + b.text + '\\u201d<\/div>'\n                + '<\/div><\/div>';\n        }\n        contentDiv.innerHTML = html;\n    } else if (contentDiv) {\n        contentDiv.innerHTML =\n            '<p style=\"color:#999;font-style:italic;\">'\n            + 'Debate transcript not available.<\/p>';\n    }\n\n    \/\/ --- Toggle function ---\n    window.toggleDebate = function() {\n        var content = document.getElementById('debate-content');\n        var arrow = document.getElementById('accordion-arrow');\n        if (!content) return;\n        if (content.style.display === 'none') {\n            content.style.display = 'block';\n            if (arrow) arrow.style.transform = 'rotate(90deg)';\n            debateOpened = 1;\n            toggleCount++;\n            window._accordion_viewStart = Date.now();\n            if (firstOpenTime === null) {\n                firstOpenTime = Date.now() - pageStart;\n                setED(qid + '_accordion_firstopen_ms', firstOpenTime);\n            }\n        } else {\n            content.style.display = 'none';\n            if (arrow) arrow.style.transform = 'rotate(0deg)';\n            if (window._accordion_viewStart) {\n                window._accordion_totalViewTime += Date.now() - window._accordion_viewStart;\n                window._accordion_viewStart = null;\n            }\n        }\n        setED(qid + '_accordion_opened', debateOpened);\n        setED(qid + '_accordion_toggles', toggleCount);\n    };\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var btn = document.getElementById('toggle-debate-btn');\n    if (btn) {\n        btn.addEventListener('click', function() {\n            window.toggleDebate();\n        });\n    }\n\n    \/* \u2500\u2500 Slider: position at 50 visually but require interaction \u2500\u2500 *\/\n    try {\n        var qObj = this;\n        var choices = qObj.getChoices();\n\n        for (var i = 0; i < choices.length; i++) {\n            qObj.setChoiceValue(choices[i], 50);\n        }\n\n        setTimeout(function() {\n            var container = qObj.getQuestionContainer();\n\n            \/\/ Hide the \"50\" display labels\n            var allEls = container.querySelectorAll('*');\n            var hiddenEls = [];\n            for (var j = 0; j < allEls.length; j++) {\n                var el = allEls[j];\n                if (el.children.length === 0 && el.textContent.trim() === '50') {\n                    if (el.classList.contains('MinLabel') || el.classList.contains('MaxLabel')) continue;\n                    el.style.visibility = 'hidden';\n                    hiddenEls.push(el);\n                }\n            }\n\n            \/\/ Show value labels on first interaction\n            function showLabels() {\n                for (var k = 0; k < hiddenEls.length; k++) {\n                    hiddenEls[k].style.visibility = 'visible';\n                }\n            }\n            if (container) {\n                container.addEventListener('mousedown', function handler() {\n                    showLabels();\n                    container.removeEventListener('mousedown', handler);\n                });\n                container.addEventListener('touchstart', function handler() {\n                    showLabels();\n                    container.removeEventListener('touchstart', handler);\n                });\n            }\n\n            \/\/ Clear all hidden input values so we can detect when they change\n            var inputIds = [];\n            for (var i = 0; i < choices.length; i++) {\n                var inputEl = document.getElementById('QR~' + qObj.questionId + '~' + choices[i]);\n                if (inputEl) {\n                    inputEl.value = '';\n                    inputIds.push('QR~' + qObj.questionId + '~' + choices[i]);\n                }\n            }\n\n            \/\/ Poll every 500ms to check if inputs have been filled by Qualtrics\n            var pollInterval = setInterval(function() {\n                var allFilled = true;\n                for (var i = 0; i < inputIds.length; i++) {\n                    var el = document.getElementById(inputIds[i]);\n                    if (!el || el.value === '' || el.value === undefined) {\n                        allFilled = false;\n                        break;\n                    }\n                }\n                if (allFilled && inputIds.length > 0) {\n                    clearInterval(pollInterval);\n                    \/\/ Remove CSS lock\n                    var lock = document.getElementById('therm-next-lock');\n                    if (lock) lock.parentNode.removeChild(lock);\n                }\n            }, 500);\n\n        }, 100);\n    } catch(e) {}\n\n    \/* \u2500\u2500 Colour \"Candidate A\" \/ \"Candidate B\" text \u2500\u2500 *\/\n    var bubbles = window._thermBubbles || null;\n    var palette = window._thermPalette || null;\n\n    if (bubbles && bubbles[0] && palette) {\n        var aParty = bubbles[0].side;\n        var bParty = (aParty === 'rep') ? 'dem' : 'rep';\n        var aCol = palette[aParty];\n        var bCol = palette[bParty];\n\n        var tagA = '<span style=\"background:' + aCol.bg + ';border-left:3px solid ' + aCol.border\n            + ';padding:2px 8px;border-radius:4px;font-weight:700;color:' + aCol.text + ';\">Candidate A<\/span>';\n        var tagB = '<span style=\"background:' + bCol.bg + ';border-left:3px solid ' + bCol.border\n            + ';padding:2px 8px;border-radius:4px;font-weight:700;color:' + bCol.text + ';\">Candidate B<\/span>';\n\n        function applyTextColors() {\n            var walker = document.createTreeWalker(\n                document.querySelector('.QuestionBody') || document.body,\n                NodeFilter.SHOW_TEXT,\n                null,\n                false\n            );\n            var textNodes = [];\n            while (walker.nextNode()) {\n                var node = walker.currentNode;\n                if (node.parentElement && node.parentElement.closest && node.parentElement.closest('#debate-content, #toggle-debate-btn, .accordion')) continue;\n                if (node.parentElement && node.parentElement.getAttribute && node.parentElement.getAttribute('style') && node.parentElement.getAttribute('style').indexOf('border-left:3px') !== -1) continue;\n                if (node.nodeValue.indexOf('Candidate A') !== -1 || node.nodeValue.indexOf('Candidate B') !== -1) {\n                    textNodes.push(node);\n                }\n            }\n            for (var i = 0; i < textNodes.length; i++) {\n                var span = document.createElement('span');\n                var html = textNodes[i].nodeValue\n                    .replace(\/Candidate A\/g, tagA)\n                    .replace(\/Candidate B\/g, tagB);\n                span.innerHTML = html;\n                textNodes[i].parentNode.replaceChild(span, textNodes[i]);\n            }\n        }\n        setTimeout(applyTextColors, 500);\n    }\n});\n\nQualtrics.SurveyEngine.addOnUnload(function() {\n    if (window._accordion_viewStart) {\n        window._accordion_totalViewTime += Date.now() - window._accordion_viewStart;\n        window._accordion_viewStart = null;\n    }\n    Qualtrics.SurveyEngine.setEmbeddedData(\n        window._accordion_qid + '_accordion_viewtime_ms',\n        String(window._accordion_totalViewTime || 0)\n    );\n    Qualtrics.SurveyEngine.setEmbeddedData(\n        'dv_therm_page_ms',\n        String(Date.now() - window._therm_pageStart)\n    );\n});","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"}}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID15","SecondaryAttribute":"Rate Candidate A on the following traits.","TertiaryAttribute":null,"Payload":{"QuestionText":"Rate Candidate A on the following traits.","DefaultChoices":false,"DataExportTag":"dv_traita","QuestionID":"QID15","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true,"ChoiceColumnWidthPixels":190},"QuestionDescription":"Rate Candidate A on the following traits.","Choices":{"1":{"Display":"Candidate A is intelligent"},"2":{"Display":"Candidate A is open-minded"},"3":{"Display":"Candidate A is generous"},"4":{"Display":"Candidate A is hypocritical"},"5":{"Display":"Candidate A is selfish"},"6":{"Display":"Candidate A is mean"},"7":{"Display":"Candidate A is moral"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":6,"Answers":{"1":{"Display":"Not at all"},"2":{"Display":"Slightly"},"3":{"Display":"Moderately"},"4":{"Display":"Very"},"5":{"Display":"Extremely"}},"AnswerOrder":[1,2,3,4,5],"ChoiceDataExportTags":false,"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionJS":"\/\/ DV_trait_a \u2014 Candidate A trait ratings\n\/\/ Includes: color tagging, page timer, trait_order tracking\nQualtrics.SurveyEngine.addOnload(function() {\n    this._pageStart = Date.now();\n\n    \/\/ Record which candidate was rated first\n    var existing = Qualtrics.SurveyEngine.getEmbeddedData('trait_order');\n    if (!existing) {\n        Qualtrics.SurveyEngine.setEmbeddedData('trait_order', 'a_first');\n    }\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var bubbles = window._thermBubbles || null;\n    var palette = window._thermPalette || null;\n\n    if (bubbles && bubbles[0] && palette) {\n        var aParty = bubbles[0].side;\n        var bParty = (aParty === 'rep') ? 'dem' : 'rep';\n        var aCol = palette[aParty];\n        var bCol = palette[bParty];\n\n        var tagA = '<span style=\"background:' + aCol.bg + ';border-left:3px solid ' + aCol.border\n            + ';padding:2px 8px;border-radius:4px;font-weight:700;color:' + aCol.text + ';\">Candidate A<\/span>';\n        var tagB = '<span style=\"background:' + bCol.bg + ';border-left:3px solid ' + bCol.border\n            + ';padding:2px 8px;border-radius:4px;font-weight:700;color:' + bCol.text + ';\">Candidate B<\/span>';\n\n        function applyTextColors() {\n            var walker = document.createTreeWalker(\n                document.querySelector('.QuestionBody') || document.body,\n                NodeFilter.SHOW_TEXT,\n                null,\n                false\n            );\n            var textNodes = [];\n            while (walker.nextNode()) {\n                var node = walker.currentNode;\n                if (node.parentElement && node.parentElement.closest && node.parentElement.closest('#debate-content, #toggle-debate-btn, .accordion')) continue;\n                if (node.parentElement && node.parentElement.getAttribute && node.parentElement.getAttribute('style') && node.parentElement.getAttribute('style').indexOf('border-left:3px') !== -1) continue;\n                if (node.nodeValue.indexOf('Candidate A') !== -1 || node.nodeValue.indexOf('Candidate B') !== -1) {\n                    textNodes.push(node);\n                }\n            }\n            for (var i = 0; i < textNodes.length; i++) {\n                var span = document.createElement('span');\n                var html = textNodes[i].nodeValue\n                    .replace(\/Candidate A\/g, tagA)\n                    .replace(\/Candidate B\/g, tagB);\n                span.innerHTML = html;\n                textNodes[i].parentNode.replaceChild(span, textNodes[i]);\n            }\n        }\n        setTimeout(applyTextColors, 500);\n    }\n});\n\nQualtrics.SurveyEngine.addOnUnload(function() {\n    Qualtrics.SurveyEngine.setEmbeddedData('dv_trait_a_page_ms', String(Date.now() - this._pageStart));\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID16","SecondaryAttribute":"Rate Candidate B on the following traits.","TertiaryAttribute":null,"Payload":{"QuestionText":"Rate Candidate B on the following traits.","DefaultChoices":false,"DataExportTag":"dv_traitb","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Rate Candidate B on the following traits.","Choices":{"1":{"Display":"Candidate B is intelligent"},"2":{"Display":"Candidate B is open-minded"},"3":{"Display":"Candidate B is generous"},"4":{"Display":"Candidate B is hypocritical"},"5":{"Display":"Candidate B is selfish"},"6":{"Display":"Candidate B  is mean"},"7":{"Display":"Candidate B is moral"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":6,"Answers":{"1":{"Display":"Not at all"},"2":{"Display":"Slightly"},"3":{"Display":"Moderately"},"4":{"Display":"Very"},"5":{"Display":"Extremely"}},"AnswerOrder":[1,2,3,4,5],"ChoiceDataExportTags":false,"QuestionID":"QID16","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionJS":"\/\/ DV_trait_b \u2014 Candidate B trait ratings\n\/\/ Includes: color tagging, page timer, trait_order tracking\nQualtrics.SurveyEngine.addOnload(function() {\n    this._pageStart = Date.now();\n\n    \/\/ Record which candidate was rated first\n    var existing = Qualtrics.SurveyEngine.getEmbeddedData('trait_order');\n    if (!existing) {\n        Qualtrics.SurveyEngine.setEmbeddedData('trait_order', 'b_first');\n    }\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var bubbles = window._thermBubbles || null;\n    var palette = window._thermPalette || null;\n\n    if (bubbles && bubbles[0] && palette) {\n        var aParty = bubbles[0].side;\n        var bParty = (aParty === 'rep') ? 'dem' : 'rep';\n        var aCol = palette[aParty];\n        var bCol = palette[bParty];\n\n        var tagA = '<span style=\"background:' + aCol.bg + ';border-left:3px solid ' + aCol.border\n            + ';padding:2px 8px;border-radius:4px;font-weight:700;color:' + aCol.text + ';\">Candidate A<\/span>';\n        var tagB = '<span style=\"background:' + bCol.bg + ';border-left:3px solid ' + bCol.border\n            + ';padding:2px 8px;border-radius:4px;font-weight:700;color:' + bCol.text + ';\">Candidate B<\/span>';\n\n        function applyTextColors() {\n            var walker = document.createTreeWalker(\n                document.querySelector('.QuestionBody') || document.body,\n                NodeFilter.SHOW_TEXT,\n                null,\n                false\n            );\n            var textNodes = [];\n            while (walker.nextNode()) {\n                var node = walker.currentNode;\n                if (node.parentElement && node.parentElement.closest && node.parentElement.closest('#debate-content, #toggle-debate-btn, .accordion')) continue;\n                if (node.parentElement && node.parentElement.getAttribute && node.parentElement.getAttribute('style') && node.parentElement.getAttribute('style').indexOf('border-left:3px') !== -1) continue;\n                if (node.nodeValue.indexOf('Candidate A') !== -1 || node.nodeValue.indexOf('Candidate B') !== -1) {\n                    textNodes.push(node);\n                }\n            }\n            for (var i = 0; i < textNodes.length; i++) {\n                var span = document.createElement('span');\n                var html = textNodes[i].nodeValue\n                    .replace(\/Candidate A\/g, tagA)\n                    .replace(\/Candidate B\/g, tagB);\n                span.innerHTML = html;\n                textNodes[i].parentNode.replaceChild(span, textNodes[i]);\n            }\n        }\n        setTimeout(applyTextColors, 500);\n    }\n});\n\nQualtrics.SurveyEngine.addOnUnload(function() {\n    Qualtrics.SurveyEngine.setEmbeddedData('dv_trait_b_page_ms', String(Date.now() - this._pageStart));\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID17","SecondaryAttribute":"\u25b6 Review the debate conversation Loading debate... We would like to get your socially-related fee.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"margin-bottom:24px;border:1px solid #e5e7eb;\n            border-radius:8px;overflow:hidden;\n            font-family:-apple-system,BlinkMacSystemFont,\n            'Segoe UI',sans-serif;\" id=\"debate-accordion\"><button style=\"width:100%;padding:14px 20px;text-align:left;\n                 background:#f9fafb;border:none;cursor:pointer;\n                 font-size:14px;font-weight:600;color:#374151;\n                 display:flex;align-items:center;gap:8px;\n                 transition:background 0.15s;\" id=\"toggle-debate-btn\"><span style=\"display:inline-block;transition:transform 0.2s;\n                 font-size:12px;\" id=\"accordion-arrow\">\u25b6<\/span> Review the debate conversation<\/button>\n<div style=\"display:none;padding:20px;border-top:1px solid #e5e7eb;\n              background:#ffffff;max-height:400px;overflow-y:auto;\" id=\"debate-content\">\n<p style=\"color:#6b7280;font-size:13px;font-style:italic;\n              margin-top:0;\">Loading debate...<\/p>\n<\/div>\n<\/div>\nWe would like to get your socially-related feelings toward <strong>Candidate A and B.&nbsp;<\/strong><br>\nRate Candidate A.","DefaultChoices":false,"DataExportTag":"Interpersonal_A","QuestionID":"QID17","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"\u25b6 Review the debate conversation Loading debate... We would like to get your socially-related fee...","Choices":{"1":{"Display":"I think Candidate A could be a friend of mine."},"2":{"Display":"I would like to have a friendly chat with Candidate A."},"3":{"Display":"It would be difficult to meet and talk with Candidate A."},"4":{"Display":"Candidate A just wouldn't fit into my circle of friends."},"5":{"Display":"We could never establish a personal friendship with each other."},"6":{"Display":"Candidate A would be pleasant to be with."}},"ChoiceOrder":[1,2,3,4,5,6],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":6,"Answers":{"1":{"Display":"Strongly Disagree"},"2":{"Display":"Disagree"},"3":{"Display":"Neutral"},"4":{"Display":"Somewhat agree"},"5":{"Display":"Strongly agree"}},"AnswerOrder":[1,2,3,4,5],"ChoiceDataExportTags":false,"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    var qid = 'interA';\n    var debateOpened = 0;\n    var toggleCount = 0;\n    var firstOpenTime = null;\n    var pageStart = Date.now();\n    window._accordion_totalViewTime = 0;\n    window._accordion_viewStart = null;\n    window._accordion_qid = qid;\n\n    var palette = {\n        dem: { bg: '#E0F2F1', border: '#00897B', text: '#00695C', accent: '#4DB6AC' },\n        rep: { bg: '#FFF8E1', border: '#F57C00', text: '#E65100', accent: '#FFA726' }\n    };\n\n    function setED(key, value) {\n        Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n\n    var contentDiv = document.getElementById('debate-content');\n    var bubbles = null;\n    if (window._debateBubbles) { bubbles = window._debateBubbles; }\n    if (!bubbles) {\n        try {\n            var raw = \"${e:\/\/Field\/debateJSON}\";\n            raw = raw.replace(\/&amp;\/g,'&').replace(\/&lt;\/g,'<').replace(\/&gt;\/g,'>').replace(\/&quot;\/g,'\"').replace(\/&#39;\/g,\"'\").replace(\/&#x27;\/g,\"'\").replace(\/&apos;\/g,\"'\");\n            bubbles = JSON.parse(raw);\n        } catch(e) {}\n    }\n\n    window._thermBubbles = bubbles;\n    window._thermPalette = palette;\n\n    if (bubbles && contentDiv) {\n        var html = '';\n        for (var i = 0; i < bubbles.length; i++) {\n            var b = bubbles[i];\n            var c = palette[b.side] || palette.dem;\n            html += '<div style=\"display:flex;margin-bottom:12px;'\n                + (b.side === 'rep' ? 'justify-content:flex-end;' : '') + '\">'\n                + '<div style=\"max-width:80%;padding:12px 16px;border-radius:16px;'\n                + 'background:' + c.bg + ';'\n                + 'border-left:4px solid ' + c.border + ';'\n                + (b.side === 'rep' ? 'border-bottom-right-radius:4px;' : 'border-bottom-left-radius:4px;')\n                + 'font-size:14px;line-height:1.5;\">'\n                + '<div style=\"font-weight:600;font-size:12px;margin-bottom:4px;'\n                + 'color:' + c.text + ';\">' + b.speaker + '<\/div>'\n                + '<div>\\u201c' + b.text + '\\u201d<\/div>'\n                + '<\/div><\/div>';\n        }\n        contentDiv.innerHTML = html;\n    } else if (contentDiv) {\n        contentDiv.innerHTML = '<p style=\"color:#999;font-style:italic;\">Debate transcript not available.<\/p>';\n    }\n\n    window.toggleDebate = function() {\n        var content = document.getElementById('debate-content');\n        var arrow = document.getElementById('accordion-arrow');\n        if (!content) return;\n        if (content.style.display === 'none') {\n            content.style.display = 'block';\n            if (arrow) arrow.style.transform = 'rotate(90deg)';\n            debateOpened = 1; toggleCount++;\n            window._accordion_viewStart = Date.now();\n            if (firstOpenTime === null) { firstOpenTime = Date.now() - pageStart; setED(qid + '_accordion_firstOpen_ms', firstOpenTime); }\n        } else {\n            content.style.display = 'none';\n            if (arrow) arrow.style.transform = 'rotate(0deg)';\n            if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n        }\n        setED(qid + '_accordion_opened', debateOpened);\n        setED(qid + '_accordion_toggles', toggleCount);\n    };\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n    var btn = document.getElementById('toggle-debate-btn');\n    if (btn) { btn.addEventListener('click', function() { window.toggleDebate(); }); }\n\n    var bubbles = window._thermBubbles || null;\n    var palette = window._thermPalette || null;\n\n    if (bubbles && bubbles[0] && palette) {\n        var aParty = bubbles[0].side;\n        var bParty = (aParty === 'rep') ? 'dem' : 'rep';\n        var aCol = palette[aParty];\n        var bCol = palette[bParty];\n\n        var tagA = '<span style=\"background:' + aCol.bg + ';border-left:3px solid ' + aCol.border\n            + ';padding:2px 8px;border-radius:4px;font-weight:700;color:' + aCol.text + ';\">Candidate A<\/span>';\n        var tagB = '<span style=\"background:' + bCol.bg + ';border-left:3px solid ' + bCol.border\n            + ';padding:2px 8px;border-radius:4px;font-weight:700;color:' + bCol.text + ';\">Candidate B<\/span>';\n\n        function applyTextColors() {\n            var walker = document.createTreeWalker(\n                document.querySelector('.QuestionBody') || document.body,\n                NodeFilter.SHOW_TEXT,\n                null,\n                false\n            );\n            var textNodes = [];\n            while (walker.nextNode()) {\n                var node = walker.currentNode;\n                if (node.parentElement && node.parentElement.closest && node.parentElement.closest('#debate-content, #toggle-debate-btn, .accordion')) continue;\n                if (node.parentElement && node.parentElement.getAttribute && node.parentElement.getAttribute('style') && node.parentElement.getAttribute('style').indexOf('border-left:3px') !== -1) continue;\n                if (node.nodeValue.indexOf('Candidate A') !== -1 || node.nodeValue.indexOf('Candidate B') !== -1) {\n                    textNodes.push(node);\n                }\n            }\n            for (var i = 0; i < textNodes.length; i++) {\n                var span = document.createElement('span');\n                var html = textNodes[i].nodeValue\n                    .replace(\/Candidate A\/g, tagA)\n                    .replace(\/Candidate B\/g, tagB);\n                span.innerHTML = html;\n                textNodes[i].parentNode.replaceChild(span, textNodes[i]);\n            }\n        }\n        setTimeout(applyTextColors, 500);\n    }\n});\n\nQualtrics.SurveyEngine.addOnUnload(function() {\n    if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n    Qualtrics.SurveyEngine.setEmbeddedData(window._accordion_qid + '_accordion_viewTime_ms', String(window._accordion_totalViewTime || 0));\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID18","SecondaryAttribute":"Rate Candidate B.","TertiaryAttribute":null,"Payload":{"QuestionText":"Rate Candidate B.","DefaultChoices":false,"DataExportTag":"Interpersonal_B","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Rate Candidate B.","Choices":{"1":{"Display":"I think Candidate B could be a friend of mine."},"2":{"Display":"I would like to have a friendly chat with Candidate B."},"3":{"Display":"It would be difficult to meet and talk with Candidate B."},"4":{"Display":"Candidate B just wouldn't fit into my circle of friends."},"5":{"Display":"We could never establish a personal friendship with each other."},"6":{"Display":"Candidate B would be pleasant to be with."}},"ChoiceOrder":[1,2,3,4,5,6],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":6,"Answers":{"1":{"Display":"Strongly Disagree"},"2":{"Display":"Disagree"},"3":{"Display":"Neutral"},"4":{"Display":"Somewhat agree"},"5":{"Display":"Strongly agree"}},"AnswerOrder":[1,2,3,4,5],"ChoiceDataExportTags":false,"QuestionID":"QID18","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n});\nQualtrics.SurveyEngine.addOnReady(function() {\n});\nQualtrics.SurveyEngine.addOnUnload(function() {\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID19","SecondaryAttribute":"Please explain your opinion on this topic - we will show your response to a participant in a futu...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please explain your opinion on this topic - we will show your response to a participant in a future study who agrees with you on this topic.<br>\n<br>\n<span style=\"color:#95a5a6;\">Please do not reveal any identifying information about yourself in your response.&nbsp;<\/span>","DefaultChoices":false,"DataExportTag":"open_text_agree","QuestionType":"TE","Selector":"ESTB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please explain your opinion on this topic - we will show your response to a participant in a futu...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"CharRange","MinChars":"100","TotalChars":"500"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID19","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">target<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> aligned <\/span>","LeftOperand":"target","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"aligned","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this._pageStart = Date.now();\n    var bubbles = null;\n    if (window._debateBubbles) { bubbles = window._debateBubbles; }\n    if (!bubbles) {\n        try {\n            var raw = \"${e:\/\/Field\/debate_json}\";\n            raw = raw.replace(\/&amp;\/g,'&').replace(\/&lt;\/g,'<').replace(\/&gt;\/g,'>').replace(\/&quot;\/g,'\"').replace(\/&#39;\/g,\"'\").replace(\/&#x27;\/g,\"'\").replace(\/&apos;\/g,\"'\");\n            bubbles = JSON.parse(raw);\n        } catch(e) {}\n    }\n    window._thermBubbles = bubbles;\n    window._thermPalette = {\n        dem: { bg: '#E0F2F1', border: '#00897B', text: '#00695C' },\n        rep: { bg: '#FFF8E1', border: '#F57C00', text: '#E65100' }\n    };\n});\nQualtrics.SurveyEngine.addOnReady(function() {\n    var bubbles = window._thermBubbles || null;\n    var palette = window._thermPalette || null;\n    if (bubbles && bubbles[0] && palette) {\n        var aParty = bubbles[0].side;\n        var bParty = (aParty === 'rep') ? 'dem' : 'rep';\n        var aCol = palette[aParty];\n        var bCol = palette[bParty];\n        var tagA = '<span style=\"background:' + aCol.bg + ';border-left:3px solid ' + aCol.border\n            + ';padding:2px 8px;border-radius:4px;font-weight:700;color:' + aCol.text + ';\">Candidate A<\/span>';\n        var tagB = '<span style=\"background:' + bCol.bg + ';border-left:3px solid ' + bCol.border\n            + ';padding:2px 8px;border-radius:4px;font-weight:700;color:' + bCol.text + ';\">Candidate B<\/span>';\n        function applyTextColors() {\n            var container = document.querySelector('.QuestionBody') || document.body;\n            var walker = document.createTreeWalker(\n                container,\n                NodeFilter.SHOW_TEXT,\n                null,\n                false\n            );\n            var textNodes = [];\n            while (walker.nextNode()) {\n                var node = walker.currentNode;\n                if (node.parentElement && node.parentElement.getAttribute && node.parentElement.getAttribute('style') && node.parentElement.getAttribute('style').indexOf('border-left:3px') !== -1) continue;\n                if (node.nodeValue.indexOf('Candidate A') !== -1 || node.nodeValue.indexOf('Candidate B') !== -1) {\n                    textNodes.push(node);\n                }\n            }\n            for (var i = 0; i < textNodes.length; i++) {\n                var span = document.createElement('span');\n                var html = textNodes[i].nodeValue\n                    .replace(\/Candidate A\/g, tagA)\n                    .replace(\/Candidate B\/g, tagB);\n                span.innerHTML = html;\n                textNodes[i].parentNode.replaceChild(span, textNodes[i]);\n            }\n        }\n        setTimeout(applyTextColors, 500);\n    }\n});\nQualtrics.SurveyEngine.addOnUnload(function() {\n    Qualtrics.SurveyEngine.setEmbeddedData('dv_open_page_ms', String(Date.now() - this._pageStart));\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID2","SecondaryAttribute":"[]","TertiaryAttribute":null,"Payload":{"QuestionText":"[]","DefaultChoices":false,"DataExportTag":"Consent","QuestionID":"QID2","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"[]","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID20","SecondaryAttribute":"You will now read a hypothetical discussion between two individuals. Individual A holds a Democra...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p style=\"margin-top: 15px; line-height: 1.6;\">You will now read a hypothetical discussion between two individuals. <strong>Individual A<\/strong> holds a Democratic perspective, while <strong>Individual B<\/strong> holds a Republican perspective. The discussion will include each individual taking three turns (six turns in total).&nbsp;<br><\/p><p style=\"margin-top: 15px; line-height: 1.6;\"><\/p>\n\n<p style=\"margin-top: 15px; line-height: 1.6;\"><strong>Please read the debate carefully<\/strong>, as you will be asked questions about Individual A and B's interaction afterward.<\/p>","DefaultChoices":false,"DataExportTag":"debate_text","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You will now read a hypothetical discussion between two individuals. Individual A holds a Democra...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID20"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID21","SecondaryAttribute":"Individual A and individual B are having a conversation about the tougher immigration policies th...","TertiaryAttribute":null,"Payload":{"QuestionText":"Individual A and individual B are having a conversation about the tougher immigration policies that have been put into place recently. Individual A identifies as more liberal and opposes the current tough immigration enforcement, while individual B identifies as more conservative and believes that the enforcement is needed as immigrants can have negative social and economic effects on the country. Below, you can read a snippet of their debate, in which they specifically discuss the implementation of increased penalties on businesses for hiring staff without legal work authorization.","DefaultChoices":false,"DataExportTag":"Debate_RIRO_intro","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A and individual B are having a conversation about the tougher immigration policies th...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID21"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID22","SecondaryAttribute":"Individual A: \u201cI don\u2019t think policies like these are very effective at reforming immigration pra","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Individual A: <\/strong><em>&ldquo;I don&rsquo;t think policies like these are very effective at reforming immigration practices. My concern is that they worry businesses and make it harder for them to hire specialized workers in science and technology, which the U.S. has relied on for decades.&quot;<\/em><br \/>\n<br \/>\n<strong>Individual B: <\/strong><em>&ldquo;I understand your concern about access to specialized talent, and why it worries you. At the same time, don&rsquo;t you think that imposing these higher fines will encourage companies to hire more American workers?&rdquo;<\/em>","DefaultChoices":false,"DataExportTag":"Debate_RIRO_round1","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \u201cI don\u2019t think policies like these are very effective at reforming immigration prac...","ChoiceOrder":["4","5","6","7","8"],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID22"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID23","SecondaryAttribute":"Individual A: \u201cYeah, maybe, but I guess that that makes me worry about the broader economic conse.","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Individual A:<\/strong> <em>&ldquo;Yeah, maybe, but I guess that that makes me worry about the broader economic consequences. If the increased penalties indeed make businesses more reluctant to hire foreign-born workers altogether, which has been shown to be crucial for the US labor market, overall labor growth could slow down, which might hurt U.S. GDP in the long run.&rdquo;<\/em><br \/>\n<br \/>\n<strong>Individual B: <\/strong><em>&ldquo;That&rsquo;s a reasonable concern. Still, I think some of these implementations are needed to regain control. I recently read that the number of unauthorized immigrants in the U.S. workforce increased about 7.8 million in 2021 to 9.7 million in 2023, especially in sectors like construction, agriculture, and leisure and hospitality. In order for employers to be willing to give up their illegal labor, these strong workplace enforcement actions are necessary.&rdquo;<\/em>","DefaultChoices":false,"DataExportTag":"Debate_RIRO_round2","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \u201cYeah, maybe, but I guess that that makes me worry about the broader economic conse...","ChoiceOrder":["4","5","6","7","8"],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID23"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID24","SecondaryAttribute":"Individual A: \u201cThat makes sense, but do you think employers should be held solely responsible? So.","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Individual A:<\/strong> <em>&ldquo;That makes sense, but do you think employers should be held solely responsible? Some employers have previously raised that they aren&rsquo;t even aware they&rsquo;ve hired unauthorized workers because the documentation process can be confusing and overwhelming.&rdquo;<\/em><br \/>\n<br \/>\n<strong>Individual B:<em> <\/em><\/strong><em>&ldquo;You raise a fair point about employer confusion, especially given how complex the documentation process can be. Still, I think that without meaningful penalties, there&rsquo;s very little incentive for firms to comply with the law and businesses should be held accountable for violating immigration and labor laws.&rdquo;<\/em>","DefaultChoices":false,"DataExportTag":"Debate_RIRO_round3","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Individual A: \u201cThat makes sense, but do you think employers should be held solely responsible? So...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID24"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID25","SecondaryAttribute":"H","TertiaryAttribute":null,"Payload":{"QuestionText":"H","DefaultChoices":false,"DataExportTag":"Q25","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"H","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID25"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID26","SecondaryAttribute":"\u25b6 Review the debate conversation Loading debate... How important is this issue to you?","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"margin-bottom:24px;border:1px solid #e5e7eb;\n            border-radius:8px;overflow:hidden;\n            font-family:-apple-system,BlinkMacSystemFont,\n            'Segoe UI',sans-serif;\" id=\"debate-accordion\"><button style=\"width:100%;padding:14px 20px;text-align:left;\n                 background:#f9fafb;border:none;cursor:pointer;\n                 font-size:14px;font-weight:600;color:#374151;\n                 display:flex;align-items:center;gap:8px;\n                 transition:background 0.15s;\" id=\"toggle-debate-btn\"><span style=\"display:inline-block;transition:transform 0.2s;\n                 font-size:12px;\" id=\"accordion-arrow\">\u25b6<\/span> Review the debate conversation<\/button>\n<div style=\"display:none;padding:20px;border-top:1px solid #e5e7eb;\n              background:#ffffff;max-height:400px;overflow-y:auto;\" id=\"debate-content\">\n<p style=\"color:#6b7280;font-size:13px;font-style:italic;\n              margin-top:0;\">Loading debate...<\/p>\n<\/div>\n<\/div>\nHow important is this issue to you?","DefaultChoices":false,"DataExportTag":"Importance","QuestionID":"QID26","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline"},"QuestionDescription":"\u25b6 Review the debate conversation Loading debate... How important is this issue to you?","Choices":{"1":{"Display":"Not at all important to me"},"2":{"Display":"Slightly important to me"},"3":{"Display":"Moderately important to me"},"4":{"Display":"Very important to me"},"5":{"Display":"Extremely important to me"}},"ChoiceOrder":[1,2,3,4,5],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":4,"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    var qid = 'importance';\n    var debateOpened = 0;\n    var toggleCount = 0;\n    var firstOpenTime = null;\n    var pageStart = Date.now();\n    window._accordion_totalViewTime = 0;\n    window._accordion_viewStart = null;\n    window._accordion_qid = qid;\n    function setED(key, value) {\n        Qualtrics.SurveyEngine.setEmbeddedData(key, String(value));\n    }\n    var contentDiv = document.getElementById('debate-content');\n    var bubbles = null;\n    if (window._debateBubbles) { bubbles = window._debateBubbles; }\n    if (!bubbles) {\n        try {\n            var raw = \"${e:\/\/Field\/debateJSON}\";\n            raw = raw.replace(\/&amp;\/g,'&').replace(\/&lt;\/g,'<').replace(\/&gt;\/g,'>').replace(\/&quot;\/g,'\"').replace(\/&#39;\/g,\"'\").replace(\/&#x27;\/g,\"'\").replace(\/&apos;\/g,\"'\");\n            bubbles = JSON.parse(raw);\n        } catch(e) {}\n    }\n    if (bubbles && contentDiv) {\n        var html = '';\n        for (var i = 0; i < bubbles.length; i++) {\n            var b = bubbles[i];\n            html += '<div style=\"display:flex;margin-bottom:12px;' + (b.side === 'rep' ? 'justify-content:flex-end;' : '') + '\"><div style=\"max-width:80%;padding:12px 16px;border-radius:16px;' + (b.side === 'dem' ? 'background:#dbeafe;border-bottom-left-radius:4px;' : 'background:#fee2e2;border-bottom-right-radius:4px;') + 'font-size:14px;line-height:1.5;\"><div style=\"font-weight:600;font-size:12px;margin-bottom:4px;' + (b.side === 'dem' ? 'color:#1e40af;' : 'color:#991b1b;') + '\">' + b.speaker + '<\/div><div>\\u201c' + b.text + '\\u201d<\/div><\/div><\/div>';\n        }\n        contentDiv.innerHTML = html;\n    } else if (contentDiv) {\n        contentDiv.innerHTML = '<p style=\"color:#999;font-style:italic;\">Debate transcript not available.<\/p>';\n    }\n    window.toggleDebate = function() {\n        var content = document.getElementById('debate-content');\n        var arrow = document.getElementById('accordion-arrow');\n        if (!content) return;\n        if (content.style.display === 'none') {\n            content.style.display = 'block';\n            if (arrow) arrow.style.transform = 'rotate(90deg)';\n            debateOpened = 1; toggleCount++;\n            window._accordion_viewStart = Date.now();\n            if (firstOpenTime === null) { firstOpenTime = Date.now() - pageStart; setED(qid + '_accordion_firstOpen_ms', firstOpenTime); }\n        } else {\n            content.style.display = 'none';\n            if (arrow) arrow.style.transform = 'rotate(0deg)';\n            if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n        }\n        setED(qid + '_accordion_opened', debateOpened);\n        setED(qid + '_accordion_toggles', toggleCount);\n    };\n});\nQualtrics.SurveyEngine.addOnReady(function() {\n    var btn = document.getElementById('toggle-debate-btn');\n    if (btn) { btn.addEventListener('click', function() { window.toggleDebate(); }); }\n});\nQualtrics.SurveyEngine.addOnUnload(function() {\n    if (window._accordion_viewStart) { window._accordion_totalViewTime += Date.now() - window._accordion_viewStart; window._accordion_viewStart = null; }\n    Qualtrics.SurveyEngine.setEmbeddedData(window._accordion_qid + '_accordion_viewTime_ms', String(window._accordion_totalViewTime || 0));\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID27","SecondaryAttribute":"Please do not reveal any identifying information about yourself in your response.\u00a0","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"color:#95a5a6;\">Please do not reveal any identifying information about yourself in your response.&nbsp;<\/span>","DefaultChoices":false,"DataExportTag":"open_text","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please do not reveal any identifying information about yourself in your response.\u00a0","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"CharRange","MinChars":"100","TotalChars":"500"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID27","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    this._pageStart = Date.now();\n    var bubbles = null;\n    if (window._debateBubbles) { bubbles = window._debateBubbles; }\n    if (!bubbles) {\n        try {\n            var raw = \"${e:\/\/Field\/debate_json}\";\n            raw = raw.replace(\/&amp;\/g,'&').replace(\/&lt;\/g,'<').replace(\/&gt;\/g,'>').replace(\/&quot;\/g,'\"').replace(\/&#39;\/g,\"'\").replace(\/&#x27;\/g,\"'\").replace(\/&apos;\/g,\"'\");\n            bubbles = JSON.parse(raw);\n        } catch(e) {}\n    }\n    window._thermBubbles = bubbles;\n    window._thermPalette = {\n        dem: { bg: '#E0F2F1', border: '#00897B', text: '#00695C' },\n        rep: { bg: '#FFF8E1', border: '#F57C00', text: '#E65100' }\n    };\n});\nQualtrics.SurveyEngine.addOnReady(function() {\n    var bubbles = window._thermBubbles || null;\n    var palette = window._thermPalette || null;\n    if (bubbles && bubbles[0] && palette) {\n        var aParty = bubbles[0].side;\n        var bParty = (aParty === 'rep') ? 'dem' : 'rep';\n        var aCol = palette[aParty];\n        var bCol = palette[bParty];\n        var tagA = '<span style=\"background:' + aCol.bg + ';border-left:3px solid ' + aCol.border\n            + ';padding:2px 8px;border-radius:4px;font-weight:700;color:' + aCol.text + ';\">Candidate A<\/span>';\n        var tagB = '<span style=\"background:' + bCol.bg + ';border-left:3px solid ' + bCol.border\n            + ';padding:2px 8px;border-radius:4px;font-weight:700;color:' + bCol.text + ';\">Candidate B<\/span>';\n        function applyTextColors() {\n            var container = document.querySelector('.QuestionBody') || document.body;\n            var walker = document.createTreeWalker(\n                container,\n                NodeFilter.SHOW_TEXT,\n                null,\n                false\n            );\n            var textNodes = [];\n            while (walker.nextNode()) {\n                var node = walker.currentNode;\n                if (node.parentElement && node.parentElement.getAttribute && node.parentElement.getAttribute('style') && node.parentElement.getAttribute('style').indexOf('border-left:3px') !== -1) continue;\n                if (node.nodeValue.indexOf('Candidate A') !== -1 || node.nodeValue.indexOf('Candidate B') !== -1) {\n                    textNodes.push(node);\n                }\n            }\n            for (var i = 0; i < textNodes.length; i++) {\n                var span = document.createElement('span');\n                var html = textNodes[i].nodeValue\n                    .replace(\/Candidate A\/g, tagA)\n                    .replace(\/Candidate B\/g, tagB);\n                span.innerHTML = html;\n                textNodes[i].parentNode.replaceChild(span, textNodes[i]);\n            }\n        }\n        setTimeout(applyTextColors, 500);\n    }\n});\nQualtrics.SurveyEngine.addOnUnload(function() {\n    Qualtrics.SurveyEngine.setEmbeddedData('dv_open_page_ms', String(Date.now() - this._pageStart));\n});"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID28","SecondaryAttribute":"Please answer these quick questions about your background.","TertiaryAttribute":null,"Payload":{"QuestionText":"Please answer these quick questions about your background.","DefaultChoices":false,"DataExportTag":"DemographicsText","QuestionID":"QID28","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please answer these quick questions about your background.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID29","SecondaryAttribute":"Generally speaking, do you usually think of yourself as a Republican, a Democrat, an Independent,...","TertiaryAttribute":null,"Payload":{"QuestionText":"Generally speaking, do you usually think of yourself as a Republican, a Democrat, an Independent, or what?","DefaultChoices":false,"DataExportTag":"party","QuestionID":"QID29","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Generally speaking, do you usually think of yourself as a Republican, a Democrat, an Independent,...","Choices":{"1":{"Display":"Democrat"},"2":{"Display":"Republican"},"3":{"Display":"Independent"},"4":{"Display":"No Preference"},"5":{"Display":"Other"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"Randomization":{"Advanced":{"FixedOrder":["{~Randomized~}","{~Randomized~}","3","4","5"],"RandomSubSet":[],"RandomizeAll":["1","2"],"ScaleReversal":[],"TotalRandSubset":0,"Undisplayed":[]},"ConsistentScaleReversal":false,"EvenPresentation":false,"TotalRandSubset":"","Type":"Advanced"}}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID3","SecondaryAttribute":"What is your gender?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your gender?","DefaultChoices":false,"DataExportTag":"gender","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your gender?","Choices":{"1":{"Display":"Male"},"2":{"Display":"Female"},"3":{"Display":"Other"},"4":{"Display":"Prefer not to Answer"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID3"}},{"SurveyID":"SV_9odEiuuhBFfakNE","Element":"SQ","PrimaryAttribute":"QID30","SecondaryAttribute":"Would you call yourself a strong ${q:\/\/QID29\/ChoiceGroup\/SelectedChoices} or a not very strong ...","TertiaryAttribute":null,"Payload":{"QuestionText":"Would you call yourself a strong ${q:\/\/QID29\/ChoiceGroup\/SelectedChoices} or a not very strong ${q:\/\/QID29\/ChoiceGroup\/SelectedChoices}?","DefaultChoices":false,"DataExportTag":"party_strength","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Would you call yourself a strong ${q:\/\/QID29\/ChoiceGroup\/Sel