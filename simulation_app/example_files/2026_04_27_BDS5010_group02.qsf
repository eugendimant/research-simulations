,"3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID38"}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID39","SecondaryAttribute":"How would you describe the overall quality of this physician visit.","TertiaryAttribute":null,"Payload":{"QuestionText":"How would you describe the overall quality of this physician visit.","DefaultChoices":false,"DataExportTag":"Q39","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How would you describe the overall quality of this physician visit.","Choices":{"1":{"Display":"Very poor"},"2":{"Display":"Poor"},"3":{"Display":"Somewhat poor"},"4":{"Display":"Neither poor nor good"},"5":{"Display":"Somewhat good"},"6":{"Display":"Good"},"7":{"Display":"Very good"}},"ChoiceOrder":["1","2","3","4","5","6","7"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":1,"QuestionID":"QID39"}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID45","SecondaryAttribute":"Informed Consent Form You are invited to take part in a study named Decision Task. The purpose of...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>Informed Consent Form<br><\/b><br>You are invited to take part in a study named Decision Task. The purpose of this research study is to understand human decision-making. You will answer a series of questions regarding beliefs and behaviors. We will also ask you to provide demographic information. We will not ask for your name or any information that will make you identifiable. Overall, this study will take approximately 5-10 minutes.<br><br>The risks to participating are no greater than those encountered in everyday life. Your participation in this study is completely voluntary, and you may refuse to participate. If you withdraw from the study before completing it, you will not be paid. Compensation will be awarded upon completion of the entire study.<br><br>If you have any questions about this study, you may contact us at scott10@sas.upenn.edu.<br><br>Please feel free to print or save a copy of this consent form.<br><br>Below, indicate that you have read and understood this consent form and wish to continue your participation in this study.","DefaultChoices":false,"DataExportTag":"Q30","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Informed Consent Form You are invited to take part in a study named Decision Task. The purpose of...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID45"}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID46","SecondaryAttribute":"What is the maximum number of tokens you can allocate to this physician","TertiaryAttribute":null,"Payload":{"QuestionText":"What is the maximum number of tokens you can allocate to this physician","DefaultChoices":false,"DataExportTag":"Attention_Check","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is the maximum number of tokens you can allocate to this physician","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None","MinChars":"1","TotalChars":"10"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID46"}},{"SurveyID":"SV_2osFuUUjuRy450y","Element":"SQ","PrimaryAttribute":"QID5","SecondaryAttribute":"The following questions ask for general background information. Your responses ar